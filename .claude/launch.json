{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "fxmily-web-ds-v3",
      "runtimeExecutable": "pnpm.cmd",
      "runtimeArgs": ["--filter", "@fxmily/web", "exec", "next", "dev"],
      "port": 3000,
      "autoPort": true,
      "env": {
        "DATABASE_URL": "postgresql://placeholder:placeholder@localhost:5432/placeholder",
        "AUTH_SECRET": "dev-ds-v3-secret-32chars-fxmily-aaaaaa",
        "AUTH_URL": "http://localhost:3000",
        "AUTH_TRUST_HOST": "true"
      }
    },
    {
      "name": "fxmily-web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@fxmily/web", "exec", "next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "fxmily-web-j8-smoke",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-NoProfile",
        "-Command",
        "$env:DATABASE_URL='postgresql://fxmily:fxmily_dev@localhost:5432/fxmily?schema=public'; $env:AUTH_SECRET='dev-smoke-secret-32chars-fxmily-j8'; $env:AUTH_URL='http://localhost:3000'; $env:CRON_SECRET='dev-smoke-cron-secret-fxmily-j8'; $env:WEEKLY_REPORT_RECIPIENT='admin@example.invalid'; pnpm --filter @fxmily/web exec next dev"
      ],
      "port": 3000,
      "autoPort": true
    }
  ]
}

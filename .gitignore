# Dependencies
node_modules/
.pnpm-store/

# Builds & caches
.next/
.next-trash*/
out/
dist/
build/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Env files (NEVER commit secrets) — allowlist .env.example/.env.template explicitly
.env
.env.*
!.env.example
!.env.template

# V1.5.2 round 4 — local secrets bootstrap files. NEVER commit these.
# Round 5 widened to `*.local.env*` to also catch .bak, ~, .swp, etc.
# Whitelist explicitly the .example template so dev can keep it tracked.
*.local.env*
!*.local.env.example

# Secrets / keys (defense in depth)
*.pem
*.key
*.cer
*.crt
*.p12
*.pfx
.ssh/
.gnupg/

# Database dumps / backups (NEVER commit — a committed pg_dump leaks ALL member
# PII into git history, irreversible without a history rewrite). Self-hosted devs
# run local dumps for debug/migration, so a stray `pg_dump > db.dump` at the repo
# root would show up untracked and could be `git add .`-ed by mistake. Prisma
# migration SQL lives under prisma/migrations/ and is explicitly re-included.
*.dump
*.dump.gz
*.sql
*.sql.gz
*.sql.gz.gpg
dump-*
backup-*
pg_dump*
!**/prisma/migrations/**/*.sql

# Logs
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# Testing
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# Prisma
**/prisma/migrations/dev.db*
**/prisma/.env
**/src/generated/
**/generated/prisma/

# Docker
.docker/

# Misc
.cache/
.eslintcache
.stylelintcache
*.local

# Local upload store (J2 — replaced by R2 in prod)
.uploads/

# VAPID keys dev fixture (J9 prep) — never commit
.vapid-keys-dev.txt

.admin-password-rotation.txt

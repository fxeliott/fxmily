# =============================================================================
# Fxmily — variables d'environnement
# Copie ce fichier en `.env` (jamais committé) et remplace les valeurs.
# =============================================================================

# -- Runtime ------------------------------------------------------------------
NODE_ENV=development

# -- Database (Postgres) ------------------------------------------------------
DATABASE_URL=postgresql://fxmily:fxmily_dev@localhost:5432/fxmily?schema=public

# -- Auth.js v5 ---------------------------------------------------------------
AUTH_SECRET=changeme_generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# -- Resend (J1) -- RESEND_API_KEY=re_...
# -- Cloudflare R2 (J1+) -- R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET, R2_PUBLIC_URL
# -- Sentry (J10) -- SENTRY_DSN, SENTRY_AUTH_TOKEN, NEXT_PUBLIC_SENTRY_DSN
# -- Anthropic (J8) -- ANTHROPIC_API_KEY, ANTHROPIC_MODEL=claude-sonnet-4-6
# -- VAPID Web Push (J9) -- VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT
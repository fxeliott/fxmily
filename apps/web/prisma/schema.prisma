// Fxmily — Prisma schema.
// Source of truth for the data model. Entities are added milestone by milestone
// per SPEC.md §6. Database connection lives in `prisma.config.ts` (Prisma 7+).
//
// J0 — datasource + generator only.
// J1 — User, Account, Session, VerificationToken, Invitation, AuditLog.
// J2 — Trade + enums (TradeDirection, TradeSession, TradeOutcome, RealizedRSource).
// J4 — TradeAnnotation + NotificationQueue + enums (AnnotationMediaType, NotificationType, NotificationStatus).
// J5 — DailyCheckin + enum CheckinSlot. Extends NotificationType with morning/evening reminders.
// J6+ — BehavioralScore, MarkDouglasCard, MarkDouglasDelivery, WeeklyReport.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  member
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

/// Trade direction (J2). Long = buy, short = sell.
enum TradeDirection {
  long
  short
}

/// Trading session (J2). Auto-derived from `enteredAt` UTC at form-fill time
/// but persisted explicitly so the user's manual override survives DST shifts.
/// Plage UTC indicatives (DST géré côté code) :
///   asia    : 00:00–07:00 UTC
///   london  : 07:00–12:00 UTC
///   overlap : 12:00–16:00 UTC (London/NY)
///   newyork : 16:00–21:00 UTC
enum TradeSession {
  asia
  london
  newyork
  overlap
}

/// Outcome reported at trade close (J2). `break_even` covers both flat exits
/// and exits within ±0.1R of entry — the wizard maps the user-friendly "BE"
/// button to this value.
enum TradeOutcome {
  win
  loss
  break_even
}

/// Provenance of `realizedR` (J2).
///   computed  : derived from entry/exit/stopLoss with the canonical
///               (exit-entry)/(entry-stopLoss) formula. Reliable for analytics.
///   estimated : fallback when no stopLoss was provided. Equals `plannedRR` on
///               win, -1 on loss, 0 on break_even. Excluded from precision-
///               sensitive aggregates (expectancy, R-distribution).
enum RealizedRSource {
  computed
  estimated
}

/// V1.5 — Setup quality classification (Steenbarger best practice).
/// Captured BEFORE the outcome is known, so it cannot rationalize a posteriori.
///   A : setup parfait, conviction haute, contexte favorable (gold standard).
///   B : setup correct, conviction moyenne, ou contexte mitigé (default acceptable).
///   C : setup limite, conviction basse, ou doute sur le contexte (à coacher).
/// Eliot uses the distribution to coach : "tes B et C ont un win-rate 30 %
/// plus bas que tes A, pourquoi tu les prends ?". Decoupled from `realizedR`
/// — a C trade that wins is still a C trade.
enum TradeQuality {
  A
  B
  C
}

/// Annotation media kind (J4). V1 supports image attachments only — the
/// 500 MiB Zoom-video upload path is deferred to J4.5 (depends on R2 wiring).
/// The enum value is kept open so the column can store `video` once available.
enum AnnotationMediaType {
  image
  video
}

/// Push-notification kinds queued for J9 dispatch (J4 + J5 + J9).
/// Values are persisted as strings — adding a new kind is an additive migration.
///   annotation_received          : a member's trade just got a new admin correction (J4).
///   training_annotation_received : a member's BACKTEST just got an admin correction
///                                  (J-T3). DISTINCT from annotation_received — a
///                                  backtest correction must never conflate with a
///                                  real-trade correction (statistical isolation §21.5).
///   checkin_morning_reminder     : nudges the member to fill their morning check-in (J5).
///   checkin_evening_reminder     : nudges the member to fill their evening check-in (J5).
///   douglas_card_delivered       : a Mark Douglas card was triggered for the member (J9).
///   weekly_report_ready          : the J8 admin weekly digest is ready (admin-only push, opt-in).
///   monthly_debrief_ready        : the V1.4 member monthly AI debrief is ready (SPEC §25 —
///                                  member-facing push, mirror douglas_card_delivered; no
///                                  admin monthly push by design).
///   mindset_check_ready          : the V1.5 weekly mindset self-check is available (SPEC §27 —
///                                  member-facing push, mirror monthly_debrief_ready;
///                                  deterministic, no AI).
enum NotificationType {
  annotation_received
  training_annotation_received
  checkin_morning_reminder
  checkin_evening_reminder
  douglas_card_delivered
  weekly_report_ready
  monthly_debrief_ready
  mindset_check_ready
}

/// Daily check-in slot (J5, SPEC §6.4 + §7.4).
///   morning : sleep, routine, mood, intention. Reminder ~07:30 local.
///   evening : discipline, stress, gratitude, journal. Reminder ~20:30 local.
enum CheckinSlot {
  morning
  evening
}

/// V2.0 TRACK module — habit logging granular kinds (FXMILY-V2-MASTER A2-A5
/// must-have features). One row per (user, date, kind). Value JSON shape
/// is kind-specific and validated at the Zod boundary in
/// `lib/schemas/habit-log.ts`.
enum HabitKind {
  /// Hours of sleep (durationMin) + optional quality rating 1-10.
  sleep
  /// Meals count + optional quality rating (poor/fair/good/excellent).
  nutrition
  /// Cups of caffeine + optional last-drink HH:MM (UTC). Master plan A3.
  caffeine
  /// Type (cardio/strength/mixed/flexibility/other) + duration + intensity.
  sport
  /// Duration (minutes) + optional quality rating 1-10. Master plan A5.
  meditation
}

/// V2.3 — Pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer if-then).
/// 4 options to answer "Pourquoi je veux prendre ce trade ?" before each entry.
/// See `docs/decisions/ADR-003-pre-trade-circuit-breaker.md` for the mapping
/// vs Douglas's 4 primary trading fears (Trading in the Zone, 2000) — `edge`
/// = absence of the 4 fears, `fomo` = fear of missing out (direct), `revenge`
/// = mixed fear of being wrong + losing money, `boredom` = Steenbarger
/// "low arousal" affect (extension hors-Douglas-canonique, documented).
enum PreTradeReason {
  /// Setup éprouvé, je suis dans ma routine (absence des 4 fears Douglas).
  edge
  /// J'ai peur de rater quelque chose (fear of missing out — Douglas).
  fomo
  /// Je veux compenser une perte (fear of being wrong + losing money — Douglas).
  revenge
  /// J'ai juste envie de faire quelque chose (Steenbarger low-arousal extension).
  boredom
}

/// V2.3 — Pre-trade affective state. Russell-Weiss-Mendelsohn 1989 affect grid
/// 2x2 (valence × arousal). 4 options mapping the 4 quadrants. See ADR-003.
enum PreTradeEmotion {
  /// Low arousal, positive valence.
  calme
  /// High arousal, positive valence.
  excite
  /// High arousal, negative valence.
  frustre
  /// Low-to-medium arousal, negative valence.
  anxieux
}

/// Mark Douglas card category (J7, SPEC §7.6).
/// Maps to canonical pillars from *Trading in the Zone* and *The Disciplined Trader*.
enum DouglasCategory {
  acceptance
  tilt
  discipline
  ego
  probabilities
  confidence
  patience
  consistency
  fear
  loss
  process
}

/// Lifecycle of a queued notification (J4 + J9).
///   pending     : waiting for the J9 dispatcher (initial state, also re-set after retryable error).
///   dispatching : claimed by a dispatcher run (atomic transition pending→dispatching via updateMany,
///                 prevents two cron instances from sending the same notification twice).
///   sent        : delivered to at least one push endpoint.
///   failed      : dispatcher gave up after the retry budget. Surfaced in admin + may trigger
///                 email fallback (SPEC §18.2 iOS push fragility mitigation).
enum NotificationStatus {
  pending
  dispatching
  sent
  failed
}

// =============================================================================
// Auth.js v5 core models (PrismaAdapter contract)
// https://authjs.dev/getting-started/adapters/prisma
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")

  // Profile (filled at onboarding completion)
  firstName String? @map("first_name")
  lastName  String? @map("last_name")
  image     String?

  // Authentication
  passwordHash String? @map("password_hash") // argon2id, optional (magic-link-only users have null)

  // Authorization & lifecycle
  role   UserRole   @default(member)
  status UserStatus @default(active)

  // SPEC §6.1 — behavioral profile fields
  timezone         String    @default("Europe/Paris")
  pushSubscription Json?     @map("push_subscription") // J9
  consentRgpdAt    DateTime? @map("consent_rgpd_at")

  // Lifecycle timestamps
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  /// J10 — RGPD soft-delete anchor. Set when `/account/delete` Server Action
  /// confirms (status flipped to `deleted`, PII scrubbed). Cleared on cancel
  /// inside the 24h grace window. Hard-purged 30 days later by
  /// `/api/cron/purge-deleted` (cascade removes all user-scoped rows).
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  accounts                    Account[]
  sessions                    Session[]
  invitationsSent             Invitation[]                @relation("InvitationsSent")
  auditLogs                   AuditLog[]
  trades                      Trade[]
  // J4 — annotations the admin authored on members' trades.
  annotationsAuthored         TradeAnnotation[]           @relation("AnnotationsAuthored")
  // J4 — push-notification queue rows targeting this user.
  notificationsQueued         NotificationQueue[]
  // J5 — morning + evening check-ins.
  dailyCheckins               DailyCheckin[]
  // J6 — daily behavioral score snapshots (cached, recomputed nightly).
  behavioralScores            BehavioralScore[]
  // J7 - Mark Douglas contextual card deliveries + manual favorites.
  douglasDeliveries           MarkDouglasDelivery[]
  douglasFavorites            MarkDouglasFavorite[]
  // J8 — weekly AI reports (admin digest, generated by Claude Sonnet 4.6).
  weeklyReports               WeeklyReport[]
  // V1.8 — member-facing reflection (Sunday wizard + CBT Ellis ABC).
  weeklyReviews               WeeklyReview[]
  reflectionEntries           ReflectionEntry[]
  // V2.0 — TRACK module habit logs (sleep/nutrition/caffeine/sport/meditation).
  habitLogs                   HabitLog[]
  // V2.1 — admin private notes (SPEC §7.7). Two named relations: notes
  // written ABOUT this member, and notes this (admin) user authored.
  adminNotesAbout             AdminNote[]                 @relation("AdminNotesAbout")
  adminNotesAuthored          AdminNote[]                 @relation("AdminNotesAuthored")
  // V1.2 — Mode Entraînement / Backtest (SPEC §21). Statistically isolated
  // from the real edge: no FK to Trade, separate enums, dedicated services.
  trainingTrades              TrainingTrade[]
  trainingAnnotationsAuthored TrainingAnnotation[]        @relation("TrainingAnnotationsAuthored")
  // V1.3 — member-owned weekly backtest-practice debrief (SPEC §23).
  // Statistically isolated like the rest of the training surface: no FK to
  // Trade / WeeklyReview / BehavioralScore, only this implicit userId link.
  trainingDebriefs            TrainingDebrief[]
  // V1.4 — monthly AI debrief (SPEC §25). IA-pipeline sibling of WeeklyReport
  // but dual-section §21.5-walled: no FK to Trade/WeeklyReport/TrainingTrade/
  // BehavioralScore — only this implicit userId link (the WeeklyReport rows
  // of the month are read as INPUT by the aggregator, never linked as FK).
  monthlyDebriefs             MonthlyDebrief[]
  // V1.5 — weekly mindset self-check (SPEC §27). Deterministic, zero-AI.
  // 0-FK statistically isolated like the rest of the training surface:
  // no FK to Trade / WeeklyReport / BehavioralScore, only this implicit
  // userId link — feeds nothing back into the real edge (§21.5/§27.7).
  mindsetChecks               MindsetCheck[]
  // V2.3 — pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer
  // if-then, Session BB). 4 questions one-tap (~30s) before each trade.
  // ZERO free-text → ZERO crisis/injection surface → ZERO AI banner needed.
  // Optional auto-link to a Trade via service-layer linkRecentCheckToTrade
  // window 15min P2002-safe. The member always stays master of the decision
  // — Fxmily NEVER blocks a trade. See docs/decisions/ADR-003-pre-trade-
  // circuit-breaker.md for the evidence base (Gollwitzer-Sheeran 2006
  // d=0.65, 94 studies, n=8461) + Mark Douglas 4 primary trading fears.
  preTradeChecks              PreTradeCheck[]
  // V2.4 — Onboarding interview profilage IA Mark Douglas (Session α, M3
  // directive Eliot 2026-05-27 verbatim "claude pour analyser au plus deep").
  // 1-1 OnboardingInterview + MemberProfile cascade User. Static questionnaire
  // ~30 questions safeFreeText-sanitized at service layer. Claude batch local
  // async post-completion (carbone V1.4 monthly-debrief — ZÉRO API payante).
  // Posture §2 strict — Claude generates psycho/process axes ONLY, never
  // trade analysis. Cf. memory/fxmily_session_2026-05-27_pipeline_ee_ii_closure.md
  // for the M3 directive context. ADR-004 future evidence base for instrument
  // versioning + crisis detection patterns.
  onboardingInterview         OnboardingInterview?
  onboardingAnswers           OnboardingInterviewAnswer[]
  memberProfile               MemberProfile?
  // V1.7 §30 — meeting attendance declarations (self-report). `Meeting` itself
  // has NO User FK (admin-scoped global entity, 0 FK real-edge); only this
  // join model links to the member. Touches ONLY engagement via the count-only
  // primitive `countMeetingAttendance` (J-M4) — never the real edge.
  meetingAttendances          MeetingAttendance[]
  // J9 — Web Push subscriptions (one row per browser/device) + per-category opt-out preferences.
  pushSubscriptions           PushSubscription[]
  notificationPreferences     NotificationPreference[]

  @@index([status])
  @@index([role])
  /// J10 — partial index for the soft-delete purge cron. Only rows where
  /// `status = 'deleted'` satisfy the predicate; the partial index keeps it
  /// trivially small even at 1000+ members. The actual `WHERE status =
  /// 'deleted'` clause lives in the migration SQL (Prisma 7 doesn't expose
  /// partial-index predicates declaratively yet).
  @@index([status, deletedAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// Fxmily-specific models
// =============================================================================

/// Admin invitation flow (SPEC §6.9, §7.1).
/// Token is generated as a 32-byte random string (nanoid), only its SHA-256 hash
/// is stored. The plain token is sent in the email link and never persisted.
model Invitation {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  invitedById String @map("invited_by_id")
  invitedBy   User   @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("invitations")
}

/// RGPD-friendly audit log (SPEC §6.8, §9.2).
/// IPs are SHA-256-hashed before storage. Never log plaintext PII in `metadata`.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// J2 — Trading journal
// =============================================================================

/// Trade journal entry (SPEC §6.2, §7.3).
///
/// Lifecycle: a trade is created in "open" state with the pre-entry fields
/// (everything before the `--- post-exit ---` block). The user can finalize it
/// later — either right away in a single wizard run, or asynchronously after
/// the trade closes — by filling the post-exit block via /journal/[id]/close.
/// The `closedAt` timestamp marks the transition; both screenshots are
/// mandatory at their respective phases (SPEC §7.3 "upload obligatoire").
///
/// `realizedR` precision: the canonical formula `(exit - entry) / (entry - SL)`
/// (signed by direction) is used when `stopLossPrice` is provided
/// (`realizedRSource = computed`). When the user skipped the SL, we fall back
/// to `plannedRR | -1 | 0` based on outcome (`realizedRSource = estimated`).
/// See `lib/trading/calculations.ts` for the implementation.
model Trade {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ----- Pre-entry block (mandatory at trade creation) -----

  /// One of the 12 allowlisted symbols (see lib/trading/pairs.ts). Stored as
  /// uppercase string rather than an enum so adding pairs doesn't require a
  /// DB migration — the allowlist is enforced at the Zod / Server Action edge.
  pair           String
  direction      TradeDirection
  session        TradeSession
  /// User-provided trade entry timestamp, persisted in UTC. The wizard
  /// pre-fills this from `Date.now()` but the user can override (useful when
  /// logging trades retroactively).
  enteredAt      DateTime       @map("entered_at")
  entryPrice     Decimal        @map("entry_price") @db.Decimal(20, 8)
  /// Position size in lots (forex/metals) or contracts (indices). Decimal(12,4)
  /// covers micro-lots (0.01) up to institutional sizes.
  lotSize        Decimal        @map("lot_size") @db.Decimal(12, 4)
  /// Optional stop-loss price. Strongly encouraged: enables exact `realizedR`.
  stopLossPrice  Decimal?       @map("stop_loss_price") @db.Decimal(20, 8)
  /// Planned reward-to-risk ratio (e.g. 2.5 means "risk 1 to make 2.5").
  /// Slider in the UI clamps to [0.5, 10] with 0.25 step.
  plannedRR      Decimal        @map("planned_rr") @db.Decimal(6, 2)
  /// Multi-select tag slugs (FR labels, EN slugs). See lib/trading/emotions.ts.
  /// UI caps the selection at 3 tags; we don't enforce in DB to allow future
  /// expansion without a migration.
  emotionBefore  String[]       @map("emotion_before")
  planRespected  Boolean        @map("plan_respected")
  /// `null` = N/A (no hedge applicable on this trade). Tri-state per SPEC §7.3.
  hedgeRespected Boolean?       @map("hedge_respected")
  notes          String?        @db.Text

  /// Storage key for the pre-entry screenshot (mandatory at creation, but the
  /// column is nullable to allow administrative repairs). Format follows
  /// `lib/storage` conventions: `trades/{userId}/{nanoid}.{ext}`.
  screenshotEntryKey String? @map("screenshot_entry_key")

  // ----- V1.5 trading-expert calibration (Steenbarger / Tharp) -----------

  /// Setup quality A/B/C (Steenbarger, *Daily Trading Coach*). Captured at
  /// trade creation. Optional — V1 trades created before V1.5 ship are NULL
  /// and excluded from quality-distribution analytics.
  tradeQuality TradeQuality? @map("trade_quality")

  /// Percentage of account risked on this trade (e.g. 1.50 = 1.5 %).
  /// Tharp gold rule: never risk more than 1-2 % per trade. Optional.
  /// Captured by the member at form-fill time (we don't have account
  /// balance in the schema — V2 candidate). Decimal(4, 2) covers 0.01 %
  /// up to 99.99 % — aligned with the Zod schema upper bound `< 100`.
  /// Code-reviewer #6 (2026-05-09) — was Decimal(5, 2) which allowed
  /// 999.99 vs Zod < 100 mismatch.
  riskPct Decimal? @map("risk_pct") @db.Decimal(4, 2)

  // ----- Post-exit block (filled at close) -----

  exitedAt        DateTime?        @map("exited_at")
  exitPrice       Decimal?         @map("exit_price") @db.Decimal(20, 8)
  outcome         TradeOutcome?
  realizedR       Decimal?         @map("realized_r") @db.Decimal(6, 2)
  realizedRSource RealizedRSource? @map("realized_r_source")
  emotionAfter    String[]         @map("emotion_after")

  // V1.8 REFLECT — post-outcome bias tags (CFA LESSOR + Steenbarger).
  // Distinct from `emotionAfter` (raw affect): `tags` is a structured
  // post-mortem classification ("loss-aversion", "revenge-trade", etc.).
  // Member self-assigned at close wizard (Q3=A actée 2026-05-13).
  // Allowlist enforced at the Zod boundary (lib/schemas/trade.ts) — DB
  // stays a plain `text[]` to keep migrations free as the slug list
  // evolves (V1.9+ may add `fomo`/`tilt` if member feedback warrants).
  // Capped at 3 tags per trade (Zod max, not DB).
  tags String[] @default([]) @map("tags")

  screenshotExitKey String? @map("screenshot_exit_key")

  /// Set when the post-exit block is filled. A trade is "open" iff this is
  /// null — used by /journal queries to split the list visually.
  closedAt DateTime? @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // J4 — admin annotations attached to this trade. Cascade so a member
  // cleanup wipes its annotations too (RGPD: data minimisation).
  annotations TradeAnnotation[]

  // Indexes — userId-leading because every member-facing query is
  // user-scoped, and the secondary order is the dominant sort key in the UI.
  @@index([userId, enteredAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, closedAt])
  // V1.5 — quality distribution analytics (admin coaching view).
  // Partial-index predicate (`WHERE trade_quality IS NOT NULL`) is added in
  // the migration SQL since Prisma 7 doesn't model it declaratively.
  @@index([userId, tradeQuality])
  @@map("trades")
}

// =============================================================================
// J4 — Admin annotation workflow (SPEC §6.3, §7.8)
// =============================================================================

/// Admin correction attached to a member trade.
///
/// `comment` is markdown-friendly free text (rendered server-side as plain text
/// at J4; markdown rendering ships when we wire react-markdown in J6+). The
/// optional `mediaKey` points to a storage object — at J4 image-only
/// (8 MiB cap, JPEG/PNG/WebP). The Zoom-video upload (500 MiB) is deferred to
/// J4.5 once R2 is wired (see `apps/web/CLAUDE.md` storage section).
///
/// `seenByMemberAt` is set the first time the trade owner opens the trade in
/// /journal/[id] AFTER the annotation was created (bulk `updateMany` per page
/// load). Reading it stays in `lib/annotations/member-service.ts`.
///
/// `adminId` cascades on User delete: V1 has a single admin (Eliot), so admin
/// deletion is a teardown event — preserving orphaned annotations would be
/// dead state. V2 multi-admin should switch to SetNull + nullable adminId.
model TradeAnnotation {
  id String @id @default(cuid())

  tradeId String @map("trade_id")
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  adminId String @map("admin_id")
  admin   User   @relation("AnnotationsAuthored", fields: [adminId], references: [id], onDelete: Cascade)

  comment String @db.Text

  /// Storage key for the optional media attachment.
  /// Format: `annotations/{tradeId}/{nanoid32}.{jpg|png|webp}` (J4) or
  ///         `annotations/{tradeId}/{nanoid32}.{mp4|webm}` (J4.5).
  mediaKey  String?              @map("media_key")
  mediaType AnnotationMediaType? @map("media_type")

  /// Timestamp of the first time the member opened the trade detail page after
  /// this annotation existed. Null = unread.
  seenByMemberAt DateTime? @map("seen_by_member_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Most reads list a trade's annotations newest-first.
  @@index([tradeId, createdAt(sort: Desc)])
  // Powers the unseen-count rollup for the member's journal list.
  @@index([tradeId, seenByMemberAt])
  // Admin "annotations I authored" feed (J6+ analytics).
  @@index([adminId, createdAt(sort: Desc)])
  // J8 perf TIER 2 fix — `lib/weekly-report/loader.ts:loadAnnotationStats`
  // filtre `createdAt: { gte, lte } AND trade.userId = X`. Sans cet index,
  // Postgres seq-scan toute la table (à 1000 membres × 6 mois = potentiel
  // 100k+ rows). Ajout d'un index `(createdAt DESC)` permet un range-scan
  // index-only sur la window puis JOIN PK Trade pour le filtre userId.
  @@index([createdAt(sort: Desc)])
  @@map("trade_annotations")
}

/// V2.1 — Admin private notes about a member (SPEC §7.7 "tes notes
/// privées sur ce membre, pas vu par lui").
///
/// The member NEVER sees these: there is deliberately no member-facing
/// read path. They are listed only through the admin member-detail
/// "Notes admin" tab. `body` is hardened at the Zod boundary
/// (`safeFreeText` + reject bidi/zero-width = Trojan-Source defense,
/// canon Fxmily — these notes are rendered back to the admin and could
/// one day feed an LLM prompt).
///
/// Cascade on BOTH relations (RGPD data minimisation, consistent with
/// the rest of the schema). V1 = solo admin Eliot; V2 multi-admin →
/// consider `authorId` SetNull + nullable so a deleted admin's notes
/// survive (same follow-up noted on `TradeAnnotation`).
model AdminNote {
  id String @id @default(cuid())

  /// The member this note is ABOUT (never the author).
  memberId String @map("member_id")
  member   User   @relation("AdminNotesAbout", fields: [memberId], references: [id], onDelete: Cascade)

  /// The admin who wrote the note.
  authorId String @map("author_id")
  author   User   @relation("AdminNotesAuthored", fields: [authorId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // The panel lists a member's notes newest-first.
  @@index([memberId, createdAt(sort: Desc)])
  // Admin "notes I authored" feed (V2 multi-admin analytics).
  @@index([authorId, createdAt(sort: Desc)])
  @@map("admin_notes")
}

// =============================================================================
// V1.2 — Mode Entraînement / Backtest TradingView (SPEC §21)
// =============================================================================

/// Outcome reported on a backtest entry. Deliberately a SEPARATE enum from
/// `TradeOutcome` (same values) — SPEC §21.2 locks "isolation béton, par
/// construction": a training model never references a real-edge type, so a
/// future refactor of `TradeOutcome` can never reach training. The marginal
/// cost (one extra Postgres type) is the explicit trade-off Eliot accepted.
enum TrainingOutcome {
  win
  loss
  break_even
}

/// Media kind for an admin training-correction attachment. SEPARATE enum
/// from `AnnotationMediaType` for the same isolation rationale (§21.2). V1.2
/// ships image-only at the Zod edge; the column accepts `video` so a later
/// video-correction path stays an additive change (mirror J4 → J4.5).
enum TrainingAnnotationMediaType {
  image
  video
}

/// Member backtest entry (SPEC §21). STATISTICALLY ISOLATED from the real
/// edge: NO FK to `Trade`, no shared enum, dedicated read services. A
/// `TrainingTrade` must NEVER surface in `/journal`, the dashboard, scoring,
/// expectancy or the Habit×Trade correlation — the real edge only reflects
/// real risk (§21.5 invariant; anti-leak tests land in J-T4).
///
/// Lighter field set than `Trade` (SPEC §21.2): no emotions / sleep /
/// confidence — backtest affect ≠ real-risk affect (Mark Douglas). The
/// pedagogical core is `lessonLearned` (mandatory). `enteredAt` mirrors
/// `Trade.enteredAt` exactly: a plain `DateTime` UTC instant (NOT `@db.Date`),
/// so backdating is allowed and no civil-day window applies (it is not a
/// calendar-day field, unlike DailyCheckin / HabitLog).
///
/// `userId` cascades on User delete (RGPD data minimisation, schema-wide).
model TrainingTrade {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// One of the allowlisted symbols (lib/trading/pairs.ts), uppercase string,
  /// enforced at the Zod edge — mirror of `Trade.pair` (no DB enum).
  pair String

  /// Storage key for the entry-analysis screenshot (the artefact the admin
  /// corrects). Nullable for administrative repairs, but the Zod create
  /// schema requires it — mirror of `Trade.screenshotEntryKey`. Format
  /// `training/{id}/{nanoid32}.{ext}` (lib/storage/keys.ts, wired J-T2).
  entryScreenshotKey String? @map("entry_screenshot_key")

  /// Planned reward-to-risk ratio. Mandatory (mirror `Trade.plannedRR`):
  /// defining R:R before is the backtest discipline.
  plannedRR Decimal @map("planned_rr") @db.Decimal(6, 2)

  /// Backtest result. Nullable until filled — mirrors the real open/close
  /// split (`Trade.outcome` / `Trade.realizedR` are nullable).
  outcome TrainingOutcome? @map("outcome")
  resultR Decimal?         @map("result_r") @db.Decimal(6, 2)

  /// `true` = system/plan respected, `false` = not, `null` = N/A. Tri-state,
  /// exact mirror of `Trade.hedgeRespected`.
  systemRespected Boolean? @map("system_respected")

  /// Lesson learned — the pedagogical core of a backtest (SPEC §21).
  /// Mandatory free text, hardened at the Zod edge (`safeFreeText` + reject
  /// bidi/zero-width = Trojan-Source canon Fxmily).
  lessonLearned String @map("lesson_learned") @db.Text

  /// User-provided backtest entry timestamp, persisted in UTC. Mirror of
  /// `Trade.enteredAt` (plain DateTime, NOT @db.Date).
  enteredAt DateTime @map("entered_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Admin training corrections attached to this backtest. Cascade so a
  /// member cleanup wipes its corrections too (RGPD: data minimisation).
  annotations TrainingAnnotation[]

  // userId-leading + enteredAt DESC: every member-facing training query is
  // user-scoped and sorts newest-first (SPEC §21.3).
  @@index([userId, enteredAt(sort: Desc)])
  @@map("training_trades")
}

/// Admin correction attached to a member backtest — EXACT mirror of the J4
/// `TradeAnnotation` flow (comment + optional capture + seen tracking) but
/// pointing at `TrainingTrade` instead of `Trade`. The member-facing read +
/// seen-marking land in J-T3 (member-service, mirror
/// `lib/annotations/member-service.ts`).
///
/// `comment` is hardened free text (Trojan-Source canon). `adminId` cascades
/// on User delete: V1 single-admin (Eliot), so admin deletion is a teardown
/// event — V2 multi-admin should switch to SetNull + nullable adminId (same
/// follow-up noted on `TradeAnnotation`).
model TrainingAnnotation {
  id String @id @default(cuid())

  trainingTradeId String        @map("training_trade_id")
  trainingTrade   TrainingTrade @relation(fields: [trainingTradeId], references: [id], onDelete: Cascade)

  adminId String @map("admin_id")
  admin   User   @relation("TrainingAnnotationsAuthored", fields: [adminId], references: [id], onDelete: Cascade)

  comment String @db.Text

  /// Storage key for the optional correction media. Format
  /// `training_annotations/{trainingTradeId}/{nanoid32}.{jpg|png|webp}`.
  mediaKey  String?                      @map("media_key")
  mediaType TrainingAnnotationMediaType? @map("media_type")

  /// First time the member opened the backtest detail after this correction
  /// existed. Null = unread. Mirror of `TradeAnnotation.seenByMemberAt`.
  seenByMemberAt DateTime? @map("seen_by_member_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Most reads list a backtest's corrections newest-first (SPEC §21.3).
  @@index([trainingTradeId, createdAt(sort: Desc)])
  // Powers the unseen-count rollup for the member's training list.
  @@index([trainingTradeId, seenByMemberAt])
  // Admin "corrections I authored" feed.
  @@index([adminId, createdAt(sort: Desc)])
  @@map("training_annotations")
}

/// V1.3 — Débrief Training dédié (SPEC §23). Member-owned WEEKLY recap of the
/// member's BACKTEST practice (SPEC §21). Structurally mirrors `WeeklyReview`
/// (idempotent `(userId, weekStart)` upsert, `weekStart` @db.Date, `submittedAt`
/// bumped on edit) BUT stays inside the §21.5 statistical-isolation boundary:
/// there is NO foreign key to `Trade` / `WeeklyReview` / `BehavioralScore` —
/// only the implicit `userId` link, exactly like `TrainingTrade`.
///
/// The process-stats panel (volume & regularity · system respect · diversity ·
/// lessons & corrections) is computed at RENDER from `TrainingTrade` /
/// `TrainingAnnotation` and NEVER stored — see `lib/training-debrief/stats.ts`.
/// That aggregator NEVER selects `resultR` / `outcome` (posture §23.2: a
/// debrief shows process effort, never backtest P&L, even intra-training).
///
/// The 4 free-text fields are Steenbarger reverse-journaling (2 process
/// strengths + 1 micro-adjustment + 1 transversal lesson), all mandatory and
/// hardened at the Zod edge (`safeFreeText` + reject bidi/zero-width =
/// Trojan-Source canon Fxmily). `userId` cascades on User delete (RGPD §17).
model TrainingDebrief {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Monday of the debriefed week, local Europe/Paris, materialised at the
  /// service layer via `parseLocalDate` (UTC-midnight pin) so Postgres
  /// `@db.Date` truncation never drifts a day (anti-flake invariant PR#96).
  weekStart DateTime @map("week_start") @db.Date

  /// Steenbarger reverse-journaling — process strength #1 (mandatory). NOT
  /// P&L: "j'ai attendu mon setup au lieu de forcer", never "+3R en backtest".
  processStrengthOne String @map("process_strength_one") @db.Text
  /// Process strength #2 (mandatory).
  processStrengthTwo String @map("process_strength_two") @db.Text
  /// One concrete micro-adjustment for next week (mandatory) — small, testable.
  microAdjustment    String @map("micro_adjustment") @db.Text
  /// The transversal lesson abstracted from the week's practice (mandatory).
  transversalLesson  String @map("transversal_lesson") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("training_debriefs")
}

/// Notification queue (J4 enqueue, J9 dispatch).
///
/// At J4 we persist the *intent* of a notification — the actual web-push
/// dispatch worker is in J9. Until then the row stays `pending`. Each kind
/// (`type`) carries its own structured `payload`:
///   annotation_received          → { annotationId, tradeId, adminId, hasMedia }
///   training_annotation_received → { trainingAnnotationId, trainingTradeId, adminId, hasMedia }
///
/// `scheduledFor` lets us delay a notification (e.g. "remind if not seen
/// after 48h" — SPEC §7.8). Null means "ASAP".
model NotificationQueue {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  payload Json
  status  NotificationStatus @default(pending)

  /// V1.6 — SPEC §18.2 email frequency cap support. `true` for transactional
  /// notifications that MUST always reach the user (auth, invitation, password
  /// reset, RGPD export-ready). `false` (default) for engagement / nudge
  /// notifications — the email fallback caps these at 3 per 24h rolling window
  /// per user to avoid spam-mailing a member with a flaky push subscription.
  /// All V1 NotificationType slugs default to `false` (none are transactional
  /// yet — future auth-push types will set this to `true` at enqueue time).
  isTransactional Boolean @default(false) @map("is_transactional")

  attempts      Int       @default(0)
  scheduledFor  DateTime? @map("scheduled_for")
  dispatchedAt  DateTime? @map("dispatched_at")
  failureReason String?   @map("failure_reason")
  /// J9 — short error code for machine classification of the last failed dispatch.
  /// One of `gone_410` | `payload_too_large_413` | `rate_limited_429` |
  /// `server_5xx` | `timeout` | `network` | `unknown`. Mirrors the
  /// `classifyError(statusCode)` taxonomy in `lib/push/dispatcher.ts`.
  /// `failureReason` keeps the human-readable detail for admin debugging.
  lastErrorCode String?   @map("last_error_code")
  /// J9 — exponential backoff anchor. Set when a retryable failure happens
  /// (5xx, 429, network) — the dispatcher only re-claims rows whose
  /// `nextAttemptAt <= now()`. Null means "claim ASAP" (initial pending or
  /// the explicit `scheduledFor` window has elapsed).
  nextAttemptAt DateTime? @map("next_attempt_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Worker hot-path (J5): pull the next pending row whose schedule has elapsed.
  @@index([status, scheduledFor])
  // J9 dispatcher hot-path: claim rows ready to be sent (status in pending|dispatching
  // AND nextAttemptAt <= now). The partial WHERE clause is added in the migration
  // SQL (Prisma 7 doesn't model partial indexes natively; same pattern as the J5
  // `notification_queue_pending_checkin_dedup` partial unique index).
  @@index([status, nextAttemptAt])
  // User-scoped admin/debug queries.
  @@index([userId, createdAt(sort: Desc)])
  // V1.6 — partial index `notification_queue_user_recent_non_transactional_idx`
  // is created via the migration SQL only (Prisma 7 doesn't model partial
  // predicates declaratively, same pattern as `notification_queue_pending_checkin_dedup`).
  // NOT declared as `@@index` here to avoid Prisma generating a duplicate
  // full-index without the WHERE predicate (would create two B-tree indexes
  // on the same columns + cause schema drift on next `prisma migrate dev`).
  @@map("notification_queue")
}

// =============================================================================
// J9 — Web Push notifications (SPEC §7.9, §16, §18.2)
// =============================================================================

/// One row per (user, browser/device) push subscription. The browser hands us
/// `{ endpoint, keys: { p256dh, auth } }` after `pushManager.subscribe()`; we
/// persist them and use `web-push` lib to send messages later.
///
/// Why a unique on `(userId, endpoint)`: a member may install Fxmily on
/// multiple devices (iPhone home screen + Android + desktop Chrome), each
/// gets its own endpoint. Re-subscribing on the same device returns the same
/// endpoint → upsert preserves continuity instead of stacking rows.
///
/// `userAgent` is captured at subscribe time for admin debugging only — never
/// shown to other users, never logged in plaintext past 512 chars.
///
/// `lastSeenAt` is bumped each time we successfully dispatch (or when the
/// browser hits `pushsubscriptionchange`). A nightly cleanup cron deletes
/// rows where `lastSeenAt < now - 90j` (RGPD data minimization, SPEC §16).
///
/// On 410 Gone from the push service the dispatcher MUST delete the row
/// immediately (SPEC §16 — "subscription révoquée 410 Gone → DELETE immédiat").
model PushSubscription {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The push service URL (FCM, APNs, Mozilla autopush). Acts as the unique
  /// identifier across re-subscriptions for the same device.
  endpoint String @db.Text

  /// ECDH P-256 public key (base64url, ~88 chars). The `web-push` lib uses it
  /// to derive the encryption key for the message payload.
  p256dhKey String @map("p256dh_key")

  /// 16-byte random secret (base64url, ~22 chars) shared with the browser.
  /// Used as part of the AES-128-GCM encryption (RFC 8291).
  authKey String @map("auth_key")

  /// User-Agent string captured at subscribe time (truncated to 512 chars).
  /// Admin-only context — never returned in member-facing endpoints (endpoint
  /// enumeration risk per SPEC §16).
  userAgent String? @map("user_agent") @db.Text

  /// Bumped on successful dispatch + at `pushsubscriptionchange` re-register.
  /// Used by the 90-day cleanup cron + admin "is this device still alive?".
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([lastSeenAt])
  @@map("push_subscriptions")
}

/// Per-category notification opt-in/opt-out preferences. Default is `enabled = true`
/// — a missing row means "consent default-on" (member toggles to opt out, never to opt in).
///
/// PK is composite `(userId, type)`: each member has at most one row per
/// `NotificationType`. The dispatcher reads via `getEffectivePreferences(userId)`
/// which materializes the full set including default-true rows.
///
/// Toggle audit (`push.preference.toggled`) carries `{type, enabled}` metadata
/// — never the underlying notification content (RGPD data minimization).
model NotificationPreference {
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  enabled   Boolean          @default(true)
  updatedAt DateTime         @updatedAt @map("updated_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@id([userId, type])
  @@map("notification_preferences")
}

// =============================================================================
// J5 — Daily check-ins (SPEC §6.4, §7.4)
// =============================================================================

/// Two-slot daily check-in: morning + evening. SPEC §6.4 keeps a single table
/// shape with `slot` discriminating which fields are populated; the Zod schemas
/// (`lib/schemas/checkin.ts`) and the wizards enforce the per-slot field set.
///
/// `date` is a Postgres `DATE` (no time component) anchored to the member's
/// local-day (Europe/Paris by default — SPEC §6.1). The unique index on
/// (userId, date, slot) prevents duplicates: filling the morning twice updates
/// the existing row instead of stacking entries. The DB stores the user's
/// local date as a calendar day; conversions live in `lib/checkin/timezone.ts`.
///
/// All slot-specific fields are nullable so the same table can serve both
/// shapes. The wizards never persist nulls for required fields — the DB shape
/// is permissive on purpose so a future "I forgot to log my mood" partial fill
/// can still write something useful.
///
/// Streak counter: `lib/checkin/streak.ts` reads the (date, slot) tuples and
/// counts consecutive days with at least one check-in (morning OR evening). The
/// streak does NOT require both slots — SPEC §7.4 mentions a soft engagement
/// score driven by completion rate, not strict morning+evening pairing.
model DailyCheckin {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Local-date the check-in is for (Europe/Paris by default, see User.timezone).
  /// `@db.Date` keeps a calendar-day stable across DST and avoids timezone math
  /// when grouping for streaks / weekly reports.
  date DateTime    @db.Date
  slot CheckinSlot

  // ----- Morning fields (mostly nullable on the DB side, required by Zod) ----

  /// Hours of sleep last night (Decimal lets us record half-hours).
  sleepHours              Decimal? @map("sleep_hours") @db.Decimal(4, 2)
  /// Subjective sleep quality 1–10.
  sleepQuality            Int?     @map("sleep_quality")
  /// Did the member follow their personal morning routine? Tri-state: true
  /// (done), false (skipped), null (slot-N/A or unanswered).
  morningRoutineCompleted Boolean? @map("morning_routine_completed")
  /// Meditation minutes (0 = "didn't meditate"). Capped at 240.
  meditationMin           Int?     @map("meditation_min")
  /// Sport type label (free-text, FR — e.g. "course", "muscu", "yoga").
  sportType               String?  @map("sport_type")
  sportDurationMin        Int?     @map("sport_duration_min")
  /// One-line intention for the day, optional. Capped at 200 chars by Zod.
  intention               String?

  // ----- Evening fields ----------------------------------------------------

  /// Did the member respect their trading plan today?
  planRespectedToday  Boolean? @map("plan_respected_today")
  /// Did the member respect their hedge plan? Null = N/A (no hedge today).
  hedgeRespectedToday Boolean? @map("hedge_respected_today")
  /// Estimated caffeine intake in mL, capped at 2000.
  caffeineMl          Int?     @map("caffeine_ml")
  /// Water intake in litres (Decimal allows half-litres).
  waterLiters         Decimal? @map("water_liters") @db.Decimal(4, 2)
  /// Average stress 1–10 across the day (evening retrospective).
  stressScore         Int?     @map("stress_score")
  /// Up to 3 gratitude items, capped at 200 chars each by Zod.
  gratitudeItems      String[] @map("gratitude_items")

  // ----- Both slots --------------------------------------------------------

  /// Mood score 1–10. Captured both morning ("how do I feel right now?") and
  /// evening ("how did I feel today on average?"). Two distinct snapshots —
  /// retained in lib/scoring (J6) for emotional-stability variance.
  moodScore   Int?     @map("mood_score")
  /// Tag slugs (lib/checkin/emotions.ts mirrors lib/trading/emotions.ts).
  /// Used both morning ("how do I feel?") and evening ("dominant emotions").
  emotionTags String[] @map("emotion_tags")
  /// Free-form journal entry (max 4000 chars by Zod).
  journalNote String?  @map("journal_note") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Idempotency: at most one row per (user, day, slot). The Zod-driven Server
  // Action upserts on this composite key.
  @@unique([userId, date, slot])
  // Streak / dashboard queries: scan the user's most recent days.
  @@index([userId, date(sort: Desc)])
  // Weekly report aggregation (J8) — fetch a 7-day window in date order.
  @@index([userId, slot, date(sort: Desc)])
  @@map("daily_checkins")
}

// =============================================================================
// J6 — Behavioral score snapshots (SPEC §6.10, §7.5, §7.11)
// =============================================================================

/// Per-user, per-day cached snapshot of the four deterministic behavioral
/// scores (SPEC §7.11) — discipline, emotional stability, consistency,
/// engagement. Recomputed nightly by `POST /api/cron/recompute-scores` for
/// `date = yesterday_local` (Europe/Paris V1) and on-demand from Server
/// Actions that meaningfully invalidate a member's data (close trade, submit
/// check-in) via `revalidateTag('user:scores:'+userId)`.
///
/// Why a snapshot table (vs computing live on every dashboard render):
/// 1. Deterministic guarantees — formulas in `lib/scoring/*.ts` are pure but
///    they touch up to 60 days of trades + 30 days of check-ins per call.
///    Caching a daily snapshot pins the dashboard read to a single indexed row.
/// 2. Trend rendering — a 30-day score trend line needs historical points; we
///    don't backfill on the fly.
/// 3. Data-minimisation friendly — RGPD purge cascades cleanly on User delete.
///
/// Why scores are nullable (`Int?`) instead of `0`:
/// `null` carries the explicit "insufficient_data" semantic — a member with
/// zero trades in the window has *no* consistency score; rendering `0/100`
/// would lie. The `components` JSON carries the per-dimension `status` and
/// `reason` (`no_trades` | `no_checkins` | `window_short`) so the UI can
/// render the disclaimer without re-running the scoring layer.
///
/// `components` shape (see `lib/scoring/types.ts` for canonical types):
/// {
///   discipline:           { score, status, reason?, parts: { planRespect, hedgeRespect, eveningPlan, intentionFilled, routineCompleted } },
///   emotionalStability:   { score, status, reason?, parts: { moodVariance, stressMedian, negativeEmotionRate, recoveryAfterLoss } },
///   consistency:          { score, status, reason?, parts: { expectancyR, profitFactor, drawdownControl, lossStreakControl, sessionDispersion } },
///   engagement:           { score, status, reason?, parts: { checkinFillRate, dualSlotRate, streakNormalized, journalDepthRate } }
/// }
///
/// `sampleSize` shape:
/// { trades: { closed, computed, estimated, sufficient }, checkins: { days, dualSlot, sufficient }, windowDays }
model BehavioralScore {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Local-day anchor in user.timezone (Europe/Paris V1). `@db.Date` is stable
  /// across DST and matches the `DailyCheckin.date` convention exactly.
  date DateTime @db.Date

  /// 0–100 each, NULL when the dimension's `status='insufficient_data'`.
  /// Per-dimension reason lives in `components[dim].reason`.
  disciplineScore         Int? @map("discipline_score")
  emotionalStabilityScore Int? @map("emotional_stability_score")
  consistencyScore        Int? @map("consistency_score")
  engagementScore         Int? @map("engagement_score")

  /// Per-dimension breakdown for UI transparency ("why is my score X?").
  /// Persisted as a typed JSON blob; `lib/scoring/types.ts` documents the shape.
  components Json

  /// Sample-size guards per dimension + raw counters, so the UI can render the
  /// disclaimer ("28/30 jours, 12 trades clôturés") without re-running.
  sampleSize Json @map("sample_size")

  /// Window used for this snapshot. 30 by default (Mark Douglas habit window),
  /// configurable for future experimentation without a migration.
  windowDays Int @default(30) @map("window_days")

  computedAt DateTime @default(now()) @map("computed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Idempotent recompute: 1 snapshot per (user, day). Cron + Server Action
  // upsert on this key.
  @@unique([userId, date])
  // Dashboard read (today + 30-day trend), index covers ORDER BY date DESC.
  @@index([userId, date(sort: Desc)])
  @@map("behavioral_scores")
}

// =============================================================================
// J7 - Module Mark Douglas (SPEC §6.5, §6.6, §7.6, §18.2)
// =============================================================================

/// Educational psychology card surfaced in /library and pushed contextually.
/// SPEC §18.2 fair use: quote ≤ 30 words + quoteSourceChapter required.
/// 	riggerRules discriminated-union JSON (lib/triggers/types.ts). Null = library-only.
/// hatClass: white (7d cooldown) | black (14d cooldown). Yu-kai Chou Octalysis.
model MarkDouglasCard {
  id                 String          @id @default(cuid())
  slug               String          @unique
  title              String
  category           DouglasCategory
  /// Direct quote ≤ 30 words (Zod-enforced) - fair use FR L122-5.
  quote              String
  /// Source attribution e.g. "Trading in the Zone, ch.7" (§18.2 compliance).
  quoteSourceChapter String          @map("quote_source_chapter")
  /// 200-400 word FR paraphrase, markdown via react-markdown + rehype-sanitize.
  /// Sanitized via lib/text/safe.ts (NFC + bidi/zero-width strip) at write.
  paraphrase         String          @db.Text
  /// [{ id, label, description }] - 1 to 3 actionable exercises.
  exercises          Json
  /// Discriminated-union trigger rule. Null = no contextual push.
  triggerRules       Json?           @map("trigger_rules")
  /// Yu-kai Chou Octalysis: "white" (default) | "black".
  hatClass           String          @default("white") @map("hat_class")
  /// 1-10. Higher = pushed first when multiple cards match.
  priority           Int             @default(5)
  /// Drafts invisible to members until admin publishes.
  published          Boolean         @default(false)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  deliveries MarkDouglasDelivery[]
  favorites  MarkDouglasFavorite[]

  @@index([published, priority(sort: Desc)])
  @@index([category, published])
  @@map("mark_douglas_cards")
}

/// Record of a card pushed to a member.
/// 	riggeredOn (@db.Date local-day) + (userId, cardId) = idempotency.
/// 7d/14d hatClass cooldown enforced application-side via lib/triggers/cooldown.
model MarkDouglasDelivery {
  id              String          @id @default(cuid())
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId          String          @map("card_id")
  card            MarkDouglasCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  /// Human FR label. Example: "3 trades perdants consécutifs sur 24h".
  triggeredBy     String          @map("triggered_by")
  /// Structured snapshot for audit + replay. Never PII.
  triggerSnapshot Json            @map("trigger_snapshot")
  /// Local-day anchor (matches DailyCheckin.date convention).
  triggeredOn     DateTime        @map("triggered_on") @db.Date
  seenAt          DateTime?       @map("seen_at")
  dismissedAt     DateTime?       @map("dismissed_at")
  helpful         Boolean?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@unique([userId, cardId, triggeredOn])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, seenAt])
  @@index([userId, cardId, createdAt(sort: Desc)])
  @@map("mark_douglas_deliveries")
}

/// User-curated favorite (manual star on a card).
model MarkDouglasFavorite {
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String          @map("card_id")
  card      MarkDouglasCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")

  @@id([userId, cardId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("mark_douglas_favorites")
}

/// J8 — Weekly AI report generated by Claude Sonnet 4.6 + dispatched by email
/// to admin (`eliot@fxmilyapp.com` V1, `fxeliott@fxmilyapp.com` post J10).
///
/// Cron: dimanche 21:00 UTC (`0 21 * * 0`). For each `status='active'` member,
/// a 7-day snapshot is built (trades + check-ins + scores + deliveries +
/// favorites + corrections) and sent to Claude with the cached system prompt
/// (1h ephemeral) + the per-member user prompt (non-cached). Output is parsed
/// via Zod (`weeklyReportOutputSchema`) and persisted here.
///
/// Idempotency: `(userId, weekStart)` unique → re-runs the same week are no-op.
/// Data minimization (RGPD): no PII in the prompt — only `userId` UUID +
/// counters + redacted journalNote (safeFreeText NFC + bidi/zero-width strip).
model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime @map("week_start") @db.Date
  weekEnd     DateTime @map("week_end") @db.Date
  generatedAt DateTime @default(now()) @map("generated_at")

  // Output Claude (Zod-validated before write).
  summary         String @db.Text
  risks           Json
  recommendations Json
  patterns        Json

  // Cost tracking + observability (cf. SPEC §16 ~5€/mois target).
  claudeModel       String  @map("claude_model")
  inputTokens       Int     @map("input_tokens")
  outputTokens      Int     @map("output_tokens")
  cacheReadTokens   Int     @default(0) @map("cache_read_tokens")
  cacheCreateTokens Int     @default(0) @map("cache_create_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking).
  costEur           Decimal @map("cost_eur") @db.Decimal(10, 6)

  // Email dispatch state (Resend).
  sentToAdminAt    DateTime? @map("sent_to_admin_at")
  sentToAdminEmail String?   @map("sent_to_admin_email")
  emailMessageId   String?   @map("email_message_id")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@index([generatedAt(sort: Desc)])
  @@map("weekly_reports")
}

/// V1.4 — Débrief Mensuel IA dédié (SPEC §25, jalon #2 de la séquence
/// §21.6). Structural IA-pipeline sibling of `WeeklyReport` (cost-tracking,
/// JSON output, idempotent upsert) BUT member-facing + dual-section and
/// inside the §21.5 statistical-isolation boundary:
///
///   - NO foreign key to `Trade` / `WeeklyReport` / `TrainingTrade` /
///     `BehavioralScore` — only the implicit `userId` link (mirror
///     `TrainingDebrief` / `TrainingTrade`). The ≤4 `WeeklyReport` rows of
///     the civil month are read as INPUT context by the pure aggregator,
///     NEVER linked as an FK.
///   - `summaryReal` (legitimate REAL-trade P&L coaching) and
///     `summaryTraining` (§21.5 firewall: count/recurrence ONLY, never a
///     backtest `resultR`/`outcome`/`plannedRR`) are STRICTLY separate
///     columns so the isolation boundary is visible in the schema itself.
///   - The debrief feeds NOTHING back into the real edge (no score, no
///     engagement, no trigger — canon §23).
///
/// `monthStart` = local Europe/Paris 1st-of-month, materialised at the
/// service layer via `parseLocalDate` (UTC-midnight pin, anti-flake PR#96).
/// `monthEnd` is ALWAYS service-computed (SSOT, anti-tamper) — NEVER
/// accepted from a client. Idempotency `(userId, monthStart)` upsert.
/// `userId` cascades on User delete (RGPD §17). Generation is batch-local
/// Claude Max (SPEC §25.2 — never the paid API); cost tracking kept for
/// audit/traceability even though the marginal cost is 0€.
model MonthlyDebrief {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  monthStart  DateTime @map("month_start") @db.Date
  /// Service-computed last calendar day of the civil month (SSOT,
  /// anti-tamper — never received from the client, SPEC §25.3/§25.7).
  monthEnd    DateTime @map("month_end") @db.Date
  generatedAt DateTime @default(now()) @map("generated_at")

  // Output Claude (Zod `monthlyDebriefOutputSchema`-validated before write).
  // Dual-section by design (§21.5 boundary visible in the data model).
  progressionNarrative String @map("progression_narrative") @db.Text
  summaryReal          String @map("summary_real") @db.Text
  summaryTraining      String @map("summary_training") @db.Text
  risks                Json
  recommendations      Json
  patterns             Json

  // Cost tracking + observability (mirror WeeklyReport; batch-local Claude
  // Max ⇒ 0€ marginal but kept for traceability/audit, SPEC §25.3).
  claudeModel       String  @map("claude_model")
  inputTokens       Int     @map("input_tokens")
  outputTokens      Int     @map("output_tokens")
  cacheReadTokens   Int     @default(0) @map("cache_read_tokens")
  cacheCreateTokens Int     @default(0) @map("cache_create_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking).
  costEur           Decimal @map("cost_eur") @db.Decimal(10, 6)

  // Member dispatch state (push + Resend). NO admin dispatch field by
  // design — Eliot reads /admin only, no monthly admin email (SPEC §25.2).
  sentToMemberAt    DateTime? @map("sent_to_member_at")
  sentToMemberEmail String?   @map("sent_to_member_email")
  pushEnqueuedAt    DateTime? @map("push_enqueued_at")

  @@unique([userId, monthStart])
  @@index([userId, monthStart(sort: Desc)])
  @@map("monthly_debriefs")
}

/// V1.5 — QCM athlète / auto-évaluation mindset hebdomadaire (SPEC §27,
/// jalon #3 de la séquence §21.6). Member-owned WEEKLY mindset self-check,
/// 100% DETERMINISTIC — zero AI, zero API, zero pipeline (mirror of the
/// deterministic check-in surface, NOT of the Claude debrief pipeline).
///
///   - 0-FK statistical isolation BY CONSTRUCTION (§21.5/§27.7): the ONLY
///     relation is the implicit `userId` link (mirror `TrainingDebrief` /
///     `MonthlyDebrief` / `TrainingTrade`). NO foreign key to `Trade` /
///     `WeeklyReport` / `TrainingTrade` / `BehavioralScore`. A mindset row
///     can never reference a real-edge object, so it can never leak into /
///     be fed by the real track-record / score / expectancy / engagement /
///     trigger. The isolation is enforced by the schema shape itself.
///   - This entity feeds NOTHING back into the real edge (no
///     `BehavioralScore`, no engagement, no trigger — canon §23/§25/§27.7).
///
/// The questionnaire instrument is a FROZEN, code-VERSIONED Likert
/// instrument (`lib/mindset/instrument.ts`) — `instrumentVersion` pins the
/// exact item set a submission was answered against, guaranteeing
/// longitudinal validity even when the instrument is later revised.
/// `responses` is the raw Likert payload (item↔version validated at the Zod
/// edge). The mindset profile (dimensions, trends) is ALWAYS computed at
/// render from `responses` + the versioned instrument, NEVER stored —
/// derived data has no column (anti-drift, single source of truth).
///
/// `weekStart` = Monday of the assessed week, local Europe/Paris,
/// materialised at the service layer via `parseLocalDate` (UTC-midnight
/// pin) so Postgres `@db.Date` truncation never drifts a day (anti-flake
/// invariant PR#96). Idempotency `(userId, weekStart)` upsert — a re-submit
/// of the same week updates the same row (`updatedAt @updatedAt` covers the
/// re-submit; no dedicated `submittedAt`). No dispatch column — the
/// `notification.enqueued` audit row is the dispatch source of truth (canon
/// `TrainingDebrief`). `userId` cascades on User delete (RGPD §17).
model MindsetCheck {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart DateTime @map("week_start") @db.Date

  instrumentVersion Int  @map("instrument_version")
  responses         Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("mindset_checks")
}

// =============================================================================
// V1.8 REFLECT — member-facing reflection module
// =============================================================================
//
// Two separate models intentionally:
//   - `WeeklyReview` = member-owned Sunday recap (5 textareas, max 4000 chars
//     each). Distinct from `WeeklyReport` above which is admin-facing IA digest.
//     Idempotency: `(userId, weekStart)` unique → re-submitting same week upserts.
//   - `ReflectionEntry` = CBT Ellis ABC + Disputation, daily granularity.
//     Multiple entries per day allowed (a member may reflect on several events).
//
// Both models:
//   - Cascade-delete with the user (RGPD §17 data-minimisation).
//   - Free-text fields are sanitised at the Zod boundary via `safeFreeText`
//     (NFC + bidi/zero-width strip) — same Trojan-Source hardening as J5/J8.
//   - Crisis routing wire (V1.7.1 carbone) runs at submit-action level on
//     the concatenated corpus BEFORE persist. PII-free audit slugs only.
//   - No PII stored beyond the userId FK (no email, no display name).

/// V1.8 — Member-facing weekly recap wizard (Sunday ritual extension).
///
/// Posture (Mark Douglas): introspection on PROCESS, not outcomes. The five
/// fields are intentionally process-oriented ("biggest mistake" → action, not
/// P&L; "best practice" → Steenbarger reverse-journaling 2025 strengths-based).
///
/// `bestPractice` is optional to lower the wizard friction (member can skip
/// when nothing strengths-based comes to mind). All four other fields are
/// mandatory: empty submission is rejected at the Zod boundary.
///
/// Idempotency: `(userId, weekStart)` unique → a member who re-opens the
/// wizard for an already-submitted week upserts; the service layer is
/// responsible for surfacing "already submitted, you can edit" UX (PR2).
model WeeklyReview {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime @map("week_start") @db.Date
  weekEnd   DateTime @map("week_end") @db.Date

  /// Mandatory — process win (e.g. "Closed at TP per plan despite tempting
  /// trail"). NOT P&L, NOT "I made +5R". Member is nudged via wizard copy.
  biggestWin     String  @map("biggest_win") @db.Text
  /// Mandatory — process mistake (e.g. "Skipped pre-trade checklist on Tuesday
  /// London open"). NOT "I lost on EURUSD". Process > outcome.
  biggestMistake String  @map("biggest_mistake") @db.Text
  /// Optional — Steenbarger 2025 reverse-journaling. "What worked AND how
  /// you did it" before fix-the-flaws. Skippable to lower wizard friction.
  bestPractice   String? @map("best_practice") @db.Text
  /// Mandatory — the lesson abstracted from biggestMistake.
  lessonLearned  String  @map("lesson_learned") @db.Text
  /// Mandatory — concrete focus for the upcoming week (one-liner action).
  nextWeekFocus  String  @map("next_week_focus") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("weekly_reviews")
}

/// V1.8 — Ellis ABC + Disputation cognitive-behavioural reflection.
///
/// **Clinical disclaimer enforced UI-side** (PR2 wizard banner):
///   "inspired by Ellis ABC, adapted for trading — not clinically validated
///   for trader population".
///
/// Granularity: one row per reflection event (a member may write 0..N entries
/// per day — no `@@unique([userId, date])` constraint). The `date` field is
/// the introspective date, not the create-time (member can backfill yesterday
/// without retroactive timestamps).
///
/// All four columns are mandatory — Ellis ABCD is a complete frame; allowing
/// partial entries dilutes the cognitive-restructuring intent.
model ReflectionEntry {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local civil date (no time component). The member picks this; the wizard
  /// pre-fills today (Europe/Paris) but allows backfill within a window.
  date   DateTime @db.Date

  /// A — Activating event (factual trigger). 10–2000 chars.
  triggerEvent String @map("trigger_event") @db.Text
  /// B — Automatic belief (the thought that fired). 10–2000 chars.
  beliefAuto   String @map("belief_auto") @db.Text
  /// C — Consequence (emotion + behaviour observed). 10–2000 chars.
  consequence  String @db.Text
  /// D — Disputation / reframe (alternative belief). 10–2000 chars.
  disputation  String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, date(sort: Desc)])
  @@map("reflection_entries")
}

/// V2.0 — TRACK module habit logging (master plan A2–A5 must-have features).
///
/// One row per `(userId, date, kind)` — upsert idempotency on retries.
/// The structured `value` payload is kind-specific and validated at the
/// Zod boundary in `lib/schemas/habit-log.ts`. We keep it as `Json` rather
/// than splitting into typed columns because :
///   - Each kind has its own value shape (durationMin for sleep, mealsCount
///     for nutrition, cups + lastDrinkAtUtc for caffeine, etc.).
///   - Sparse-typed columns would balloon the row width and waste storage.
///   - Posture Mark Douglas : we'd rather extend kinds (HealthKit auto-imports,
///     new wearables) without forcing a schema migration each time.
///
/// `notes` is optional free-text — bounded by Zod (500 chars) so the LLM
/// digest pipeline (master plan D-features) has a predictable budget.
model HabitLog {
  id     String    @id @default(cuid())
  userId String    @map("user_id")
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local civil date (no time component). Anchors the unique constraint
  /// + the daily aggregation queries.
  date   DateTime  @db.Date
  kind   HabitKind

  /// Kind-specific structured payload — see lib/schemas/habit-log.ts.
  value Json
  /// Optional free-text caveat ("manqué la sieste à cause d'une réunion").
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date, kind])
  @@index([userId, date(sort: Desc)])
  @@index([userId, kind, date(sort: Desc)])
  @@map("habit_logs")
}

// =============================================================================
// V2.3 — Pre-trade circuit breaker (Session BB, ADR-003)
// =============================================================================
//
// Mark Douglas anti-FOMO + Gollwitzer if-then implementation intentions
// (meta-analysis Gollwitzer-Sheeran 2006: d=0.65, 94 studies, n=8461,
// CI 95% [0.6, 0.7] — *Advances in Experimental Social Psychology* vol.38,
// updates Sheeran 2024 ERSP 642 tests + Gollwitzer-Sheeran 2025 Annu. Rev.
// Psychol. 76:303-328). See docs/decisions/ADR-003-pre-trade-circuit-breaker.md
// for the full mapping vs Mark Douglas's 4 primary trading fears (Trading
// in the Zone, 2000).
//
// 4 questions one-tap (~30s) before each trade entry:
//   reasonToTrade      : edge / fomo / revenge / boredom (PreTradeReason)
//   emotionLabel       : calme / excite / frustre / anxieux (PreTradeEmotion)
//   planAlignment      : does this trade respect the documented plan?
//   stopLossPredefined : is the stop-loss defined BEFORE entry?
//
// Statistical scope: REAL edge surface (NOT §21.5 training).
// Free-text fields: NONE → safeFreeText NOT needed, no crisis/injection
// surface, no EU AI Act 50(1) banner needed (zero AI).
//
// Optional auto-link via service-layer `linkRecentCheckToTrade(userId,
// tradeId, windowMin=15)` — a Trade created within 15min after a check
// sets `linkedTradeId` (P2002-safe via WHERE linkedTradeId IS NULL).
// String only (no FK constraint): if the linked Trade is later deleted,
// the linkedTradeId becomes a dangling pointer — gracefully handled via
// leftJoin null in service-layer reads. Trade deletion ≠ check deletion.
// =============================================================================

/// V2.3 — Pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer).
/// One row per (member, pre-trade self-assessment). Cascade-delete with the
/// user (RGPD §17). See enum docs + ADR-003 for the evidence base.
model PreTradeCheck {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  /// Why the member is about to enter the trade. 4 options Mark Douglas + Steenbarger.
  reasonToTrade PreTradeReason @map("reason_to_trade")

  /// Affective state at the moment of decision. Russell-Weiss-Mendelsohn 1989 2x2.
  emotionLabel PreTradeEmotion @map("emotion_label")

  /// Does this trade respect the member's documented plan? Yes/No.
  planAlignment Boolean @map("plan_alignment")

  /// Is the stop-loss defined BEFORE entry? Mark Douglas "accepting risk" ch.8.
  stopLossPredefined Boolean @map("stop_loss_predefined")

  /// Optional auto-link to a Trade created within 15min after this check.
  /// String only (no FK constraint): a deleted Trade leaves the linkedTradeId
  /// dangling rather than nulling out the check (graceful via leftJoin null
  /// in service-layer reads). Set via linkRecentCheckToTrade window 15min,
  /// P2002-safe via WHERE linkedTradeId IS NULL predicate in the UPDATE.
  linkedTradeId String? @map("linked_trade_id")

  @@index([userId, createdAt(sort: Desc)])
  @@map("pre_trade_checks")
}

// =============================================================================
// T-RECORD — Public-facing Eliott + Fxmily trade showcase (T0 2026-05-21).
// Décision : table dédiée séparée du Journal membre (table `trades`). Les
// trades public-facing appartiennent à Eliott (formateur), pas aux membres
// — surface RGPD distincte, schema sur mesure pour la vitrine publique :
// segments HISTORICAL/LIVE, partials, BE, tags news, screenshot R2.
// Pas de relation User : Eliott seul écrit, monovendeur.
//
// 🚨 DEPRECATED 2026-05-25 — Track Record split to standalone repo.
// These two models (PublicTrade + PublicTradePartial) and their enums
// (PublicTradeSegment + PublicTradeStatus) are still declared so Prisma
// stays in sync with the prod Hetzner DB tables, but no application code
// in this monorepo touches them anymore. The CRUD + vitrine live in
// <https://github.com/fxeliott/trackrecord-fxmily> (Hono Worker + Neon).
//
// To drop the tables from this DB, follow `docs/runbook-hetzner-deploy.md`
// §21 (T5 rollback recipe) — pg_dump + `DROP TABLE public_trade_partials,
// public_trades` + `DROP TYPE "PublicTradeSegment", "PublicTradeStatus"`
// (order matters: tables first, then types). Then remove the models below
// + run `prisma migrate dev --name v1_13_drop_public_trades`.
// =============================================================================

/// @deprecated 2026-05-25 — moved to trackrecord-fxmily standalone repo.
enum PublicTradeSegment {
  historical
  live
}

/// Statut d'un trade public.
enum PublicTradeStatus {
  open
  closed
  break_even
}

model PublicTrade {
  id            String               @id @default(cuid())
  segment       PublicTradeSegment
  /// Position chronologique 1..N. Conservée depuis l'ODS pour les
  /// historiques, auto-incrémentée ensuite via service layer.
  ordinal       Int                  @unique
  /// Instrument (EURUSD, XAUUSD, US30, USOIL...). Pas d'enum DB car la
  /// liste s'étend au-delà des paires majeures de l'app membre.
  instrument    String
  /// Direction long/short — réutilise enum existant. Nullable car certains
  /// historiques ODS n'ont pas le sens renseigné (action col vide).
  direction     TradeDirection?
  /// Date d'entrée. Pour les historiques importés ODS, anchored au lundi
  /// de la semaine (week label tel que "20 JANVIER" + année à confirmer).
  enteredAt     DateTime             @map("entered_at")
  exitedAt      DateTime?            @map("exited_at")
  /// % de capital risqué (0.50, 1.00, 2.00). Stocké en % brut, pas en
  /// fraction décimale (1.0 = 1%, pas 0.01). Decimal(4,2) cohérent avec
  /// `Trade.riskPct` V1.5 + Tharp ceiling (< 100%).
  riskPercent   Decimal              @map("risk_percent") @db.Decimal(4, 2)
  /// R-multiple final atteint (1R = +1×risque, -1R = stop plein, 0R = BE).
  resultR       Decimal?             @map("result_r") @db.Decimal(6, 3)
  /// % de portefeuille net (riskPercent × resultR). Précalculé pour
  /// performance lecture.
  resultPercent Decimal?             @map("result_percent") @db.Decimal(6, 3)
  status        PublicTradeStatus
  /// Session de trading — réutilise enum TradeSession existant.
  session       TradeSession?
  /// Tag setup (ICT FVG, OB retest, SMC liquidity sweep, breakout...).
  setup         String?
  /// Tags additionnels (news, FOMC, CPI, partagé en réunion live...).
  tags          String[]
  /// Commentaire post-trade public (sanitized via safeFreeText).
  notes         String?              @db.Text
  /// Lien screenshot — R2 key ou URL externe.
  screenshotUrl String?              @map("screenshot_url")
  /// Provenance du trade (audit / re-import).
  source        String               @default("import")
  /// Toggle publication. False = draft admin.
  isPublished   Boolean              @default(true) @map("is_published")
  publishedAt   DateTime             @default(now()) @map("published_at")
  partials      PublicTradePartial[]
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@index([segment, enteredAt(sort: Desc)])
  @@index([isPublished, enteredAt(sort: Desc)])
  @@index([instrument])
  @@map("public_trades")
}

/// Clôture partielle d'un trade public (legs successives).
model PublicTradePartial {
  id            String      @id @default(cuid())
  publicTradeId String      @map("public_trade_id")
  publicTrade   PublicTrade @relation(fields: [publicTradeId], references: [id], onDelete: Cascade)
  /// R-multiple atteint sur cette leg (1.5R = TP1).
  closedAtR     Decimal     @map("closed_at_r") @db.Decimal(6, 3)
  /// % de la position fermée sur cette leg (0..100).
  closedPercent Decimal     @map("closed_percent") @db.Decimal(5, 2)
  closedAt      DateTime    @map("closed_at")
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([publicTradeId, closedAt(sort: Asc)])
  @@map("public_trade_partials")
}

// =============================================================================
// V2.4 — Onboarding interview profilage IA (Session α, M3 directive 2026-05-27)
// =============================================================================
// Pattern : static questionnaire ~30 questions safeFreeText-sanitized service-
// side. Claude batch local async post-completion (carbone V1.4 monthly-debrief
// — ZÉRO API payante consommée, §canon dur). Posture §2 strict — Claude generates
// psycho/process axes ONLY (Mark Douglas / Steenbarger), never trade analysis.
// 1-1 cascade User × OnboardingInterview × MemberProfile.

/// Status lifecycle of an OnboardingInterview row.
/// started      → row created, no answers yet
/// in_progress  → ≥1 answer submitted (member is mid-questionnaire)
/// completed    → finalize() invoked → MemberProfile generated (Claude batch)
/// abandoned    → member inactive >7d post-creation (cron sweep V2.4+ future)
enum InterviewStatus {
  started
  in_progress
  completed
  abandoned
}

/// V2.4 — Onboarding interview profilage IA (Session α, M3 directive).
///
/// 1-1 cascade User. Static questionnaire ~30 questions Mark Douglas-aligned,
/// instrumentVersion semver-tracked for longitudinal validity (mirror V1.5
/// MindsetCheck pattern). claudeModelVersion + totalTokens{Input,Output} tracked
/// for cost transparency (batch local Claude Max = $0 but tokens logged for audit).
///
/// Pipeline pattern : carbone V1.4 monthly-debrief —
/// 1. Member répond aux questions (UI wizard V2.4 Phase B future)
/// 2. finalize() flips status started/in_progress → completed
/// 3. Cron OR admin batch local triggers Claude analysis → MemberProfile created
/// 4. Member sees MemberProfile in dashboard "Mon profil"
/// 5. Admin (Eliot) sees pseudonymized profile in /admin/members/[id]?tab=profil
///
/// Posture §2 strict : Claude's job is to extract psycho/process axes from
/// the answers (discipline, patience, acceptance, probabilities thinking,
/// emotion regulation, process focus, etc.). NEVER trade analysis. NEVER setup
/// recommendation. Regex AMF post-gen guard at claude-client layer.
model OnboardingInterview {
  id                 String                      @id @default(cuid())
  userId             String                      @unique @map("user_id")
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             InterviewStatus             @default(started)
  startedAt          DateTime                    @default(now()) @map("started_at")
  completedAt        DateTime?                   @map("completed_at")
  claudeModelVersion String?                     @map("claude_model_version")
  totalTokensInput   Int                         @default(0) @map("total_tokens_input")
  totalTokensOutput  Int                         @default(0) @map("total_tokens_output")
  instrumentVersion  String                      @default("v1") @map("instrument_version")
  answers            OnboardingInterviewAnswer[]
  profile            MemberProfile?
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  @@index([status, completedAt])
  @@map("onboarding_interviews")
}

/// V2.4 — Onboarding interview answer (one row per question/answer pair).
///
/// Cascade via OnboardingInterview AND via User (for RGPD export Art. 15 +
/// soft-delete cascade J10). answerText is safeFreeText-sanitized at service
/// layer (crisis/injection detection BEFORE persist — carbone V1.8 REFLECT
/// pattern). questionKey is the slug stable for analytics (questionText may
/// evolve across instrumentVersion bumps).
///
/// @@unique [interviewId, questionIndex] guarantees idempotent append (cant
/// double-submit same question — service handles via upsert semantics).
model OnboardingInterviewAnswer {
  id            String              @id @default(cuid())
  interviewId   String              @map("interview_id")
  interview     OnboardingInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId        String              @map("user_id")
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIndex Int                 @map("question_index")
  questionKey   String              @map("question_key")
  questionText  String              @map("question_text") @db.Text
  answerText    String              @map("answer_text") @db.Text
  createdAt     DateTime            @default(now()) @map("created_at")

  @@unique([interviewId, questionIndex])
  @@index([userId, createdAt(sort: Desc)])
  @@map("onboarding_interview_answers")
}

/// V2.4 — MemberProfile = final Claude-synthesized output of OnboardingInterview.
///
/// 1-1 cascade User + 1-1 Restrict to OnboardingInterview (preserves audit trail
/// even if downstream interview row is touched — equivalent V1.4 MonthlyDebrief
/// retention pattern). summary = 200-800 chars Claude-generated synthesis.
/// highlights = JSON [{ key, label, evidence: [{ answerId, excerpt }] }]
/// structured insights with traceable evidence references back to InterviewAnswer.
/// axesPrioritaires = JSON ["discipline", "patience", "acceptance", ...] 3-5
/// Mark Douglas psycho/process axes the member should focus on first.
///
/// claudeModelVersion + instrumentVersion mirror OnboardingInterview row for
/// audit/longitudinal traceability. analyzedAt = batch-local job timestamp.
model MemberProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique @map("user_id")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId        String              @unique @map("interview_id")
  interview          OnboardingInterview @relation(fields: [interviewId], references: [id], onDelete: Restrict)
  summary            String              @db.Text
  highlights         Json
  axesPrioritaires   Json                @map("axes_prioritaires")
  claudeModelVersion String              @map("claude_model_version")
  instrumentVersion  String              @map("instrument_version")
  analyzedAt         DateTime            @default(now()) @map("analyzed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@map("member_profiles")
}

// =============================================================================
// V1.7 §30 — Meeting attendance tracking (suivi de présence aux réunions).
//
// Recurring Fxmily meetings (Mon–Fri 12h & 20h Europe/Paris, Zoom) are
// materialised as `Meeting` rows by a cron (J-M3). Each member self-declares
// attendance in-app via `MeetingAttendance`. Posture §2 verrouillée: the app
// tracks the ACT (présence + lecture = discipline/exécution) via a boolean
// `contentReviewed` ONLY — it NEVER stores / displays / comments the Ichor
// analysis content. Attendance feeds ONLY the `engagement` dimension via the
// count-only primitive `countMeetingAttendance` (J-M4), never the real edge.
// See SPEC §30 (source of truth) for the full rationale + invariants §30.7.
// =============================================================================

/// V1.7 §30 — meeting slot. `midday` = 12h00 Paris (Ichor analyse), `evening`
/// = 20h00 Paris (Ichor bilan/débrief). The slot carries the expected content
/// type — no separate content entity (KISS, SPEC §30.2).
enum MeetingSlot {
  midday
  evening
}

/// V1.7 §30 — meeting lifecycle. `cancelled` = admin unavailable / no meeting
/// → excluded from the attendance-rate denominator (a member is NEVER
/// penalised when Eliot is not available, SPEC §30.2).
enum MeetingStatus {
  scheduled
  cancelled
}

/// V1.7 §30 — how the member attended. `live` = present on Zoom, `replay` =
/// watched the Drive recording. Null on a `MeetingAttendance` row means "not
/// yet declared". A complete attendance = `attendanceMode != null` AND
/// `contentReviewed = true` (SPEC §30.3).
enum MeetingAttendanceMode {
  live
  replay
}

/// V1.7 §30 — a recurring Fxmily meeting occurrence (admin-scoped, cron-generated).
/// 0 FK to the real-edge models (`Trade` / `BehavioralScore`): a meeting is an
/// attendance datum, not a trading one (SPEC §30.3 isolation by construction).
model Meeting {
  id String @id @default(cuid())

  /// Civil day (Europe/Paris) of the meeting. DERIVED from `scheduledAt` by
  /// construction = `localDateOf(scheduledAt, 'Europe/Paris')` — never computed
  /// independently (anti DST-drift on the switch day, invariant §30.7).
  /// `@db.Date` pins UTC-midnight (canon DailyCheckin).
  date DateTime    @db.Date
  slot MeetingSlot

  /// Exact UTC instant of the 12h/20h Paris slot for `date`, DST-aware via
  /// `localInstantToUtc` (CET = 11h UTC / CEST = 10h UTC). Drives sort + the
  /// "past meeting" check. Never `12:00 UTC` hardcoded (invariant §30.7).
  scheduledAt DateTime @map("scheduled_at")

  status MeetingStatus @default(scheduled)

  /// Optional admin note when cancelling a slot ("pas dispo"). Free-text,
  /// `safeFreeText`-sanitised at the J-M3 admin Server Action boundary.
  cancelledReason String? @map("cancelled_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attendances MeetingAttendance[]

  /// Idempotent cron generation: at most one meeting per slot per civil day.
  /// Doubles as the `date >=` / `scheduledAt` denominator filter index.
  @@unique([date, slot])
  /// Denominator filter: scheduled meetings ordered by recency. No standalone
  /// `[scheduledAt]` index — it is a redundant prefix of this composite
  /// (repo convention: no redundant single-column index, cf. DailyCheckin/Trade).
  @@index([status, scheduledAt(sort: Desc)])
  @@map("meetings")
}

/// V1.7 §30 — a member's self-reported attendance for one `Meeting`. Cascade on
/// both `Meeting` and `User` delete (RGPD §17 data minimisation).
model MeetingAttendance {
  id String @id @default(cuid())

  meetingId String  @map("meeting_id")
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// How the member attended (live Zoom OR Drive replay). Null until declared.
  attendanceMode MeetingAttendanceMode? @map("attendance_mode")

  /// Did the member read the associated Ichor content (analyse@12h / bilan@20h)?
  /// Boolean ONLY — the app NEVER stores the content itself (posture §2). A
  /// complete attendance = `attendanceMode != null` AND `contentReviewed = true`.
  contentReviewed Boolean @default(false) @map("content_reviewed")

  declaredAt DateTime @default(now()) @map("declared_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  /// Idempotent declaration: re-declaring updates the same row, never stacks
  /// (upsert on this composite key — pattern DailyCheckin `(userId,date,slot)`).
  @@unique([meetingId, userId])
  /// Member view: their recent declarations. No standalone `[meetingId]` index
  /// — the admin per-meeting lookup is served by the `[meetingId, userId]`
  /// unique prefix (repo convention: no redundant single-column index).
  @@index([userId, declaredAt(sort: Desc)])
  @@map("meeting_attendances")
}

// Fxmily ‚Äî Prisma schema.
// Source of truth for the data model. Entities are added milestone by milestone
// per SPEC.md ¬ß6. Database connection lives in `prisma.config.ts` (Prisma 7+).
//
// J0 ‚Äî datasource + generator only.
// J1 ‚Äî User, Account, Session, VerificationToken, Invitation, AuditLog.
// J2 ‚Äî Trade + enums (TradeDirection, TradeSession, TradeOutcome, RealizedRSource).
// J4 ‚Äî TradeAnnotation + NotificationQueue + enums (AnnotationMediaType, NotificationType, NotificationStatus).
// J5 ‚Äî DailyCheckin + enum CheckinSlot. Extends NotificationType with morning/evening reminders.
// J6+ ‚Äî BehavioralScore, MarkDouglasCard, MarkDouglasDelivery, WeeklyReport.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  member
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

/// Self-service access request lifecycle (V2.5 ‚Äî public "Rejoindre" front door).
/// A public visitor submits pr√©nom/nom/email on `/rejoindre` ‚Üí a `pending` row.
/// The admin reviews it in `/admin/access-requests` and either:
///   approved : an `Invitation` is minted (existing onboarding pipeline reused)
///              and a premium "demande accept√©e" email is sent. The created
///              invitation id is stored on the request for traceability.
///   rejected : terminal, a refusal email IS sent (¬ß26.4 ‚Äî no longer a silent
///              refusal), but no account is ever created.
/// RGPD: a non-member's name+email is PII stored before any consent ‚Äî the
/// `/api/cron/purge-access-requests` weekly cron purges resolved rows (and
/// stale pending ones > 30d) so this surface never accumulates dormant PII.
enum AccessRequestStatus {
  pending
  approved
  rejected
}

/// Trade direction (J2). Long = buy, short = sell.
enum TradeDirection {
  long
  short
}

/// Trading session (J2). Auto-derived from `enteredAt` UTC at form-fill time
/// but persisted explicitly so the user's manual override survives DST shifts.
/// Plage UTC indicatives (DST g√©r√© c√¥t√© code) :
///   asia    : 00:00‚Äì07:00 UTC
///   london  : 07:00‚Äì12:00 UTC
///   overlap : 12:00‚Äì16:00 UTC (London/NY)
///   newyork : 16:00‚Äì21:00 UTC
enum TradeSession {
  asia
  london
  newyork
  overlap
}

/// Outcome reported at trade close (J2). `break_even` covers both flat exits
/// and exits within ¬±0.1R of entry ‚Äî the wizard maps the user-friendly "BE"
/// button to this value.
enum TradeOutcome {
  win
  loss
  break_even
}

/// Provenance of `realizedR` (J2).
///   computed  : derived from entry/exit/stopLoss with the canonical
///               (exit-entry)/(entry-stopLoss) formula. Reliable for analytics.
///   estimated : fallback when no stopLoss was provided. Equals `plannedRR` on
///               win, -1 on loss, 0 on break_even. Excluded from precision-
///               sensitive aggregates (expectancy, R-distribution).
enum RealizedRSource {
  computed
  estimated
}

/// V1.5 ‚Äî Setup quality classification (Steenbarger best practice).
/// Captured BEFORE the outcome is known, so it cannot rationalize a posteriori.
///   A : setup parfait, conviction haute, contexte favorable (gold standard).
///   B : setup correct, conviction moyenne, ou contexte mitig√© (default acceptable).
///   C : setup limite, conviction basse, ou doute sur le contexte (√Ý coacher).
/// Eliot uses the distribution to coach : "tes B et C ont un win-rate 30 %
/// plus bas que tes A, pourquoi tu les prends ?". Decoupled from `realizedR`
/// ‚Äî a C trade that wins is still a C trade.
enum TradeQuality {
  A
  B
  C
}

/// Annotation media kind (J4). V1 supports image attachments only ‚Äî the
/// 500 MiB Zoom-video upload path is deferred to J4.5 (depends on R2 wiring).
/// The enum value is kept open so the column can store `video` once available.
enum AnnotationMediaType {
  image
  video
}

/// Push-notification kinds queued for J9 dispatch (J4 + J5 + J9).
/// Values are persisted as strings ‚Äî adding a new kind is an additive migration.
///   annotation_received          : a member's trade just got a new admin correction (J4).
///   training_annotation_received : a member's BACKTEST just got an admin correction
///                                  (J-T3). DISTINCT from annotation_received ‚Äî a
///                                  backtest correction must never conflate with a
///                                  real-trade correction (statistical isolation ¬ß21.5).
///   checkin_morning_reminder     : nudges the member to fill their morning check-in (J5).
///   checkin_evening_reminder     : nudges the member to fill their evening check-in (J5).
///   douglas_card_delivered       : a Mark Douglas card was triggered for the member (J9).
///   weekly_report_ready          : the J8 admin weekly digest is ready (admin-only push, opt-in).
///   monthly_debrief_ready        : the V1.4 member monthly AI debrief is ready (SPEC ¬ß25 ‚Äî
///                                  member-facing push, mirror douglas_card_delivered; no
///                                  admin monthly push by design).
///   mindset_check_ready          : the V1.5 weekly mindset self-check is available (SPEC ¬ß27 ‚Äî
///                                  member-facing push, mirror monthly_debrief_ready;
///                                  deterministic, no AI).
enum NotificationType {
  annotation_received
  training_annotation_received
  checkin_morning_reminder
  checkin_evening_reminder
  douglas_card_delivered
  weekly_report_ready
  monthly_debrief_ready
  mindset_check_ready
}

/// Daily check-in slot (J5, SPEC ¬ß6.4 + ¬ß7.4).
///   morning : sleep, routine, mood, intention. Reminder ~07:30 local.
///   evening : discipline, stress, gratitude, journal. Reminder ~20:30 local.
enum CheckinSlot {
  morning
  evening
}

/// V2.0 TRACK module ‚Äî habit logging granular kinds (FXMILY-V2-MASTER A2-A5
/// must-have features). One row per (user, date, kind). Value JSON shape
/// is kind-specific and validated at the Zod boundary in
/// `lib/schemas/habit-log.ts`.
enum HabitKind {
  /// Hours of sleep (durationMin) + optional quality rating 1-10.
  sleep
  /// Meals count + optional quality rating (poor/fair/good/excellent).
  nutrition
  /// Cups of caffeine + optional last-drink HH:MM (UTC). Master plan A3.
  caffeine
  /// Type (cardio/strength/mixed/flexibility/other) + duration + intensity.
  sport
  /// Duration (minutes) + optional quality rating 1-10. Master plan A5.
  meditation
}

/// V2.3 ‚Äî Pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer if-then).
/// 4 options to answer "Pourquoi je veux prendre ce trade ?" before each entry.
/// See `docs/decisions/ADR-003-pre-trade-circuit-breaker.md` for the mapping
/// vs Douglas's 4 primary trading fears (Trading in the Zone, 2000) ‚Äî `edge`
/// = absence of the 4 fears, `fomo` = fear of missing out (direct), `revenge`
/// = mixed fear of being wrong + losing money, `boredom` = Steenbarger
/// "low arousal" affect (extension hors-Douglas-canonique, documented).
enum PreTradeReason {
  /// Setup √©prouv√©, je suis dans ma routine (absence des 4 fears Douglas).
  edge
  /// J'ai peur de rater quelque chose (fear of missing out ‚Äî Douglas).
  fomo
  /// Je veux compenser une perte (fear of being wrong + losing money ‚Äî Douglas).
  revenge
  /// J'ai juste envie de faire quelque chose (Steenbarger low-arousal extension).
  boredom
}

/// V2.3 ‚Äî Pre-trade affective state. Russell-Weiss-Mendelsohn 1989 affect grid
/// 2x2 (valence √ó arousal). 4 options mapping the 4 quadrants. See ADR-003.
enum PreTradeEmotion {
  /// Low arousal, positive valence.
  calme
  /// High arousal, positive valence.
  excite
  /// High arousal, negative valence.
  frustre
  /// Low-to-medium arousal, negative valence.
  anxieux
}

/// Mark Douglas card category (J7, SPEC ¬ß7.6).
/// Maps to canonical pillars from *Trading in the Zone* and *The Disciplined Trader*.
enum DouglasCategory {
  acceptance
  tilt
  discipline
  ego
  probabilities
  confidence
  patience
  consistency
  fear
  loss
  process
}

/// Lifecycle of a queued notification (J4 + J9).
///   pending     : waiting for the J9 dispatcher (initial state, also re-set after retryable error).
///   dispatching : claimed by a dispatcher run (atomic transition pending‚Üídispatching via updateMany,
///                 prevents two cron instances from sending the same notification twice).
///   sent        : delivered to at least one push endpoint.
///   failed      : dispatcher gave up after the retry budget. Surfaced in admin + may trigger
///                 email fallback (SPEC ¬ß18.2 iOS push fragility mitigation).
enum NotificationStatus {
  pending
  dispatching
  sent
  failed
}

/// ¬ß26 Calendrier adaptatif ‚Äî the three coarse parts of a member's day. KISS
/// 3-slot granularity (Q2 default) shared vocabulary between the weekly
/// questionnaire (`energy_peak_slot`) and the generated schedule blocks
/// (JSON-validated by `adaptiveCalendarOutputSchema`). Distinct from
/// `CheckinSlot` (morning/evening only) ‚Äî the calendar needs an afternoon
/// band to organise the practice day. Bump the instrument version (not this
/// enum in place) if a 4th band is ever needed.
enum CalendarSlot {
  morning
  afternoon
  evening
}

/// ¬ß26 Calendrier adaptatif ‚Äî what a scheduled time-block organises. Posture
/// ¬ß2 (BLOQUANT): every category is about the TIME of practice, NEVER a market
/// call. `live_trading` = a session the member plans to be at the screen,
/// `backtest` = training/replay, `mark_douglas_review` = psychology reading,
/// `checkin` = daily check-in ritual, `meeting` = ¬ß30 r√©union, `rest` =
/// deliberate recovery, `free` = unstructured. The generated `schedule` JSON
/// is validated against these values; `AdaptiveCalendar.primary_category`
/// denormalises the dominant one for admin week-at-a-glance.
enum CalendarBlockCategory {
  live_trading
  backtest
  mark_douglas_review
  checkin
  rest
  meeting
  free
}

// =============================================================================
// Auth.js v5 core models (PrismaAdapter contract)
// https://authjs.dev/getting-started/adapters/prisma
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")

  // Profile (filled at onboarding completion)
  firstName String? @map("first_name")
  lastName  String? @map("last_name")
  image     String?

  // Authentication
  passwordHash String? @map("password_hash") // argon2id, optional (magic-link-only users have null)
  /// J4 (security T2-1) ‚Äî JWT session-revocation epoch. Bumped to invalidate
  /// every outstanding JWT for this user (suspend / hard-delete / future
  /// password reset). The Node-side `jwt` callback in `auth.ts` re-reads this
  /// on each `auth()` call and tears the session down when the token's stale
  /// claim no longer matches. See `lib/auth/session-revocation.ts`.
  tokenVersion Int     @default(0) @map("token_version")

  // Authorization & lifecycle
  role   UserRole   @default(member)
  status UserStatus @default(active)

  // SPEC ¬ß6.1 ‚Äî behavioral profile fields
  timezone         String    @default("Europe/Paris")
  pushSubscription Json?     @map("push_subscription") // J9
  consentRgpdAt    DateTime? @map("consent_rgpd_at")

  /// S3 ‚Äî number of broker accounts the vision pipeline detected from the
  /// member's MT5 proof uploads (Claude counts distinct account headers across
  /// proofs). Null = never analysed. Denormalised convenience for the admin
  /// "r√©alit√© vs d√©clar√©" view; the source of truth is the `BrokerAccount`
  /// rows themselves.
  detectedAccountCount Int? @map("detected_account_count")

  // Lifecycle timestamps
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  /// J10 ‚Äî RGPD soft-delete anchor. Set when `/account/delete` Server Action
  /// confirms (status flipped to `deleted`, PII scrubbed). Cleared on cancel
  /// inside the 24h grace window. Hard-purged 30 days later by
  /// `/api/cron/purge-deleted` (cascade removes all user-scoped rows).
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  accounts                     Account[]
  sessions                     Session[]
  invitationsSent              Invitation[]                  @relation("InvitationsSent")
  auditLogs                    AuditLog[]
  trades                       Trade[]
  // J4 ‚Äî annotations the admin authored on members' trades.
  annotationsAuthored          TradeAnnotation[]             @relation("AnnotationsAuthored")
  // J4 ‚Äî push-notification queue rows targeting this user.
  notificationsQueued          NotificationQueue[]
  // J5 ‚Äî morning + evening check-ins.
  dailyCheckins                DailyCheckin[]
  // J6 ‚Äî daily behavioral score snapshots (cached, recomputed nightly).
  behavioralScores             BehavioralScore[]
  // J7 - Mark Douglas contextual card deliveries + manual favorites.
  douglasDeliveries            MarkDouglasDelivery[]
  douglasFavorites             MarkDouglasFavorite[]
  // J8 ‚Äî weekly AI reports (admin digest, generated by Claude Sonnet 4.6).
  weeklyReports                WeeklyReport[]
  // V1.8 ‚Äî member-facing reflection (Sunday wizard + CBT Ellis ABC).
  weeklyReviews                WeeklyReview[]
  reflectionEntries            ReflectionEntry[]
  // V2.0 ‚Äî TRACK module habit logs (sleep/nutrition/caffeine/sport/meditation).
  habitLogs                    HabitLog[]
  // V2.1 ‚Äî admin private notes (SPEC ¬ß7.7). Two named relations: notes
  // written ABOUT this member, and notes this (admin) user authored.
  adminNotesAbout              AdminNote[]                   @relation("AdminNotesAbout")
  adminNotesAuthored           AdminNote[]                   @relation("AdminNotesAuthored")
  // V1.2 ‚Äî Mode Entra√Ænement / Backtest (SPEC ¬ß21). Statistically isolated
  // from the real edge: no FK to Trade, separate enums, dedicated services.
  trainingTrades               TrainingTrade[]
  trainingAnnotationsAuthored  TrainingAnnotation[]          @relation("TrainingAnnotationsAuthored")
  // V1.3 ‚Äî member-owned weekly backtest-practice debrief (SPEC ¬ß23).
  // Statistically isolated like the rest of the training surface: no FK to
  // Trade / WeeklyReview / BehavioralScore, only this implicit userId link.
  trainingDebriefs             TrainingDebrief[]
  // V1.4 ‚Äî monthly AI debrief (SPEC ¬ß25). IA-pipeline sibling of WeeklyReport
  // but dual-section ¬ß21.5-walled: no FK to Trade/WeeklyReport/TrainingTrade/
  // BehavioralScore ‚Äî only this implicit userId link (the WeeklyReport rows
  // of the month are read as INPUT by the aggregator, never linked as FK).
  monthlyDebriefs              MonthlyDebrief[]
  // V1.5 ‚Äî weekly mindset self-check (SPEC ¬ß27). Deterministic, zero-AI.
  // 0-FK statistically isolated like the rest of the training surface:
  // no FK to Trade / WeeklyReport / BehavioralScore, only this implicit
  // userId link ‚Äî feeds nothing back into the real edge (¬ß21.5/¬ß27.7).
  mindsetChecks                MindsetCheck[]
  // V2.3 ‚Äî pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer
  // if-then, Session BB). 4 questions one-tap (~30s) before each trade.
  // ZERO free-text ‚Üí ZERO crisis/injection surface ‚Üí ZERO AI banner needed.
  // Optional auto-link to a Trade via service-layer linkRecentCheckToTrade
  // window 15min P2002-safe. The member always stays master of the decision
  // ‚Äî Fxmily NEVER blocks a trade. See docs/decisions/ADR-003-pre-trade-
  // circuit-breaker.md for the evidence base (Gollwitzer-Sheeran 2006
  // d=0.65, 94 studies, n=8461) + Mark Douglas 4 primary trading fears.
  preTradeChecks               PreTradeCheck[]
  // V2.4 ‚Äî Onboarding interview profilage IA Mark Douglas (Session Œ±, M3
  // directive Eliot 2026-05-27 verbatim "claude pour analyser au plus deep").
  // 1-1 OnboardingInterview + MemberProfile cascade User. Static questionnaire
  // ~30 questions safeFreeText-sanitized at service layer. Claude batch local
  // async post-completion (carbone V1.4 monthly-debrief ‚Äî Z√âRO API payante).
  // Posture ¬ß2 strict ‚Äî Claude generates psycho/process axes ONLY, never
  // trade analysis. Cf. memory/fxmily_session_2026-05-27_pipeline_ee_ii_closure.md
  // for the M3 directive context. ADR-004 future evidence base for instrument
  // versioning + crisis detection patterns.
  onboardingInterview          OnboardingInterview?
  onboardingAnswers            OnboardingInterviewAnswer[]
  memberProfile                MemberProfile?
  // ¬ß26 ‚Äî Calendrier adaptatif. Weekly closed questionnaire ‚Üí Claude batch
  // local generates a personal weekly schedule. Posture ¬ß2 strict: organises
  // the member's TIME of practice (sessions/backtest/Mark Douglas/r√©unions
  // ¬ß30/rest), NEVER trades. `AdaptiveCalendar` carries NO P&L field and has
  // NO FK to the questionnaire (snapshot-at-generation decoupled). The Claude
  // snapshot reads count-only activity (lib/calendar/snapshot.ts) ‚Äî ¬ß21.5/¬ß27.7
  // isolation enforced by test/anti-leak/calendar-isolation.test.ts.
  weeklyScheduleQuestionnaires WeeklyScheduleQuestionnaire[]
  adaptiveCalendars            AdaptiveCalendar[]
  // V1.7 ¬ß30 ‚Äî meeting attendance declarations (self-report). `Meeting` has
  // NO User FK (admin-scoped global entity); only this join links the member.
  // Touches ONLY engagement via the count-only primitive countMeetingAttendance (J-M4).
  meetingAttendances           MeetingAttendance[]
  // J9 ‚Äî Web Push subscriptions (one row per browser/device) + per-category opt-out preferences.
  pushSubscriptions            PushSubscription[]
  notificationPreferences      NotificationPreference[]
  // V2.5 ‚Äî public self-service access requests reviewed by this admin
  // (approve/reject). SetNull on the request so a deleted admin doesn't
  // cascade-wipe the audit trail of who reviewed a non-member's request.
  reviewedAccessRequests       AccessRequest[]               @relation("AccessRequestsReviewed")
  // S3 ‚Äî V√©rification & Honn√™tet√© radicale (preuve MT5 + score de constance).
  // All cascade on User delete (RGPD ¬ß17 data minimisation, schema-wide).
  brokerAccounts               BrokerAccount[]
  mt5AccountProofs             Mt5AccountProof[]
  discrepancies                Discrepancy[]
  constancyScores              ConstancyScore[]
  scoreEvents                  ScoreEvent[]
  alerts                       Alert[]
  // S3/S8 ‚Äî training-session containers (firewall ¬ß21.5: training world only).
  trainingSessions             TrainingSession[]
  // V2 S2 ‚Äî universal tracking engine (recurring code-defined instruments).
  // ¬ß21.5/¬ß27.7 isolated: NO FK to Trade/BehavioralScore ‚Äî captured responses +
  // D1/D2/D3 metadata only, feeds nothing into the real edge. Cascade on delete.
  trackingEntries              TrackingEntry[]
  trackingSchedules            TrackingSchedule[]

  @@index([status])
  @@index([role])
  /// J10 ‚Äî partial index for the soft-delete purge cron. Only rows where
  /// `status = 'deleted'` satisfy the predicate; the partial index keeps it
  /// trivially small even at 1000+ members. The actual `WHERE status =
  /// 'deleted'` clause lives in the migration SQL (Prisma 7 doesn't expose
  /// partial-index predicates declaratively yet).
  @@index([status, deletedAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// Fxmily-specific models
// =============================================================================

/// Admin invitation flow (SPEC ¬ß6.9, ¬ß7.1).
/// Token is generated as a 32-byte random string (nanoid), only its SHA-256 hash
/// is stored. The plain token is sent in the email link and never persisted.
model Invitation {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  invitedById String @map("invited_by_id")
  invitedBy   User   @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("invitations")
}

/// RGPD-friendly audit log (SPEC ¬ß6.8, ¬ß9.2).
/// IPs are SHA-256-hashed before storage. Never log plaintext PII in `metadata`.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// J2 ‚Äî Trading journal
// =============================================================================

/// Trade journal entry (SPEC ¬ß6.2, ¬ß7.3).
///
/// Lifecycle: a trade is created in "open" state with the pre-entry fields
/// (everything before the `--- post-exit ---` block). The user can finalize it
/// later ‚Äî either right away in a single wizard run, or asynchronously after
/// the trade closes ‚Äî by filling the post-exit block via /journal/[id]/close.
/// The `closedAt` timestamp marks the transition; both screenshots are
/// mandatory at their respective phases (SPEC ¬ß7.3 "upload obligatoire").
///
/// `realizedR` precision: the canonical formula `(exit - entry) / (entry - SL)`
/// (signed by direction) is used when `stopLossPrice` is provided
/// (`realizedRSource = computed`). When the user skipped the SL, we fall back
/// to `plannedRR | -1 | 0` based on outcome (`realizedRSource = estimated`).
/// See `lib/trading/calculations.ts` for the implementation.
model Trade {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ----- Pre-entry block (mandatory at trade creation) -----

  /// One of the 12 allowlisted symbols (see lib/trading/pairs.ts). Stored as
  /// uppercase string rather than an enum so adding pairs doesn't require a
  /// DB migration ‚Äî the allowlist is enforced at the Zod / Server Action edge.
  pair            String
  direction       TradeDirection
  session         TradeSession
  /// User-provided trade entry timestamp, persisted in UTC. The wizard
  /// pre-fills this from `Date.now()` but the user can override (useful when
  /// logging trades retroactively).
  enteredAt       DateTime       @map("entered_at")
  entryPrice      Decimal        @map("entry_price") @db.Decimal(20, 8)
  /// Position size in lots (forex/metals) or contracts (indices). Decimal(12,4)
  /// covers micro-lots (0.01) up to institutional sizes.
  lotSize         Decimal        @map("lot_size") @db.Decimal(12, 4)
  /// Optional stop-loss price. Strongly encouraged: enables exact `realizedR`.
  stopLossPrice   Decimal?       @map("stop_loss_price") @db.Decimal(20, 8)
  /// Planned reward-to-risk ratio (e.g. 2.5 means "risk 1 to make 2.5").
  /// Slider in the UI clamps to [0.5, 10] with 0.25 step.
  plannedRR       Decimal        @map("planned_rr") @db.Decimal(6, 2)
  /// Multi-select tag slugs (FR labels, EN slugs). See lib/trading/emotions.ts.
  /// UI caps the selection at 3 tags; we don't enforce in DB to allow future
  /// expansion without a migration.
  emotionBefore   String[]       @map("emotion_before")
  planRespected   Boolean        @map("plan_respected")
  /// `null` = N/A (no hedge applicable on this trade). Tri-state per SPEC ¬ß7.3.
  hedgeRespected  Boolean?       @map("hedge_respected")
  /// SPEC ¬ß28/¬ß21 ‚Äî "oublis" tracking axis (master prompt ¬ß28: "ex√©cution en
  /// position r√©elle (respect du plan, oublis)" / ¬ß21: "s'il oublie des choses
  /// ou non"). Positive framing (anti-Black-Hat): `true` = "j'ai suivi tout mon
  /// process, rien oubli√©", `false` = forgot/missed steps, `null` = not answered
  /// / legacy row. Answered at CLOSE alongside `emotionDuring` (PR #236 precedent)
  /// and parallel to `planRespected`/`hedgeRespected`. SPEC ¬ß2 posture: we track
  /// the ACT of completeness/forgetting, NEVER advise on the trade itself. Pure
  /// additive nullable Boolean ‚Äî exact mirror of `DailyCheckin.marketAnalysisDone`.
  processComplete Boolean?       @map("process_complete")

  /// S26 ‚Äî ¬´ Fid√©lit√© √Ý la gestion ¬ª. Three management hard-rules of Eliott's
  /// method (transcript "gestion de trades technique"), answered at CLOSE next to
  /// `processComplete`. Tri-state each: `true` (followed the rule), `false` (did
  /// not), `null` (not answered ‚Äî OPTIONAL, NO required-field gate, CANON). SPEC
  /// ¬ß2 posture (identical to `processComplete`/`marketAnalysisDone`): we track
  /// the ACT of following YOUR OWN execution rule, NEVER the trade content / a
  /// market call (no level, no direction, no setup). Pure additive nullable
  /// Booleans ‚Üí null-skip everywhere ‚Üí byte-identical for legacy trades.

  /// Method rule: "SL plac√© en M15, toujours au-del√Ý de mon dernier extr√™me,
  /// jamais au hasard". The ACT of placing the stop per the member's OWN rule.
  slPerRule       Boolean? @map("sl_per_rule")
  /// Method rule: "d√®s le RR 1, je passe mon SL au break-even (l√©g√®rement
  /// positif)". The ACT of moving to break-even at RR 1 as planned.
  movedToBe       Boolean? @map("moved_to_be")
  /// Method rule: "au TP (RR 2‚Äì3), je cl√¥ture 90 % et laisse 10 % courir jusqu'√Ý
  /// la bougie 20h". The ACT of the planned partial secure at target.
  partialAtTarget Boolean? @map("partial_at_target")

  notes String? @db.Text

  /// Storage key for the pre-entry screenshot (mandatory at creation, but the
  /// column is nullable to allow administrative repairs). Format follows
  /// `lib/storage` conventions: `trades/{userId}/{nanoid}.{ext}`.
  screenshotEntryKey String? @map("screenshot_entry_key")

  // ----- V1.5 trading-expert calibration (Steenbarger / Tharp) -----------

  /// Setup quality A/B/C (Steenbarger, *Daily Trading Coach*). Captured at
  /// trade creation. Optional ‚Äî V1 trades created before V1.5 ship are NULL
  /// and excluded from quality-distribution analytics.
  tradeQuality TradeQuality? @map("trade_quality")

  /// Percentage of account risked on this trade (e.g. 1.50 = 1.5 %).
  /// Tharp gold rule: never risk more than 1-2 % per trade. Optional.
  /// Captured by the member at form-fill time (we don't have account
  /// balance in the schema ‚Äî V2 candidate). Decimal(4, 2) covers 0.01 %
  /// up to 99.99 % ‚Äî aligned with the Zod schema upper bound `< 100`.
  /// Code-reviewer #6 (2026-05-09) ‚Äî was Decimal(5, 2) which allowed
  /// 999.99 vs Zod < 100 mismatch.
  riskPct Decimal? @map("risk_pct") @db.Decimal(4, 2)

  // ----- Post-exit block (filled at close) -----

  exitedAt        DateTime?        @map("exited_at")
  exitPrice       Decimal?         @map("exit_price") @db.Decimal(20, 8)
  outcome         TradeOutcome?
  realizedR       Decimal?         @map("realized_r") @db.Decimal(6, 2)
  realizedRSource RealizedRSource? @map("realized_r_source")
  emotionAfter    String[]         @map("emotion_after")
  /// Multi-select emotion slugs felt DURING the open position, recalled at
  /// close next to `emotionAfter`. Same allowlist as `emotionBefore`/
  /// `emotionAfter` (lib/trading/emotions.ts), capped at 3 by the Zod boundary.
  /// Closes the "avant / pendant / apr√®s" emotional axis (master prompt ¬ß22).
  /// Plain `text[]` (no DB allowlist) for migration-free slug evolution; trades
  /// closed before this field shipped carry `{}` (migration DEFAULT).
  emotionDuring   String[]         @map("emotion_during")

  // V1.8 REFLECT ‚Äî post-outcome bias tags (CFA LESSOR + Steenbarger).
  // Distinct from `emotionAfter` (raw affect): `tags` is a structured
  // post-mortem classification ("loss-aversion", "revenge-trade", etc.).
  // Member self-assigned at close wizard (Q3=A act√©e 2026-05-13).
  // Allowlist enforced at the Zod boundary (lib/schemas/trade.ts) ‚Äî DB
  // stays a plain `text[]` to keep migrations free as the slug list
  // evolves (V1.9+ may add `fomo`/`tilt` if member feedback warrants).
  // Capped at 3 tags per trade (Zod max, not DB).
  tags String[] @default([]) @map("tags")

  screenshotExitKey String? @map("screenshot_exit_key")

  /// Set when the post-exit block is filled. A trade is "open" iff this is
  /// null ‚Äî used by /journal queries to split the list visually.
  closedAt DateTime? @map("closed_at")

  // ----- S3 ‚Äî V√©rification & Honn√™tet√© radicale (preuve par la r√©alit√©) -----

  /// S3 ‚Äî provenance of this journal entry. Every pre-S3 trade is implicitly
  /// declarative, hence the `self_declared` default (SQL DEFAULT backfills
  /// existing rows without a table rewrite). `mt5_verified` is set by the S3
  /// reconciliation engine once the trade has been matched against an
  /// `ExtractedPosition` coming from an MT5 history screenshot (vision
  /// pipeline). Posture ¬ß2: verification concerns the FACT of the trade
  /// (existence, direction, timing, volume), never its analysis.
  source TradeSource @default(self_declared)

  /// S3 ‚Äî when the reconciliation engine confirmed this trade against the
  /// member's real MT5 history. Null = never confronted yet.
  verifiedAt DateTime? @map("verified_at")

  /// S3 ‚Äî outcome of the declarative ‚Üî reality confrontation. Null = not yet
  /// confronted (legacy rows / no proof uploaded for the period). `mismatch`
  /// rows also materialise a `Discrepancy` for follow-up.
  matchStatus TradeMatchStatus? @map("match_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // J4 ‚Äî admin annotations attached to this trade. Cascade so a member
  // cleanup wipes its annotations too (RGPD: data minimisation).
  annotations   TradeAnnotation[]
  // S3 ‚Äî multi-capture attachments (entry/exit/other). The legacy
  // `screenshotEntryKey`/`screenshotExitKey` columns stay untouched
  // (backward compat); new multi-photo flows append here.
  media         TradeMedia[]
  // S3 ‚Äî discrepancies referencing this trade as the declared side.
  discrepancies Discrepancy[]

  // Indexes ‚Äî userId-leading because every member-facing query is
  // user-scoped, and the secondary order is the dominant sort key in the UI.
  @@index([userId, enteredAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, closedAt])
  // V1.5 ‚Äî quality distribution analytics (admin coaching view).
  // Partial-index predicate (`WHERE trade_quality IS NOT NULL`) is added in
  // the migration SQL since Prisma 7 doesn't model it declaratively.
  @@index([userId, tradeQuality])
  @@map("trades")
}

// =============================================================================
// J4 ‚Äî Admin annotation workflow (SPEC ¬ß6.3, ¬ß7.8)
// =============================================================================

/// Admin correction attached to a member trade.
///
/// `comment` is markdown-friendly free text (rendered server-side as plain text
/// at J4; markdown rendering ships when we wire react-markdown in J6+). The
/// optional `mediaKey` points to a storage object ‚Äî at J4 image-only
/// (8 MiB cap, JPEG/PNG/WebP). The Zoom-video upload (500 MiB) is deferred to
/// J4.5 once R2 is wired (see `apps/web/CLAUDE.md` storage section).
///
/// `seenByMemberAt` is set the first time the trade owner opens the trade in
/// /journal/[id] AFTER the annotation was created (bulk `updateMany` per page
/// load). Reading it stays in `lib/annotations/member-service.ts`.
///
/// `adminId` cascades on User delete: V1 has a single admin (Eliot), so admin
/// deletion is a teardown event ‚Äî preserving orphaned annotations would be
/// dead state. V2 multi-admin should switch to SetNull + nullable adminId.
model TradeAnnotation {
  id String @id @default(cuid())

  tradeId String @map("trade_id")
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  adminId String @map("admin_id")
  admin   User   @relation("AnnotationsAuthored", fields: [adminId], references: [id], onDelete: Cascade)

  comment String @db.Text

  /// Storage key for the optional media attachment.
  /// Format: `annotations/{tradeId}/{nanoid32}.{jpg|png|webp}` (J4) or
  ///         `annotations/{tradeId}/{nanoid32}.{mp4|webm}` (J4.5).
  mediaKey  String?              @map("media_key")
  mediaType AnnotationMediaType? @map("media_type")

  /// Timestamp of the first time the member opened the trade detail page after
  /// this annotation existed. Null = unread.
  seenByMemberAt DateTime? @map("seen_by_member_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Most reads list a trade's annotations newest-first.
  @@index([tradeId, createdAt(sort: Desc)])
  // Powers the unseen-count rollup for the member's journal list.
  @@index([tradeId, seenByMemberAt])
  // Admin "annotations I authored" feed (J6+ analytics).
  @@index([adminId, createdAt(sort: Desc)])
  // J8 perf TIER 2 fix ‚Äî `lib/weekly-report/loader.ts:loadAnnotationStats`
  // filtre `createdAt: { gte, lte } AND trade.userId = X`. Sans cet index,
  // Postgres seq-scan toute la table (√Ý 1000 membres √ó 6 mois = potentiel
  // 100k+ rows). Ajout d'un index `(createdAt DESC)` permet un range-scan
  // index-only sur la window puis JOIN PK Trade pour le filtre userId.
  @@index([createdAt(sort: Desc)])
  @@map("trade_annotations")
}

/// V2.1 ‚Äî Admin private notes about a member (SPEC ¬ß7.7 "tes notes
/// priv√©es sur ce membre, pas vu par lui").
///
/// The member NEVER sees these: there is deliberately no member-facing
/// read path. They are listed only through the admin member-detail
/// "Notes admin" tab. `body` is hardened at the Zod boundary
/// (`safeFreeText` + reject bidi/zero-width = Trojan-Source defense,
/// canon Fxmily ‚Äî these notes are rendered back to the admin and could
/// one day feed an LLM prompt).
///
/// Cascade on BOTH relations (RGPD data minimisation, consistent with
/// the rest of the schema). V1 = solo admin Eliot; V2 multi-admin ‚Üí
/// consider `authorId` SetNull + nullable so a deleted admin's notes
/// survive (same follow-up noted on `TradeAnnotation`).
model AdminNote {
  id String @id @default(cuid())

  /// The member this note is ABOUT (never the author).
  memberId String @map("member_id")
  member   User   @relation("AdminNotesAbout", fields: [memberId], references: [id], onDelete: Cascade)

  /// The admin who wrote the note.
  authorId String @map("author_id")
  author   User   @relation("AdminNotesAuthored", fields: [authorId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // The panel lists a member's notes newest-first.
  @@index([memberId, createdAt(sort: Desc)])
  // Admin "notes I authored" feed (V2 multi-admin analytics).
  @@index([authorId, createdAt(sort: Desc)])
  @@map("admin_notes")
}

// =============================================================================
// V1.2 ‚Äî Mode Entra√Ænement / Backtest TradingView (SPEC ¬ß21)
// =============================================================================

/// Outcome reported on a backtest entry. Deliberately a SEPARATE enum from
/// `TradeOutcome` (same values) ‚Äî SPEC ¬ß21.2 locks "isolation b√©ton, par
/// construction": a training model never references a real-edge type, so a
/// future refactor of `TradeOutcome` can never reach training. The marginal
/// cost (one extra Postgres type) is the explicit trade-off Eliot accepted.
enum TrainingOutcome {
  win
  loss
  break_even
}

/// Media kind for an admin training-correction attachment. SEPARATE enum
/// from `AnnotationMediaType` for the same isolation rationale (¬ß21.2). V1.2
/// ships image-only at the Zod edge; the column accepts `video` so a later
/// video-correction path stays an additive change (mirror J4 ‚Üí J4.5).
enum TrainingAnnotationMediaType {
  image
  video
}

/// Member backtest entry (SPEC ¬ß21). STATISTICALLY ISOLATED from the real
/// edge: NO FK to `Trade`, no shared enum, dedicated read services. A
/// `TrainingTrade` must NEVER surface in `/journal`, the dashboard, scoring,
/// expectancy or the Habit√óTrade correlation ‚Äî the real edge only reflects
/// real risk (¬ß21.5 invariant; anti-leak tests land in J-T4).
///
/// Lighter field set than `Trade` (SPEC ¬ß21.2): no emotions / sleep /
/// confidence ‚Äî backtest affect ‚âÝ real-risk affect (Mark Douglas). The
/// pedagogical core is `lessonLearned` (mandatory). `enteredAt` mirrors
/// `Trade.enteredAt` exactly: a plain `DateTime` UTC instant (NOT `@db.Date`),
/// so backdating is allowed and no civil-day window applies (it is not a
/// calendar-day field, unlike DailyCheckin / HabitLog).
///
/// `userId` cascades on User delete (RGPD data minimisation, schema-wide).
model TrainingTrade {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// S8 ‚Äî optional parent backtest session ("cr√©e une session de backtest").
  /// SetNull: deleting a session container never destroys the entries logged
  /// inside it. Lives 100% inside the ¬ß21.5 training world ‚Äî `TrainingSession`
  /// has NO link to any real-edge model.
  sessionId       String?          @map("session_id")
  trainingSession TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  /// One of the allowlisted symbols (lib/trading/pairs.ts), uppercase string,
  /// enforced at the Zod edge ‚Äî mirror of `Trade.pair` (no DB enum).
  pair String

  /// Storage key for the entry-analysis screenshot (the artefact the admin
  /// corrects). Nullable for administrative repairs, but the Zod create
  /// schema requires it ‚Äî mirror of `Trade.screenshotEntryKey`. Format
  /// `training/{id}/{nanoid32}.{ext}` (lib/storage/keys.ts, wired J-T2).
  entryScreenshotKey String? @map("entry_screenshot_key")

  /// Planned reward-to-risk ratio. Mandatory (mirror `Trade.plannedRR`):
  /// defining R:R before is the backtest discipline.
  plannedRR Decimal @map("planned_rr") @db.Decimal(6, 2)

  /// Backtest result. Nullable until filled ‚Äî mirrors the real open/close
  /// split (`Trade.outcome` / `Trade.realizedR` are nullable).
  outcome TrainingOutcome? @map("outcome")
  resultR Decimal?         @map("result_r") @db.Decimal(6, 2)

  /// `true` = system/plan respected, `false` = not, `null` = N/A. Tri-state,
  /// exact mirror of `Trade.hedgeRespected`.
  systemRespected Boolean? @map("system_respected")

  /// Lesson learned ‚Äî the pedagogical core of a backtest (SPEC ¬ß21).
  /// Mandatory free text, hardened at the Zod edge (`safeFreeText` + reject
  /// bidi/zero-width = Trojan-Source canon Fxmily).
  lessonLearned String @map("lesson_learned") @db.Text

  /// User-provided backtest entry timestamp, persisted in UTC. Mirror of
  /// `Trade.enteredAt` (plain DateTime, NOT @db.Date).
  enteredAt DateTime @map("entered_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Admin training corrections attached to this backtest. Cascade so a
  /// member cleanup wipes its corrections too (RGPD: data minimisation).
  annotations TrainingAnnotation[]

  // userId-leading + enteredAt DESC: every member-facing training query is
  // user-scoped and sorts newest-first (SPEC ¬ß21.3).
  @@index([userId, enteredAt(sort: Desc)])
  // S8 ‚Äî the backtest-session detail joins the entries by `session_id` then
  // sorts them newest-first (`getTrainingSessionWithTrades*`). Index the FK so
  // the now-live join never seq-scans `training_trades` (the other hot FKs are
  // all indexed; this was the only un-indexed one ‚Äî audit S8 d6).
  @@index([sessionId, enteredAt(sort: Desc)])
  @@map("training_trades")
}

/// Admin correction attached to a member backtest ‚Äî EXACT mirror of the J4
/// `TradeAnnotation` flow (comment + optional capture + seen tracking) but
/// pointing at `TrainingTrade` instead of `Trade`. The member-facing read +
/// seen-marking land in J-T3 (member-service, mirror
/// `lib/annotations/member-service.ts`).
///
/// `comment` is hardened free text (Trojan-Source canon). `adminId` cascades
/// on User delete: V1 single-admin (Eliot), so admin deletion is a teardown
/// event ‚Äî V2 multi-admin should switch to SetNull + nullable adminId (same
/// follow-up noted on `TradeAnnotation`).
model TrainingAnnotation {
  id String @id @default(cuid())

  trainingTradeId String        @map("training_trade_id")
  trainingTrade   TrainingTrade @relation(fields: [trainingTradeId], references: [id], onDelete: Cascade)

  adminId String @map("admin_id")
  admin   User   @relation("TrainingAnnotationsAuthored", fields: [adminId], references: [id], onDelete: Cascade)

  comment String @db.Text

  /// Storage key for the optional correction media. Format
  /// `training_annotations/{trainingTradeId}/{nanoid32}.{jpg|png|webp}`.
  mediaKey  String?                      @map("media_key")
  mediaType TrainingAnnotationMediaType? @map("media_type")

  /// First time the member opened the backtest detail after this correction
  /// existed. Null = unread. Mirror of `TradeAnnotation.seenByMemberAt`.
  seenByMemberAt DateTime? @map("seen_by_member_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Most reads list a backtest's corrections newest-first (SPEC ¬ß21.3).
  @@index([trainingTradeId, createdAt(sort: Desc)])
  // Powers the unseen-count rollup for the member's training list.
  @@index([trainingTradeId, seenByMemberAt])
  // Admin "corrections I authored" feed.
  @@index([adminId, createdAt(sort: Desc)])
  @@map("training_annotations")
}

/// V1.3 ‚Äî D√©brief Training d√©di√© (SPEC ¬ß23). Member-owned WEEKLY recap of the
/// member's BACKTEST practice (SPEC ¬ß21). Structurally mirrors `WeeklyReview`
/// (idempotent `(userId, weekStart)` upsert, `weekStart` @db.Date, `submittedAt`
/// bumped on edit) BUT stays inside the ¬ß21.5 statistical-isolation boundary:
/// there is NO foreign key to `Trade` / `WeeklyReview` / `BehavioralScore` ‚Äî
/// only the implicit `userId` link, exactly like `TrainingTrade`.
///
/// The process-stats panel (volume & regularity ¬∑ system respect ¬∑ diversity ¬∑
/// lessons & corrections) is computed at RENDER from `TrainingTrade` /
/// `TrainingAnnotation` and NEVER stored ‚Äî see `lib/training-debrief/stats.ts`.
/// That aggregator NEVER selects `resultR` / `outcome` (posture ¬ß23.2: a
/// debrief shows process effort, never backtest P&L, even intra-training).
///
/// The 4 free-text fields are Steenbarger reverse-journaling (2 process
/// strengths + 1 micro-adjustment + 1 transversal lesson), all mandatory and
/// hardened at the Zod edge (`safeFreeText` + reject bidi/zero-width =
/// Trojan-Source canon Fxmily). `userId` cascades on User delete (RGPD ¬ß17).
model TrainingDebrief {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Monday of the debriefed week, local Europe/Paris, materialised at the
  /// service layer via `parseLocalDate` (UTC-midnight pin) so Postgres
  /// `@db.Date` truncation never drifts a day (anti-flake invariant PR#96).
  weekStart DateTime @map("week_start") @db.Date

  /// Steenbarger reverse-journaling ‚Äî process strength #1 (mandatory). NOT
  /// P&L: "j'ai attendu mon setup au lieu de forcer", never "+3R en backtest".
  processStrengthOne String @map("process_strength_one") @db.Text
  /// Process strength #2 (mandatory).
  processStrengthTwo String @map("process_strength_two") @db.Text
  /// One concrete micro-adjustment for next week (mandatory) ‚Äî small, testable.
  microAdjustment    String @map("micro_adjustment") @db.Text
  /// The transversal lesson abstracted from the week's practice (mandatory).
  transversalLesson  String @map("transversal_lesson") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("training_debriefs")
}

/// Notification queue (J4 enqueue, J9 dispatch).
///
/// At J4 we persist the *intent* of a notification ‚Äî the actual web-push
/// dispatch worker is in J9. Until then the row stays `pending`. Each kind
/// (`type`) carries its own structured `payload`:
///   annotation_received          ‚Üí { annotationId, tradeId, adminId, hasMedia }
///   training_annotation_received ‚Üí { trainingAnnotationId, trainingTradeId, adminId, hasMedia }
///
/// `scheduledFor` lets us delay a notification (e.g. "remind if not seen
/// after 48h" ‚Äî SPEC ¬ß7.8). Null means "ASAP".
model NotificationQueue {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  payload Json
  status  NotificationStatus @default(pending)

  /// V1.6 ‚Äî SPEC ¬ß18.2 email frequency cap support. `true` for transactional
  /// notifications that MUST always reach the user (auth, invitation, password
  /// reset, RGPD export-ready). `false` (default) for engagement / nudge
  /// notifications ‚Äî the email fallback caps these at 3 per 24h rolling window
  /// per user to avoid spam-mailing a member with a flaky push subscription.
  /// All V1 NotificationType slugs default to `false` (none are transactional
  /// yet ‚Äî future auth-push types will set this to `true` at enqueue time).
  isTransactional Boolean @default(false) @map("is_transactional")

  attempts      Int       @default(0)
  scheduledFor  DateTime? @map("scheduled_for")
  dispatchedAt  DateTime? @map("dispatched_at")
  failureReason String?   @map("failure_reason")
  /// J9 ‚Äî short error code for machine classification of the last failed dispatch.
  /// One of `gone_410` | `payload_too_large_413` | `rate_limited_429` |
  /// `server_5xx` | `timeout` | `network` | `unknown`. Mirrors the
  /// `classifyError(statusCode)` taxonomy in `lib/push/dispatcher.ts`.
  /// `failureReason` keeps the human-readable detail for admin debugging.
  lastErrorCode String?   @map("last_error_code")
  /// J9 ‚Äî exponential backoff anchor. Set when a retryable failure happens
  /// (5xx, 429, network) ‚Äî the dispatcher only re-claims rows whose
  /// `nextAttemptAt <= now()`. Null means "claim ASAP" (initial pending or
  /// the explicit `scheduledFor` window has elapsed).
  nextAttemptAt DateTime? @map("next_attempt_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Worker hot-path (J5): pull the next pending row whose schedule has elapsed.
  @@index([status, scheduledFor])
  // J9 dispatcher hot-path: claim rows ready to be sent (status in pending|dispatching
  // AND nextAttemptAt <= now). The partial WHERE clause is added in the migration
  // SQL (Prisma 7 doesn't model partial indexes natively; same pattern as the J5
  // `notification_queue_pending_checkin_dedup` partial unique index). The index is
  // named by Prisma's default (`notification_queue_status_next_attempt_at_idx`);
  // the S8 index migration reconciled a pre-existing name drift (the J9 SQL had
  // hand-named it `pending_dispatch_idx` while the schema declared no `map:`) via
  // a safe `ALTER INDEX ‚Ä¶ RENAME` that preserves the partial predicate.
  @@index([status, nextAttemptAt])
  // User-scoped admin/debug queries.
  @@index([userId, createdAt(sort: Desc)])
  // V1.6 ‚Äî partial index `notification_queue_user_recent_non_transactional_idx`
  // is created via the migration SQL only (Prisma 7 doesn't model partial
  // predicates declaratively, same pattern as `notification_queue_pending_checkin_dedup`).
  // NOT declared as `@@index` here to avoid Prisma generating a duplicate
  // full-index without the WHERE predicate (would create two B-tree indexes
  // on the same columns + cause schema drift on next `prisma migrate dev`).
  @@map("notification_queue")
}

// =============================================================================
// J9 ‚Äî Web Push notifications (SPEC ¬ß7.9, ¬ß16, ¬ß18.2)
// =============================================================================

/// One row per (user, browser/device) push subscription. The browser hands us
/// `{ endpoint, keys: { p256dh, auth } }` after `pushManager.subscribe()`; we
/// persist them and use `web-push` lib to send messages later.
///
/// Why a unique on `(userId, endpoint)`: a member may install Fxmily on
/// multiple devices (iPhone home screen + Android + desktop Chrome), each
/// gets its own endpoint. Re-subscribing on the same device returns the same
/// endpoint ‚Üí upsert preserves continuity instead of stacking rows.
///
/// `userAgent` is captured at subscribe time for admin debugging only ‚Äî never
/// shown to other users, never logged in plaintext past 512 chars.
///
/// `lastSeenAt` is bumped each time we successfully dispatch (or when the
/// browser hits `pushsubscriptionchange`). A nightly cleanup cron deletes
/// rows where `lastSeenAt < now - 90j` (RGPD data minimization, SPEC ¬ß16).
///
/// On 410 Gone from the push service the dispatcher MUST delete the row
/// immediately (SPEC ¬ß16 ‚Äî "subscription r√©voqu√©e 410 Gone ‚Üí DELETE imm√©diat").
model PushSubscription {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The push service URL (FCM, APNs, Mozilla autopush). Acts as the unique
  /// identifier across re-subscriptions for the same device.
  endpoint String @db.Text

  /// ECDH P-256 public key (base64url, ~88 chars). The `web-push` lib uses it
  /// to derive the encryption key for the message payload.
  p256dhKey String @map("p256dh_key")

  /// 16-byte random secret (base64url, ~22 chars) shared with the browser.
  /// Used as part of the AES-128-GCM encryption (RFC 8291).
  authKey String @map("auth_key")

  /// User-Agent string captured at subscribe time (truncated to 512 chars).
  /// Admin-only context ‚Äî never returned in member-facing endpoints (endpoint
  /// enumeration risk per SPEC ¬ß16).
  userAgent String? @map("user_agent") @db.Text

  /// Bumped on successful dispatch + at `pushsubscriptionchange` re-register.
  /// Used by the 90-day cleanup cron + admin "is this device still alive?".
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([lastSeenAt])
  @@map("push_subscriptions")
}

/// Per-category notification opt-in/opt-out preferences. Default is `enabled = true`
/// ‚Äî a missing row means "consent default-on" (member toggles to opt out, never to opt in).
///
/// PK is composite `(userId, type)`: each member has at most one row per
/// `NotificationType`. The dispatcher reads via `getEffectivePreferences(userId)`
/// which materializes the full set including default-true rows.
///
/// Toggle audit (`push.preference.toggled`) carries `{type, enabled}` metadata
/// ‚Äî never the underlying notification content (RGPD data minimization).
model NotificationPreference {
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  enabled   Boolean          @default(true)
  updatedAt DateTime         @updatedAt @map("updated_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@id([userId, type])
  @@map("notification_preferences")
}

// =============================================================================
// J5 ‚Äî Daily check-ins (SPEC ¬ß6.4, ¬ß7.4)
// =============================================================================

/// Two-slot daily check-in: morning + evening. SPEC ¬ß6.4 keeps a single table
/// shape with `slot` discriminating which fields are populated; the Zod schemas
/// (`lib/schemas/checkin.ts`) and the wizards enforce the per-slot field set.
///
/// `date` is a Postgres `DATE` (no time component) anchored to the member's
/// local-day (Europe/Paris by default ‚Äî SPEC ¬ß6.1). The unique index on
/// (userId, date, slot) prevents duplicates: filling the morning twice updates
/// the existing row instead of stacking entries. The DB stores the user's
/// local date as a calendar day; conversions live in `lib/checkin/timezone.ts`.
///
/// All slot-specific fields are nullable so the same table can serve both
/// shapes. The wizards never persist nulls for required fields ‚Äî the DB shape
/// is permissive on purpose so a future "I forgot to log my mood" partial fill
/// can still write something useful.
///
/// Streak counter: `lib/checkin/streak.ts` reads the (date, slot) tuples and
/// counts consecutive days with at least one check-in (morning OR evening). The
/// streak does NOT require both slots ‚Äî SPEC ¬ß7.4 mentions a soft engagement
/// score driven by completion rate, not strict morning+evening pairing.
model DailyCheckin {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Local-date the check-in is for (Europe/Paris by default, see User.timezone).
  /// `@db.Date` keeps a calendar-day stable across DST and avoids timezone math
  /// when grouping for streaks / weekly reports.
  date DateTime    @db.Date
  slot CheckinSlot

  // ----- Morning fields (mostly nullable on the DB side, required by Zod) ----

  /// Hours of sleep last night (Decimal lets us record half-hours).
  sleepHours              Decimal? @map("sleep_hours") @db.Decimal(4, 2)
  /// Subjective sleep quality 1‚Äì10.
  sleepQuality            Int?     @map("sleep_quality")
  /// Did the member follow their personal morning routine? Tri-state: true
  /// (done), false (skipped), null (slot-N/A or unanswered).
  morningRoutineCompleted Boolean? @map("morning_routine_completed")
  /// Meditation minutes (0 = "didn't meditate"). Capped at 240.
  meditationMin           Int?     @map("meditation_min")
  /// Sport type label (free-text, FR ‚Äî e.g. "course", "muscu", "yoga").
  sportType               String?  @map("sport_type")
  sportDurationMin        Int?     @map("sport_duration_min")
  /// One-line intention for the day, optional. Capped at 200 chars by Zod.
  intention               String?
  /// Did the member do their market analysis before the session? Pure
  /// pre-session discipline signal ‚Äî declarative binary, NO market content
  /// (SPEC ¬ß2: we track that the prep happened, never the prep itself).
  /// Tri-state: true (done), false (skipped), null (unanswered/legacy row).
  marketAnalysisDone      Boolean? @map("market_analysis_done")

  // ----- Evening fields ----------------------------------------------------

  /// Did the member respect their trading plan today?
  planRespectedToday  Boolean? @map("plan_respected_today")
  /// SPEC ¬ß28/¬ß22 ‚Äî did the member KEEP the intention they set this morning?
  /// Answered in the EVENING (the morning sets `intention`, the evening closes
  /// the loop), sibling of `planRespectedToday`. Tri-state: true (kept), false
  /// (not kept ‚Äî a calm effort signal, NEVER a punitive verdict ¬ß31.2), null
  /// (no morning intention that day / unanswered / legacy row). We score THAT
  /// the intention was kept, never the intention CONTENT (SPEC ¬ß2). Pure
  /// additive nullable Boolean, mirror of `marketAnalysisDone`/`processComplete`
  /// ‚Äî the existing discipline weights are NEVER rebalanced. The S12 morning
  /// recall stays a verdict-free echo; THIS is a distinct evening self-report.
  intentionKept       Boolean? @map("intention_kept")
  /// Did the member respect their hedge plan? Null = N/A (no hedge today).
  hedgeRespectedToday Boolean? @map("hedge_respected_today")
  /// Estimated caffeine intake in mL, capped at 2000.
  caffeineMl          Int?     @map("caffeine_ml")
  /// Water intake in litres (Decimal allows half-litres).
  waterLiters         Decimal? @map("water_liters") @db.Decimal(4, 2)
  /// Average stress 1‚Äì10 across the day (evening retrospective).
  stressScore         Int?     @map("stress_score")
  /// Up to 3 gratitude items, capped at 200 chars each by Zod.
  gratitudeItems      String[] @map("gratitude_items")
  /// SPEC ¬ß28/¬ß22 ‚Äî evening "bilan" self-report: did the member study / make
  /// progress in Eliot's COURSE (la formation) today? A course-adherence ACT
  /// only ‚Äî SPEC ¬ß2 posture: we track THAT the member studied, NEVER the
  /// content of what was studied (no curriculum body, no progress %, no edge).
  /// Distinct from the ¬ß21 Entra√Ænement/TrainingTrade module (backtest); this
  /// is a plain habit-signal boolean on the check-in, no training-module link.
  /// Tri-state: true (studied), false (skipped), null (slot-N/A / unanswered /
  /// legacy row) ‚Äî nullable & additive, mirroring `marketAnalysisDone`.
  formationFollowed   Boolean? @map("formation_followed")

  // ----- Both slots --------------------------------------------------------

  /// Mood score 1‚Äì10. Captured both morning ("how do I feel right now?") and
  /// evening ("how did I feel today on average?"). Two distinct snapshots ‚Äî
  /// retained in lib/scoring (J6) for emotional-stability variance.
  moodScore   Int?     @map("mood_score")
  /// Tag slugs (lib/checkin/emotions.ts mirrors lib/trading/emotions.ts).
  /// Used both morning ("how do I feel?") and evening ("dominant emotions").
  emotionTags String[] @map("emotion_tags")
  /// Free-form journal entry (max 4000 chars by Zod).
  journalNote String?  @map("journal_note") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Idempotency: at most one row per (user, day, slot). The Zod-driven Server
  // Action upserts on this composite key.
  @@unique([userId, date, slot])
  // Streak / dashboard queries: scan the user's most recent days.
  @@index([userId, date(sort: Desc)])
  // Weekly report aggregation (J8) ‚Äî fetch a 7-day window in date order.
  @@index([userId, slot, date(sort: Desc)])
  @@map("daily_checkins")
}

// =============================================================================
// J6 ‚Äî Behavioral score snapshots (SPEC ¬ß6.10, ¬ß7.5, ¬ß7.11)
// =============================================================================

/// Per-user, per-day cached snapshot of the four deterministic behavioral
/// scores (SPEC ¬ß7.11) ‚Äî discipline, emotional stability, consistency,
/// engagement. Recomputed nightly by `POST /api/cron/recompute-scores` for
/// `date = yesterday_local` (Europe/Paris V1) and on-demand from Server
/// Actions that meaningfully invalidate a member's data (close trade, submit
/// check-in) via `revalidateTag('user:scores:'+userId)`.
///
/// Why a snapshot table (vs computing live on every dashboard render):
/// 1. Deterministic guarantees ‚Äî formulas in `lib/scoring/*.ts` are pure but
///    they touch up to 60 days of trades + 30 days of check-ins per call.
///    Caching a daily snapshot pins the dashboard read to a single indexed row.
/// 2. Trend rendering ‚Äî a 30-day score trend line needs historical points; we
///    don't backfill on the fly.
/// 3. Data-minimisation friendly ‚Äî RGPD purge cascades cleanly on User delete.
///
/// Why scores are nullable (`Int?`) instead of `0`:
/// `null` carries the explicit "insufficient_data" semantic ‚Äî a member with
/// zero trades in the window has *no* consistency score; rendering `0/100`
/// would lie. The `components` JSON carries the per-dimension `status` and
/// `reason` (`no_trades` | `no_checkins` | `window_short`) so the UI can
/// render the disclaimer without re-running the scoring layer.
///
/// `components` shape (see `lib/scoring/types.ts` for canonical types):
/// {
///   discipline:           { score, status, reason?, parts: { planRespect, hedgeRespect, eveningPlan, intentionFilled, routineCompleted } },
///   emotionalStability:   { score, status, reason?, parts: { moodVariance, stressMedian, negativeEmotionRate, recoveryAfterLoss } },
///   consistency:          { score, status, reason?, parts: { expectancyR, profitFactor, drawdownControl, lossStreakControl, sessionDispersion } },
///   engagement:           { score, status, reason?, parts: { checkinFillRate, dualSlotRate, streakNormalized, journalDepthRate } }
/// }
///
/// `sampleSize` shape:
/// { trades: { closed, computed, estimated, sufficient }, checkins: { days, dualSlot, sufficient }, windowDays }
model BehavioralScore {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Local-day anchor in user.timezone (Europe/Paris V1). `@db.Date` is stable
  /// across DST and matches the `DailyCheckin.date` convention exactly.
  date DateTime @db.Date

  /// 0‚Äì100 each, NULL when the dimension's `status='insufficient_data'`.
  /// Per-dimension reason lives in `components[dim].reason`.
  disciplineScore         Int? @map("discipline_score")
  emotionalStabilityScore Int? @map("emotional_stability_score")
  consistencyScore        Int? @map("consistency_score")
  engagementScore         Int? @map("engagement_score")

  /// Per-dimension breakdown for UI transparency ("why is my score X?").
  /// Persisted as a typed JSON blob; `lib/scoring/types.ts` documents the shape.
  components Json

  /// Sample-size guards per dimension + raw counters, so the UI can render the
  /// disclaimer ("28/30 jours, 12 trades cl√¥tur√©s") without re-running.
  sampleSize Json @map("sample_size")

  /// Window used for this snapshot. 30 by default (Mark Douglas habit window),
  /// configurable for future experimentation without a migration.
  windowDays Int @default(30) @map("window_days")

  computedAt DateTime @default(now()) @map("computed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Idempotent recompute: 1 snapshot per (user, day). Cron + Server Action
  // upsert on this key.
  @@unique([userId, date])
  // Dashboard read (today + 30-day trend), index covers ORDER BY date DESC.
  @@index([userId, date(sort: Desc)])
  @@map("behavioral_scores")
}

// =============================================================================
// J7 - Module Mark Douglas (SPEC ¬ß6.5, ¬ß6.6, ¬ß7.6, ¬ß18.2)
// =============================================================================

/// Educational psychology card surfaced in /library and pushed contextually.
/// SPEC ¬ß18.2 fair use: quote ‚â§ 30 words + quoteSourceChapter required.
/// 	riggerRules discriminated-union JSON (lib/triggers/types.ts). Null = library-only.
/// hatClass: white (7d cooldown) | black (14d cooldown). Yu-kai Chou Octalysis.
model MarkDouglasCard {
  id                 String          @id @default(cuid())
  slug               String          @unique
  title              String
  category           DouglasCategory
  /// Direct quote ‚â§ 30 words (Zod-enforced) - fair use FR L122-5.
  quote              String
  /// Source attribution e.g. "Trading in the Zone, ch.7" (¬ß18.2 compliance).
  quoteSourceChapter String          @map("quote_source_chapter")
  /// 200-400 word FR paraphrase, markdown via react-markdown + rehype-sanitize.
  /// Sanitized via lib/text/safe.ts (NFC + bidi/zero-width strip) at write.
  paraphrase         String          @db.Text
  /// [{ id, label, description }] - 1 to 3 actionable exercises.
  exercises          Json
  /// Discriminated-union trigger rule. Null = no contextual push.
  triggerRules       Json?           @map("trigger_rules")
  /// Yu-kai Chou Octalysis: "white" (default) | "black".
  hatClass           String          @default("white") @map("hat_class")
  /// 1-10. Higher = pushed first when multiple cards match.
  priority           Int             @default(5)
  /// Drafts invisible to members until admin publishes.
  published          Boolean         @default(false)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  deliveries MarkDouglasDelivery[]
  favorites  MarkDouglasFavorite[]

  @@index([published, priority(sort: Desc)])
  @@index([category, published])
  @@map("mark_douglas_cards")
}

/// Record of a card pushed to a member.
/// 	riggeredOn (@db.Date local-day) + (userId, cardId) = idempotency.
/// 7d/14d hatClass cooldown enforced application-side via lib/triggers/cooldown.
model MarkDouglasDelivery {
  id              String          @id @default(cuid())
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId          String          @map("card_id")
  card            MarkDouglasCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  /// Human FR label. Example: "3 trades perdants cons√©cutifs sur 24h".
  triggeredBy     String          @map("triggered_by")
  /// Structured snapshot for audit + replay. Never PII.
  triggerSnapshot Json            @map("trigger_snapshot")
  /// Local-day anchor (matches DailyCheckin.date convention).
  triggeredOn     DateTime        @map("triggered_on") @db.Date
  /// S3 ‚Äî optional provenance link when this delivery was caused by a
  /// repetition `Alert` (S3 ‚Üí S5 coaching junction). SetNull keeps the
  /// delivery history if the alert row is later purged. Null = delivery
  /// triggered by the classic J7 evaluators, not by the constancy engine.
  sourceAlertId   String?         @map("source_alert_id")
  sourceAlert     Alert?          @relation(fields: [sourceAlertId], references: [id], onDelete: SetNull)
  seenAt          DateTime?       @map("seen_at")
  dismissedAt     DateTime?       @map("dismissed_at")
  helpful         Boolean?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@unique([userId, cardId, triggeredOn])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, seenAt])
  @@index([userId, cardId, createdAt(sort: Desc)])
  @@map("mark_douglas_deliveries")
}

/// User-curated favorite (manual star on a card).
model MarkDouglasFavorite {
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String          @map("card_id")
  card      MarkDouglasCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")

  @@id([userId, cardId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("mark_douglas_favorites")
}

/// J8 ‚Äî Weekly AI report generated by Claude Sonnet 4.6 + dispatched by email
/// to admin (`eliot@fxmilyapp.com` V1, `fxeliott@fxmilyapp.com` post J10).
///
/// Cron: dimanche 21:00 UTC (`0 21 * * 0`). For each `status='active'` member,
/// a 7-day snapshot is built (trades + check-ins + scores + deliveries +
/// favorites + corrections) and sent to Claude with the cached system prompt
/// (1h ephemeral) + the per-member user prompt (non-cached). Output is parsed
/// via Zod (`weeklyReportOutputSchema`) and persisted here.
///
/// Idempotency: `(userId, weekStart)` unique ‚Üí re-runs the same week are no-op.
/// Data minimization (RGPD): no PII in the prompt ‚Äî only `userId` UUID +
/// counters + redacted journalNote (safeFreeText NFC + bidi/zero-width strip).
model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime @map("week_start") @db.Date
  weekEnd     DateTime @map("week_end") @db.Date
  generatedAt DateTime @default(now()) @map("generated_at")

  // Output Claude (Zod-validated before write).
  summary         String @db.Text
  risks           Json
  recommendations Json
  patterns        Json

  // Cost tracking + observability (cf. SPEC ¬ß16 ~5‚Ç¨/mois target).
  claudeModel       String  @map("claude_model")
  inputTokens       Int     @map("input_tokens")
  outputTokens      Int     @map("output_tokens")
  cacheReadTokens   Int     @default(0) @map("cache_read_tokens")
  cacheCreateTokens Int     @default(0) @map("cache_create_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking).
  costEur           Decimal @map("cost_eur") @db.Decimal(10, 6)

  // Email dispatch state (Resend).
  sentToAdminAt    DateTime? @map("sent_to_admin_at")
  sentToAdminEmail String?   @map("sent_to_admin_email")
  emailMessageId   String?   @map("email_message_id")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@index([generatedAt(sort: Desc)])
  @@map("weekly_reports")
}

/// V1.4 ‚Äî D√©brief Mensuel IA d√©di√© (SPEC ¬ß25, jalon #2 de la s√©quence
/// ¬ß21.6). Structural IA-pipeline sibling of `WeeklyReport` (cost-tracking,
/// JSON output, idempotent upsert) BUT member-facing + dual-section and
/// inside the ¬ß21.5 statistical-isolation boundary:
///
///   - NO foreign key to `Trade` / `WeeklyReport` / `TrainingTrade` /
///     `BehavioralScore` ‚Äî only the implicit `userId` link (mirror
///     `TrainingDebrief` / `TrainingTrade`). The ‚â§4 `WeeklyReport` rows of
///     the civil month are read as INPUT context by the pure aggregator,
///     NEVER linked as an FK.
///   - `summaryReal` (legitimate REAL-trade P&L coaching) and
///     `summaryTraining` (¬ß21.5 firewall: count/recurrence ONLY, never a
///     backtest `resultR`/`outcome`/`plannedRR`) are STRICTLY separate
///     columns so the isolation boundary is visible in the schema itself.
///   - The debrief feeds NOTHING back into the real edge (no score, no
///     engagement, no trigger ‚Äî canon ¬ß23).
///
/// `monthStart` = local Europe/Paris 1st-of-month, materialised at the
/// service layer via `parseLocalDate` (UTC-midnight pin, anti-flake PR#96).
/// `monthEnd` is ALWAYS service-computed (SSOT, anti-tamper) ‚Äî NEVER
/// accepted from a client. Idempotency `(userId, monthStart)` upsert.
/// `userId` cascades on User delete (RGPD ¬ß17). Generation is batch-local
/// Claude Max (SPEC ¬ß25.2 ‚Äî never the paid API); cost tracking kept for
/// audit/traceability even though the marginal cost is 0‚Ç¨.
model MonthlyDebrief {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  monthStart  DateTime @map("month_start") @db.Date
  /// Service-computed last calendar day of the civil month (SSOT,
  /// anti-tamper ‚Äî never received from the client, SPEC ¬ß25.3/¬ß25.7).
  monthEnd    DateTime @map("month_end") @db.Date
  generatedAt DateTime @default(now()) @map("generated_at")

  // Output Claude (Zod `monthlyDebriefOutputSchema`-validated before write).
  // Dual-section by design (¬ß21.5 boundary visible in the data model).
  progressionNarrative String @map("progression_narrative") @db.Text
  summaryReal          String @map("summary_real") @db.Text
  summaryTraining      String @map("summary_training") @db.Text
  risks                Json
  recommendations      Json
  patterns             Json

  // Cost tracking + observability (mirror WeeklyReport; batch-local Claude
  // Max ‚áí 0‚Ç¨ marginal but kept for traceability/audit, SPEC ¬ß25.3).
  claudeModel       String  @map("claude_model")
  inputTokens       Int     @map("input_tokens")
  outputTokens      Int     @map("output_tokens")
  cacheReadTokens   Int     @default(0) @map("cache_read_tokens")
  cacheCreateTokens Int     @default(0) @map("cache_create_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking).
  costEur           Decimal @map("cost_eur") @db.Decimal(10, 6)

  // Member dispatch state (push + Resend). NO admin dispatch field by
  // design ‚Äî Eliot reads /admin only, no monthly admin email (SPEC ¬ß25.2).
  sentToMemberAt    DateTime? @map("sent_to_member_at")
  sentToMemberEmail String?   @map("sent_to_member_email")
  pushEnqueuedAt    DateTime? @map("push_enqueued_at")
  /// First time the member opened this debrief on /debrief-mensuel (S6 audit
  /// enrichment). Drives the calm dashboard "ton d√©brief est pr√™t" nudge: the
  /// widget surfaces only the latest UNREAD debrief and goes quiet once read
  /// (anti-Black-Hat ¬ß25.2 ‚Äî acknowledge, never nag). Mirror of
  /// MarkDouglasDelivery.seenAt + the calendar aiDisclosureShownAt stamp.
  seenAt            DateTime? @map("seen_at")

  @@unique([userId, monthStart])
  @@index([userId, monthStart(sort: Desc)])
  @@map("monthly_debriefs")
}

/// V1.5 ‚Äî QCM athl√®te / auto-√©valuation mindset hebdomadaire (SPEC ¬ß27,
/// jalon #3 de la s√©quence ¬ß21.6). Member-owned WEEKLY mindset self-check,
/// 100% DETERMINISTIC ‚Äî zero AI, zero API, zero pipeline (mirror of the
/// deterministic check-in surface, NOT of the Claude debrief pipeline).
///
///   - 0-FK statistical isolation BY CONSTRUCTION (¬ß21.5/¬ß27.7): the ONLY
///     relation is the implicit `userId` link (mirror `TrainingDebrief` /
///     `MonthlyDebrief` / `TrainingTrade`). NO foreign key to `Trade` /
///     `WeeklyReport` / `TrainingTrade` / `BehavioralScore`. A mindset row
///     can never reference a real-edge object, so it can never leak into /
///     be fed by the real track-record / score / expectancy / engagement /
///     trigger. The isolation is enforced by the schema shape itself.
///   - This entity feeds NOTHING back into the real edge (no
///     `BehavioralScore`, no engagement, no trigger ‚Äî canon ¬ß23/¬ß25/¬ß27.7).
///
/// The questionnaire instrument is a FROZEN, code-VERSIONED Likert
/// instrument (`lib/mindset/instrument.ts`) ‚Äî `instrumentVersion` pins the
/// exact item set a submission was answered against, guaranteeing
/// longitudinal validity even when the instrument is later revised.
/// `responses` is the raw Likert payload (item‚Üîversion validated at the Zod
/// edge). The mindset profile (dimensions, trends) is ALWAYS computed at
/// render from `responses` + the versioned instrument, NEVER stored ‚Äî
/// derived data has no column (anti-drift, single source of truth).
///
/// `weekStart` = Monday of the assessed week, local Europe/Paris,
/// materialised at the service layer via `parseLocalDate` (UTC-midnight
/// pin) so Postgres `@db.Date` truncation never drifts a day (anti-flake
/// invariant PR#96). Idempotency `(userId, weekStart)` upsert ‚Äî a re-submit
/// of the same week updates the same row (`updatedAt @updatedAt` covers the
/// re-submit; no dedicated `submittedAt`). No dispatch column ‚Äî the
/// `notification.enqueued` audit row is the dispatch source of truth (canon
/// `TrainingDebrief`). `userId` cascades on User delete (RGPD ¬ß17).
model MindsetCheck {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart DateTime @map("week_start") @db.Date

  instrumentVersion Int  @map("instrument_version")
  responses         Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("mindset_checks")
}

// =============================================================================
// V1.8 REFLECT ‚Äî member-facing reflection module
// =============================================================================
//
// Two separate models intentionally:
//   - `WeeklyReview` = member-owned Sunday recap (5 textareas, max 4000 chars
//     each). Distinct from `WeeklyReport` above which is admin-facing IA digest.
//     Idempotency: `(userId, weekStart)` unique ‚Üí re-submitting same week upserts.
//   - `ReflectionEntry` = CBT Ellis ABC + Disputation, daily granularity.
//     Multiple entries per day allowed (a member may reflect on several events).
//
// Both models:
//   - Cascade-delete with the user (RGPD ¬ß17 data-minimisation).
//   - Free-text fields are sanitised at the Zod boundary via `safeFreeText`
//     (NFC + bidi/zero-width strip) ‚Äî same Trojan-Source hardening as J5/J8.
//   - Crisis routing wire (V1.7.1 carbone) runs at submit-action level on
//     the concatenated corpus BEFORE persist. PII-free audit slugs only.
//   - No PII stored beyond the userId FK (no email, no display name).

/// V1.8 ‚Äî Member-facing weekly recap wizard (Sunday ritual extension).
///
/// Posture (Mark Douglas): introspection on PROCESS, not outcomes. The five
/// fields are intentionally process-oriented ("biggest mistake" ‚Üí action, not
/// P&L; "best practice" ‚Üí Steenbarger reverse-journaling 2025 strengths-based).
///
/// `bestPractice` is optional to lower the wizard friction (member can skip
/// when nothing strengths-based comes to mind). All four other fields are
/// mandatory: empty submission is rejected at the Zod boundary.
///
/// Idempotency: `(userId, weekStart)` unique ‚Üí a member who re-opens the
/// wizard for an already-submitted week upserts; the service layer is
/// responsible for surfacing "already submitted, you can edit" UX (PR2).
model WeeklyReview {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime @map("week_start") @db.Date
  weekEnd   DateTime @map("week_end") @db.Date

  /// Mandatory ‚Äî process win (e.g. "Closed at TP per plan despite tempting
  /// trail"). NOT P&L, NOT "I made +5R". Member is nudged via wizard copy.
  biggestWin     String  @map("biggest_win") @db.Text
  /// Mandatory ‚Äî process mistake (e.g. "Skipped pre-trade checklist on Tuesday
  /// London open"). NOT "I lost on EURUSD". Process > outcome.
  biggestMistake String  @map("biggest_mistake") @db.Text
  /// Optional ‚Äî Steenbarger 2025 reverse-journaling. "What worked AND how
  /// you did it" before fix-the-flaws. Skippable to lower wizard friction.
  bestPractice   String? @map("best_practice") @db.Text
  /// Mandatory ‚Äî the lesson abstracted from biggestMistake.
  lessonLearned  String  @map("lesson_learned") @db.Text
  /// Mandatory ‚Äî concrete focus for the upcoming week (one-liner action).
  nextWeekFocus  String  @map("next_week_focus") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("weekly_reviews")
}

/// V1.8 ‚Äî Ellis ABC + Disputation cognitive-behavioural reflection.
///
/// **Clinical disclaimer enforced UI-side** (PR2 wizard banner):
///   "inspired by Ellis ABC, adapted for trading ‚Äî not clinically validated
///   for trader population".
///
/// Granularity: one row per reflection event (a member may write 0..N entries
/// per day ‚Äî no `@@unique([userId, date])` constraint). The `date` field is
/// the introspective date, not the create-time (member can backfill yesterday
/// without retroactive timestamps).
///
/// All four columns are mandatory ‚Äî Ellis ABCD is a complete frame; allowing
/// partial entries dilutes the cognitive-restructuring intent.
model ReflectionEntry {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local civil date (no time component). The member picks this; the wizard
  /// pre-fills today (Europe/Paris) but allows backfill within a window.
  date   DateTime @db.Date

  /// A ‚Äî Activating event (factual trigger). 10‚Äì2000 chars.
  triggerEvent String @map("trigger_event") @db.Text
  /// B ‚Äî Automatic belief (the thought that fired). 10‚Äì2000 chars.
  beliefAuto   String @map("belief_auto") @db.Text
  /// C ‚Äî Consequence (emotion + behaviour observed). 10‚Äì2000 chars.
  consequence  String @db.Text
  /// D ‚Äî Disputation / reframe (alternative belief). 10‚Äì2000 chars.
  disputation  String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, date(sort: Desc)])
  @@map("reflection_entries")
}

/// V2.0 ‚Äî TRACK module habit logging (master plan A2‚ÄìA5 must-have features).
///
/// One row per `(userId, date, kind)` ‚Äî upsert idempotency on retries.
/// The structured `value` payload is kind-specific and validated at the
/// Zod boundary in `lib/schemas/habit-log.ts`. We keep it as `Json` rather
/// than splitting into typed columns because :
///   - Each kind has its own value shape (durationMin for sleep, mealsCount
///     for nutrition, cups + lastDrinkAtUtc for caffeine, etc.).
///   - Sparse-typed columns would balloon the row width and waste storage.
///   - Posture Mark Douglas : we'd rather extend kinds (HealthKit auto-imports,
///     new wearables) without forcing a schema migration each time.
///
/// `notes` is optional free-text ‚Äî bounded by Zod (500 chars) so the LLM
/// digest pipeline (master plan D-features) has a predictable budget.
model HabitLog {
  id     String    @id @default(cuid())
  userId String    @map("user_id")
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local civil date (no time component). Anchors the unique constraint
  /// + the daily aggregation queries.
  date   DateTime  @db.Date
  kind   HabitKind

  /// Kind-specific structured payload ‚Äî see lib/schemas/habit-log.ts.
  value Json
  /// Optional free-text caveat ("manqu√© la sieste √Ý cause d'une r√©union").
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date, kind])
  @@index([userId, date(sort: Desc)])
  @@index([userId, kind, date(sort: Desc)])
  @@map("habit_logs")
}

// =============================================================================
// V2.3 ‚Äî Pre-trade circuit breaker (Session BB, ADR-003)
// =============================================================================
//
// Mark Douglas anti-FOMO + Gollwitzer if-then implementation intentions
// (meta-analysis Gollwitzer-Sheeran 2006: d=0.65, 94 studies, n=8461,
// CI 95% [0.6, 0.7] ‚Äî *Advances in Experimental Social Psychology* vol.38,
// updates Sheeran 2024 ERSP 642 tests + Gollwitzer-Sheeran 2025 Annu. Rev.
// Psychol. 76:303-328). See docs/decisions/ADR-003-pre-trade-circuit-breaker.md
// for the full mapping vs Mark Douglas's 4 primary trading fears (Trading
// in the Zone, 2000).
//
// 4 questions one-tap (~30s) before each trade entry:
//   reasonToTrade      : edge / fomo / revenge / boredom (PreTradeReason)
//   emotionLabel       : calme / excite / frustre / anxieux (PreTradeEmotion)
//   planAlignment      : does this trade respect the documented plan?
//   stopLossPredefined : is the stop-loss defined BEFORE entry?
//
// Statistical scope: REAL edge surface (NOT ¬ß21.5 training).
// Free-text fields: NONE ‚Üí safeFreeText NOT needed, no crisis/injection
// surface, no EU AI Act 50(1) banner needed (zero AI).
//
// Optional auto-link via service-layer `linkRecentCheckToTrade(userId,
// tradeId, windowMin=15)` ‚Äî a Trade created within 15min after a check
// sets `linkedTradeId` (P2002-safe via WHERE linkedTradeId IS NULL).
// String only (no FK constraint): if the linked Trade is later deleted,
// the linkedTradeId becomes a dangling pointer ‚Äî gracefully handled via
// leftJoin null in service-layer reads. Trade deletion ‚âÝ check deletion.
// =============================================================================

/// V2.3 ‚Äî Pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer).
/// One row per (member, pre-trade self-assessment). Cascade-delete with the
/// user (RGPD ¬ß17). See enum docs + ADR-003 for the evidence base.
model PreTradeCheck {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  /// Why the member is about to enter the trade. 4 options Mark Douglas + Steenbarger.
  reasonToTrade PreTradeReason @map("reason_to_trade")

  /// Affective state at the moment of decision. Russell-Weiss-Mendelsohn 1989 2x2.
  emotionLabel PreTradeEmotion @map("emotion_label")

  /// Does this trade respect the member's documented plan? Yes/No.
  planAlignment Boolean @map("plan_alignment")

  /// Is the stop-loss defined BEFORE entry? Mark Douglas "accepting risk" ch.8.
  stopLossPredefined Boolean @map("stop_loss_predefined")

  /// Optional auto-link to a Trade created within 15min after this check.
  /// String only (no FK constraint): a deleted Trade leaves the linkedTradeId
  /// dangling rather than nulling out the check (graceful via leftJoin null
  /// in service-layer reads). Set via linkRecentCheckToTrade window 15min,
  /// P2002-safe via WHERE linkedTradeId IS NULL predicate in the UPDATE.
  linkedTradeId String? @map("linked_trade_id")

  @@index([userId, createdAt(sort: Desc)])
  @@map("pre_trade_checks")
}

// =============================================================================
// T-RECORD ‚Äî Public-facing Eliott + Fxmily trade showcase (T0 2026-05-21).
// D√©cision : table d√©di√©e s√©par√©e du Journal membre (table `trades`). Les
// trades public-facing appartiennent √Ý Eliott (formateur), pas aux membres
// ‚Äî surface RGPD distincte, schema sur mesure pour la vitrine publique :
// segments HISTORICAL/LIVE, partials, BE, tags news, screenshot R2.
// Pas de relation User : Eliott seul √©crit, monovendeur.
//
// üö® DEPRECATED 2026-05-25 ‚Äî Track Record split to standalone repo.
// These two models (PublicTrade + PublicTradePartial) and their enums
// (PublicTradeSegment + PublicTradeStatus) are still declared so Prisma
// stays in sync with the prod Hetzner DB tables, but no application code
// in this monorepo touches them anymore. The CRUD + vitrine live in
// <https://github.com/fxeliott/trackrecord-fxmily> (Hono Worker + Neon).
//
// To drop the tables from this DB, follow `docs/runbook-hetzner-deploy.md`
// ¬ß21 (T5 rollback recipe) ‚Äî pg_dump + `DROP TABLE public_trade_partials,
// public_trades` + `DROP TYPE "PublicTradeSegment", "PublicTradeStatus"`
// (order matters: tables first, then types). Then remove the models below
// + run `prisma migrate dev --name v1_13_drop_public_trades`.
// =============================================================================

/// @deprecated 2026-05-25 ‚Äî moved to trackrecord-fxmily standalone repo.
enum PublicTradeSegment {
  historical
  live
}

/// Statut d'un trade public.
enum PublicTradeStatus {
  open
  closed
  break_even
}

model PublicTrade {
  id            String               @id @default(cuid())
  segment       PublicTradeSegment
  /// Position chronologique 1..N. Conserv√©e depuis l'ODS pour les
  /// historiques, auto-incr√©ment√©e ensuite via service layer.
  ordinal       Int                  @unique
  /// Instrument (EURUSD, XAUUSD, US30, USOIL...). Pas d'enum DB car la
  /// liste s'√©tend au-del√Ý des paires majeures de l'app membre.
  instrument    String
  /// Direction long/short ‚Äî r√©utilise enum existant. Nullable car certains
  /// historiques ODS n'ont pas le sens renseign√© (action col vide).
  direction     TradeDirection?
  /// Date d'entr√©e. Pour les historiques import√©s ODS, anchored au lundi
  /// de la semaine (week label tel que "20 JANVIER" + ann√©e √Ý confirmer).
  enteredAt     DateTime             @map("entered_at")
  exitedAt      DateTime?            @map("exited_at")
  /// % de capital risqu√© (0.50, 1.00, 2.00). Stock√© en % brut, pas en
  /// fraction d√©cimale (1.0 = 1%, pas 0.01). Decimal(4,2) coh√©rent avec
  /// `Trade.riskPct` V1.5 + Tharp ceiling (< 100%).
  riskPercent   Decimal              @map("risk_percent") @db.Decimal(4, 2)
  /// R-multiple final atteint (1R = +1√órisque, -1R = stop plein, 0R = BE).
  resultR       Decimal?             @map("result_r") @db.Decimal(6, 3)
  /// % de portefeuille net (riskPercent √ó resultR). Pr√©calcul√© pour
  /// performance lecture.
  resultPercent Decimal?             @map("result_percent") @db.Decimal(6, 3)
  status        PublicTradeStatus
  /// Session de trading ‚Äî r√©utilise enum TradeSession existant.
  session       TradeSession?
  /// Tag setup (ICT FVG, OB retest, SMC liquidity sweep, breakout...).
  setup         String?
  /// Tags additionnels (news, FOMC, CPI, partag√© en r√©union live...).
  tags          String[]
  /// Commentaire post-trade public (sanitized via safeFreeText).
  notes         String?              @db.Text
  /// Lien screenshot ‚Äî R2 key ou URL externe.
  screenshotUrl String?              @map("screenshot_url")
  /// Provenance du trade (audit / re-import).
  source        String               @default("import")
  /// Toggle publication. False = draft admin.
  isPublished   Boolean              @default(true) @map("is_published")
  publishedAt   DateTime             @default(now()) @map("published_at")
  partials      PublicTradePartial[]
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@index([segment, enteredAt(sort: Desc)])
  @@index([isPublished, enteredAt(sort: Desc)])
  @@index([instrument])
  @@map("public_trades")
}

/// Cl√¥ture partielle d'un trade public (legs successives).
model PublicTradePartial {
  id            String      @id @default(cuid())
  publicTradeId String      @map("public_trade_id")
  publicTrade   PublicTrade @relation(fields: [publicTradeId], references: [id], onDelete: Cascade)
  /// R-multiple atteint sur cette leg (1.5R = TP1).
  closedAtR     Decimal     @map("closed_at_r") @db.Decimal(6, 3)
  /// % de la position ferm√©e sur cette leg (0..100).
  closedPercent Decimal     @map("closed_percent") @db.Decimal(5, 2)
  closedAt      DateTime    @map("closed_at")
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([publicTradeId, closedAt(sort: Asc)])
  @@map("public_trade_partials")
}

// =============================================================================
// V2.4 ‚Äî Onboarding interview profilage IA (Session Œ±, M3 directive 2026-05-27)
// =============================================================================
// Pattern : static questionnaire ~30 questions safeFreeText-sanitized service-
// side. Claude batch local async post-completion (carbone V1.4 monthly-debrief
// ‚Äî Z√âRO API payante consomm√©e, ¬ßcanon dur). Posture ¬ß2 strict ‚Äî Claude generates
// psycho/process axes ONLY (Mark Douglas / Steenbarger), never trade analysis.
// 1-1 cascade User √ó OnboardingInterview √ó MemberProfile.

/// Status lifecycle of an OnboardingInterview row.
/// started      ‚Üí row created, no answers yet
/// in_progress  ‚Üí ‚â•1 answer submitted (member is mid-questionnaire)
/// completed    ‚Üí finalize() invoked ‚Üí MemberProfile generated (Claude batch)
/// abandoned    ‚Üí member inactive >7d post-creation (cron sweep V2.4+ future)
enum InterviewStatus {
  started
  in_progress
  completed
  abandoned
}

/// V2.4 ‚Äî Onboarding interview profilage IA (Session Œ±, M3 directive).
///
/// 1-1 cascade User. Static questionnaire ~30 questions Mark Douglas-aligned,
/// instrumentVersion semver-tracked for longitudinal validity (mirror V1.5
/// MindsetCheck pattern). claudeModelVersion + totalTokens{Input,Output} tracked
/// for cost transparency (batch local Claude Max = $0 but tokens logged for audit).
///
/// Pipeline pattern : carbone V1.4 monthly-debrief ‚Äî
/// 1. Member r√©pond aux questions (UI wizard V2.4 Phase B future)
/// 2. finalize() flips status started/in_progress ‚Üí completed
/// 3. Cron OR admin batch local triggers Claude analysis ‚Üí MemberProfile created
/// 4. Member sees MemberProfile in dashboard "Mon profil"
/// 5. Admin (Eliot) sees pseudonymized profile in /admin/members/[id]?tab=profil
///
/// Posture ¬ß2 strict : Claude's job is to extract psycho/process axes from
/// the answers (discipline, patience, acceptance, probabilities thinking,
/// emotion regulation, process focus, etc.). NEVER trade analysis. NEVER setup
/// recommendation. Regex AMF post-gen guard at claude-client layer.
model OnboardingInterview {
  id                 String                      @id @default(cuid())
  userId             String                      @unique @map("user_id")
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             InterviewStatus             @default(started)
  startedAt          DateTime                    @default(now()) @map("started_at")
  completedAt        DateTime?                   @map("completed_at")
  claudeModelVersion String?                     @map("claude_model_version")
  totalTokensInput   Int                         @default(0) @map("total_tokens_input")
  totalTokensOutput  Int                         @default(0) @map("total_tokens_output")
  instrumentVersion  String                      @default("v1") @map("instrument_version")
  answers            OnboardingInterviewAnswer[]
  profile            MemberProfile?
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  @@index([status, completedAt])
  @@map("onboarding_interviews")
}

/// V2.4 ‚Äî Onboarding interview answer (one row per question/answer pair).
///
/// Cascade via OnboardingInterview AND via User (for RGPD export Art. 15 +
/// soft-delete cascade J10). answerText is safeFreeText-sanitized at service
/// layer (crisis/injection detection BEFORE persist ‚Äî carbone V1.8 REFLECT
/// pattern). questionKey is the slug stable for analytics (questionText may
/// evolve across instrumentVersion bumps).
///
/// @@unique [interviewId, questionIndex] guarantees idempotent append (cant
/// double-submit same question ‚Äî service handles via upsert semantics).
model OnboardingInterviewAnswer {
  id            String              @id @default(cuid())
  interviewId   String              @map("interview_id")
  interview     OnboardingInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId        String              @map("user_id")
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIndex Int                 @map("question_index")
  questionKey   String              @map("question_key")
  questionText  String              @map("question_text") @db.Text
  answerText    String              @map("answer_text") @db.Text
  createdAt     DateTime            @default(now()) @map("created_at")

  @@unique([interviewId, questionIndex])
  @@index([userId, createdAt(sort: Desc)])
  @@map("onboarding_interview_answers")
}

/// V2.4 ‚Äî MemberProfile = final Claude-synthesized output of OnboardingInterview.
///
/// 1-1 cascade User + 1-1 Restrict to OnboardingInterview (preserves audit trail
/// even if downstream interview row is touched ‚Äî equivalent V1.4 MonthlyDebrief
/// retention pattern). summary = 200-800 chars Claude-generated synthesis.
/// highlights = JSON [{ key, label, evidence: [{ answerId, excerpt }] }]
/// structured insights with traceable evidence references back to InterviewAnswer.
/// axesPrioritaires = JSON ["discipline", "patience", "acceptance", ...] 3-5
/// Mark Douglas psycho/process axes the member should focus on first.
///
/// claudeModelVersion + instrumentVersion mirror OnboardingInterview row for
/// audit/longitudinal traceability. analyzedAt = batch-local job timestamp.
model MemberProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique @map("user_id")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId        String              @unique @map("interview_id")
  interview          OnboardingInterview @relation(fields: [interviewId], references: [id], onDelete: Restrict)
  summary            String              @db.Text
  highlights         Json
  axesPrioritaires   Json                @map("axes_prioritaires")
  claudeModelVersion String              @map("claude_model_version")
  instrumentVersion  String              @map("instrument_version")
  analyzedAt         DateTime            @default(now()) @map("analyzed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  /// V2.5 (#17) ‚Äî member-written if-then recovery protocol (Mark Douglas ¬ß18,
  /// Gollwitzer implementation-intention). Re-served READ-ONLY on the
  /// `after_n_consecutive_losses` trigger (JITAI) so the member meets their OWN
  /// cold-state plan at the exact hot moment. Closed shape validated by
  /// `recoveryProtocolSchema`. SPEC ¬ß2: discipline recovery (stop/cooldown/
  /// self-talk) ONLY ‚Äî never market re-entry timing/setup. ¬ß31.2: non-punitive,
  /// no broker lock. NULL = not set; NEVER a scoring input (firewall-clean).
  recoveryProtocol Json? @map("recovery_protocol")

  @@map("member_profiles")
}

// =============================================================================
// V2 S2 ‚Äî Universal tracking engine (SPEC ¬ß2 posture / longitudinal invariant)
// =============================================================================
//
// Generic, recurring, code-defined-instrument capture layer. ANY behavioural /
// process axis (execution, risk-discipline, training, meetings, emotions...)
// is tracked by a FROZEN, VERSIONED instrument declared in code
// (`lib/tracking/instruments/<key>-v<n>.ts`) ‚Äî the SAME longitudinal-validity
// invariant as `MindsetCheck` / `OnboardingInterview`: instruments are STATIC
// and VERSIONED, NEVER mutated in place. The DB stores only captured RESPONSES
// + the instrument key/version pin, never the instrument body.
//
// STATISTICAL ISOLATION (SPEC ¬ß21.5 / ¬ß27.7 ‚Äî BLOQUANT): these two models carry
// NO FK to `Trade` / `BehavioralScore` / `PreTradeCheck`. They are a structured
// capture + reliability (D2) + confidence (D3) + completeness (D1) surface that
// feeds NOTHING back into the real edge. Only the `userId` cascade link exists
// (RGPD ¬ß17). Enforced by `test/anti-leak/tracking-isolation.test.ts`.
//
// POSTURE ¬ß2 (BLOQUANT): instruments capture PROCESS / PSYCHOLOGY only ‚Äî THAT an
// act happened (cut at 20h? one risk-trade today? SL predefined?), NEVER market-
// analysis CONTENT. No instrument asks "what setup / which direction". The
// `responses` JSON is a CLOSED Zod-validated shape (`lib/tracking/schema.ts`) ‚Äî
// no raw edge free-text ‚Äî and the instrument labels run through the existing
// `detectAMFViolation` guard in tests (`lib/tracking/instruments/*.test.ts`).

/// Reliability dimension (D2) of a capture: WHEN/HOW it was answered. Lets the
/// member dashboard and S3 confrontation weight a hot, in-the-moment answer
/// differently from a cold retrospective one. NEVER a scoring input.
enum CaptureContext {
  /// In-the-moment (pre-trade decision, live during a session).
  hot
  /// Retrospective (evening review, end-of-week recall).
  cold
  /// Engine-prompted at the instrument's scheduled due time.
  scheduled
}

/// Canonical tracking taxonomy (FR labels in `lib/tracking/axes.ts`). Covers the
/// full m√©thodo surface with ZERO loss (DoD case 5): execution, risk-discipline,
/// market-analysis prep, entra√Ænement/backtest, la formation, r√©unions ¬ß30,
/// emotions+confidence, sleep/lifestyle, evening "bilan", travail sur soi,
/// routine. Pure analytics dimension ‚Äî a `TrackingEntry.axis` is NOT a scoring
/// input. Append a value here only additively (Postgres: new enum value is
/// non-destructive; never reuse/rename an existing one ‚Äî longitudinal contract).
enum TrackingAxis {
  execution
  risk_discipline
  market_analysis
  training
  formation
  meeting_presence
  emotions_confidence
  sleep_lifestyle
  evening_review
  self_work
  routine
}

/// V2 S2 ‚Äî one captured response set for one recurring instrument occurrence.
///
/// Idempotency: `@@unique([userId, instrumentKey, occurrenceKey])`. The service
/// upserts on this composite key ‚Äî re-submitting the same occurrence overwrites
/// (never duplicates), so the spread/recurring collection (DoD case 4) is safe
/// against double-taps and retries. `occurrenceKey` is the canonical slot the
/// entry answers ("2026-06-24" daily, "2026-W26" weekly, or a pre-trade nonce).
///
/// Confrontable S3 + consumable S4‚ÄìS7 (DoD case 6): the read contract lives in
/// `lib/tracking/service.ts` (count-only / per-axis aggregates, NO P&L join).
model TrackingEntry {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Stable slug of the code-defined instrument (e.g. "process-fidelity"). The
  /// instrument body lives in `lib/tracking/instruments/<key>-v<n>.ts` ‚Äî NEVER
  /// in the DB (frozen-instrument invariant).
  instrumentKey     String @map("instrument_key")
  /// Instrument version at capture time. Pinning per row keeps longitudinal
  /// comparisons valid across bumps (mirror MindsetCheck.instrumentVersion).
  instrumentVersion String @default("v1") @map("instrument_version")

  /// Behavioural/process axis (taxonomy `lib/tracking/axes.ts`). NOT a score input.
  axis TrackingAxis

  /// Idempotency discriminator ‚Äî the canonical occurrence this entry answers.
  occurrenceKey String @map("occurrence_key")

  /// Structured answers, validated by the instrument's Zod schema BEFORE persist
  /// (`lib/tracking/schema.ts`). CLOSED shape per instrument ‚Äî no raw edge
  /// free-text (SPEC ¬ß2). Shape = `{ [questionKey]: answerValue }`.
  responses Json

  // ----- D3 ‚Äî emotion + confidence (simple recurring scale) -----------------
  /// Optional 1‚Äì5 confidence self-rating attached to this capture (D3). Null =
  /// the instrument didn't ask, or unanswered. NEVER a scoring input.
  confidenceLevel Int? @map("confidence_level")

  // ----- D2 ‚Äî reliability metadata ------------------------------------------
  /// hot (in-the-moment) / cold (retrospective) / scheduled (engine-prompted).
  captureContext    CaptureContext? @map("capture_context")
  /// Milliseconds between prompt render and submit ‚Äî a reliability signal
  /// (rushed vs considered). Null = not measured. NEVER a scoring input.
  responseLatencyMs Int?            @map("response_latency_ms")
  /// When the engine prompted this capture (D2 ‚Äî paired with `submittedAt`).
  promptedAt        DateTime?       @map("prompted_at")

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Idempotent append: one entry per (user, instrument, occurrence).
  @@unique([userId, instrumentKey, occurrenceKey])
  // Per-axis dashboard + S3 confrontation reads (most-recent first).
  @@index([userId, axis, submittedAt(sort: Desc)])
  // Per-instrument longitudinal reads.
  @@index([userId, instrumentKey, submittedAt(sort: Desc)])
  @@map("tracking_entries")
}

/// V2 S2 ‚Äî per-(member, instrument) cadence bookkeeping for the recurring engine.
///
/// The engine reads `nextDueAt` to surface a CALM action via `getDailyGuidance`
/// (SPEC ¬ß2 posture: no streak, no urgency, no punitive nudge ¬ß31.2). The member
/// can snooze via `pausedUntil` ‚Äî anti-overload so captures are SPREAD over time,
/// never piled up (DoD case 4). One row per (user, instrument).
model TrackingSchedule {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  instrumentKey String @map("instrument_key")

  /// Next time this instrument is due for the member.
  nextDueAt       DateTime  @map("next_due_at")
  /// Last completed occurrence timestamp (null = never completed).
  lastCompletedAt DateTime? @map("last_completed_at")
  /// Opaque cadence bookkeeping owned by `lib/tracking/cadence.ts`
  /// (e.g. consecutive-skips, adaptive interval). Null = default cadence.
  cadenceState    Json?     @map("cadence_state")
  /// Member-set snooze ‚Äî the engine skips this instrument until `pausedUntil`.
  pausedUntil     DateTime? @map("paused_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, instrumentKey])
  // Engine sweep: "what is due for this member now?"
  @@index([userId, nextDueAt])
  @@map("tracking_schedules")
}

// =============================================================================
// ¬ß26 ‚Äî Calendrier personnel adaptatif (J-C1 data layer)
// =============================================================================
//
// Two models, statistically isolated from the real edge by construction
// (posture ¬ß2 BLOQUANT / ¬ß21.5 / ¬ß27.7):
//   - `WeeklyScheduleQuestionnaire` = member-owned closed weekly questionnaire
//     (9 items, instrument-versioned, ZERO free-text V1 ‚Üí zero crisis/injection
//     surface, carbone MindsetCheck ¬ß27). Captures availability + practice
//     profile for the week ahead. Idempotent `(userId, weekStart)` upsert.
//   - `AdaptiveCalendar` = the Claude-generated weekly plan (organises TIME of
//     practice, NEVER trades). Validated by `adaptiveCalendarOutputSchema`
//     `.strict()` before persist. Cost-tracked like `WeeklyReport`/`MonthlyDebrief`.
//
// Both models:
//   - Cascade-delete with the user (RGPD ¬ß17 data-minimisation).
//   - Carry NO P&L field (`realizedR`/`outcome`/`plannedRR`). The Claude
//     snapshot reads count-only activity (lib/calendar/snapshot.ts). The
//     isolation is enforced by test/anti-leak/calendar-isolation.test.ts.
//   - `weekStart` = Monday Europe/Paris materialised at the service layer via
//     `parseLocalDate` (UTC-midnight pin) so Postgres `@db.Date` never drifts a
//     day (anti-flake invariant PR#96).
//
// `AdaptiveCalendar` has NO FK to `WeeklyScheduleQuestionnaire`: the calendar is
// a snapshot-at-generation artefact. A later edit of the questionnaire must NOT
// rewrite the history of an already-generated calendar ‚Äî the two are decoupled
// on purpose (the calendar persists `calendar_instrument_version` to record
// which questionnaire instrument fed it). This is justified on its own merits,
// not by analogy to MemberProfile (which DOES keep an FK to OnboardingInterview).

model WeeklyScheduleQuestionnaire {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Monday of the planned week, local Europe/Paris, UTC-midnight pinned via
  /// `parseLocalDate` at the service layer (anti-flake PR#96).
  weekStart DateTime @map("week_start") @db.Date

  /// Frozen instrument version this answer set belongs to (longitudinal
  /// validity ¬ß27.7). Trends are only ever compared intra-version.
  instrumentVersion Int          @map("instrument_version")
  /// Denormalised typed projection of `responses.energyPeak` ‚Äî the member's
  /// self-reported energy-peak slot. Anchors `CalendarSlot` at the DB layer +
  /// keeps the field admin-queryable. The full versioned answer set lives in
  /// `responses` (single source of truth for longitudinal analysis).
  energyPeakSlot    CalendarSlot @map("energy_peak_slot")
  /// All 9 closed answers, instrument-versioned. Shape validated by
  /// `lib/schemas/weekly-schedule-questionnaire.ts`. ZERO free-text V1.
  responses         Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  /// The calendar batch filters by `weekStart` ALONE (loadAllSnapshots /
  /// persistGeneratedCalendars). The composite above is userId-led, so Postgres
  /// can't use it for a weekStart-only scan ‚Äî this single-column index keeps the
  /// weekly batch index-bound as the questionnaire history grows (S6 audit).
  @@index([weekStart])
  @@map("weekly_schedule_questionnaires")
}

model AdaptiveCalendar {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Monday of the planned week, local Europe/Paris, UTC-midnight pinned.
  weekStart DateTime @map("week_start") @db.Date

  /// Claude-generated weekly plan, validated by `adaptiveCalendarOutputSchema`
  /// `.strict()` before persist. Shape: { overview, days[7]{ blocks[] },
  /// weeklyFocus, warnings[] }. Organises TIME (sessions/backtest/Mark Douglas/
  /// r√©unions ¬ß30/rest), NEVER trades ‚Äî posture ¬ß2.
  schedule        Json
  /// Denormalised dominant block category of the week ‚Äî admin week-at-a-glance.
  /// Anchors `CalendarBlockCategory` at the DB layer. Computed from `schedule`
  /// at persist time; nullable for the empty-schedule edge.
  primaryCategory CalendarBlockCategory? @map("primary_category")

  // Cost tracking ‚Äî Claude batch LOCAL (`claude --print`, abonnement Max,
  // $0 API marginal ¬ß8). Mirrors WeeklyReport/MonthlyDebrief sub-cent tracking.
  claudeModel  String  @map("claude_model")
  inputTokens  Int     @map("input_tokens")
  outputTokens Int     @map("output_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking, SPEC ¬ß16).
  costEur      Decimal @map("cost_eur") @db.Decimal(10, 6)

  /// EU AI Act 50(1) ‚Äî when the AI-generated banner was first shown to the
  /// member (7th production disclosure site). Set on first calendar view (J-C4).
  aiDisclosureShownAt       DateTime? @map("ai_disclosure_shown_at")
  /// Version of the questionnaire instrument that fed this calendar generation
  /// (snapshot-at-generation provenance ‚Äî the FK-free decoupling rationale).
  calendarInstrumentVersion Int       @map("calendar_instrument_version")

  generatedAt DateTime @default(now()) @map("generated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@index([generatedAt(sort: Desc)])
  /// Same rationale as WeeklyScheduleQuestionnaire ‚Äî the batch reads existing
  /// calendars by `weekStart` alone (freshness gate). Keeps it index-bound at
  /// scale (S6 audit).
  @@index([weekStart])
  @@map("adaptive_calendars")
}

// =============================================================================
// V1.7 ¬ß30 ‚Äî Meeting attendance tracking (suivi de pr√©sence aux r√©unions).
//
// Recurring Fxmily meetings (Mon‚ÄìFri 12h & 20h Europe/Paris, Zoom) are
// materialised as `Meeting` rows by a cron (J-M3). Each member self-declares
// attendance in-app via `MeetingAttendance`. Posture ¬ß2 verrouill√©e: the app
// tracks the ACT (pr√©sence + lecture = discipline/ex√©cution) via a boolean
// `contentReviewed` ONLY ‚Äî it NEVER stores / displays / comments the Ichor
// analysis content. Attendance feeds ONLY the `engagement` dimension via the
// count-only primitive `countMeetingAttendance` (J-M4), never the real edge.
// See SPEC ¬ß30 (source of truth) for the full rationale + invariants ¬ß30.7.
// =============================================================================

/// V1.7 ¬ß30 ‚Äî meeting slot. `midday` = 12h00 Paris (Ichor analyse), `evening`
/// = 20h00 Paris (Ichor bilan/d√©brief). The slot carries the expected content
/// type ‚Äî no separate content entity (KISS, SPEC ¬ß30.2).
enum MeetingSlot {
  midday
  evening
}

/// V1.7 ¬ß30 ‚Äî meeting lifecycle. `cancelled` = admin unavailable / no meeting
/// ‚Üí excluded from the attendance-rate denominator (a member is NEVER
/// penalised when Eliot is not available, SPEC ¬ß30.2).
enum MeetingStatus {
  scheduled
  cancelled
}

/// V1.7 ¬ß30 ‚Äî how the member attended. `live` = present on Zoom, `replay` =
/// watched the Drive recording. Null on a `MeetingAttendance` row means "not
/// yet declared". A complete attendance = `attendanceMode != null` AND
/// `contentReviewed = true` (SPEC ¬ß30.3).
enum MeetingAttendanceMode {
  live
  replay
}

/// V1.7 ¬ß30 ‚Äî a recurring Fxmily meeting occurrence (admin-scoped, cron-generated).
/// 0 FK to the real-edge models (`Trade` / `BehavioralScore`): a meeting is an
/// attendance datum, not a trading one (SPEC ¬ß30.3 isolation by construction).
model Meeting {
  id String @id @default(cuid())

  /// Civil day (Europe/Paris) of the meeting. DERIVED from `scheduledAt` by
  /// construction = `localDateOf(scheduledAt, 'Europe/Paris')` ‚Äî never computed
  /// independently (anti DST-drift on the switch day, invariant ¬ß30.7).
  /// `@db.Date` pins UTC-midnight (canon DailyCheckin).
  date DateTime    @db.Date
  slot MeetingSlot

  /// Exact UTC instant of the 12h/20h Paris slot for `date`, DST-aware via
  /// `localInstantToUtc` (CET = 11h UTC / CEST = 10h UTC). Drives sort + the
  /// "past meeting" check. Never `12:00 UTC` hardcoded (invariant ¬ß30.7).
  scheduledAt DateTime @map("scheduled_at")

  status MeetingStatus @default(scheduled)

  /// Optional admin note when cancelling a slot ("pas dispo"). Free-text,
  /// `safeFreeText`-sanitised at the J-M3 admin Server Action boundary.
  cancelledReason String? @map("cancelled_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attendances   MeetingAttendance[]
  /// S3 ¬ß31 ‚Äî `meeting_missed_no_reason` gaps materialised for no-shows.
  discrepancies Discrepancy[]

  /// Idempotent cron generation: at most one meeting per slot per civil day.
  /// Doubles as the `date >=` / `scheduledAt` denominator filter index.
  @@unique([date, slot])
  /// Denominator filter: scheduled meetings ordered by recency. No standalone
  /// `[scheduledAt]` index ‚Äî it is a redundant prefix of this composite
  /// (repo convention: no redundant single-column index, cf. DailyCheckin/Trade).
  @@index([status, scheduledAt(sort: Desc)])
  @@map("meetings")
}

/// V1.7 ¬ß30 ‚Äî a member's self-reported attendance for one `Meeting`. Cascade on
/// both `Meeting` and `User` delete (RGPD ¬ß17 data minimisation).
model MeetingAttendance {
  id String @id @default(cuid())

  meetingId String  @map("meeting_id")
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// How the member attended (live Zoom OR Drive replay). Null until declared.
  attendanceMode MeetingAttendanceMode? @map("attendance_mode")

  /// Did the member read the associated Ichor content (analyse@12h / bilan@20h)?
  /// Boolean ONLY ‚Äî the app NEVER stores the content itself (posture ¬ß2). A
  /// complete attendance = `attendanceMode != null` AND `contentReviewed = true`.
  contentReviewed Boolean @default(false) @map("content_reviewed")

  declaredAt DateTime @default(now()) @map("declared_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  /// Idempotent declaration: re-declaring updates the same row, never stacks
  /// (upsert on this composite key ‚Äî pattern DailyCheckin `(userId,date,slot)`).
  @@unique([meetingId, userId])
  /// Member view: their recent declarations. No standalone `[meetingId]` index
  /// ‚Äî the admin per-meeting lookup is served by the `[meetingId, userId]`
  /// unique prefix (repo convention: no redundant single-column index).
  @@index([userId, declaredAt(sort: Desc)])
  @@map("meeting_attendances")
}

// =============================================================================
// V2.5 ‚Äî Self-service access requests (public "Rejoindre" front door)
// =============================================================================

/// A public visitor's request to join Fxmily. Submitted unauthenticated on
/// `/rejoindre` (pr√©nom + nom + email), reviewed by the admin in
/// `/admin/access-requests`. On approval the existing invitation/onboarding
/// pipeline is reused (an `Invitation` is minted + a premium email sent) ‚Äî this
/// model NEVER creates an account itself.
///
/// PII (RGPD): `firstName` + `lastName` + `email` belong to a NON-member who has
/// given no account-level consent. We minimise exposure : (a) the public action
/// is anti-enumeration (same neutral success whether or not a row is created);
/// (b) audit rows carry NO name/email (PII-free metadata); (c) the
/// `/api/cron/purge-access-requests` weekly cron deletes resolved rows
/// (approved/rejected) and stale pending rows (> 30d) so this table never
/// accumulates dormant non-member PII.
///
/// `reviewedBy` is SetNull on admin delete (the request keeps its lifecycle
/// trace even if the reviewing admin's account is later purged). `invitationId`
/// is a loose pointer (no FK) to the invitation minted on approval ‚Äî the
/// invitation has its own TTL + purge path, so a dangling pointer after the
/// invitation expires/is-purged is acceptable and intentional.
model AccessRequest {
  id        String              @id @default(cuid())
  firstName String              @map("first_name")
  lastName  String              @map("last_name")
  email     String
  status    AccessRequestStatus @default(pending)

  /// When the admin approved/rejected the request (null while pending).
  reviewedAt   DateTime? @map("reviewed_at")
  /// The admin who reviewed it. SetNull so a purged admin doesn't erase the
  /// request's lifecycle trace.
  reviewedById String?   @map("reviewed_by_id")
  reviewedBy   User?     @relation("AccessRequestsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  /// Loose pointer (no FK) to the `Invitation` minted on approval. The
  /// invitation has its own TTL + RGPD purge path; we don't cascade-couple
  /// the two lifecycles.
  invitationId String? @map("invitation_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Admin pending-queue read: filter by status, newest-first.
  @@index([status, createdAt])
  // Dedup lookup on submit (an active pending request for this email).
  @@index([email])
  @@map("access_requests")
}

// =============================================================================
// S3 ‚Äî V√©rification & Honn√™tet√© radicale (preuve MT5 + score de constance)
// =============================================================================
//
// Session 3 of the 10-session plan ("rendre le mensonge impossible" ‚Äî the
// truth is proven BY REALITY, not by declaration alone). Data layer only at
// S1-Fondations time; the upload UI, vision pipeline (Claude Opus 4.8 local,
// image input proven 2026-06-10), reconciliation engine, scoring service and
// alert dispatch are built in the dedicated S3 session.
//
// Design invariants (PROJECT_STATE.md ¬ß13.3 + brief 03 ¬ß29-¬ß31):
//   - Cascade on User delete everywhere (RGPD ¬ß17 data minimisation).
//   - Posture ¬ß2 BLOQUANT: verification concerns FACTS (a trade existed, a
//     form was filled), NEVER the quality of an analysis. `Alert.category`
//     is structurally pinned to `psychological` ‚Äî there is no "trading
//     advice" alert by construction.
//   - Alerts fire on REPETITION ONLY (repeatCount >= threshold), never on a
//     first slip (brief ¬ß31 DoD: "les alertes ne se d√©clenchent que lorsque
//     les manquements se r√©p√®tent").
//   - Honest limit (decision Eliot 2026-06-10): a screenshot proof raises the
//     cost of lying but is NOT forensic truth (cropping/demo accounts stay
//     possible). True broker-API verification remains SPEC V3 roadmap.
//   - `Discrepancy.claudeReasoning` contains STATIC ¬ß2-clean labels produced by
//     the DETERMINISTIC reconciliation engine (reconcile.ts + constancy.ts) ‚Äî
//     NOT free-text emitted by Claude. The 4 write-sites write fixed French
//     strings (e.g. "Un trade d√©clar√© dans le journal n'a pas de contrepartie‚Ä¶").
//     If a future change writes real Claude output here it MUST add
//     detectAMFViolation + detectCrisis + safeFreeText at the write-site.

/// S3 ‚Äî kind of broker account a member trades on. Lowercase values per repo
/// enum convention (deviation from the ¬ß13.3 draft's uppercase, documented).
enum BrokerAccountType {
  prop_firm
  personal
}

/// S3 ‚Äî lifecycle of an uploaded MT5 proof through the vision pipeline.
enum ProofOcrStatus {
  pending
  done
  failed
}

/// S3 ‚Äî provenance of an extracted position. Single value today (vision OCR
/// of an MT5 history screenshot); a future V3 broker-API import becomes an
/// additive enum value, not a new model.
enum ExtractedPositionSource {
  mt5_screen_ocr
}

/// S3 ‚Äî provenance of a journal `Trade`. Every pre-S3 row is `self_declared`.
enum TradeSource {
  self_declared
  mt5_verified
}

/// S3 ‚Äî result of confronting a declared `Trade` with the extracted reality.
enum TradeMatchStatus {
  unmatched
  matched
  mismatch
}

/// S3 ‚Äî kind of declarative ‚Üî reality gap the reconciliation engine found.
///   missing_declared   : a real MT5 position has no declared trade (oubli).
///   false_declared     : a declared trade has no real MT5 counterpart.
///   mismatch           : both exist but the numbers/timing diverge.
///   unfilled_no_reason : a required ritual (check-in, declaration‚Ä¶) was left
///                        empty with no valid member reason (brief ¬ß29 ‚Äî
///                        "ne rien remplir sans motif valable n'est pas neutre").
enum DiscrepancyType {
  missing_declared
  false_declared
  mismatch
  unfilled_no_reason
  /// S3 ¬ß31 g√©n√©ralis√©e ‚Äî a SCHEDULED meeting the member neither attended (live
  /// or replay) nor excused before its 30-day rattrapage window closed. Cancelled
  /// slots are NEVER counted (no unjust accusation, ¬ß30.2/¬ß33.6).
  meeting_missed_no_reason
  /// S3 ¬ß32 g√©n√©ralis√©e ‚Äî a DUE recurring tracking instrument (S2 universal
  /// engine, e.g. the weekly process-fidelity) the member left unfilled past its
  /// rattrapage grace, without a reason. Snoozed instruments are NEVER counted
  /// (calm self-pacing, ¬ß2). Excusable like every other gap; feeds the discipline
  /// axis only (completion metadata ‚Äî never the capture content, ¬ß21.5).
  tracking_skipped_no_reason
}

/// S3 ‚Äî lifecycle of a discrepancy (open ‚Üí member acknowledged ‚Üí resolved).
enum DiscrepancyStatus {
  open
  acknowledged
  resolved
}

/// S3 ‚Äî why a constancy score event was emitted.
///   filled            : positive delta ‚Äî the member did the work.
///   forgot_no_reason  : negative delta ‚Äî unfilled without a valid reason.
///   reality_gap       : negative delta ‚Äî declarative ‚Üî reality discrepancy.
///   false_declaration : strongest negative delta ‚Äî proven false declaration.
enum ScoreEventReason {
  filled
  forgot_no_reason
  reality_gap
  false_declaration
}

/// S3 ‚Äî alert category. Structurally single-valued: an alert is ALWAYS
/// psychological (discipline / ego / honn√™tet√©, √Ý la Mark Douglas). Garde-fou
/// ¬ß2: no enum value for trading advice can ever exist here.
enum AlertCategory {
  psychological
}

/// S3 ‚Äî alert lifecycle. `delivered` = handed to the S5 coaching surface
/// (Mark Douglas delivery / admin view), `dismissed` = closed without action.
enum AlertStatus {
  open
  delivered
  dismissed
}

/// S4/S7 ‚Äî kind of a multi-capture trade attachment ("photos" pluriel ¬ß28).
enum TradeMediaKind {
  entry
  exit
  other
}

/// S3 ‚Äî a broker account the member trades on (prop firm or personal). Rows
/// are created either by the member (self-setup) or by the vision pipeline
/// (`detectedByAI = true` + `confidence`) when Claude counts distinct account
/// headers across the member's MT5 proofs ("d√©tecte au plus pr√©cis le nombre
/// exact de comptes" ‚Äî brief ¬ß30).
model BrokerAccount {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Member-facing label ("FTMO 100k", "Compte perso IC Markets").
  label      String
  type       BrokerAccountType
  /// Optional broker name as read from the proof header (free-text, short).
  brokerName String?           @map("broker_name")

  /// S3 vision ‚Äî the MT5 login (account number) as printed in the proof
  /// header. THE dedup key for "combien de comptes" (¬ß30): two proofs of the
  /// same login resolve to ONE account row. Null for member-declared rows
  /// whose proofs haven't been analysed yet; backfilled by the vision persist
  /// when a proof linked to this row reveals the login.
  accountLogin String? @map("account_login")

  /// True when this account row was created by the vision pipeline rather
  /// than declared by the member ‚Äî the "r√©alit√© vs d√©clar√©" signal.
  detectedByAI Boolean @default(false) @map("detected_by_ai")
  /// Vision confidence 0-1 for AI-detected accounts. Null for member-created.
  confidence   Float?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  proofs    Mt5AccountProof[]
  positions ExtractedPosition[]

  // One account row per (member, MT5 login). Postgres treats NULLs as
  // distinct, so member-declared rows without a login yet never collide.
  @@unique([memberId, accountLogin])
  @@index([memberId])
  @@map("broker_accounts")
}

/// S3 ‚Äî one uploaded MT5 history screenshot for one account. The vision
/// pipeline (Claude Opus 4.8 local, 5th batch pipeline) consumes `pending`
/// rows and extracts `ExtractedPosition` rows from the image.
model Mt5AccountProof {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// The account this proof documents. Nullable: at upload time the member
  /// may not have attached the proof to an account yet (the pipeline or the
  /// member links it later). SetNull keeps the proof if the account row goes.
  brokerAccountId String?        @map("broker_account_id")
  brokerAccount   BrokerAccount? @relation(fields: [brokerAccountId], references: [id], onDelete: SetNull)

  /// Storage key, `lib/storage` conventions (mirror `Trade.screenshotEntryKey`):
  /// `proofs/{userId}/{nanoid}.{ext}`.
  fileKey  String @map("file_key")
  /// SHA-256 hex of the file bytes ‚Äî anti-double-upload (a member cannot
  /// submit the same screenshot twice as two "different" proofs) and a cheap
  /// tamper trace. Uniqueness is per-member: two members CAN coincidentally
  /// upload identical bytes (e.g. a shared demo image during testing).
  fileHash String @map("file_hash")

  /// Account type as declared at upload (cross-checked against detection).
  accountType BrokerAccountType? @map("account_type")

  ocrStatus   ProofOcrStatus @default(pending) @map("ocr_status")
  /// Vision batch run identifier (mirror of the other pipelines' audit trail).
  claudeRunId String?        @map("claude_run_id")

  uploadedAt DateTime @default(now()) @map("uploaded_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  positions ExtractedPosition[]

  @@unique([memberId, fileHash])
  @@index([memberId, uploadedAt(sort: Desc)])
  // Vision batch pull: oldest pending proofs first.
  @@index([ocrStatus, uploadedAt])
  @@map("mt5_account_proofs")
}

/// S3 ‚Äî one position extracted by Claude vision from an MT5 proof. This is
/// the REALITY side of the declarative ‚Üî reality confrontation. Numbers are
/// Decimal (mirror `Trade` precision); `confidence` carries the vision
/// reading confidence (drives `BrokerAccount.confidence`, shown to the admin).
/// NOTE: the anti-survente guarantee (¬ß33.6 "ne pas accuser √Ý tort") is NOT
/// enforced through this confidence today ‚Äî it is the reconciliation COVERAGE
/// WINDOW (uncovered vs false_declared, reconcile.ts) that shields an honest
/// member. A per-row confidence gate (a `needs_review` status) stays a possible
/// V2, once the vision emits per-LINE confidence (today it is global per proof).
model ExtractedPosition {
  id String @id @default(cuid())

  brokerAccountId String        @map("broker_account_id")
  brokerAccount   BrokerAccount @relation(fields: [brokerAccountId], references: [id], onDelete: Cascade)

  /// Forensic provenance: which uploaded proof this position was read from.
  /// SetNull ‚Äî deleting a proof file row keeps the extracted history.
  proofId String?          @map("proof_id")
  proof   Mt5AccountProof? @relation(fields: [proofId], references: [id], onDelete: SetNull)

  /// S3 vision ‚Äî MT5 ticket/order number as printed in the history row.
  /// Forensic provenance + the strongest dedup key when present (mobile
  /// layouts don't print tickets ‚Üí nullable; dedup then falls back to the
  /// (symbol, side, openTime, volume) heuristic).
  ticket String?

  /// Instrument as printed by MT5 (uppercase string, no DB enum ‚Äî mirror
  /// `Trade.pair` rationale).
  symbol String
  side   TradeDirection

  openTime  DateTime  @map("open_time")
  closeTime DateTime? @map("close_time")

  /// Lots, mirror `Trade.lotSize` precision.
  volume     Decimal  @db.Decimal(12, 4)
  entryPrice Decimal? @map("entry_price") @db.Decimal(20, 8)
  exitPrice  Decimal? @map("exit_price") @db.Decimal(20, 8)
  /// P&L in account currency as printed in the MT5 history (2 decimals).
  pnl        Decimal? @db.Decimal(14, 2)

  source     ExtractedPositionSource @default(mt5_screen_ocr)
  /// Vision extraction confidence 0-1 for THIS row.
  confidence Float?

  createdAt DateTime @default(now()) @map("created_at")

  discrepancies Discrepancy[]

  // Reconciliation hot-path: account-scoped, time-ordered window scans.
  @@index([brokerAccountId, openTime])
  @@map("extracted_positions")
}

/// S3 ‚Äî one detected gap between what the member declared and the proven
/// reality (or an unfilled ritual without a valid reason). Severity 1-3:
/// 1 = minor (timing/size drift), 2 = notable (oubli), 3 = major (false
/// declaration). `claudeReasoning` holds STATIC ¬ß2-clean labels written by the
/// deterministic reconciliation engine (reconcile.ts + constancy.ts) ‚Äî NOT
/// AI-emitted free text. If a future change writes real Claude output here it
/// MUST add detectAMFViolation + detectCrisis + safeFreeText at the write-site.
/// `memberReason` is the member's own explanation ("motif valable" ‚Äî brief ¬ß29:
/// an excused absence is NOT indiscipline); member free text ‚Üí safeFreeText +
/// crisis routing at the Zod boundary.
model Discrepancy {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  type DiscrepancyType

  /// Declared side (null for missing_declared / unfilled_no_reason).
  declaredTradeId String? @map("declared_trade_id")
  declaredTrade   Trade?  @relation(fields: [declaredTradeId], references: [id], onDelete: SetNull)

  /// Reality side (null for false_declared / unfilled_no_reason).
  extractedPositionId String?            @map("extracted_position_id")
  extractedPosition   ExtractedPosition? @relation(fields: [extractedPositionId], references: [id], onDelete: SetNull)

  /// S3 ¬ß31 g√©n√©ralis√©e ‚Äî the SCHEDULED meeting this `meeting_missed_no_reason`
  /// gap refers to (null for every other type). THE dedup key: one gap per
  /// (member, meeting). SetNull keeps the gap's lifecycle if the meeting row is
  /// later purged. `detectedAt` is the DETECTION instant (‚âà when the rattrapage
  /// window closed, ~30 j after the meeting) so the gap lands inside the
  /// constancy (28 j) + alert (14 j) windows ‚Äî NOT the old meeting date.
  meetingId String?  @map("meeting_id")
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  /// S3 ¬ß32 g√©n√©ralis√©e ‚Äî THE dedup ref of a `tracking_skipped_no_reason` gap:
  /// "<instrumentKey>@<occurrenceKey>" (e.g. "process-fidelity@2026-W26"), null for
  /// every other type. `detectedAt` is the DETECTION instant (‚âà when the rattrapage
  /// grace closed) so the gap lands inside the constancy (28 j) + alert (14 j)
  /// windows. No FK to the tracking engine (¬ß21.5 isolation: the verification side
  /// references a skipped occurrence by an opaque string, never by a tracking row).
  trackingRef String? @map("tracking_ref")

  /// 1 = minor, 2 = notable, 3 = major. Display/sort signal only ‚Äî the
  /// ScoreEvent delta is a fixed per-reason constant (reconcile.ts), NOT
  /// derived from this severity.
  severity Int
  status   DiscrepancyStatus @default(open)

  /// Static ¬ß2-clean label produced by the deterministic reconciliation engine
  /// (reconcile.ts / constancy.ts). NOT free-text from Claude ‚Äî the 4 write-
  /// sites write fixed French strings (e.g. "Un trade d√©clar√© dans le journal‚Ä¶").
  /// If a future change writes real Claude output here it MUST add
  /// detectAMFViolation + detectCrisis + safeFreeText at the write-site.
  claudeReasoning String? @map("claude_reasoning") @db.Text

  /// Member-provided valid reason ("j'√©tais malade", "panne internet").
  /// Distinguishes an EXCUSED gap from indiscipline (brief ¬ß29 "sans motif
  /// valable"). safeFreeText + crisis routing at the Zod boundary.
  memberReason   String?   @map("member_reason") @db.Text
  memberReasonAt DateTime? @map("member_reason_at")

  detectedAt DateTime @default(now()) @map("detected_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  scoreEvents ScoreEvent[]

  // One meeting-miss gap per (member, meeting) ‚Äî the scan dedup key. NULL
  // meetingId rows (every other type) never collide (Postgres NULLs distinct).
  @@unique([memberId, meetingId])
  // One tracking-skip gap per (member, instrument@occurrence). NULL trackingRef
  // rows (every other type) never collide (Postgres NULLs distinct).
  @@unique([memberId, trackingRef])
  // Member + admin views: open discrepancies first.
  @@index([memberId, status])
  @@index([memberId, detectedAt(sort: Desc)])
  @@map("discrepancies")
}

/// S3 ‚Äî the constancy & work-investment score (DEDICATED model, decision
/// Eliot 2026-06-10 ‚Äî distinct from the 4 declarative `BehavioralScore`
/// dimensions because THIS one is confronted with external reality).
/// `value` 0-100; `breakdown` JSON `{ honesty, regularity, discipline }`
/// mirrors the BehavioralScore `components` transparency pattern ("why is
/// my score X?"). Window convention mirrors `WeeklyReport` (periodStart/
/// periodEnd @db.Date + idempotent upsert per period).
model ConstancyScore {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// 0-100. Float (not Int) ‚Äî event-sourced fractional deltas accumulate;
  /// the UI rounds for display.
  value     Float
  /// `{ honesty: number, regularity: number, discipline: number }` 0-100 each
  /// ‚Äî validated at the Zod boundary (lib/schemas, S3 session).
  breakdown Json

  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date

  computedAt DateTime @default(now()) @map("computed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Idempotent recompute: one score row per (member, period).
  @@unique([memberId, periodStart])
  @@index([memberId, computedAt(sort: Desc)])
  @@map("constancy_scores")
}

/// S3 ‚Äî event-sourced journal of constancy deltas ("le score monte et
/// descend correctement selon le comportement" ‚Äî brief ¬ß31 DoD#3). Each row
/// is one auditable reason why the score moved; the score recompute folds
/// the window's events. Keeps the score explainable to the member without
/// complaisance ni culpabilisation gratuite.
model ScoreEvent {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Signed per-event weight (positive = filled/did the work, negative =
  /// forgot / reality gap / false declaration). It records the event's
  /// direction and relative magnitude; it is NOT summed into the score
  /// directly ‚Äî the weekly fold (constancy.ts) recomputes `value` from the
  /// event REASONS via the honesty/regularity/discipline formulas, so a stored
  /// `-8` does not mean "-8 points on the 0-100 score".
  delta  Float
  reason ScoreEventReason

  /// Audit link to the discrepancy that caused a negative event. SetNull ‚Äî
  /// purging a discrepancy keeps the score history intact.
  relatedDiscrepancyId String?      @map("related_discrepancy_id")
  relatedDiscrepancy   Discrepancy? @relation(fields: [relatedDiscrepancyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([memberId, createdAt(sort: Desc)])
  @@map("score_events")
}

/// S3 ‚Äî repetition alert feeding the S5 coaching surface. Garde-fou ¬ß2 by
/// construction: `category` is structurally `psychological` (single-value
/// enum ‚Äî no trading-advice alert can exist). An alert row is only created
/// when `repeatCount >= threshold` (REPETITION ONLY ‚Äî a single slip never
/// alerts, brief ¬ß31 DoD#4). Downstream: a Mark Douglas delivery may carry
/// `sourceAlertId` (S3 ‚Üí S5 junction), and the weekly/monthly snapshots read
/// count-only alert stats.
model Alert {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Slug of the repeated failure pattern, e.g. `forgot_no_reason_repeat`,
  /// `reality_gap_repeat`, `false_declaration_repeat`. Bounded server-side by
  /// the `ALERT_RULES` constant (alerts.ts) ‚Äî the single write-site ‚Äî not by a
  /// Zod allowlist.
  triggerType String @map("trigger_type")

  /// How many times the pattern occurred in the evaluation window‚Ä¶
  repeatCount Int @map("repeat_count")
  /// ‚Ä¶and the threshold that was crossed (kept for auditability: "3 oublis
  /// sans motif en 14 jours").
  threshold   Int

  category AlertCategory @default(psychological)
  status   AlertStatus   @default(open)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// S5 coaching deliveries this alert caused (Mark Douglas accompaniment).
  douglasDeliveries MarkDouglasDelivery[]

  @@index([memberId, status])
  @@map("alerts")
}

/// S4/S7 ‚Äî multi-capture trade attachment ("photos" pluriel, briefs ¬ß28/¬ß29).
/// The legacy single `screenshotEntryKey`/`screenshotExitKey` columns on
/// `Trade` remain the V1 path (backward compat); this table is the additive
/// 1-N path for multi-photo flows. Cascade with the trade (RGPD, mirror
/// `TradeAnnotation`).
model TradeMedia {
  id      String @id @default(cuid())
  tradeId String @map("trade_id")
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  kind    TradeMediaKind @default(entry)
  /// Storage key, `lib/storage` conventions: `trades/{userId}/{nanoid}.{ext}`.
  fileKey String         @map("file_key")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tradeId])
  @@map("trade_media")
}

/// S8 ‚Äî backtest session container ("cr√©e une session de backtest" ‚Äî brief
/// 08). Groups `TrainingTrade` entries logged during one practice sitting.
/// FIREWALL ¬ß21.5: lives 100% inside the training world ‚Äî NO link to `Trade`,
/// `BehavioralScore` or any real-edge model, only the implicit User link.
/// All free text safeFreeText-hardened at the Zod boundary.
model TrainingSession {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Member label ("Backtest GBPUSD janvier 2024").
  label     String?
  /// Practised instrument (uppercase string, mirror `TrainingTrade.pair`).
  symbol    String?
  /// Practised timeframe label ("M15", "H1") ‚Äî free short string, no enum
  /// (mirror `pair` rationale: list evolves without migration).
  timeframe String?

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  notes     String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trades TrainingTrade[]

  @@index([memberId, startedAt(sort: Desc)])
  @@map("training_sessions")
}

// Fxmily — Prisma schema.
// Source of truth for the data model. Entities are added milestone by milestone
// per SPEC.md §6. Database connection lives in `prisma.config.ts` (Prisma 7+).
//
// J0 — datasource + generator only.
// J1 — User, Account, Session, VerificationToken, Invitation, AuditLog.
// J2 — Trade + enums (TradeDirection, TradeSession, TradeOutcome, RealizedRSource).
// J4 — TradeAnnotation + NotificationQueue + enums (AnnotationMediaType, NotificationType, NotificationStatus).
// J5 — DailyCheckin + enum CheckinSlot. Extends NotificationType with morning/evening reminders.
// J6+ — BehavioralScore, MarkDouglasCard, MarkDouglasDelivery, WeeklyReport.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum UserRole {
  member
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

/// Self-service access request lifecycle (V2.5 — public "Rejoindre" front door).
/// A public visitor submits prénom/nom/email on `/rejoindre` → a `pending` row.
/// The admin reviews it in `/admin/access-requests` and either:
///   approved : an `Invitation` is minted (existing onboarding pipeline reused)
///              and a premium "demande acceptée" email is sent. The created
///              invitation id is stored on the request for traceability.
///   rejected : terminal, a refusal email IS sent (§26.4 — no longer a silent
///              refusal), but no account is ever created.
/// RGPD: a non-member's name+email is PII stored before any consent — the
/// `/api/cron/purge-access-requests` weekly cron purges resolved rows (and
/// stale pending ones > 30d) so this surface never accumulates dormant PII.
enum AccessRequestStatus {
  pending
  approved
  rejected
}

/// Trade direction (J2). Long = buy, short = sell.
enum TradeDirection {
  long
  short
}

/// Trading session (J2). Auto-derived from `enteredAt` UTC at form-fill time
/// but persisted explicitly so the user's manual override survives DST shifts.
/// Plage UTC indicatives (DST géré côté code) :
///   asia    : 00:00–07:00 UTC
///   london  : 07:00–12:00 UTC
///   overlap : 12:00–16:00 UTC (London/NY)
///   newyork : 16:00–21:00 UTC
enum TradeSession {
  asia
  london
  newyork
  overlap
}

/// Outcome reported at trade close (J2). `break_even` covers both flat exits
/// and exits within ±0.1R of entry — the wizard maps the user-friendly "BE"
/// button to this value.
enum TradeOutcome {
  win
  loss
  break_even
}

/// Tour 10 — factual nature of the exit, answered at CLOSE. Captures HOW the
/// position ended (the ACT, never a judgement — SPEC §2): crossed with
/// `emotionDuring` it surfaces fear-driven early exits, the single biggest
/// expectancy killer the method's rules (S26) guard against. OPTIONAL —
/// tri-state pattern of `processComplete` (null = not answered, no gate).
enum TradeExitReason {
  /// Take-profit reached as planned.
  tp_hit
  /// Initial stop-loss was hit.
  sl_hit
  /// Exited at break-even (SL moved to BE per the RR-1 rule, then hit).
  be_exit
  /// Manual exit BEFORE the target, outside the plan's exit rules.
  manual_before_target
  /// Runner closed at the 20h candle (method's time-exit rule).
  time_exit
}

/// Provenance of `realizedR` (J2).
///   computed  : derived from entry/exit/stopLoss with the canonical
///               (exit-entry)/(entry-stopLoss) formula. Reliable for analytics.
///   estimated : fallback when no stopLoss was provided. Equals `plannedRR` on
///               win, -1 on loss, 0 on break_even. Excluded from precision-
///               sensitive aggregates (expectancy, R-distribution).
enum RealizedRSource {
  computed
  estimated
}

/// V1.5 — Setup quality classification (Steenbarger best practice).
/// Captured BEFORE the outcome is known, so it cannot rationalize a posteriori.
///   A : setup parfait, conviction haute, contexte favorable (gold standard).
///   B : setup correct, conviction moyenne, ou contexte mitigé (default acceptable).
///   C : setup limite, conviction basse, ou doute sur le contexte (à coacher).
/// Eliot uses the distribution to coach : "tes B et C ont un win-rate 30 %
/// plus bas que tes A, pourquoi tu les prends ?". Decoupled from `realizedR`
/// — a C trade that wins is still a C trade.
enum TradeQuality {
  A
  B
  C
}

/// Annotation media kind (J4). V1 supports image attachments only — the
/// 500 MiB Zoom-video upload path is deferred to J4.5 (depends on R2 wiring).
/// The enum value is kept open so the column can store `video` once available.
enum AnnotationMediaType {
  image
  video
}

/// Push-notification kinds queued for J9 dispatch (J4 + J5 + J9).
/// Values are persisted as strings — adding a new kind is an additive migration.
///   annotation_received          : a member's trade just got a new admin correction (J4).
///   training_annotation_received : a member's BACKTEST just got an admin correction
///                                  (J-T3). DISTINCT from annotation_received — a
///                                  backtest correction must never conflate with a
///                                  real-trade correction (statistical isolation §21.5).
///   training_reply_received      : a member REPLIED to an admin backtest correction
///                                  (S8 V2, brief §32-4). Admin-facing push — the
///                                  reverse direction of training_annotation_received.
///                                  Stays inside the §21.5 training world (no P&L).
///   checkin_morning_reminder     : nudges the member to fill their morning check-in (J5).
///   checkin_evening_reminder     : nudges the member to fill their evening check-in (J5).
///   douglas_card_delivered       : a Mark Douglas card was triggered for the member (J9).
///   weekly_report_ready          : the J8 admin weekly digest is ready (admin-only push, opt-in).
///   monthly_debrief_ready        : the V1.4 member monthly AI debrief is ready (SPEC §25 —
///                                  member-facing push, mirror douglas_card_delivered; no
///                                  admin monthly push by design).
///   mindset_check_ready          : the V1.5 weekly mindset self-check is available (SPEC §27 —
///                                  member-facing push, mirror monthly_debrief_ready;
///                                  deterministic, no AI).
enum NotificationType {
  annotation_received
  training_annotation_received
  training_reply_received
  checkin_morning_reminder
  checkin_evening_reminder
  douglas_card_delivered
  weekly_report_ready
  monthly_debrief_ready
  mindset_check_ready
  /// S3 §33 enrichment — « micro-relance avant l'alerte ». A single gentle,
  /// benevolent push on an ISOLATED unexcused gap (below the alert threshold),
  /// asking the member to look and give a reason if there is one — BEFORE any
  /// repetition alert escalates. Strictly psychological (honnêteté/discipline,
  /// Mark Douglas), never a trading advice. ≤1 per gap (Discrepancy.gentleReminderAt).
  verification_gentle_reminder
}

/// Daily check-in slot (J5, SPEC §6.4 + §7.4).
///   morning : sleep, routine, mood, intention. Reminder ~07:30 local.
///   evening : discipline, stress, gratitude, journal. Reminder ~20:30 local.
enum CheckinSlot {
  morning
  evening
}

/// V2.0 TRACK module — habit logging granular kinds (FXMILY-V2-MASTER A2-A5
/// must-have features). One row per (user, date, kind). Value JSON shape
/// is kind-specific and validated at the Zod boundary in
/// `lib/schemas/habit-log.ts`.
enum HabitKind {
  /// Hours of sleep (durationMin) + optional quality rating 1-10.
  sleep
  /// Meals count + optional quality rating (poor/fair/good/excellent).
  nutrition
  /// Cups of caffeine + optional last-drink HH:MM (UTC). Master plan A3.
  caffeine
  /// Type (cardio/strength/mixed/flexibility/other) + duration + intensity.
  sport
  /// Duration (minutes) + optional quality rating 1-10. Master plan A5.
  meditation
}

/// V2.3 — Pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer if-then).
/// 4 options to answer "Pourquoi je veux prendre ce trade ?" before each entry.
/// See `docs/decisions/ADR-003-pre-trade-circuit-breaker.md` for the mapping
/// vs Douglas's 4 primary trading fears (Trading in the Zone, 2000) — `edge`
/// = absence of the 4 fears, `fomo` = fear of missing out (direct), `revenge`
/// = mixed fear of being wrong + losing money, `boredom` = Steenbarger
/// "low arousal" affect (extension hors-Douglas-canonique, documented).
enum PreTradeReason {
  /// Setup éprouvé, je suis dans ma routine (absence des 4 fears Douglas).
  edge
  /// J'ai peur de rater quelque chose (fear of missing out — Douglas).
  fomo
  /// Je veux compenser une perte (fear of being wrong + losing money — Douglas).
  revenge
  /// J'ai juste envie de faire quelque chose (Steenbarger low-arousal extension).
  boredom
}

/// V2.3 — Pre-trade affective state. Russell-Weiss-Mendelsohn 1989 affect grid
/// 2x2 (valence × arousal). 4 options mapping the 4 quadrants. See ADR-003.
enum PreTradeEmotion {
  /// Low arousal, positive valence.
  calme
  /// High arousal, positive valence.
  excite
  /// High arousal, negative valence.
  frustre
  /// Low-to-medium arousal, negative valence.
  anxieux
}

/// Mark Douglas card category (J7, SPEC §7.6).
/// Maps to canonical pillars from *Trading in the Zone* and *The Disciplined Trader*.
enum DouglasCategory {
  acceptance
  tilt
  discipline
  ego
  probabilities
  confidence
  patience
  consistency
  fear
  loss
  process
}

/// Lifecycle of a queued notification (J4 + J9).
///   pending     : waiting for the J9 dispatcher (initial state, also re-set after retryable error).
///   dispatching : claimed by a dispatcher run (atomic transition pending→dispatching via updateMany,
///                 prevents two cron instances from sending the same notification twice).
///   sent        : delivered to at least one push endpoint.
///   failed      : dispatcher gave up after the retry budget. Surfaced in admin + may trigger
///                 email fallback (SPEC §18.2 iOS push fragility mitigation).
enum NotificationStatus {
  pending
  dispatching
  sent
  failed
}

/// §26 Calendrier adaptatif — the three coarse parts of a member's day. KISS
/// 3-slot granularity (Q2 default) shared vocabulary between the weekly
/// questionnaire (`energy_peak_slot`) and the generated schedule blocks
/// (JSON-validated by `adaptiveCalendarOutputSchema`). Distinct from
/// `CheckinSlot` (morning/evening only) — the calendar needs an afternoon
/// band to organise the practice day. Bump the instrument version (not this
/// enum in place) if a 4th band is ever needed.
enum CalendarSlot {
  morning
  afternoon
  evening
}

/// §26 Calendrier adaptatif — what a scheduled time-block organises. Posture
/// §2 (BLOQUANT): every category is about the TIME of practice, NEVER a market
/// call. `live_trading` = a session the member plans to be at the screen,
/// `backtest` = training/replay, `mark_douglas_review` = psychology reading,
/// `checkin` = daily check-in ritual, `meeting` = §30 réunion, `rest` =
/// deliberate recovery, `free` = unstructured. The generated `schedule` JSON
/// is validated against these values; `AdaptiveCalendar.primary_category`
/// denormalises the dominant one for admin week-at-a-glance.
enum CalendarBlockCategory {
  live_trading
  backtest
  mark_douglas_review
  checkin
  rest
  meeting
  free
}

// =============================================================================
// Auth.js v5 core models (PrismaAdapter contract)
// https://authjs.dev/getting-started/adapters/prisma
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")

  // Profile (filled at onboarding completion)
  firstName String? @map("first_name")
  lastName  String? @map("last_name")
  image     String?

  // Authentication
  passwordHash String? @map("password_hash") // argon2id, optional (magic-link-only users have null)
  /// J4 (security T2-1) — JWT session-revocation epoch. Bumped to invalidate
  /// every outstanding JWT for this user (suspend / hard-delete / future
  /// password reset). The Node-side `jwt` callback in `auth.ts` re-reads this
  /// on each `auth()` call and tears the session down when the token's stale
  /// claim no longer matches. See `lib/auth/session-revocation.ts`.
  tokenVersion Int     @default(0) @map("token_version")

  // Authorization & lifecycle
  role   UserRole   @default(member)
  status UserStatus @default(active)

  // SPEC §6.1 — behavioral profile fields
  timezone         String    @default("Europe/Paris")
  pushSubscription Json?     @map("push_subscription") // J9
  consentRgpdAt    DateTime? @map("consent_rgpd_at")

  /// S3 — number of broker accounts the vision pipeline detected from the
  /// member's MT5 proof uploads (Claude counts distinct account headers across
  /// proofs). Null = never analysed. Denormalised convenience for the admin
  /// "réalité vs déclaré" view; the source of truth is the `BrokerAccount`
  /// rows themselves.
  detectedAccountCount Int? @map("detected_account_count")

  // Lifecycle timestamps
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  /// J10 — RGPD soft-delete anchor. Set when `/account/delete` Server Action
  /// confirms (status flipped to `deleted`, PII scrubbed). Cleared on cancel
  /// inside the 24h grace window. Hard-purged 30 days later by
  /// `/api/cron/purge-deleted` (cascade removes all user-scoped rows).
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  accounts                      Account[]
  sessions                      Session[]
  invitationsSent               Invitation[]                   @relation("InvitationsSent")
  // S-overhaul §7.1 — pending "mot de passe oublié" reset tokens (bounded ~1/user).
  passwordResetTokens           PasswordResetToken[]
  auditLogs                     AuditLog[]
  trades                        Trade[]
  // J4 — annotations the admin authored on members' trades.
  annotationsAuthored           TradeAnnotation[]              @relation("AnnotationsAuthored")
  // J4 — push-notification queue rows targeting this user.
  notificationsQueued           NotificationQueue[]
  // J5 — morning + evening check-ins.
  dailyCheckins                 DailyCheckin[]
  // J6 — daily behavioral score snapshots (cached, recomputed nightly).
  behavioralScores              BehavioralScore[]
  // J7 - Mark Douglas contextual card deliveries + manual favorites.
  douglasDeliveries             MarkDouglasDelivery[]
  douglasFavorites              MarkDouglasFavorite[]
  // J8 — weekly AI reports (admin digest, generated by Claude Sonnet 4.6).
  weeklyReports                 WeeklyReport[]
  // V1.8 — member-facing reflection (Sunday wizard + CBT Ellis ABC).
  weeklyReviews                 WeeklyReview[]
  reflectionEntries             ReflectionEntry[]
  // V2.0 — TRACK module habit logs (sleep/nutrition/caffeine/sport/meditation).
  habitLogs                     HabitLog[]
  // V2.1 — admin private notes (SPEC §7.7). Two named relations: notes
  // written ABOUT this member, and notes this (admin) user authored.
  adminNotesAbout               AdminNote[]                    @relation("AdminNotesAbout")
  adminNotesAuthored            AdminNote[]                    @relation("AdminNotesAuthored")
  // V1.2 — Mode Entraînement / Backtest (SPEC §21). Statistically isolated
  // from the real edge: no FK to Trade, separate enums, dedicated services.
  trainingTrades                TrainingTrade[]
  trainingAnnotationsAuthored   TrainingAnnotation[]           @relation("TrainingAnnotationsAuthored")
  // V1.3 — member-owned weekly backtest-practice debrief (SPEC §23).
  // Statistically isolated like the rest of the training surface: no FK to
  // Trade / WeeklyReview / BehavioralScore, only this implicit userId link.
  trainingDebriefs              TrainingDebrief[]
  // V1.4 — monthly AI debrief (SPEC §25). IA-pipeline sibling of WeeklyReport
  // but dual-section §21.5-walled: no FK to Trade/WeeklyReport/TrainingTrade/
  // BehavioralScore — only this implicit userId link (the WeeklyReport rows
  // of the month are read as INPUT by the aggregator, never linked as FK).
  monthlyDebriefs               MonthlyDebrief[]
  // V1.5 — weekly mindset self-check (SPEC §27). Deterministic, zero-AI.
  // 0-FK statistically isolated like the rest of the training surface:
  // no FK to Trade / WeeklyReport / BehavioralScore, only this implicit
  // userId link — feeds nothing back into the real edge (§21.5/§27.7).
  mindsetChecks                 MindsetCheck[]
  // V2.3 — pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer
  // if-then, Session BB). 4 questions one-tap (~30s) before each trade.
  // ZERO free-text → ZERO crisis/injection surface → ZERO AI banner needed.
  // Optional auto-link to a Trade via service-layer linkRecentCheckToTrade
  // window 15min P2002-safe. The member always stays master of the decision
  // — Fxmily NEVER blocks a trade. See docs/decisions/ADR-003-pre-trade-
  // circuit-breaker.md for the evidence base (Gollwitzer-Sheeran 2006
  // d=0.65, 94 studies, n=8461) + Mark Douglas 4 primary trading fears.
  preTradeChecks                PreTradeCheck[]
  // V2.4 — Onboarding interview profilage IA Mark Douglas (Session α, M3
  // directive Eliot 2026-05-27 verbatim "claude pour analyser au plus deep").
  // 1-1 OnboardingInterview + MemberProfile cascade User. Static questionnaire
  // ~30 questions safeFreeText-sanitized at service layer. Claude batch local
  // async post-completion (carbone V1.4 monthly-debrief — ZÉRO API payante).
  // Posture §2 strict — Claude generates psycho/process axes ONLY, never
  // trade analysis. Cf. memory/fxmily_session_2026-05-27_pipeline_ee_ii_closure.md
  // for the M3 directive context. ADR-004 future evidence base for instrument
  // versioning + crisis detection patterns.
  onboardingInterview           OnboardingInterview?
  onboardingAnswers             OnboardingInterviewAnswer[]
  memberProfile                 MemberProfile?
  // J-E — trajectoire longitudinale ADMIN-ONLY des 4 dimensions IA profondes,
  // re-profilees chaque mois civil (ADD-only, n'ecrase jamais le baseline
  // `memberProfile`). Cascade User (RGPD §17). Aucune dim n'est un input scoring
  // (firewall §21.5) ; `weakSignals` reste admin-only. 0 FK real-edge (userId).
  memberProfileMonthlySnapshots MemberProfileMonthlySnapshot[]
  // §26 — Calendrier adaptatif. Weekly closed questionnaire → Claude batch
  // local generates a personal weekly schedule. Posture §2 strict: organises
  // the member's TIME of practice (sessions/backtest/Mark Douglas/réunions
  // §30/rest), NEVER trades. `AdaptiveCalendar` carries NO P&L field and has
  // NO FK to the questionnaire (snapshot-at-generation decoupled). The Claude
  // snapshot reads count-only activity (lib/calendar/snapshot.ts) — §21.5/§27.7
  // isolation enforced by test/anti-leak/calendar-isolation.test.ts.
  weeklyScheduleQuestionnaires  WeeklyScheduleQuestionnaire[]
  adaptiveCalendars             AdaptiveCalendar[]
  // V1.7 §30 — meeting attendance declarations (self-report). `Meeting` has
  // NO User FK (admin-scoped global entity); only this join links the member.
  // Touches ONLY engagement via the count-only primitive countMeetingAttendance (J-M4).
  meetingAttendances            MeetingAttendance[]
  // J9 — Web Push subscriptions (one row per browser/device) + per-category opt-out preferences.
  pushSubscriptions             PushSubscription[]
  notificationPreferences       NotificationPreference[]
  // V2.5 — public self-service access requests reviewed by this admin
  // (approve/reject). SetNull on the request so a deleted admin doesn't
  // cascade-wipe the audit trail of who reviewed a non-member's request.
  reviewedAccessRequests        AccessRequest[]                @relation("AccessRequestsReviewed")
  // S3 — Vérification & Honnêteté radicale (preuve MT5 + score de constance).
  // All cascade on User delete (RGPD §17 data minimisation, schema-wide).
  brokerAccounts                BrokerAccount[]
  mt5AccountProofs              Mt5AccountProof[]
  discrepancies                 Discrepancy[]
  constancyScores               ConstancyScore[]
  scoreEvents                   ScoreEvent[]
  alerts                        Alert[]
  // S5 §32-E3 — mental micro-objective engagement loop (Mark Douglas). Cascade
  // on User delete (RGPD §17). Firewall §21.5: psychological/process only, no
  // FK to the real edge (only this implicit memberId link).
  mentalMicroObjectives         MentalMicroObjective[]
  // S3/S8 — training-session containers (firewall §21.5: training world only).
  trainingSessions              TrainingSession[]
  // V2 S2 — universal tracking engine (recurring code-defined instruments).
  // §21.5/§27.7 isolated: NO FK to Trade/BehavioralScore — captured responses +
  // D1/D2/D3 metadata only, feeds nothing into the real edge. Cascade on delete.
  trackingEntries               TrackingEntry[]
  trackingSchedules             TrackingSchedule[]
  // F5 (overhaul) — admin moderation log. Two named relations: events ABOUT
  // this member (target, cascade on delete so a purged member's log vanishes,
  // RGPD §17) and events this (admin) user PERFORMED (actor, SetNull on delete
  // so losing the admin row never erases a member's moderation history —
  // mirrors the AccessRequest reviewer + AuditLog user relations).
  moderationEvents              MemberModerationEvent[]        @relation("MemberModerationTarget")
  moderationActionsTaken        MemberModerationEvent[]        @relation("MemberModerationActor")

  @@index([status])
  @@index([role])
  /// J10 — partial index for the soft-delete purge cron. Only rows where
  /// `status = 'deleted'` satisfy the predicate; the partial index keeps it
  /// trivially small even at 1000+ members. The actual `WHERE status =
  /// 'deleted'` clause lives in the migration SQL (Prisma 7 doesn't expose
  /// partial-index predicates declaratively yet).
  @@index([status, deletedAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// Fxmily-specific models
// =============================================================================

/// Admin invitation flow (SPEC §6.9, §7.1).
/// Token is generated as a 32-byte random string (nanoid), only its SHA-256 hash
/// is stored. The plain token is sent in the email link and never persisted.
model Invitation {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  invitedById String @map("invited_by_id")
  invitedBy   User   @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("invitations")
}

/// Password-reset flow (SPEC §7.1 — "mot de passe oublié", 2026-06-30).
/// Exact mirror of `Invitation`: a high-entropy plain token (nanoid 32 ≈ 192
/// bits) is e-mailed, and ONLY its SHA-256 hash is stored — the plain value
/// never touches disk, so a DB compromise cannot forge a reset. Single-use
/// (`usedAt`) + short TTL (PASSWORD_RESET_TTL_MS = 30 min, much tighter than the
/// 7-day invitation). On consumption the user's `passwordHash` is rehashed AND
/// `User.tokenVersion` is bumped (revokes every outstanding JWT — the
/// tokenVersion doc on `User` anticipates exactly this "future password reset").
/// Bounded by construction: each forgot request `deleteMany`s the member's prior
/// tokens before creating a fresh one, so at most one row ever exists per user
/// (no purge cron needed). FK → User onDelete:Cascade (RGPD §17 — a deleted
/// member's reset tokens vanish with the account).
model PasswordResetToken {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  /// "Invalidate all my prior tokens" lookup (deleteMany on a new request) +
  /// the per-user uniqueness sweep. `tokenHash` (unique) serves the consume
  /// lookup; no standalone `[expiresAt]` index since rows are bounded to ~1/user.
  @@index([userId])
  @@map("password_reset_tokens")
}

/// RGPD-friendly audit log (SPEC §6.8, §9.2).
/// IPs are SHA-256-hashed before storage. Never log plaintext PII in `metadata`.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  // Retention purge (ops cron) deletes on `createdAt` ALONE — without this
  // index every purge is a full-table seq-scan on the busiest table.
  @@index([createdAt])
  @@map("audit_logs")
}

/// F5 (overhaul, 2026-06-30) — admin member-moderation log.
///
/// Each row records ONE status transition the admin performed on a member:
///   - `suspended`  : expel / retirer l'accès. The service flips the member's
///     `status` active→suspended AND bumps `User.tokenVersion` in one atomic
///     `updateMany` — every outstanding JWT is torn down on its next `auth()`
///     round-trip (immediate eject) and `authorize` refuses a non-active login
///     (reconnection blocked).
///   - `reinstated` : suspended→active (no tokenVersion bump needed — a
///     suspended member already holds no valid session).
///
/// The optional free-text `reason` (motif) lives HERE, deliberately NOT in
/// `AuditLog`: AuditLog is a PII-free trail (opaque ids only, schema doc
/// :536-537), whereas a moderation motif is admin prose about a member — same
/// privacy class as `AdminNote`. The member NEVER sees these rows (admin-only
/// service + Server Action role gate, no member-facing read path). AuditLog
/// still gets a PII-free row per action for the security trail.
///
/// Append-only history: the admin keeps a who/when/why record of every
/// moderation decision. `member` FK cascades on delete so a hard-purged
/// member's log vanishes with them (RGPD §17); `actor` FK is SetNull so losing
/// the admin row never erases a member's moderation history.
model MemberModerationEvent {
  id        String                 @id @default(cuid())
  memberId  String                 @map("member_id")
  member    User                   @relation("MemberModerationTarget", fields: [memberId], references: [id], onDelete: Cascade)
  actorId   String?                @map("actor_id")
  actor     User?                  @relation("MemberModerationActor", fields: [actorId], references: [id], onDelete: SetNull)
  action    MemberModerationAction
  reason    String?                @db.Text
  createdAt DateTime               @default(now()) @map("created_at")

  @@index([memberId, createdAt])
  @@map("member_moderation_events")
}

enum MemberModerationAction {
  suspended
  reinstated
}

// =============================================================================
// J2 — Trading journal
// =============================================================================

/// Trade journal entry (SPEC §6.2, §7.3).
///
/// Lifecycle: a trade is created in "open" state with the pre-entry fields
/// (everything before the `--- post-exit ---` block). The user can finalize it
/// later — either right away in a single wizard run, or asynchronously after
/// the trade closes — by filling the post-exit block via /journal/[id]/close.
/// The `closedAt` timestamp marks the transition; both screenshots are
/// mandatory at their respective phases (SPEC §7.3 "upload obligatoire").
///
/// `realizedR` precision: the canonical formula `(exit - entry) / (entry - SL)`
/// (signed by direction) is used when `stopLossPrice` is provided
/// (`realizedRSource = computed`). When the user skipped the SL, we fall back
/// to `plannedRR | -1 | 0` based on outcome (`realizedRSource = estimated`).
/// See `lib/trading/calculations.ts` for the implementation.
model Trade {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ----- Pre-entry block (mandatory at trade creation) -----

  /// One of the 12 allowlisted symbols (see lib/trading/pairs.ts). Stored as
  /// uppercase string rather than an enum so adding pairs doesn't require a
  /// DB migration — the allowlist is enforced at the Zod / Server Action edge.
  pair            String
  direction       TradeDirection
  session         TradeSession
  /// User-provided trade entry timestamp, persisted in UTC. The wizard
  /// pre-fills this from `Date.now()` but the user can override (useful when
  /// logging trades retroactively).
  enteredAt       DateTime       @map("entered_at")
  entryPrice      Decimal        @map("entry_price") @db.Decimal(20, 8)
  /// Position size in lots (forex/metals) or contracts (indices). Decimal(12,4)
  /// covers micro-lots (0.01) up to institutional sizes.
  lotSize         Decimal        @map("lot_size") @db.Decimal(12, 4)
  /// Optional stop-loss price. Strongly encouraged: enables exact `realizedR`.
  stopLossPrice   Decimal?       @map("stop_loss_price") @db.Decimal(20, 8)
  /// Planned reward-to-risk ratio (e.g. 2.5 means "risk 1 to make 2.5").
  /// Slider in the UI clamps to [0.5, 10] with 0.25 step.
  plannedRR       Decimal        @map("planned_rr") @db.Decimal(6, 2)
  /// Multi-select tag slugs (FR labels, EN slugs). See lib/trading/emotions.ts.
  /// UI caps the selection at 3 tags; we don't enforce in DB to allow future
  /// expansion without a migration.
  emotionBefore   String[]       @map("emotion_before")
  planRespected   Boolean        @map("plan_respected")
  /// `null` = N/A (no hedge applicable on this trade). Tri-state per SPEC §7.3.
  hedgeRespected  Boolean?       @map("hedge_respected")
  /// SPEC §28/§21 — "oublis" tracking axis (master prompt §28: "exécution en
  /// position réelle (respect du plan, oublis)" / §21: "s'il oublie des choses
  /// ou non"). Positive framing (anti-Black-Hat): `true` = "j'ai suivi tout mon
  /// process, rien oublié", `false` = forgot/missed steps, `null` = not answered
  /// / legacy row. Answered at CLOSE alongside `emotionDuring` (PR #236 precedent)
  /// and parallel to `planRespected`/`hedgeRespected`. SPEC §2 posture: we track
  /// the ACT of completeness/forgetting, NEVER advise on the trade itself. Pure
  /// additive nullable Boolean — exact mirror of `DailyCheckin.marketAnalysisDone`.
  processComplete Boolean?       @map("process_complete")

  /// S26 — « Fidélité à la gestion ». Three management hard-rules of Eliott's
  /// method (transcript "gestion de trades technique"), answered at CLOSE next to
  /// `processComplete`. Tri-state each: `true` (followed the rule), `false` (did
  /// not), `null` (not answered — OPTIONAL, NO required-field gate, CANON). SPEC
  /// §2 posture (identical to `processComplete`/`marketAnalysisDone`): we track
  /// the ACT of following YOUR OWN execution rule, NEVER the trade content / a
  /// market call (no level, no direction, no setup). Pure additive nullable
  /// Booleans → null-skip everywhere → byte-identical for legacy trades.

  /// Method rule: "SL placé en M15, toujours au-delà de mon dernier extrême,
  /// jamais au hasard". The ACT of placing the stop per the member's OWN rule.
  slPerRule       Boolean? @map("sl_per_rule")
  /// Method rule: "dès le RR 1, je passe mon SL au break-even (légèrement
  /// positif)". The ACT of moving to break-even at RR 1 as planned.
  movedToBe       Boolean? @map("moved_to_be")
  /// Method rule: "au TP (RR 2–3), je clôture 90 % et laisse 10 % courir jusqu'à
  /// la bougie 20h". The ACT of the planned partial secure at target.
  partialAtTarget Boolean? @map("partial_at_target")

  notes String? @db.Text

  /// Storage key for the pre-entry screenshot. J1 pivot (capture → lien) :
  /// pre-J1 trades keep their stored capture, new trades leave this NULL. The
  /// column is nullable (legacy rows + administrative repairs). Format follows
  /// `lib/storage` conventions: `trades/{userId}/{nanoid}.{ext}`.
  screenshotEntryKey String? @map("screenshot_entry_key")

  /// J1 — mandatory TradingView entry link (replaces the pre-entry screenshot
  /// upload). Nullable in DB for pre-J1 rows + administrative repairs, but the
  /// Zod create schema REQUIRES it (mirror of the former screenshot rule). The
  /// link is HTTPS-only + tradingview.com host-allowlisted at the Zod edge
  /// (`lib/schemas/tradingview-url`) so it can never become an open-redirect /
  /// XSS / SSRF vector once rendered as a clickable `<a>` to the admin.
  tradingViewEntryUrl String? @map("trading_view_entry_url")

  // ----- V1.5 trading-expert calibration (Steenbarger / Tharp) -----------

  /// Setup quality A/B/C (Steenbarger, *Daily Trading Coach*). Captured at
  /// trade creation. Optional — V1 trades created before V1.5 ship are NULL
  /// and excluded from quality-distribution analytics.
  tradeQuality TradeQuality? @map("trade_quality")

  /// Percentage of account risked on this trade (e.g. 1.50 = 1.5 %).
  /// Tharp gold rule: never risk more than 1-2 % per trade. Optional.
  /// Captured by the member at form-fill time (we don't have account
  /// balance in the schema — V2 candidate). Decimal(4, 2) covers 0.01 %
  /// up to 99.99 % — aligned with the Zod schema upper bound `< 100`.
  /// Code-reviewer #6 (2026-05-09) — was Decimal(5, 2) which allowed
  /// 999.99 vs Zod < 100 mismatch.
  riskPct Decimal? @map("risk_pct") @db.Decimal(4, 2)

  // ----- Post-exit block (filled at close) -----

  exitedAt        DateTime?        @map("exited_at")
  exitPrice       Decimal?         @map("exit_price") @db.Decimal(20, 8)
  outcome         TradeOutcome?
  realizedR       Decimal?         @map("realized_r") @db.Decimal(6, 2)
  realizedRSource RealizedRSource? @map("realized_r_source")
  emotionAfter    String[]         @map("emotion_after")
  /// Multi-select emotion slugs felt DURING the open position, recalled at
  /// close next to `emotionAfter`. Same allowlist as `emotionBefore`/
  /// `emotionAfter` (lib/trading/emotions.ts), capped at 3 by the Zod boundary.
  /// Closes the "avant / pendant / après" emotional axis (master prompt §22).
  /// Plain `text[]` (no DB allowlist) for migration-free slug evolution; trades
  /// closed before this field shipped carry `{}` (migration DEFAULT).
  emotionDuring   String[]         @map("emotion_during")

  /// Tour 10 — factual nature of the exit (see `TradeExitReason`). OPTIONAL,
  /// answered at close next to `outcome`. Pure additive nullable enum: legacy
  /// and unanswered rows stay NULL (null-skip everywhere, CANON — a new
  /// required close field would break the shared-wizard e2e).
  exitReason      TradeExitReason? @map("exit_reason")

  // V1.8 REFLECT — post-outcome bias tags (CFA LESSOR + Steenbarger).
  // Distinct from `emotionAfter` (raw affect): `tags` is a structured
  // post-mortem classification ("loss-aversion", "revenge-trade", etc.).
  // Member self-assigned at close wizard (Q3=A actée 2026-05-13).
  // Allowlist enforced at the Zod boundary (lib/schemas/trade.ts) — DB
  // stays a plain `text[]` to keep migrations free as the slug list
  // evolves (V1.9+ may add `fomo`/`tilt` if member feedback warrants).
  // Capped at 3 tags per trade (Zod max, not DB).
  tags String[] @default([]) @map("tags")

  /// Storage key for the exit screenshot. J1 pivot (capture → lien) : pre-J1
  /// trades keep their stored capture, new trades leave this NULL. Nullable
  /// (legacy rows + administrative repairs).
  screenshotExitKey String? @map("screenshot_exit_key")

  /// J1 — mandatory TradingView exit link (replaces the exit screenshot upload
  /// at close). Nullable in DB for pre-J1 / still-open rows, but the Zod close
  /// schema REQUIRES it. Same host-allowlist hardening as `tradingViewEntryUrl`.
  tradingViewExitUrl String? @map("trading_view_exit_url")

  /// Set when the post-exit block is filled. A trade is "open" iff this is
  /// null — used by /journal queries to split the list visually.
  closedAt DateTime? @map("closed_at")

  // ----- S3 — Vérification & Honnêteté radicale (preuve par la réalité) -----

  /// S3 — provenance of this journal entry. Every pre-S3 trade is implicitly
  /// declarative, hence the `self_declared` default (SQL DEFAULT backfills
  /// existing rows without a table rewrite). `mt5_verified` is set by the S3
  /// reconciliation engine once the trade has been matched against an
  /// `ExtractedPosition` coming from an MT5 history screenshot (vision
  /// pipeline). Posture §2: verification concerns the FACT of the trade
  /// (existence, direction, timing, volume), never its analysis.
  source TradeSource @default(self_declared)

  /// S3 — when the reconciliation engine confirmed this trade against the
  /// member's real MT5 history. Null = never confronted yet.
  verifiedAt DateTime? @map("verified_at")

  /// S3 — outcome of the declarative ↔ reality confrontation. Null = not yet
  /// confronted (legacy rows / no proof uploaded for the period). `mismatch`
  /// rows also materialise a `Discrepancy` for follow-up.
  matchStatus TradeMatchStatus? @map("match_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // J4 — admin annotations attached to this trade. Cascade so a member
  // cleanup wipes its annotations too (RGPD: data minimisation).
  annotations   TradeAnnotation[]
  // S3 — multi-capture attachments (entry/exit/other). The legacy
  // `screenshotEntryKey`/`screenshotExitKey` columns stay untouched
  // (backward compat); new multi-photo flows append here.
  media         TradeMedia[]
  // S3 — discrepancies referencing this trade as the declared side.
  discrepancies Discrepancy[]

  // Indexes — userId-leading because every member-facing query is
  // user-scoped, and the secondary order is the dominant sort key in the UI.
  @@index([userId, enteredAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, closedAt])
  // V1.5 — quality distribution analytics (admin coaching view).
  // Partial-index predicate (`WHERE trade_quality IS NOT NULL`) is added in
  // the migration SQL since Prisma 7 doesn't model it declaratively.
  @@index([userId, tradeQuality])
  @@map("trades")
}

// =============================================================================
// J4 — Admin annotation workflow (SPEC §6.3, §7.8)
// =============================================================================

/// Admin correction attached to a member trade.
///
/// `comment` is markdown-friendly free text (rendered server-side as plain text
/// at J4; markdown rendering ships when we wire react-markdown in J6+). The
/// optional `mediaKey` points to a storage object — at J4 image-only
/// (8 MiB cap, JPEG/PNG/WebP). The Zoom-video upload (500 MiB) is deferred to
/// J4.5 once R2 is wired (see `apps/web/CLAUDE.md` storage section).
///
/// `seenByMemberAt` is set the first time the trade owner opens the trade in
/// /journal/[id] AFTER the annotation was created (bulk `updateMany` per page
/// load). Reading it stays in `lib/annotations/member-service.ts`.
///
/// `adminId` cascades on User delete: V1 has a single admin (Eliot), so admin
/// deletion is a teardown event — preserving orphaned annotations would be
/// dead state. V2 multi-admin should switch to SetNull + nullable adminId.
model TradeAnnotation {
  id String @id @default(cuid())

  tradeId String @map("trade_id")
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  adminId String @map("admin_id")
  admin   User   @relation("AnnotationsAuthored", fields: [adminId], references: [id], onDelete: Cascade)

  comment String @db.Text

  /// Optional coaching axis the admin tags this correction with (J-AI corrections
  /// echo). Nullable + additive — an untagged correction stays null and is simply
  /// ignored by the theming aggregate (`lib/annotations/correction-themes.ts`).
  /// Reuses the existing `TrackingAxis` taxonomy (FR labels in `lib/tracking/axes.ts`)
  /// so admin, member echo and monthly IA pipelines share ONE vocabulary.
  axis TrackingAxis?

  /// Storage key for the optional media attachment.
  /// Format: `annotations/{tradeId}/{nanoid32}.{jpg|png|webp}` (J4) or
  ///         `annotations/{tradeId}/{nanoid32}.{mp4|webm}` (J4.5).
  mediaKey  String?              @map("media_key")
  mediaType AnnotationMediaType? @map("media_type")

  /// Timestamp of the first time the member opened the trade detail page after
  /// this annotation existed. Null = unread.
  seenByMemberAt DateTime? @map("seen_by_member_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Most reads list a trade's annotations newest-first.
  @@index([tradeId, createdAt(sort: Desc)])
  // Powers the unseen-count rollup for the member's journal list.
  @@index([tradeId, seenByMemberAt])
  // Admin "annotations I authored" feed (J6+ analytics).
  @@index([adminId, createdAt(sort: Desc)])
  // J8 perf TIER 2 fix — `lib/weekly-report/loader.ts:loadAnnotationStats`
  // filtre `createdAt: { gte, lte } AND trade.userId = X`. Sans cet index,
  // Postgres seq-scan toute la table (à 1000 membres × 6 mois = potentiel
  // 100k+ rows). Ajout d'un index `(createdAt DESC)` permet un range-scan
  // index-only sur la window puis JOIN PK Trade pour le filtre userId.
  @@index([createdAt(sort: Desc)])
  @@map("trade_annotations")
}

/// V2.1 — Admin private notes about a member (SPEC §7.7 "tes notes
/// privées sur ce membre, pas vu par lui").
///
/// The member NEVER sees these: there is deliberately no member-facing
/// read path. They are listed only through the admin member-detail
/// "Notes admin" tab. `body` is hardened at the Zod boundary
/// (`safeFreeText` + reject bidi/zero-width = Trojan-Source defense,
/// canon Fxmily — these notes are rendered back to the admin and could
/// one day feed an LLM prompt).
///
/// Cascade on BOTH relations (RGPD data minimisation, consistent with
/// the rest of the schema). V1 = solo admin Eliot; V2 multi-admin →
/// consider `authorId` SetNull + nullable so a deleted admin's notes
/// survive (same follow-up noted on `TradeAnnotation`).
model AdminNote {
  id String @id @default(cuid())

  /// The member this note is ABOUT (never the author).
  memberId String @map("member_id")
  member   User   @relation("AdminNotesAbout", fields: [memberId], references: [id], onDelete: Cascade)

  /// The admin who wrote the note.
  authorId String @map("author_id")
  author   User   @relation("AdminNotesAuthored", fields: [authorId], references: [id], onDelete: Cascade)

  body String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // The panel lists a member's notes newest-first.
  @@index([memberId, createdAt(sort: Desc)])
  // Admin "notes I authored" feed (V2 multi-admin analytics).
  @@index([authorId, createdAt(sort: Desc)])
  @@map("admin_notes")
}

// =============================================================================
// V1.2 — Mode Entraînement / Backtest TradingView (SPEC §21)
// =============================================================================

/// Outcome reported on a backtest entry. Deliberately a SEPARATE enum from
/// `TradeOutcome` (same values) — SPEC §21.2 locks "isolation béton, par
/// construction": a training model never references a real-edge type, so a
/// future refactor of `TradeOutcome` can never reach training. The marginal
/// cost (one extra Postgres type) is the explicit trade-off Eliot accepted.
enum TrainingOutcome {
  win
  loss
  break_even
}

/// Media kind for an admin training-correction attachment. SEPARATE enum
/// from `AnnotationMediaType` for the same isolation rationale (§21.2). V1.2
/// ships image-only at the Zod edge; the column accepts `video` so a later
/// video-correction path stays an additive change (mirror J4 → J4.5).
enum TrainingAnnotationMediaType {
  image
  video
}

/// Member backtest entry (SPEC §21). STATISTICALLY ISOLATED from the real
/// edge: NO FK to `Trade`, no shared enum, dedicated read services. A
/// `TrainingTrade` must NEVER surface in `/journal`, the dashboard, scoring,
/// expectancy or the Habit×Trade correlation — the real edge only reflects
/// real risk (§21.5 invariant; anti-leak tests land in J-T4).
///
/// Lighter field set than `Trade` (SPEC §21.2): no emotions / sleep /
/// confidence — backtest affect ≠ real-risk affect (Mark Douglas). The
/// pedagogical core is `lessonLearned` (mandatory). `enteredAt` mirrors
/// `Trade.enteredAt` exactly: a plain `DateTime` UTC instant (NOT `@db.Date`),
/// so backdating is allowed and no civil-day window applies (it is not a
/// calendar-day field, unlike DailyCheckin / HabitLog).
///
/// `userId` cascades on User delete (RGPD data minimisation, schema-wide).
model TrainingTrade {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// S8 — optional parent backtest session ("crée une session de backtest").
  /// SetNull: deleting a session container never destroys the entries logged
  /// inside it. Lives 100% inside the §21.5 training world — `TrainingSession`
  /// has NO link to any real-edge model.
  sessionId       String?          @map("session_id")
  trainingSession TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  /// One of the allowlisted symbols (lib/trading/pairs.ts), uppercase string,
  /// enforced at the Zod edge — mirror of `Trade.pair` (no DB enum).
  pair String

  /// Storage key for the entry-analysis screenshot (the artefact the admin
  /// corrects). Nullable for administrative repairs, but the Zod create
  /// schema requires it — mirror of `Trade.screenshotEntryKey`. Format
  /// `training/{id}/{nanoid32}.{ext}` (lib/storage/keys.ts, wired J-T2).
  entryScreenshotKey String? @map("entry_screenshot_key")

  /// F1 — OPTIONAL TradingView analysis link the member may paste BESIDE the
  /// mandatory screenshot (copier-coller direct: a `/x/` snapshot or `/chart/`
  /// layout URL). Optional at every layer (the screenshot stays mandatory via
  /// Zod). Hardened at the Zod edge like `push-subscription` `endpointSchema`:
  /// https-only + hostname allowlisted to tradingview.com + length cap + reject
  /// Trojan-Source — so a member-pasted link rendered as a clickable `<a>` to
  /// the admin can never become an open-redirect / XSS / SSRF vector. §21.5:
  /// a chart link is process metadata, NEVER a P&L — never read by the real edge.
  tradingViewUrl String? @map("trading_view_url")

  /// Planned reward-to-risk ratio. Mandatory (mirror `Trade.plannedRR`):
  /// defining R:R before is the backtest discipline.
  plannedRR Decimal @map("planned_rr") @db.Decimal(6, 2)

  /// Backtest result. Nullable until filled — mirrors the real open/close
  /// split (`Trade.outcome` / `Trade.realizedR` are nullable).
  outcome TrainingOutcome? @map("outcome")
  resultR Decimal?         @map("result_r") @db.Decimal(6, 2)

  /// `true` = system/plan respected, `false` = not, `null` = N/A. Tri-state,
  /// exact mirror of `Trade.hedgeRespected`.
  systemRespected Boolean? @map("system_respected")

  /// S8 V2 — process-discipline checklist filled WHEN journaling a backtest
  /// (brief §33-2). Each item is a discipline ACT (tri-state true/false/null =
  /// not answered), NEVER a market-analysis judgement and NEVER an affect value.
  /// `emotionalStateNoted` records that the member OBSERVED their state, never
  /// the mood itself — this preserves the §21.2 lock "no emotions in backtest"
  /// (backtest affect ≠ real-risk affect, Mark Douglas) while still capturing
  /// the awareness discipline the brief asks for. Items are generic / method-
  /// agnostic: the app never encodes the Lhedge system (garde-fou §2). Pure
  /// process signals — never read by the real edge (§21.5); the completion rate
  /// feeds only the training-internal stats (computed at render).
  planFollowed         Boolean? @map("plan_followed")
  riskDefinedBefore    Boolean? @map("risk_defined_before")
  emotionalStateNoted  Boolean? @map("emotional_state_noted")
  noImpulsiveDeviation Boolean? @map("no_impulsive_deviation")

  /// Lesson learned — the pedagogical core of a backtest (SPEC §21).
  /// Mandatory free text, hardened at the Zod edge (`safeFreeText` + reject
  /// bidi/zero-width = Trojan-Source canon Fxmily).
  lessonLearned String @map("lesson_learned") @db.Text

  /// User-provided backtest entry timestamp, persisted in UTC. Mirror of
  /// `Trade.enteredAt` (plain DateTime, NOT @db.Date).
  enteredAt DateTime @map("entered_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// Admin training corrections attached to this backtest. Cascade so a
  /// member cleanup wipes its corrections too (RGPD: data minimisation).
  annotations TrainingAnnotation[]

  // userId-leading + enteredAt DESC: every member-facing training query is
  // user-scoped and sorts newest-first (SPEC §21.3).
  @@index([userId, enteredAt(sort: Desc)])
  // S8 — the backtest-session detail joins the entries by `session_id` then
  // sorts them newest-first (`getTrainingSessionWithTrades*`). Index the FK so
  // the now-live join never seq-scans `training_trades` (the other hot FKs are
  // all indexed; this was the only un-indexed one — audit S8 d6).
  @@index([sessionId, enteredAt(sort: Desc)])
  @@map("training_trades")
}

/// Admin correction attached to a member backtest — EXACT mirror of the J4
/// `TradeAnnotation` flow (comment + optional capture + seen tracking) but
/// pointing at `TrainingTrade` instead of `Trade`. The member-facing read +
/// seen-marking land in J-T3 (member-service, mirror
/// `lib/annotations/member-service.ts`).
///
/// `comment` is hardened free text (Trojan-Source canon). `adminId` cascades
/// on User delete: V1 single-admin (Eliot), so admin deletion is a teardown
/// event — V2 multi-admin should switch to SetNull + nullable adminId (same
/// follow-up noted on `TradeAnnotation`).
model TrainingAnnotation {
  id String @id @default(cuid())

  trainingTradeId String        @map("training_trade_id")
  trainingTrade   TrainingTrade @relation(fields: [trainingTradeId], references: [id], onDelete: Cascade)

  adminId String @map("admin_id")
  admin   User   @relation("TrainingAnnotationsAuthored", fields: [adminId], references: [id], onDelete: Cascade)

  comment String @db.Text

  /// Optional coaching axis the admin tags this backtest correction with (J-AI
  /// corrections echo). Nullable + additive — mirror of `TradeAnnotation.axis`,
  /// same `TrackingAxis` taxonomy so trade + training corrections theme together.
  axis TrackingAxis?

  /// Storage key for the optional correction media. Format
  /// `training_annotations/{trainingTradeId}/{nanoid32}.{jpg|png|webp}`.
  mediaKey  String?                      @map("media_key")
  mediaType TrainingAnnotationMediaType? @map("media_type")

  /// First time the member opened the backtest detail after this correction
  /// existed. Null = unread. Mirror of `TradeAnnotation.seenByMemberAt`.
  seenByMemberAt DateTime? @map("seen_by_member_at")

  /// S8 V2 — the member's single reply to this correction (brief §32-4 : « le
  /// membre les voit et peut y répondre »). Closes the admin↔member loop while
  /// staying 100% inside the §21.5 training world (NO FK to any real model).
  /// Hardened free text at the Zod edge (Trojan-Source canon). One reply per
  /// correction — the member edits it in place. `memberRepliedAt` null = no
  /// reply yet; it powers the admin "member replied" surfacing & notification
  /// (`training_reply_received`). Strictly psychology/process — never analysis.
  memberReply     String?   @map("member_reply") @db.Text
  memberRepliedAt DateTime? @map("member_replied_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Most reads list a backtest's corrections newest-first (SPEC §21.3).
  @@index([trainingTradeId, createdAt(sort: Desc)])
  // Powers the unseen-count rollup for the member's training list.
  @@index([trainingTradeId, seenByMemberAt])
  // Admin "corrections I authored" feed.
  @@index([adminId, createdAt(sort: Desc)])
  @@map("training_annotations")
}

/// V1.3 — Débrief Training dédié (SPEC §23). Member-owned WEEKLY recap of the
/// member's BACKTEST practice (SPEC §21). Structurally mirrors `WeeklyReview`
/// (idempotent `(userId, weekStart)` upsert, `weekStart` @db.Date, `submittedAt`
/// bumped on edit) BUT stays inside the §21.5 statistical-isolation boundary:
/// there is NO foreign key to `Trade` / `WeeklyReview` / `BehavioralScore` —
/// only the implicit `userId` link, exactly like `TrainingTrade`.
///
/// The process-stats panel (volume & regularity · system respect · diversity ·
/// lessons & corrections) is computed at RENDER from `TrainingTrade` /
/// `TrainingAnnotation` and NEVER stored — see `lib/training-debrief/stats.ts`.
/// That aggregator NEVER selects `resultR` / `outcome` (posture §23.2: a
/// debrief shows process effort, never backtest P&L, even intra-training).
///
/// The 4 free-text fields are Steenbarger reverse-journaling (2 process
/// strengths + 1 micro-adjustment + 1 transversal lesson), all mandatory and
/// hardened at the Zod edge (`safeFreeText` + reject bidi/zero-width =
/// Trojan-Source canon Fxmily). `userId` cascades on User delete (RGPD §17).
model TrainingDebrief {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Monday of the debriefed week, local Europe/Paris, materialised at the
  /// service layer via `parseLocalDate` (UTC-midnight pin) so Postgres
  /// `@db.Date` truncation never drifts a day (anti-flake invariant PR#96).
  weekStart DateTime @map("week_start") @db.Date

  /// Steenbarger reverse-journaling — process strength #1 (mandatory). NOT
  /// P&L: "j'ai attendu mon setup au lieu de forcer", never "+3R en backtest".
  processStrengthOne String @map("process_strength_one") @db.Text
  /// Process strength #2 (mandatory).
  processStrengthTwo String @map("process_strength_two") @db.Text
  /// One concrete micro-adjustment for next week (mandatory) — small, testable.
  microAdjustment    String @map("micro_adjustment") @db.Text
  /// The transversal lesson abstracted from the week's practice (mandatory).
  transversalLesson  String @map("transversal_lesson") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("training_debriefs")
}

/// Notification queue (J4 enqueue, J9 dispatch).
///
/// At J4 we persist the *intent* of a notification — the actual web-push
/// dispatch worker is in J9. Until then the row stays `pending`. Each kind
/// (`type`) carries its own structured `payload`:
///   annotation_received          → { annotationId, tradeId, adminId, hasMedia }
///   training_annotation_received → { trainingAnnotationId, trainingTradeId, adminId, hasMedia }
///   training_reply_received      → { trainingAnnotationId, trainingTradeId, memberId }
///
/// `scheduledFor` lets us delay a notification (e.g. "remind if not seen
/// after 48h" — SPEC §7.8). Null means "ASAP".
model NotificationQueue {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  payload Json
  status  NotificationStatus @default(pending)

  /// V1.6 — SPEC §18.2 email frequency cap support. `true` for transactional
  /// notifications that MUST always reach the user (auth, invitation, password
  /// reset, RGPD export-ready). `false` (default) for engagement / nudge
  /// notifications — the email fallback caps these at 3 per 24h rolling window
  /// per user to avoid spam-mailing a member with a flaky push subscription.
  /// All V1 NotificationType slugs default to `false` (none are transactional
  /// yet — future auth-push types will set this to `true` at enqueue time).
  isTransactional Boolean @default(false) @map("is_transactional")

  attempts      Int       @default(0)
  scheduledFor  DateTime? @map("scheduled_for")
  dispatchedAt  DateTime? @map("dispatched_at")
  failureReason String?   @map("failure_reason")
  /// J9 — short error code for machine classification of the last failed dispatch.
  /// One of `gone_410` | `payload_too_large_413` | `rate_limited_429` |
  /// `server_5xx` | `timeout` | `network` | `unknown`. Mirrors the
  /// `classifyError(statusCode)` taxonomy in `lib/push/dispatcher.ts`.
  /// `failureReason` keeps the human-readable detail for admin debugging.
  lastErrorCode String?   @map("last_error_code")
  /// J9 — exponential backoff anchor. Set when a retryable failure happens
  /// (5xx, 429, network) — the dispatcher only re-claims rows whose
  /// `nextAttemptAt <= now()`. Null means "claim ASAP" (initial pending or
  /// the explicit `scheduledFor` window has elapsed).
  nextAttemptAt DateTime? @map("next_attempt_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Worker hot-path (J5): pull the next pending row whose schedule has elapsed.
  @@index([status, scheduledFor])
  // J9 dispatcher hot-path: claim rows ready to be sent (status in pending|dispatching
  // AND nextAttemptAt <= now). The partial WHERE clause is added in the migration
  // SQL (Prisma 7 doesn't model partial indexes natively; same pattern as the J5
  // `notification_queue_pending_checkin_dedup` partial unique index). The index is
  // named by Prisma's default (`notification_queue_status_next_attempt_at_idx`);
  // the S8 index migration reconciled a pre-existing name drift (the J9 SQL had
  // hand-named it `pending_dispatch_idx` while the schema declared no `map:`) via
  // a safe `ALTER INDEX … RENAME` that preserves the partial predicate.
  @@index([status, nextAttemptAt])
  // User-scoped admin/debug queries.
  @@index([userId, createdAt(sort: Desc)])
  // V1.6 — partial index `notification_queue_user_recent_non_transactional_idx`
  // is created via the migration SQL only (Prisma 7 doesn't model partial
  // predicates declaratively, same pattern as `notification_queue_pending_checkin_dedup`).
  // NOT declared as `@@index` here to avoid Prisma generating a duplicate
  // full-index without the WHERE predicate (would create two B-tree indexes
  // on the same columns + cause schema drift on next `prisma migrate dev`).
  //
  // RC#4 — two further partial UNIQUE indexes give every nudge kind a DB-level
  // idempotency guarantee (was app-side dedup only). Created in migration
  // 20260629100000_rc4_notification_dedup_mindset_gentle, NOT as `@@unique`
  // (same partial-predicate / drift reason as above) :
  //   * `notification_queue_pending_mindset_dedup`
  //       UNIQUE (user_id, type, payload->>'weekStart') WHERE status='pending'
  //       AND type='mindset_check_ready'
  //   * `notification_queue_pending_gentle_dedup`
  //       UNIQUE (user_id, type, payload->>'discrepancyId') WHERE status='pending'
  //       AND type='verification_gentle_reminder'
  // Enforced by enqueue.ts P2002 no-op folds + their unit tests.
  @@map("notification_queue")
}

// =============================================================================
// J9 — Web Push notifications (SPEC §7.9, §16, §18.2)
// =============================================================================

/// One row per (user, browser/device) push subscription. The browser hands us
/// `{ endpoint, keys: { p256dh, auth } }` after `pushManager.subscribe()`; we
/// persist them and use `web-push` lib to send messages later.
///
/// Why a unique on `(userId, endpoint)`: a member may install Fxmily on
/// multiple devices (iPhone home screen + Android + desktop Chrome), each
/// gets its own endpoint. Re-subscribing on the same device returns the same
/// endpoint → upsert preserves continuity instead of stacking rows.
///
/// `userAgent` is captured at subscribe time for admin debugging only — never
/// shown to other users, never logged in plaintext past 512 chars.
///
/// `lastSeenAt` is bumped each time we successfully dispatch (or when the
/// browser hits `pushsubscriptionchange`). A nightly cleanup cron deletes
/// rows where `lastSeenAt < now - 90j` (RGPD data minimization, SPEC §16).
///
/// On 410 Gone from the push service the dispatcher MUST delete the row
/// immediately (SPEC §16 — "subscription révoquée 410 Gone → DELETE immédiat").
model PushSubscription {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// The push service URL (FCM, APNs, Mozilla autopush). Acts as the unique
  /// identifier across re-subscriptions for the same device.
  endpoint String @db.Text

  /// ECDH P-256 public key (base64url, ~88 chars). The `web-push` lib uses it
  /// to derive the encryption key for the message payload.
  p256dhKey String @map("p256dh_key")

  /// 16-byte random secret (base64url, ~22 chars) shared with the browser.
  /// Used as part of the AES-128-GCM encryption (RFC 8291).
  authKey String @map("auth_key")

  /// User-Agent string captured at subscribe time (truncated to 512 chars).
  /// Admin-only context — never returned in member-facing endpoints (endpoint
  /// enumeration risk per SPEC §16).
  userAgent String? @map("user_agent") @db.Text

  /// Bumped on successful dispatch + at `pushsubscriptionchange` re-register.
  /// Used by the 90-day cleanup cron + admin "is this device still alive?".
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([lastSeenAt])
  @@map("push_subscriptions")
}

/// Per-category notification opt-in/opt-out preferences. Default is `enabled = true`
/// — a missing row means "consent default-on" (member toggles to opt out, never to opt in).
///
/// PK is composite `(userId, type)`: each member has at most one row per
/// `NotificationType`. The dispatcher reads via `getEffectivePreferences(userId)`
/// which materializes the full set including default-true rows.
///
/// Toggle audit (`push.preference.toggled`) carries `{type, enabled}` metadata
/// — never the underlying notification content (RGPD data minimization).
model NotificationPreference {
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  enabled   Boolean          @default(true)
  updatedAt DateTime         @updatedAt @map("updated_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@id([userId, type])
  @@map("notification_preferences")
}

// =============================================================================
// J5 — Daily check-ins (SPEC §6.4, §7.4)
// =============================================================================

/// Two-slot daily check-in: morning + evening. SPEC §6.4 keeps a single table
/// shape with `slot` discriminating which fields are populated; the Zod schemas
/// (`lib/schemas/checkin.ts`) and the wizards enforce the per-slot field set.
///
/// `date` is a Postgres `DATE` (no time component) anchored to the member's
/// local-day (Europe/Paris by default — SPEC §6.1). The unique index on
/// (userId, date, slot) prevents duplicates: filling the morning twice updates
/// the existing row instead of stacking entries. The DB stores the user's
/// local date as a calendar day; conversions live in `lib/checkin/timezone.ts`.
///
/// All slot-specific fields are nullable so the same table can serve both
/// shapes. The wizards never persist nulls for required fields — the DB shape
/// is permissive on purpose so a future "I forgot to log my mood" partial fill
/// can still write something useful.
///
/// Streak counter: `lib/checkin/streak.ts` reads the (date, slot) tuples and
/// counts consecutive days with at least one check-in (morning OR evening). The
/// streak does NOT require both slots — SPEC §7.4 mentions a soft engagement
/// score driven by completion rate, not strict morning+evening pairing.
model DailyCheckin {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Local-date the check-in is for (Europe/Paris by default, see User.timezone).
  /// `@db.Date` keeps a calendar-day stable across DST and avoids timezone math
  /// when grouping for streaks / weekly reports.
  date DateTime    @db.Date
  slot CheckinSlot

  // ----- Morning fields (mostly nullable on the DB side, required by Zod) ----

  /// Hours of sleep last night (Decimal lets us record half-hours).
  sleepHours              Decimal? @map("sleep_hours") @db.Decimal(4, 2)
  /// Subjective sleep quality 1–10.
  sleepQuality            Int?     @map("sleep_quality")
  /// Did the member follow their personal morning routine? Tri-state: true
  /// (done), false (skipped), null (slot-N/A or unanswered).
  morningRoutineCompleted Boolean? @map("morning_routine_completed")
  /// Meditation minutes (0 = "didn't meditate"). Capped at 240.
  meditationMin           Int?     @map("meditation_min")
  /// Sport type label (free-text, FR — e.g. "course", "muscu", "yoga").
  sportType               String?  @map("sport_type")
  sportDurationMin        Int?     @map("sport_duration_min")
  /// One-line intention for the day, optional. Capped at 200 chars by Zod.
  intention               String?
  /// Did the member do their market analysis before the session? Pure
  /// pre-session discipline signal — declarative binary, NO market content
  /// (SPEC §2: we track that the prep happened, never the prep itself).
  /// Tri-state: true (done), false (skipped), null (unanswered/legacy row).
  marketAnalysisDone      Boolean? @map("market_analysis_done")

  // ----- Evening fields ----------------------------------------------------

  /// Did the member respect their trading plan today?
  planRespectedToday  Boolean? @map("plan_respected_today")
  /// SPEC §28/§22 — did the member KEEP the intention they set this morning?
  /// Answered in the EVENING (the morning sets `intention`, the evening closes
  /// the loop), sibling of `planRespectedToday`. Tri-state: true (kept), false
  /// (not kept — a calm effort signal, NEVER a punitive verdict §31.2), null
  /// (no morning intention that day / unanswered / legacy row). We score THAT
  /// the intention was kept, never the intention CONTENT (SPEC §2). Pure
  /// additive nullable Boolean, mirror of `marketAnalysisDone`/`processComplete`
  /// — the existing discipline weights are NEVER rebalanced. The S12 morning
  /// recall stays a verdict-free echo; THIS is a distinct evening self-report.
  intentionKept       Boolean? @map("intention_kept")
  /// Did the member respect their hedge plan? Null = N/A (no hedge today).
  hedgeRespectedToday Boolean? @map("hedge_respected_today")
  /// Estimated caffeine intake in mL, capped at 2000.
  caffeineMl          Int?     @map("caffeine_ml")
  /// Water intake in litres (Decimal allows half-litres).
  waterLiters         Decimal? @map("water_liters") @db.Decimal(4, 2)
  /// Average stress 1–10 across the day (evening retrospective).
  stressScore         Int?     @map("stress_score")
  /// Up to 3 gratitude items, capped at 200 chars each by Zod.
  gratitudeItems      String[] @map("gratitude_items")
  /// SPEC §28/§22 — evening "bilan" self-report: did the member study / make
  /// progress in Eliot's COURSE (la formation) today? A course-adherence ACT
  /// only — SPEC §2 posture: we track THAT the member studied, NEVER the
  /// content of what was studied (no curriculum body, no progress %, no edge).
  /// Distinct from the §21 Entraînement/TrainingTrade module (backtest); this
  /// is a plain habit-signal boolean on the check-in, no training-module link.
  /// Tri-state: true (studied), false (skipped), null (slot-N/A / unanswered /
  /// legacy row) — nullable & additive, mirroring `marketAnalysisDone`.
  formationFollowed   Boolean? @map("formation_followed")

  // ----- Both slots --------------------------------------------------------

  /// Mood score 1–10. Captured both morning ("how do I feel right now?") and
  /// evening ("how did I feel today on average?"). Two distinct snapshots —
  /// retained in lib/scoring (J6) for emotional-stability variance.
  moodScore   Int?     @map("mood_score")
  /// Tag slugs (lib/checkin/emotions.ts mirrors lib/trading/emotions.ts).
  /// Used both morning ("how do I feel?") and evening ("dominant emotions").
  emotionTags String[] @map("emotion_tags")
  /// Free-form journal entry (max 4000 chars by Zod).
  journalNote String?  @map("journal_note") @db.Text

  // ----- Rattrapage / backfill (F7) ----------------------------------------

  /// F7 — member's free-text reason when this row was filled for a PAST local
  /// day (a "rattrapage"). Mirror of `Discrepancy.memberReason` exactly: pure
  /// additive nullable `@db.Text`, safeFreeText + crisis routing at the Zod
  /// boundary. NULL for same-day check-ins (no justification asked — filling
  /// today is the norm, only late fills are "exceptionnel", brief §F7). The
  /// deterministic repetition signal (§33.2) and the J2 local AI worker read
  /// THIS field; we store the ACT of justifying, never a market claim (§2).
  lateJustification String?   @map("late_justification") @db.Text
  /// F7 — the instant a late (past-day) fill happened; NULL when the row was
  /// filled on its own local day. Mirror of `Discrepancy.memberReasonAt`. Lets
  /// the tracking page + admin panel distinguish an on-time entry from a
  /// rattrapage without re-deriving it from `date` vs `submittedAt` (which
  /// drift across edits). Completion metadata only (§21.5), never P&L.
  backfilledAt      DateTime? @map("backfilled_at")

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Idempotency: at most one row per (user, day, slot). The Zod-driven Server
  // Action upserts on this composite key.
  @@unique([userId, date, slot])
  // Streak / dashboard queries: scan the user's most recent days.
  @@index([userId, date(sort: Desc)])
  // Weekly report aggregation (J8) — fetch a 7-day window in date order.
  @@index([userId, slot, date(sort: Desc)])
  @@map("daily_checkins")
}

// =============================================================================
// J6 — Behavioral score snapshots (SPEC §6.10, §7.5, §7.11)
// =============================================================================

/// Per-user, per-day cached snapshot of the four deterministic behavioral
/// scores (SPEC §7.11) — discipline, emotional stability, consistency,
/// engagement. Recomputed nightly by `POST /api/cron/recompute-scores` for
/// `date = yesterday_local` (Europe/Paris V1) and on-demand from Server
/// Actions that meaningfully invalidate a member's data (close trade, submit
/// check-in) via `revalidateTag('user:scores:'+userId)`.
///
/// Why a snapshot table (vs computing live on every dashboard render):
/// 1. Deterministic guarantees — formulas in `lib/scoring/*.ts` are pure but
///    they touch up to 60 days of trades + 30 days of check-ins per call.
///    Caching a daily snapshot pins the dashboard read to a single indexed row.
/// 2. Trend rendering — a 30-day score trend line needs historical points; we
///    don't backfill on the fly.
/// 3. Data-minimisation friendly — RGPD purge cascades cleanly on User delete.
///
/// Why scores are nullable (`Int?`) instead of `0`:
/// `null` carries the explicit "insufficient_data" semantic — a member with
/// zero trades in the window has *no* consistency score; rendering `0/100`
/// would lie. The `components` JSON carries the per-dimension `status` and
/// `reason` (`no_trades` | `no_checkins` | `window_short`) so the UI can
/// render the disclaimer without re-running the scoring layer.
///
/// `components` shape (see `lib/scoring/types.ts` for canonical types):
/// {
///   discipline:           { score, status, reason?, parts: { planRespect, hedgeRespect, eveningPlan, intentionFilled, routineCompleted } },
///   emotionalStability:   { score, status, reason?, parts: { moodVariance, stressMedian, negativeEmotionRate, recoveryAfterLoss } },
///   consistency:          { score, status, reason?, parts: { expectancyR, profitFactor, drawdownControl, lossStreakControl, sessionDispersion } },
///   engagement:           { score, status, reason?, parts: { checkinFillRate, dualSlotRate, streakNormalized, journalDepthRate } }
/// }
///
/// `sampleSize` shape:
/// { trades: { closed, computed, estimated, sufficient }, checkins: { days, dualSlot, sufficient }, windowDays }
model BehavioralScore {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Local-day anchor in user.timezone (Europe/Paris V1). `@db.Date` is stable
  /// across DST and matches the `DailyCheckin.date` convention exactly.
  date DateTime @db.Date

  /// 0–100 each, NULL when the dimension's `status='insufficient_data'`.
  /// Per-dimension reason lives in `components[dim].reason`.
  disciplineScore         Int? @map("discipline_score")
  emotionalStabilityScore Int? @map("emotional_stability_score")
  consistencyScore        Int? @map("consistency_score")
  engagementScore         Int? @map("engagement_score")

  /// Per-dimension breakdown for UI transparency ("why is my score X?").
  /// Persisted as a typed JSON blob; `lib/scoring/types.ts` documents the shape.
  components Json

  /// Sample-size guards per dimension + raw counters, so the UI can render the
  /// disclaimer ("28/30 jours, 12 trades clôturés") without re-running.
  sampleSize Json @map("sample_size")

  /// Window used for this snapshot. 30 by default (Mark Douglas habit window),
  /// configurable for future experimentation without a migration.
  windowDays Int @default(30) @map("window_days")

  computedAt DateTime @default(now()) @map("computed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Idempotent recompute: 1 snapshot per (user, day). Cron + Server Action
  // upsert on this key.
  @@unique([userId, date])
  // Dashboard read (today + 30-day trend), index covers ORDER BY date DESC.
  @@index([userId, date(sort: Desc)])
  @@map("behavioral_scores")
}

// =============================================================================
// J7 - Module Mark Douglas (SPEC §6.5, §6.6, §7.6, §18.2)
// =============================================================================

/// Educational psychology card surfaced in /library and pushed contextually.
/// SPEC §18.2 fair use: quote ≤ 30 words + quoteSourceChapter required.
/// 	riggerRules discriminated-union JSON (lib/triggers/types.ts). Null = library-only.
/// hatClass: white (7d cooldown) | black (14d cooldown). Yu-kai Chou Octalysis.
model MarkDouglasCard {
  id                 String          @id @default(cuid())
  slug               String          @unique
  title              String
  category           DouglasCategory
  /// Direct quote ≤ 30 words (Zod-enforced) - fair use FR L122-5.
  quote              String
  /// Source attribution e.g. "Trading in the Zone, ch.7" (§18.2 compliance).
  quoteSourceChapter String          @map("quote_source_chapter")
  /// 200-400 word FR paraphrase, markdown via react-markdown + rehype-sanitize.
  /// Sanitized via lib/text/safe.ts (NFC + bidi/zero-width strip) at write.
  paraphrase         String          @db.Text
  /// [{ id, label, description }] - 1 to 3 actionable exercises.
  exercises          Json
  /// Discriminated-union trigger rule. Null = no contextual push.
  triggerRules       Json?           @map("trigger_rules")
  /// Yu-kai Chou Octalysis: "white" (default) | "black".
  hatClass           String          @default("white") @map("hat_class")
  /// 1-10. Higher = pushed first when multiple cards match.
  priority           Int             @default(5)
  /// Drafts invisible to members until admin publishes.
  published          Boolean         @default(false)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  deliveries MarkDouglasDelivery[]
  favorites  MarkDouglasFavorite[]

  @@index([published, priority(sort: Desc)])
  @@index([category, published])
  @@map("mark_douglas_cards")
}

/// Record of a card pushed to a member.
/// 	riggeredOn (@db.Date local-day) + (userId, cardId) = idempotency.
/// 7d/14d hatClass cooldown enforced application-side via lib/triggers/cooldown.
model MarkDouglasDelivery {
  id              String          @id @default(cuid())
  userId          String          @map("user_id")
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId          String          @map("card_id")
  card            MarkDouglasCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  /// Human FR label. Example: "3 trades perdants consécutifs sur 24h".
  triggeredBy     String          @map("triggered_by")
  /// Structured snapshot for audit + replay. Never PII.
  triggerSnapshot Json            @map("trigger_snapshot")
  /// Local-day anchor (matches DailyCheckin.date convention).
  triggeredOn     DateTime        @map("triggered_on") @db.Date
  /// S3 — optional provenance link when this delivery was caused by a
  /// repetition `Alert` (S3 → S5 coaching junction). SetNull keeps the
  /// delivery history if the alert row is later purged. Null = delivery
  /// triggered by the classic J7 evaluators, not by the constancy engine.
  sourceAlertId   String?         @map("source_alert_id")
  sourceAlert     Alert?          @relation(fields: [sourceAlertId], references: [id], onDelete: SetNull)
  seenAt          DateTime?       @map("seen_at")
  dismissedAt     DateTime?       @map("dismissed_at")
  helpful         Boolean?
  createdAt       DateTime        @default(now()) @map("created_at")

  @@unique([userId, cardId, triggeredOn])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, seenAt])
  @@index([userId, cardId, createdAt(sort: Desc)])
  @@map("mark_douglas_deliveries")
}

/// User-curated favorite (manual star on a card).
model MarkDouglasFavorite {
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId    String          @map("card_id")
  card      MarkDouglasCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")

  @@id([userId, cardId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("mark_douglas_favorites")
}

/// J8 — Weekly AI report generated by Claude Sonnet 4.6 + dispatched by email
/// to admin (`eliot@fxmilyapp.com` V1, `fxeliott@fxmilyapp.com` post J10).
///
/// Cron: dimanche 21:00 UTC (`0 21 * * 0`). For each `status='active'` member,
/// a 7-day snapshot is built (trades + check-ins + scores + deliveries +
/// favorites + corrections) and sent to Claude with the cached system prompt
/// (1h ephemeral) + the per-member user prompt (non-cached). Output is parsed
/// via Zod (`weeklyReportOutputSchema`) and persisted here.
///
/// Idempotency: `(userId, weekStart)` unique → re-runs the same week are no-op.
/// Data minimization (RGPD): no PII in the prompt — only `userId` UUID +
/// counters + redacted journalNote (safeFreeText NFC + bidi/zero-width strip).
model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime @map("week_start") @db.Date
  weekEnd     DateTime @map("week_end") @db.Date
  generatedAt DateTime @default(now()) @map("generated_at")

  // Output Claude (Zod-validated before write).
  summary         String @db.Text
  risks           Json
  recommendations Json
  patterns        Json

  // Cost tracking + observability (cf. SPEC §16 ~5€/mois target).
  claudeModel       String  @map("claude_model")
  inputTokens       Int     @map("input_tokens")
  outputTokens      Int     @map("output_tokens")
  cacheReadTokens   Int     @default(0) @map("cache_read_tokens")
  cacheCreateTokens Int     @default(0) @map("cache_create_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking).
  costEur           Decimal @map("cost_eur") @db.Decimal(10, 6)

  // Email dispatch state (Resend).
  sentToAdminAt    DateTime? @map("sent_to_admin_at")
  sentToAdminEmail String?   @map("sent_to_admin_email")
  emailMessageId   String?   @map("email_message_id")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@index([generatedAt(sort: Desc)])
  @@map("weekly_reports")
}

/// V1.4 — Débrief Mensuel IA dédié (SPEC §25, jalon #2 de la séquence
/// §21.6). Structural IA-pipeline sibling of `WeeklyReport` (cost-tracking,
/// JSON output, idempotent upsert) BUT member-facing + dual-section and
/// inside the §21.5 statistical-isolation boundary:
///
///   - NO foreign key to `Trade` / `WeeklyReport` / `TrainingTrade` /
///     `BehavioralScore` — only the implicit `userId` link (mirror
///     `TrainingDebrief` / `TrainingTrade`). The ≤4 `WeeklyReport` rows of
///     the civil month are read as INPUT context by the pure aggregator,
///     NEVER linked as an FK.
///   - `summaryReal` (legitimate REAL-trade P&L coaching) and
///     `summaryTraining` (§21.5 firewall: count/recurrence ONLY, never a
///     backtest `resultR`/`outcome`/`plannedRR`) are STRICTLY separate
///     columns so the isolation boundary is visible in the schema itself.
///   - The debrief feeds NOTHING back into the real edge (no score, no
///     engagement, no trigger — canon §23).
///
/// `monthStart` = local Europe/Paris 1st-of-month, materialised at the
/// service layer via `parseLocalDate` (UTC-midnight pin, anti-flake PR#96).
/// `monthEnd` is ALWAYS service-computed (SSOT, anti-tamper) — NEVER
/// accepted from a client. Idempotency `(userId, monthStart)` upsert.
/// `userId` cascades on User delete (RGPD §17). Generation is batch-local
/// Claude Max (SPEC §25.2 — never the paid API); cost tracking kept for
/// audit/traceability even though the marginal cost is 0€.
model MonthlyDebrief {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  monthStart  DateTime @map("month_start") @db.Date
  /// Service-computed last calendar day of the civil month (SSOT,
  /// anti-tamper — never received from the client, SPEC §25.3/§25.7).
  monthEnd    DateTime @map("month_end") @db.Date
  generatedAt DateTime @default(now()) @map("generated_at")

  // Output Claude (Zod `monthlyDebriefOutputSchema`-validated before write).
  // Dual-section by design (§21.5 boundary visible in the data model).
  progressionNarrative String @map("progression_narrative") @db.Text
  summaryReal          String @map("summary_real") @db.Text
  summaryTraining      String @map("summary_training") @db.Text
  risks                Json
  recommendations      Json
  patterns             Json

  // Cost tracking + observability (mirror WeeklyReport; batch-local Claude
  // Max ⇒ 0€ marginal but kept for traceability/audit, SPEC §25.3).
  claudeModel       String  @map("claude_model")
  inputTokens       Int     @map("input_tokens")
  outputTokens      Int     @map("output_tokens")
  cacheReadTokens   Int     @default(0) @map("cache_read_tokens")
  cacheCreateTokens Int     @default(0) @map("cache_create_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking).
  costEur           Decimal @map("cost_eur") @db.Decimal(10, 6)

  // Member dispatch state (push + Resend). NO admin dispatch field by
  // design — Eliot reads /admin only, no monthly admin email (SPEC §25.2).
  sentToMemberAt    DateTime? @map("sent_to_member_at")
  sentToMemberEmail String?   @map("sent_to_member_email")
  pushEnqueuedAt    DateTime? @map("push_enqueued_at")
  /// First time the member opened this debrief on /debrief-mensuel (S6 audit
  /// enrichment). Drives the calm dashboard "ton débrief est prêt" nudge: the
  /// widget surfaces only the latest UNREAD debrief and goes quiet once read
  /// (anti-Black-Hat §25.2 — acknowledge, never nag). Mirror of
  /// MarkDouglasDelivery.seenAt + the calendar aiDisclosureShownAt stamp.
  seenAt            DateTime? @map("seen_at")

  @@unique([userId, monthStart])
  @@index([userId, monthStart(sort: Desc)])
  @@map("monthly_debriefs")
}

/// V1.5 — QCM athlète / auto-évaluation mindset hebdomadaire (SPEC §27,
/// jalon #3 de la séquence §21.6). Member-owned WEEKLY mindset self-check,
/// 100% DETERMINISTIC — zero AI, zero API, zero pipeline (mirror of the
/// deterministic check-in surface, NOT of the Claude debrief pipeline).
///
///   - 0-FK statistical isolation BY CONSTRUCTION (§21.5/§27.7): the ONLY
///     relation is the implicit `userId` link (mirror `TrainingDebrief` /
///     `MonthlyDebrief` / `TrainingTrade`). NO foreign key to `Trade` /
///     `WeeklyReport` / `TrainingTrade` / `BehavioralScore`. A mindset row
///     can never reference a real-edge object, so it can never leak into /
///     be fed by the real track-record / score / expectancy / engagement /
///     trigger. The isolation is enforced by the schema shape itself.
///   - This entity feeds NOTHING back into the real edge (no
///     `BehavioralScore`, no engagement, no trigger — canon §23/§25/§27.7).
///
/// The questionnaire instrument is a FROZEN, code-VERSIONED Likert
/// instrument (`lib/mindset/instrument.ts`) — `instrumentVersion` pins the
/// exact item set a submission was answered against, guaranteeing
/// longitudinal validity even when the instrument is later revised.
/// `responses` is the raw Likert payload (item↔version validated at the Zod
/// edge). The mindset profile (dimensions, trends) is ALWAYS computed at
/// render from `responses` + the versioned instrument, NEVER stored —
/// derived data has no column (anti-drift, single source of truth).
///
/// `weekStart` = Monday of the assessed week, local Europe/Paris,
/// materialised at the service layer via `parseLocalDate` (UTC-midnight
/// pin) so Postgres `@db.Date` truncation never drifts a day (anti-flake
/// invariant PR#96). Idempotency `(userId, weekStart)` upsert — a re-submit
/// of the same week updates the same row (`updatedAt @updatedAt` covers the
/// re-submit; no dedicated `submittedAt`). No dispatch column — the
/// `notification.enqueued` audit row is the dispatch source of truth (canon
/// `TrainingDebrief`). `userId` cascades on User delete (RGPD §17).
model MindsetCheck {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart DateTime @map("week_start") @db.Date

  instrumentVersion Int  @map("instrument_version")
  responses         Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("mindset_checks")
}

// =============================================================================
// V1.8 REFLECT — member-facing reflection module
// =============================================================================
//
// Two separate models intentionally:
//   - `WeeklyReview` = member-owned Sunday recap (5 textareas, max 4000 chars
//     each). Distinct from `WeeklyReport` above which is admin-facing IA digest.
//     Idempotency: `(userId, weekStart)` unique → re-submitting same week upserts.
//   - `ReflectionEntry` = CBT Ellis ABC + Disputation, daily granularity.
//     Multiple entries per day allowed (a member may reflect on several events).
//
// Both models:
//   - Cascade-delete with the user (RGPD §17 data-minimisation).
//   - Free-text fields are sanitised at the Zod boundary via `safeFreeText`
//     (NFC + bidi/zero-width strip) — same Trojan-Source hardening as J5/J8.
//   - Crisis routing wire (V1.7.1 carbone) runs at submit-action level on
//     the concatenated corpus BEFORE persist. PII-free audit slugs only.
//   - No PII stored beyond the userId FK (no email, no display name).

/// V1.8 — Member-facing weekly recap wizard (Sunday ritual extension).
///
/// Posture (Mark Douglas): introspection on PROCESS, not outcomes. The five
/// fields are intentionally process-oriented ("biggest mistake" → action, not
/// P&L; "best practice" → Steenbarger reverse-journaling 2025 strengths-based).
///
/// `bestPractice` is optional to lower the wizard friction (member can skip
/// when nothing strengths-based comes to mind). All four other fields are
/// mandatory: empty submission is rejected at the Zod boundary.
///
/// Idempotency: `(userId, weekStart)` unique → a member who re-opens the
/// wizard for an already-submitted week upserts; the service layer is
/// responsible for surfacing "already submitted, you can edit" UX (PR2).
model WeeklyReview {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime @map("week_start") @db.Date
  weekEnd   DateTime @map("week_end") @db.Date

  /// Mandatory — process win (e.g. "Closed at TP per plan despite tempting
  /// trail"). NOT P&L, NOT "I made +5R". Member is nudged via wizard copy.
  biggestWin     String  @map("biggest_win") @db.Text
  /// Mandatory — process mistake (e.g. "Skipped pre-trade checklist on Tuesday
  /// London open"). NOT "I lost on EURUSD". Process > outcome.
  biggestMistake String  @map("biggest_mistake") @db.Text
  /// Optional — Steenbarger 2025 reverse-journaling. "What worked AND how
  /// you did it" before fix-the-flaws. Skippable to lower wizard friction.
  bestPractice   String? @map("best_practice") @db.Text
  /// Mandatory — the lesson abstracted from biggestMistake.
  lessonLearned  String  @map("lesson_learned") @db.Text
  /// Mandatory — concrete focus for the upcoming week (one-liner action).
  nextWeekFocus  String  @map("next_week_focus") @db.Text

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@map("weekly_reviews")
}

/// V1.8 — Ellis ABC + Disputation cognitive-behavioural reflection.
///
/// **Clinical disclaimer enforced UI-side** (PR2 wizard banner):
///   "inspired by Ellis ABC, adapted for trading — not clinically validated
///   for trader population".
///
/// Granularity: one row per reflection event (a member may write 0..N entries
/// per day — no `@@unique([userId, date])` constraint). The `date` field is
/// the introspective date, not the create-time (member can backfill yesterday
/// without retroactive timestamps).
///
/// All four columns are mandatory — Ellis ABCD is a complete frame; allowing
/// partial entries dilutes the cognitive-restructuring intent.
model ReflectionEntry {
  id     String   @id @default(cuid())
  userId String   @map("user_id")
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local civil date (no time component). The member picks this; the wizard
  /// pre-fills today (Europe/Paris) but allows backfill within a window.
  date   DateTime @db.Date

  /// A — Activating event (factual trigger). 10–2000 chars.
  triggerEvent String @map("trigger_event") @db.Text
  /// B — Automatic belief (the thought that fired). 10–2000 chars.
  beliefAuto   String @map("belief_auto") @db.Text
  /// C — Consequence (emotion + behaviour observed). 10–2000 chars.
  consequence  String @db.Text
  /// D — Disputation / reframe (alternative belief). 10–2000 chars.
  disputation  String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, date(sort: Desc)])
  @@map("reflection_entries")
}

/// V2.0 — TRACK module habit logging (master plan A2–A5 must-have features).
///
/// One row per `(userId, date, kind)` — upsert idempotency on retries.
/// The structured `value` payload is kind-specific and validated at the
/// Zod boundary in `lib/schemas/habit-log.ts`. We keep it as `Json` rather
/// than splitting into typed columns because :
///   - Each kind has its own value shape (durationMin for sleep, mealsCount
///     for nutrition, cups + lastDrinkAtUtc for caffeine, etc.).
///   - Sparse-typed columns would balloon the row width and waste storage.
///   - Posture Mark Douglas : we'd rather extend kinds (HealthKit auto-imports,
///     new wearables) without forcing a schema migration each time.
///
/// `notes` is optional free-text — bounded by Zod (500 chars) so the LLM
/// digest pipeline (master plan D-features) has a predictable budget.
model HabitLog {
  id     String    @id @default(cuid())
  userId String    @map("user_id")
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Local civil date (no time component). Anchors the unique constraint
  /// + the daily aggregation queries.
  date   DateTime  @db.Date
  kind   HabitKind

  /// Kind-specific structured payload — see lib/schemas/habit-log.ts.
  value Json
  /// Optional free-text caveat ("manqué la sieste à cause d'une réunion").
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date, kind])
  @@index([userId, date(sort: Desc)])
  @@index([userId, kind, date(sort: Desc)])
  @@map("habit_logs")
}

// =============================================================================
// V2.3 — Pre-trade circuit breaker (Session BB, ADR-003)
// =============================================================================
//
// Mark Douglas anti-FOMO + Gollwitzer if-then implementation intentions
// (meta-analysis Gollwitzer-Sheeran 2006: d=0.65, 94 studies, n=8461,
// CI 95% [0.6, 0.7] — *Advances in Experimental Social Psychology* vol.38,
// updates Sheeran 2024 ERSP 642 tests + Gollwitzer-Sheeran 2025 Annu. Rev.
// Psychol. 76:303-328). See docs/decisions/ADR-003-pre-trade-circuit-breaker.md
// for the full mapping vs Mark Douglas's 4 primary trading fears (Trading
// in the Zone, 2000).
//
// 4 questions one-tap (~30s) before each trade entry:
//   reasonToTrade      : edge / fomo / revenge / boredom (PreTradeReason)
//   emotionLabel       : calme / excite / frustre / anxieux (PreTradeEmotion)
//   planAlignment      : does this trade respect the documented plan?
//   stopLossPredefined : is the stop-loss defined BEFORE entry?
//
// Statistical scope: REAL edge surface (NOT §21.5 training).
// Free-text fields: NONE → safeFreeText NOT needed, no crisis/injection
// surface, no EU AI Act 50(1) banner needed (zero AI).
//
// Optional auto-link via service-layer `linkRecentCheckToTrade(userId,
// tradeId, windowMin=15)` — a Trade created within 15min after a check
// sets `linkedTradeId` (P2002-safe via WHERE linkedTradeId IS NULL).
// String only (no FK constraint): if the linked Trade is later deleted,
// the linkedTradeId becomes a dangling pointer — gracefully handled via
// leftJoin null in service-layer reads. Trade deletion ≠ check deletion.
// =============================================================================

/// V2.3 — Pre-trade circuit breaker (Mark Douglas anti-FOMO + Gollwitzer).
/// One row per (member, pre-trade self-assessment). Cascade-delete with the
/// user (RGPD §17). See enum docs + ADR-003 for the evidence base.
model PreTradeCheck {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  /// Why the member is about to enter the trade. 4 options Mark Douglas + Steenbarger.
  reasonToTrade PreTradeReason @map("reason_to_trade")

  /// Affective state at the moment of decision. Russell-Weiss-Mendelsohn 1989 2x2.
  emotionLabel PreTradeEmotion @map("emotion_label")

  /// Does this trade respect the member's documented plan? Yes/No.
  planAlignment Boolean @map("plan_alignment")

  /// Is the stop-loss defined BEFORE entry? Mark Douglas "accepting risk" ch.8.
  stopLossPredefined Boolean @map("stop_loss_predefined")

  /// Optional auto-link to a Trade created within 15min after this check.
  /// String only (no FK constraint): a deleted Trade leaves the linkedTradeId
  /// dangling rather than nulling out the check (graceful via leftJoin null
  /// in service-layer reads). Set via linkRecentCheckToTrade window 15min,
  /// P2002-safe via WHERE linkedTradeId IS NULL predicate in the UPDATE.
  linkedTradeId String? @map("linked_trade_id")

  @@index([userId, createdAt(sort: Desc)])
  @@map("pre_trade_checks")
}

// =============================================================================
// T-RECORD — Public-facing Eliott + Fxmily trade showcase (T0 2026-05-21).
// Décision : table dédiée séparée du Journal membre (table `trades`). Les
// trades public-facing appartiennent à Eliott (formateur), pas aux membres
// — surface RGPD distincte, schema sur mesure pour la vitrine publique :
// segments HISTORICAL/LIVE, partials, BE, tags news, screenshot R2.
// Pas de relation User : Eliott seul écrit, monovendeur.
//
// 🚨 DEPRECATED 2026-05-25 — Track Record split to standalone repo.
// These two models (PublicTrade + PublicTradePartial) and their enums
// (PublicTradeSegment + PublicTradeStatus) are still declared so Prisma
// stays in sync with the prod Hetzner DB tables, but no application code
// in this monorepo touches them anymore. The CRUD + vitrine live in
// <https://github.com/fxeliott/trackrecord-fxmily> (Hono Worker + Neon).
//
// To drop the tables from this DB, follow `docs/runbook-hetzner-deploy.md`
// §21 (T5 rollback recipe) — pg_dump + `DROP TABLE public_trade_partials,
// public_trades` + `DROP TYPE "PublicTradeSegment", "PublicTradeStatus"`
// (order matters: tables first, then types). Then remove the models below
// + run `prisma migrate dev --name v1_13_drop_public_trades`.
// =============================================================================

/// @deprecated 2026-05-25 — moved to trackrecord-fxmily standalone repo.
enum PublicTradeSegment {
  historical
  live
}

/// Statut d'un trade public.
enum PublicTradeStatus {
  open
  closed
  break_even
}

model PublicTrade {
  id            String               @id @default(cuid())
  segment       PublicTradeSegment
  /// Position chronologique 1..N. Conservée depuis l'ODS pour les
  /// historiques, auto-incrémentée ensuite via service layer.
  ordinal       Int                  @unique
  /// Instrument (EURUSD, XAUUSD, US30, USOIL...). Pas d'enum DB car la
  /// liste s'étend au-delà des paires majeures de l'app membre.
  instrument    String
  /// Direction long/short — réutilise enum existant. Nullable car certains
  /// historiques ODS n'ont pas le sens renseigné (action col vide).
  direction     TradeDirection?
  /// Date d'entrée. Pour les historiques importés ODS, anchored au lundi
  /// de la semaine (week label tel que "20 JANVIER" + année à confirmer).
  enteredAt     DateTime             @map("entered_at")
  exitedAt      DateTime?            @map("exited_at")
  /// % de capital risqué (0.50, 1.00, 2.00). Stocké en % brut, pas en
  /// fraction décimale (1.0 = 1%, pas 0.01). Decimal(4,2) cohérent avec
  /// `Trade.riskPct` V1.5 + Tharp ceiling (< 100%).
  riskPercent   Decimal              @map("risk_percent") @db.Decimal(4, 2)
  /// R-multiple final atteint (1R = +1×risque, -1R = stop plein, 0R = BE).
  resultR       Decimal?             @map("result_r") @db.Decimal(6, 3)
  /// % de portefeuille net (riskPercent × resultR). Précalculé pour
  /// performance lecture.
  resultPercent Decimal?             @map("result_percent") @db.Decimal(6, 3)
  status        PublicTradeStatus
  /// Session de trading — réutilise enum TradeSession existant.
  session       TradeSession?
  /// Tag setup (ICT FVG, OB retest, SMC liquidity sweep, breakout...).
  setup         String?
  /// Tags additionnels (news, FOMC, CPI, partagé en réunion live...).
  tags          String[]
  /// Commentaire post-trade public (sanitized via safeFreeText).
  notes         String?              @db.Text
  /// Lien screenshot — R2 key ou URL externe.
  screenshotUrl String?              @map("screenshot_url")
  /// Provenance du trade (audit / re-import).
  source        String               @default("import")
  /// Toggle publication. False = draft admin.
  isPublished   Boolean              @default(true) @map("is_published")
  publishedAt   DateTime             @default(now()) @map("published_at")
  partials      PublicTradePartial[]
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@index([segment, enteredAt(sort: Desc)])
  @@index([isPublished, enteredAt(sort: Desc)])
  @@index([instrument])
  @@map("public_trades")
}

/// Clôture partielle d'un trade public (legs successives).
model PublicTradePartial {
  id            String      @id @default(cuid())
  publicTradeId String      @map("public_trade_id")
  publicTrade   PublicTrade @relation(fields: [publicTradeId], references: [id], onDelete: Cascade)
  /// R-multiple atteint sur cette leg (1.5R = TP1).
  closedAtR     Decimal     @map("closed_at_r") @db.Decimal(6, 3)
  /// % de la position fermée sur cette leg (0..100).
  closedPercent Decimal     @map("closed_percent") @db.Decimal(5, 2)
  closedAt      DateTime    @map("closed_at")
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([publicTradeId, closedAt(sort: Asc)])
  @@map("public_trade_partials")
}

// =============================================================================
// V2.4 — Onboarding interview profilage IA (Session α, M3 directive 2026-05-27)
// =============================================================================
// Pattern : static questionnaire ~30 questions safeFreeText-sanitized service-
// side. Claude batch local async post-completion (carbone V1.4 monthly-debrief
// — ZÉRO API payante consommée, §canon dur). Posture §2 strict — Claude generates
// psycho/process axes ONLY (Mark Douglas / Steenbarger), never trade analysis.
// 1-1 cascade User × OnboardingInterview × MemberProfile.

/// Status lifecycle of an OnboardingInterview row.
/// started      → row created, no answers yet
/// in_progress  → ≥1 answer submitted (member is mid-questionnaire)
/// completed    → finalize() invoked → MemberProfile generated (Claude batch)
/// abandoned    → member inactive >7d post-creation (cron sweep V2.4+ future)
enum InterviewStatus {
  started
  in_progress
  completed
  abandoned
}

/// V2.4 — Onboarding interview profilage IA (Session α, M3 directive).
///
/// 1-1 cascade User. Static questionnaire ~30 questions Mark Douglas-aligned,
/// instrumentVersion semver-tracked for longitudinal validity (mirror V1.5
/// MindsetCheck pattern). claudeModelVersion + totalTokens{Input,Output} tracked
/// for cost transparency (batch local Claude Max = $0 but tokens logged for audit).
///
/// Pipeline pattern : carbone V1.4 monthly-debrief —
/// 1. Member répond aux questions (UI wizard V2.4 Phase B future)
/// 2. finalize() flips status started/in_progress → completed
/// 3. Cron OR admin batch local triggers Claude analysis → MemberProfile created
/// 4. Member sees MemberProfile in dashboard "Mon profil"
/// 5. Admin (Eliot) sees pseudonymized profile in /admin/members/[id]?tab=profil
///
/// Posture §2 strict : Claude's job is to extract psycho/process axes from
/// the answers (discipline, patience, acceptance, probabilities thinking,
/// emotion regulation, process focus, etc.). NEVER trade analysis. NEVER setup
/// recommendation. Regex AMF post-gen guard at claude-client layer.
model OnboardingInterview {
  id                 String                      @id @default(cuid())
  userId             String                      @unique @map("user_id")
  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             InterviewStatus             @default(started)
  startedAt          DateTime                    @default(now()) @map("started_at")
  completedAt        DateTime?                   @map("completed_at")
  claudeModelVersion String?                     @map("claude_model_version")
  totalTokensInput   Int                         @default(0) @map("total_tokens_input")
  totalTokensOutput  Int                         @default(0) @map("total_tokens_output")
  instrumentVersion  String                      @default("v1") @map("instrument_version")
  answers            OnboardingInterviewAnswer[]
  profile            MemberProfile?
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")

  @@index([status, completedAt])
  @@map("onboarding_interviews")
}

/// V2.4 — Onboarding interview answer (one row per question/answer pair).
///
/// Cascade via OnboardingInterview AND via User (for RGPD export Art. 15 +
/// soft-delete cascade J10). answerText is safeFreeText-sanitized at service
/// layer (crisis/injection detection BEFORE persist — carbone V1.8 REFLECT
/// pattern). questionKey is the slug stable for analytics (questionText may
/// evolve across instrumentVersion bumps).
///
/// @@unique [interviewId, questionIndex] guarantees idempotent append (cant
/// double-submit same question — service handles via upsert semantics).
model OnboardingInterviewAnswer {
  id            String              @id @default(cuid())
  interviewId   String              @map("interview_id")
  interview     OnboardingInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  userId        String              @map("user_id")
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIndex Int                 @map("question_index")
  questionKey   String              @map("question_key")
  questionText  String              @map("question_text") @db.Text
  answerText    String              @map("answer_text") @db.Text
  createdAt     DateTime            @default(now()) @map("created_at")

  @@unique([interviewId, questionIndex])
  @@index([userId, createdAt(sort: Desc)])
  @@map("onboarding_interview_answers")
}

/// V2.4 — MemberProfile = final Claude-synthesized output of OnboardingInterview.
///
/// 1-1 cascade User + 1-1 Restrict to OnboardingInterview (preserves audit trail
/// even if downstream interview row is touched — equivalent V1.4 MonthlyDebrief
/// retention pattern). summary = 200-800 chars Claude-generated synthesis.
/// highlights = JSON [{ key, label, evidence: [{ answerId, excerpt }] }]
/// structured insights with traceable evidence references back to InterviewAnswer.
/// axesPrioritaires = JSON ["discipline", "patience", "acceptance", ...] 3-5
/// Mark Douglas psycho/process axes the member should focus on first.
///
/// claudeModelVersion + instrumentVersion mirror OnboardingInterview row for
/// audit/longitudinal traceability. analyzedAt = batch-local job timestamp.
model MemberProfile {
  id                 String              @id @default(cuid())
  userId             String              @unique @map("user_id")
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewId        String              @unique @map("interview_id")
  interview          OnboardingInterview @relation(fields: [interviewId], references: [id], onDelete: Restrict)
  summary            String              @db.Text
  highlights         Json
  axesPrioritaires   Json                @map("axes_prioritaires")
  claudeModelVersion String              @map("claude_model_version")
  instrumentVersion  String              @map("instrument_version")
  analyzedAt         DateTime            @default(now()) @map("analyzed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  /// V2.5 (#17) — member-written if-then recovery protocol (Mark Douglas §18,
  /// Gollwitzer implementation-intention). Re-served READ-ONLY on the
  /// `after_n_consecutive_losses` trigger (JITAI) so the member meets their OWN
  /// cold-state plan at the exact hot moment. Closed shape validated by
  /// `recoveryProtocolSchema`. SPEC §2: discipline recovery (stop/cooldown/
  /// self-talk) ONLY — never market re-entry timing/setup. §31.2: non-punitive,
  /// no broker lock. NULL = not set; NEVER a scoring input (firewall-clean).
  recoveryProtocol Json? @map("recovery_protocol")

  /// J-A (expansion IA profonde) — 4 dimensions structurees, evidence-grounded,
  /// produites par le pipeline onboarding enrichi. Toutes ADD-only, nullable,
  /// read-only, JAMAIS un input du score comportemental (firewall §21.5, meme
  /// contrat que recoveryProtocol ci-dessus). Shapes valides par les sous-schemas
  /// Zod stricts dans schemas/onboarding-interview.ts. Chaque champ porte son
  /// propre evidence[] (verbatim substring NFC), valide au persist par
  /// runSafetyGate. NULL = signal insuffisant a l'onboarding (le modele omet).
  ///
  /// coachingTone   = {register: direct|pedagogique|socratique, rationale, evidence[]}
  ///                  registre de coaching adapte, propage aux prompts membre-facing.
  /// learningStage  = {stage: mechanical|subjective|intuitive, rationale, evidence[]}
  ///                  stade Mark Douglas (Disciplined Trader ch.8).
  /// axesStructured = [{axis, dimensionId, priority 1-5, evidence[]}] axes priorises.
  /// weakSignals    = [{signal, dimensionId, evidence[]}] patterns latents a
  ///                  observer, surface ADMIN uniquement (non anxiogene cote membre).
  coachingTone   Json? @map("coaching_tone")
  learningStage  Json? @map("learning_stage")
  axesStructured Json? @map("axes_structured")
  weakSignals    Json? @map("weak_signals")

  @@map("member_profiles")
}

/// J-E (expansion IA profonde — check-in mensuel) — trajectoire LONGITUDINALE
/// ADMIN-ONLY des 4 dimensions IA re-profilees chaque mois civil. ADD-only : ce
/// snapshot n'ECRASE JAMAIS le baseline onboarding `MemberProfile` (write-once) ;
/// il empile un point de trajectoire par mois pour que l'admin (Eliott) voie
/// COMMENT le membre evolue (registre de coaching, stade Mark Douglas, axes
/// prioritaires, signaux faibles) au fil du temps. Idempotence `(userId, monthStart)`.
///
/// FIREWALL (SPEC §21.5/§27.7, meme contrat que les 4 dims de `MemberProfile`) :
///   - aucune des 4 dims n'est JAMAIS un input du score comportemental ;
///   - `weakSignals` ne traverse JAMAIS une surface de COACHING membre
///     (ADMIN-ONLY, non-anxiogene) ; la table alimente l'espace admin ET
///     l'export RGPD du membre (droit d'acces Art. 15, comme `member_profiles`),
///     mais AUCUN dashboard / surface de coaching membre ;
///   - 0 FK vers un objet real-edge (Trade / WeeklyReport / BehavioralScore) :
///     la SEULE relation est `userId` -> `users` (mirror `MonthlyDebrief`).
///
/// `monthStart` = 1er du mois civil local Europe/Paris (UTC-midnight pin,
/// `parseLocalDate`), `monthEnd` = dernier jour civil SERVICE-computed (SSOT,
/// anti-tamper, jamais recu du client). `userId` cascade a la suppression User
/// (RGPD §17). Generation batch-local Claude Max (SPEC §25.2 — jamais l'API
/// payante) ; cost tracking garde pour l'audit meme si le cout marginal est 0€.
/// Chaque dim porte son evidence[] (verbatim substring NFC), valide au persist
/// par le meme `runSafetyGate` que l'onboarding. NULL = signal insuffisant ce
/// mois (le modele omet la dim). Shapes valides par les sous-schemas stricts de
/// schemas/member-profile-monthly-snapshot.ts (reutilisent ceux de l'onboarding).
model MemberProfileMonthlySnapshot {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  monthStart  DateTime @map("month_start") @db.Date
  /// Service-computed last calendar day of the civil month (SSOT, anti-tamper —
  /// never received from the client, mirror `MonthlyDebrief.monthEnd`).
  monthEnd    DateTime @map("month_end") @db.Date
  generatedAt DateTime @default(now()) @map("generated_at")

  /// Recit ADMIN-ONLY de l'evolution mois-sur-mois des dimensions profondes
  /// (Zod `memberProfileMonthlySnapshotOutputSchema`-valide avant write).
  evolutionNarrative String @map("evolution_narrative") @db.Text

  /// 4 dimensions IA profondes re-profilees ce mois (meme shape que
  /// `MemberProfile`). Toutes nullable (NULL = signal insuffisant), read-only,
  /// JAMAIS un input du score (firewall §21.5). `weakSignals` reste ADMIN-ONLY.
  coachingTone   Json? @map("coaching_tone")
  learningStage  Json? @map("learning_stage")
  axesStructured Json? @map("axes_structured")
  weakSignals    Json? @map("weak_signals")

  // Cost tracking + observability (mirror `MonthlyDebrief` ; batch-local Claude
  // Max ⇒ 0€ marginal mais garde pour tracabilite/audit, SPEC §25.3).
  claudeModel       String  @map("claude_model")
  inputTokens       Int     @map("input_tokens")
  outputTokens      Int     @map("output_tokens")
  cacheReadTokens   Int     @default(0) @map("cache_read_tokens")
  cacheCreateTokens Int     @default(0) @map("cache_create_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking).
  costEur           Decimal @map("cost_eur") @db.Decimal(10, 6)

  @@unique([userId, monthStart])
  @@index([userId, monthStart(sort: Desc)])
  @@map("member_profile_monthly_snapshots")
}

// =============================================================================
// V2 S2 — Universal tracking engine (SPEC §2 posture / longitudinal invariant)
// =============================================================================
//
// Generic, recurring, code-defined-instrument capture layer. ANY behavioural /
// process axis (execution, risk-discipline, training, meetings, emotions...)
// is tracked by a FROZEN, VERSIONED instrument declared in code
// (`lib/tracking/instruments/<key>-v<n>.ts`) — the SAME longitudinal-validity
// invariant as `MindsetCheck` / `OnboardingInterview`: instruments are STATIC
// and VERSIONED, NEVER mutated in place. The DB stores only captured RESPONSES
// + the instrument key/version pin, never the instrument body.
//
// STATISTICAL ISOLATION (SPEC §21.5 / §27.7 — BLOQUANT): these two models carry
// NO FK to `Trade` / `BehavioralScore` / `PreTradeCheck`. They are a structured
// capture + reliability (D2) + confidence (D3) + completeness (D1) surface that
// feeds NOTHING back into the real edge. Only the `userId` cascade link exists
// (RGPD §17). Enforced by `test/anti-leak/tracking-isolation.test.ts`.
//
// POSTURE §2 (BLOQUANT): instruments capture PROCESS / PSYCHOLOGY only — THAT an
// act happened (cut at 20h? one risk-trade today? SL predefined?), NEVER market-
// analysis CONTENT. No instrument asks "what setup / which direction". The
// `responses` JSON is a CLOSED Zod-validated shape (`lib/tracking/schema.ts`) —
// no raw edge free-text — and the instrument labels run through the existing
// `detectAMFViolation` guard in tests (`lib/tracking/instruments/*.test.ts`).

/// Reliability dimension (D2) of a capture: WHEN/HOW it was answered. Lets the
/// member dashboard and S3 confrontation weight a hot, in-the-moment answer
/// differently from a cold retrospective one. NEVER a scoring input.
enum CaptureContext {
  /// In-the-moment (pre-trade decision, live during a session).
  hot
  /// Retrospective (evening review, end-of-week recall).
  cold
  /// Engine-prompted at the instrument's scheduled due time.
  scheduled
}

/// Canonical tracking taxonomy (FR labels in `lib/tracking/axes.ts`). Covers the
/// full méthodo surface with ZERO loss (DoD case 5): execution, risk-discipline,
/// market-analysis prep, entraînement/backtest, la formation, réunions §30,
/// emotions+confidence, sleep/lifestyle, evening "bilan", travail sur soi,
/// routine. Pure analytics dimension — a `TrackingEntry.axis` is NOT a scoring
/// input. Append a value here only additively (Postgres: new enum value is
/// non-destructive; never reuse/rename an existing one — longitudinal contract).
enum TrackingAxis {
  execution
  risk_discipline
  market_analysis
  training
  formation
  meeting_presence
  emotions_confidence
  sleep_lifestyle
  evening_review
  self_work
  routine
}

/// V2 S2 — one captured response set for one recurring instrument occurrence.
///
/// Idempotency: `@@unique([userId, instrumentKey, occurrenceKey])`. The service
/// upserts on this composite key — re-submitting the same occurrence overwrites
/// (never duplicates), so the spread/recurring collection (DoD case 4) is safe
/// against double-taps and retries. `occurrenceKey` is the canonical slot the
/// entry answers ("2026-06-24" daily, "2026-W26" weekly, or a pre-trade nonce).
///
/// Confrontable S3 + consumable S4–S7 (DoD case 6): the read contract lives in
/// `lib/tracking/service.ts` (count-only / per-axis aggregates, NO P&L join).
model TrackingEntry {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Stable slug of the code-defined instrument (e.g. "process-fidelity"). The
  /// instrument body lives in `lib/tracking/instruments/<key>-v<n>.ts` — NEVER
  /// in the DB (frozen-instrument invariant).
  instrumentKey     String @map("instrument_key")
  /// Instrument version at capture time. Pinning per row keeps longitudinal
  /// comparisons valid across bumps (mirror MindsetCheck.instrumentVersion).
  instrumentVersion String @default("v1") @map("instrument_version")

  /// Behavioural/process axis (taxonomy `lib/tracking/axes.ts`). NOT a score input.
  axis TrackingAxis

  /// Idempotency discriminator — the canonical occurrence this entry answers.
  occurrenceKey String @map("occurrence_key")

  /// Structured answers, validated by the instrument's Zod schema BEFORE persist
  /// (`lib/tracking/schema.ts`). CLOSED shape per instrument — no raw edge
  /// free-text (SPEC §2). Shape = `{ [questionKey]: answerValue }`.
  responses Json

  // ----- D3 — emotion + confidence (simple recurring scale) -----------------
  /// Optional 1–5 confidence self-rating attached to this capture (D3). Null =
  /// the instrument didn't ask, or unanswered. NEVER a scoring input.
  confidenceLevel Int? @map("confidence_level")

  // ----- D2 — reliability metadata ------------------------------------------
  /// hot (in-the-moment) / cold (retrospective) / scheduled (engine-prompted).
  captureContext    CaptureContext? @map("capture_context")
  /// Milliseconds between prompt render and submit — a reliability signal
  /// (rushed vs considered). Null = not measured. NEVER a scoring input.
  responseLatencyMs Int?            @map("response_latency_ms")
  /// When the engine prompted this capture (D2 — paired with `submittedAt`).
  promptedAt        DateTime?       @map("prompted_at")

  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Idempotent append: one entry per (user, instrument, occurrence).
  @@unique([userId, instrumentKey, occurrenceKey])
  // Per-axis dashboard + S3 confrontation reads (most-recent first).
  @@index([userId, axis, submittedAt(sort: Desc)])
  // Per-instrument longitudinal reads.
  @@index([userId, instrumentKey, submittedAt(sort: Desc)])
  @@map("tracking_entries")
}

/// V2 S2 — per-(member, instrument) cadence bookkeeping for the recurring engine.
///
/// The engine reads `nextDueAt` to surface a CALM action via `getDailyGuidance`
/// (SPEC §2 posture: no streak, no urgency, no punitive nudge §31.2). The member
/// can snooze via `pausedUntil` — anti-overload so captures are SPREAD over time,
/// never piled up (DoD case 4). One row per (user, instrument).
model TrackingSchedule {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  instrumentKey String @map("instrument_key")

  /// Next time this instrument is due for the member.
  nextDueAt       DateTime  @map("next_due_at")
  /// Last completed occurrence timestamp (null = never completed).
  lastCompletedAt DateTime? @map("last_completed_at")
  /// Opaque cadence bookkeeping owned by `lib/tracking/cadence.ts`
  /// (e.g. consecutive-skips, adaptive interval). Null = default cadence.
  cadenceState    Json?     @map("cadence_state")
  /// Member-set snooze — the engine skips this instrument until `pausedUntil`.
  pausedUntil     DateTime? @map("paused_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, instrumentKey])
  // Engine sweep: "what is due for this member now?"
  @@index([userId, nextDueAt])
  @@map("tracking_schedules")
}

// =============================================================================
// §26 — Calendrier personnel adaptatif (J-C1 data layer)
// =============================================================================
//
// Two models, statistically isolated from the real edge by construction
// (posture §2 BLOQUANT / §21.5 / §27.7):
//   - `WeeklyScheduleQuestionnaire` = member-owned closed weekly questionnaire
//     (9 items, instrument-versioned, ZERO free-text V1 → zero crisis/injection
//     surface, carbone MindsetCheck §27). Captures availability + practice
//     profile for the week ahead. Idempotent `(userId, weekStart)` upsert.
//   - `AdaptiveCalendar` = the Claude-generated weekly plan (organises TIME of
//     practice, NEVER trades). Validated by `adaptiveCalendarOutputSchema`
//     `.strict()` before persist. Cost-tracked like `WeeklyReport`/`MonthlyDebrief`.
//
// Both models:
//   - Cascade-delete with the user (RGPD §17 data-minimisation).
//   - Carry NO P&L field (`realizedR`/`outcome`/`plannedRR`). The Claude
//     snapshot reads count-only activity (lib/calendar/snapshot.ts). The
//     isolation is enforced by test/anti-leak/calendar-isolation.test.ts.
//   - `weekStart` = Monday Europe/Paris materialised at the service layer via
//     `parseLocalDate` (UTC-midnight pin) so Postgres `@db.Date` never drifts a
//     day (anti-flake invariant PR#96).
//
// `AdaptiveCalendar` has NO FK to `WeeklyScheduleQuestionnaire`: the calendar is
// a snapshot-at-generation artefact. A later edit of the questionnaire must NOT
// rewrite the history of an already-generated calendar — the two are decoupled
// on purpose (the calendar persists `calendar_instrument_version` to record
// which questionnaire instrument fed it). This is justified on its own merits,
// not by analogy to MemberProfile (which DOES keep an FK to OnboardingInterview).

model WeeklyScheduleQuestionnaire {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Monday of the planned week, local Europe/Paris, UTC-midnight pinned via
  /// `parseLocalDate` at the service layer (anti-flake PR#96).
  weekStart DateTime @map("week_start") @db.Date

  /// Frozen instrument version this answer set belongs to (longitudinal
  /// validity §27.7). Trends are only ever compared intra-version.
  instrumentVersion Int          @map("instrument_version")
  /// Denormalised typed projection of `responses.energyPeak` — the member's
  /// self-reported energy-peak slot. Anchors `CalendarSlot` at the DB layer +
  /// keeps the field admin-queryable. The full versioned answer set lives in
  /// `responses` (single source of truth for longitudinal analysis).
  energyPeakSlot    CalendarSlot @map("energy_peak_slot")
  /// All 9 closed answers, instrument-versioned. Shape validated by
  /// `lib/schemas/weekly-schedule-questionnaire.ts`. ZERO free-text V1.
  responses         Json

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  /// The calendar batch filters by `weekStart` ALONE (loadAllSnapshots /
  /// persistGeneratedCalendars). The composite above is userId-led, so Postgres
  /// can't use it for a weekStart-only scan — this single-column index keeps the
  /// weekly batch index-bound as the questionnaire history grows (S6 audit).
  @@index([weekStart])
  @@map("weekly_schedule_questionnaires")
}

model AdaptiveCalendar {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Monday of the planned week, local Europe/Paris, UTC-midnight pinned.
  weekStart DateTime @map("week_start") @db.Date

  /// Claude-generated weekly plan, validated by `adaptiveCalendarOutputSchema`
  /// `.strict()` before persist. Shape: { overview, days[7]{ blocks[] },
  /// weeklyFocus, warnings[] }. Organises TIME (sessions/backtest/Mark Douglas/
  /// réunions §30/rest), NEVER trades — posture §2.
  schedule        Json
  /// Denormalised dominant block category of the week — admin week-at-a-glance.
  /// Anchors `CalendarBlockCategory` at the DB layer. Computed from `schedule`
  /// at persist time; nullable for the empty-schedule edge.
  primaryCategory CalendarBlockCategory? @map("primary_category")

  // Cost tracking — Claude batch LOCAL (`claude --print`, abonnement Max,
  // $0 API marginal §8). Mirrors WeeklyReport/MonthlyDebrief sub-cent tracking.
  claudeModel  String  @map("claude_model")
  inputTokens  Int     @map("input_tokens")
  outputTokens Int     @map("output_tokens")
  /// Cost in EUR with 6 decimals precision (sub-cent tracking, SPEC §16).
  costEur      Decimal @map("cost_eur") @db.Decimal(10, 6)

  /// EU AI Act 50(1) — when the AI-generated banner was first shown to the
  /// member (7th production disclosure site). Set on first calendar view (J-C4).
  aiDisclosureShownAt       DateTime? @map("ai_disclosure_shown_at")
  /// Version of the questionnaire instrument that fed this calendar generation
  /// (snapshot-at-generation provenance — the FK-free decoupling rationale).
  calendarInstrumentVersion Int       @map("calendar_instrument_version")

  generatedAt DateTime @default(now()) @map("generated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, weekStart])
  @@index([userId, weekStart(sort: Desc)])
  @@index([generatedAt(sort: Desc)])
  /// Same rationale as WeeklyScheduleQuestionnaire — the batch reads existing
  /// calendars by `weekStart` alone (freshness gate). Keeps it index-bound at
  /// scale (S6 audit).
  @@index([weekStart])
  @@map("adaptive_calendars")
}

// =============================================================================
// V1.7 §30 — Meeting attendance tracking (suivi de présence aux réunions).
//
// Recurring Fxmily meetings (Mon–Fri 12h & 20h Europe/Paris, Zoom) are
// materialised as `Meeting` rows by a cron (J-M3). Each member self-declares
// attendance in-app via `MeetingAttendance`. Posture §2 verrouillée: the app
// tracks the ACT (présence + lecture = discipline/exécution) via a boolean
// `contentReviewed` ONLY — it NEVER stores / displays / comments the Ichor
// analysis content. Attendance feeds ONLY the `engagement` dimension via the
// count-only primitive `countMeetingAttendance` (J-M4), never the real edge.
// See SPEC §30 (source of truth) for the full rationale + invariants §30.7.
// =============================================================================

/// V1.7 §30 — meeting slot. `midday` = 12h00 Paris (Ichor analyse), `evening`
/// = 20h00 Paris (Ichor bilan/débrief). The slot carries the expected content
/// type — no separate content entity (KISS, SPEC §30.2).
enum MeetingSlot {
  midday
  evening
}

/// V1.7 §30 — meeting lifecycle. `cancelled` = admin unavailable / no meeting
/// → excluded from the attendance-rate denominator (a member is NEVER
/// penalised when Eliot is not available, SPEC §30.2).
enum MeetingStatus {
  scheduled
  cancelled
}

/// V1.7 §30 — how the member attended. `live` = present on Zoom, `replay` =
/// watched the Drive recording. Null on a `MeetingAttendance` row means "not
/// yet declared". A complete attendance = `attendanceMode != null` AND
/// `contentReviewed = true` (SPEC §30.3).
enum MeetingAttendanceMode {
  live
  replay
}

/// V1.7 §30 — a recurring Fxmily meeting occurrence (admin-scoped, cron-generated).
/// 0 FK to the real-edge models (`Trade` / `BehavioralScore`): a meeting is an
/// attendance datum, not a trading one (SPEC §30.3 isolation by construction).
model Meeting {
  id String @id @default(cuid())

  /// Civil day (Europe/Paris) of the meeting. DERIVED from `scheduledAt` by
  /// construction = `localDateOf(scheduledAt, 'Europe/Paris')` — never computed
  /// independently (anti DST-drift on the switch day, invariant §30.7).
  /// `@db.Date` pins UTC-midnight (canon DailyCheckin).
  date DateTime    @db.Date
  slot MeetingSlot

  /// Exact UTC instant of the 12h/20h Paris slot for `date`, DST-aware via
  /// `localInstantToUtc` (CET = 11h UTC / CEST = 10h UTC). Drives sort + the
  /// "past meeting" check. Never `12:00 UTC` hardcoded (invariant §30.7).
  scheduledAt DateTime @map("scheduled_at")

  status MeetingStatus @default(scheduled)

  /// Optional admin note when cancelling a slot ("pas dispo"). Free-text,
  /// `safeFreeText`-sanitised at the J-M3 admin Server Action boundary.
  cancelledReason String? @map("cancelled_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attendances   MeetingAttendance[]
  /// S3 §31 — `meeting_missed_no_reason` gaps materialised for no-shows.
  discrepancies Discrepancy[]

  /// Idempotent cron generation: at most one meeting per slot per civil day.
  /// Doubles as the `date >=` / `scheduledAt` denominator filter index.
  @@unique([date, slot])
  /// Denominator filter: scheduled meetings ordered by recency. No standalone
  /// `[scheduledAt]` index — it is a redundant prefix of this composite
  /// (repo convention: no redundant single-column index, cf. DailyCheckin/Trade).
  @@index([status, scheduledAt(sort: Desc)])
  @@map("meetings")
}

/// V1.7 §30 — a member's self-reported attendance for one `Meeting`. Cascade on
/// both `Meeting` and `User` delete (RGPD §17 data minimisation).
model MeetingAttendance {
  id String @id @default(cuid())

  meetingId String  @map("meeting_id")
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// How the member attended (live Zoom OR Drive replay). Null until declared.
  attendanceMode MeetingAttendanceMode? @map("attendance_mode")

  /// Did the member read the associated Ichor content (analyse@12h / bilan@20h)?
  /// Boolean ONLY — the app NEVER stores the content itself (posture §2). A
  /// complete attendance = `attendanceMode != null` AND `contentReviewed = true`.
  contentReviewed Boolean @default(false) @map("content_reviewed")

  /// F4 — the member's EXPLICIT "je n'ai pas pu y assister". Distinct from a
  /// not-yet-declared slot (`en_attente`, rattrapable) : `false` = never declared
  /// absent (default, byte-identical to prior behaviour) · `true` = the member
  /// acknowledged they missed this meeting. Declaring a presence
  /// (`attendanceMode`) flips it back to `false` (mutually exclusive — a member
  /// can't be present AND absent). Anti-Black-Hat §31.2 : an acknowledged absence
  /// is a calm, honest data point, NEVER a red failure ; it never counts as a
  /// completion (rate/engagement untouched — it only clarifies the "why nothing").
  memberDeclaredAbsent Boolean @default(false) @map("member_declared_absent")

  /// S10 §30.8 — presence as DECLARED BY ELIOTT (admin), distinct from the
  /// member self-report above. The cross-check the brief calls "recoupement
  /// admin↔membre": null = admin said nothing (default — byte-identical to the
  /// pre-S10 behaviour, no member is ever affected until Eliott marks a slot) ·
  /// true = admin confirms the member was present · false = admin states the
  /// member was absent. An ÉCART (gap) is derived purely from
  /// (adminPresent, member-complete) at read-time — never stored — by
  /// `computeAttendanceGap` (lib/meeting/attendance-gap.ts). The ONLY scoring
  /// impact is honest accounting: a self-declared completion contradicted by
  /// `adminPresent = false` does NOT count toward the engagement numerator
  /// (`attendanceCountsAsComplete`) — no separate penalty, no discrepancy
  /// lifecycle, auto-healing when Eliott corrects. Posture §2: booleans only,
  /// never any Ichor content.
  adminPresent  Boolean?  @map("admin_present")
  /// When Eliott last set `adminPresent` (audit/recency of the admin mark).
  adminMarkedAt DateTime? @map("admin_marked_at")
  /// The admin `User.id` who set `adminPresent` (trace; no FK — kept opaque so a
  /// purged admin never cascades a member's attendance row, mirror §30.4).
  adminMarkedBy String?   @map("admin_marked_by")

  declaredAt DateTime @default(now()) @map("declared_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  /// Idempotent declaration: re-declaring updates the same row, never stacks
  /// (upsert on this composite key — pattern DailyCheckin `(userId,date,slot)`).
  @@unique([meetingId, userId])
  /// Member view: their recent declarations. No standalone `[meetingId]` index
  /// — the admin per-meeting lookup is served by the `[meetingId, userId]`
  /// unique prefix (repo convention: no redundant single-column index).
  @@index([userId, declaredAt(sort: Desc)])
  @@map("meeting_attendances")
}

// =============================================================================
// V2.5 — Self-service access requests (public "Rejoindre" front door)
// =============================================================================

/// A public visitor's request to join Fxmily. Submitted unauthenticated on
/// `/rejoindre` (prénom + nom + email), reviewed by the admin in
/// `/admin/access-requests`. On approval the existing invitation/onboarding
/// pipeline is reused (an `Invitation` is minted + a premium email sent) — this
/// model NEVER creates an account itself.
///
/// PII (RGPD): `firstName` + `lastName` + `email` belong to a NON-member who has
/// given no account-level consent. We minimise exposure : (a) the public action
/// is anti-enumeration (same neutral success whether or not a row is created);
/// (b) audit rows carry NO name/email (PII-free metadata); (c) the
/// `/api/cron/purge-access-requests` weekly cron deletes resolved rows
/// (approved/rejected) and stale pending rows (> 30d) so this table never
/// accumulates dormant non-member PII.
///
/// `reviewedBy` is SetNull on admin delete (the request keeps its lifecycle
/// trace even if the reviewing admin's account is later purged). `invitationId`
/// is a loose pointer (no FK) to the invitation minted on approval — the
/// invitation has its own TTL + purge path, so a dangling pointer after the
/// invitation expires/is-purged is acceptable and intentional.
model AccessRequest {
  id        String              @id @default(cuid())
  firstName String              @map("first_name")
  lastName  String              @map("last_name")
  email     String
  status    AccessRequestStatus @default(pending)

  /// When the admin approved/rejected the request (null while pending).
  reviewedAt   DateTime? @map("reviewed_at")
  /// The admin who reviewed it. SetNull so a purged admin doesn't erase the
  /// request's lifecycle trace.
  reviewedById String?   @map("reviewed_by_id")
  reviewedBy   User?     @relation("AccessRequestsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  /// Loose pointer (no FK) to the `Invitation` minted on approval. The
  /// invitation has its own TTL + RGPD purge path; we don't cascade-couple
  /// the two lifecycles.
  invitationId String? @map("invitation_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Admin pending-queue read: filter by status, newest-first.
  @@index([status, createdAt])
  // Dedup lookup on submit (an active pending request for this email).
  @@index([email])
  @@map("access_requests")
}

// =============================================================================
// S3 — Vérification & Honnêteté radicale (preuve MT5 + score de constance)
// =============================================================================
//
// Session 3 of the 10-session plan ("rendre le mensonge impossible" — the
// truth is proven BY REALITY, not by declaration alone). Data layer only at
// S1-Fondations time; the upload UI, vision pipeline (Claude Opus 4.8 local,
// image input proven 2026-06-10), reconciliation engine, scoring service and
// alert dispatch are built in the dedicated S3 session.
//
// Design invariants (PROJECT_STATE.md §13.3 + brief 03 §29-§31):
//   - Cascade on User delete everywhere (RGPD §17 data minimisation).
//   - Posture §2 BLOQUANT: verification concerns FACTS (a trade existed, a
//     form was filled), NEVER the quality of an analysis. `Alert.category`
//     is structurally pinned to `psychological` — there is no "trading
//     advice" alert by construction.
//   - Alerts fire on REPETITION ONLY (repeatCount >= threshold), never on a
//     first slip (brief §31 DoD: "les alertes ne se déclenchent que lorsque
//     les manquements se répètent").
//   - Honest limit (decision Eliot 2026-06-10): a screenshot proof raises the
//     cost of lying but is NOT forensic truth (cropping/demo accounts stay
//     possible). True broker-API verification remains SPEC V3 roadmap.
//   - `Discrepancy.claudeReasoning` contains STATIC §2-clean labels produced by
//     the DETERMINISTIC reconciliation engine (reconcile.ts + constancy.ts) —
//     NOT free-text emitted by Claude. The 4 write-sites write fixed French
//     strings (e.g. "Un trade déclaré dans le journal n'a pas de contrepartie…").
//     If a future change writes real Claude output here it MUST add
//     detectAMFViolation + detectCrisis + safeFreeText at the write-site.

/// S3 — kind of broker account a member trades on. Lowercase values per repo
/// enum convention (deviation from the §13.3 draft's uppercase, documented).
enum BrokerAccountType {
  prop_firm
  personal
}

/// S3 — lifecycle of an uploaded MT5 proof through the vision pipeline.
enum ProofOcrStatus {
  pending
  done
  failed
}

/// S3 — provenance of an extracted position. Single value today (vision OCR
/// of an MT5 history screenshot); a future V3 broker-API import becomes an
/// additive enum value, not a new model.
enum ExtractedPositionSource {
  mt5_screen_ocr
}

/// S3 — provenance of a journal `Trade`. Every pre-S3 row is `self_declared`.
enum TradeSource {
  self_declared
  mt5_verified
}

/// S3 — result of confronting a declared `Trade` with the extracted reality.
enum TradeMatchStatus {
  unmatched
  matched
  mismatch
}

/// S3 — kind of declarative ↔ reality gap the reconciliation engine found.
///   missing_declared   : a real MT5 position has no declared trade (oubli).
///   false_declared     : a declared trade has no real MT5 counterpart.
///   mismatch           : both exist but the numbers/timing diverge.
///   unfilled_no_reason : a required ritual (check-in, declaration…) was left
///                        empty with no valid member reason (brief §29 —
///                        "ne rien remplir sans motif valable n'est pas neutre").
enum DiscrepancyType {
  missing_declared
  false_declared
  mismatch
  unfilled_no_reason
  /// S3 §31 généralisée — a SCHEDULED meeting the member neither attended (live
  /// or replay) nor excused before its 30-day rattrapage window closed. Cancelled
  /// slots are NEVER counted (no unjust accusation, §30.2/§33.6).
  meeting_missed_no_reason
  /// S3 §32 généralisée — a DUE recurring tracking instrument (S2 universal
  /// engine, e.g. the weekly process-fidelity) the member left unfilled past its
  /// rattrapage grace, without a reason. Snoozed instruments are NEVER counted
  /// (calm self-pacing, §2). Excusable like every other gap; feeds the discipline
  /// axis only (completion metadata — never the capture content, §21.5).
  tracking_skipped_no_reason
}

/// S3 — lifecycle of a discrepancy (open → member acknowledged → resolved).
enum DiscrepancyStatus {
  open
  acknowledged
  resolved
}

/// S3 — why a constancy score event was emitted.
///   filled            : positive delta — the member did the work.
///   forgot_no_reason  : negative delta — unfilled without a valid reason.
///   reality_gap       : negative delta — declarative ↔ reality discrepancy.
///   false_declaration : strongest negative delta — proven false declaration.
enum ScoreEventReason {
  filled
  forgot_no_reason
  reality_gap
  false_declaration
}

/// S3 — alert category. Structurally single-valued: an alert is ALWAYS
/// psychological (discipline / ego / honnêteté, à la Mark Douglas). Garde-fou
/// §2: no enum value for trading advice can ever exist here.
enum AlertCategory {
  psychological
}

/// S3 — alert lifecycle. `delivered` = handed to the S5 coaching surface
/// (Mark Douglas delivery / admin view), `dismissed` = closed without action.
enum AlertStatus {
  open
  delivered
  dismissed
}

/// S5 §32-E3 — lifecycle of a mental micro-objective (Mark Douglas engagement
/// loop). `open` = proposed, awaiting the member's next-visit follow-up. The
/// three closed states record HOW the loop closed, never a verdict (§33.2):
///   kept      : the member followed through (the loop's healthy outcome).
///   missed    : not yet done — a progression DATUM, not a reproach.
///   dismissed : the member set it aside.
/// Garde-fou §2: every value is process/mental — no trading outcome can exist here.
enum MentalObjectiveStatus {
  open
  kept
  missed
  dismissed
}

/// S4/S7 — kind of a multi-capture trade attachment ("photos" pluriel §28).
enum TradeMediaKind {
  entry
  exit
  other
}

/// S3 — a broker account the member trades on (prop firm or personal). Rows
/// are created either by the member (self-setup) or by the vision pipeline
/// (`detectedByAI = true` + `confidence`) when Claude counts distinct account
/// headers across the member's MT5 proofs ("détecte au plus précis le nombre
/// exact de comptes" — brief §30).
model BrokerAccount {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Member-facing label ("FTMO 100k", "Compte perso IC Markets").
  label      String
  type       BrokerAccountType
  /// Optional broker name as read from the proof header (free-text, short).
  brokerName String?           @map("broker_name")

  /// S3 vision — the MT5 login (account number) as printed in the proof
  /// header. THE dedup key for "combien de comptes" (§30): two proofs of the
  /// same login resolve to ONE account row. Null for member-declared rows
  /// whose proofs haven't been analysed yet; backfilled by the vision persist
  /// when a proof linked to this row reveals the login.
  accountLogin String? @map("account_login")

  /// True when this account row was created by the vision pipeline rather
  /// than declared by the member — the "réalité vs déclaré" signal.
  detectedByAI Boolean @default(false) @map("detected_by_ai")
  /// Vision confidence 0-1 for AI-detected accounts. Null for member-created.
  confidence   Float?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  proofs    Mt5AccountProof[]
  positions ExtractedPosition[]

  // One account row per (member, MT5 login). Postgres treats NULLs as
  // distinct, so member-declared rows without a login yet never collide.
  @@unique([memberId, accountLogin])
  @@index([memberId])
  @@map("broker_accounts")
}

/// S3 — one uploaded MT5 history screenshot for one account. The vision
/// pipeline (Claude Opus 4.8 local, 5th batch pipeline) consumes `pending`
/// rows and extracts `ExtractedPosition` rows from the image.
model Mt5AccountProof {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// The account this proof documents. Nullable: at upload time the member
  /// may not have attached the proof to an account yet (the pipeline or the
  /// member links it later). SetNull keeps the proof if the account row goes.
  brokerAccountId String?        @map("broker_account_id")
  brokerAccount   BrokerAccount? @relation(fields: [brokerAccountId], references: [id], onDelete: SetNull)

  /// Storage key, `lib/storage` conventions (mirror `Trade.screenshotEntryKey`):
  /// `proofs/{userId}/{nanoid}.{ext}`.
  fileKey  String @map("file_key")
  /// SHA-256 hex of the file bytes — anti-double-upload (a member cannot
  /// submit the same screenshot twice as two "different" proofs) and a cheap
  /// tamper trace. Uniqueness is per-member: two members CAN coincidentally
  /// upload identical bytes (e.g. a shared demo image during testing).
  fileHash String @map("file_hash")

  /// Account type as declared at upload (cross-checked against detection).
  accountType BrokerAccountType? @map("account_type")

  ocrStatus   ProofOcrStatus @default(pending) @map("ocr_status")
  /// Vision batch run identifier (mirror of the other pipelines' audit trail).
  claudeRunId String?        @map("claude_run_id")

  uploadedAt DateTime @default(now()) @map("uploaded_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  positions ExtractedPosition[]

  @@unique([memberId, fileHash])
  @@index([memberId, uploadedAt(sort: Desc)])
  // Vision batch pull: oldest pending proofs first.
  @@index([ocrStatus, uploadedAt])
  @@map("mt5_account_proofs")
}

/// S3 — one position extracted by Claude vision from an MT5 proof. This is
/// the REALITY side of the declarative ↔ reality confrontation. Numbers are
/// Decimal (mirror `Trade` precision); `confidence` carries the vision
/// reading confidence (drives `BrokerAccount.confidence`, shown to the admin).
/// NOTE: the anti-survente guarantee (§33.6 "ne pas accuser à tort") is NOT
/// enforced through this confidence today — it is the reconciliation COVERAGE
/// WINDOW (uncovered vs false_declared, reconcile.ts) that shields an honest
/// member. A per-row confidence gate (a `needs_review` status) stays a possible
/// V2, once the vision emits per-LINE confidence (today it is global per proof).
model ExtractedPosition {
  id String @id @default(cuid())

  brokerAccountId String        @map("broker_account_id")
  brokerAccount   BrokerAccount @relation(fields: [brokerAccountId], references: [id], onDelete: Cascade)

  /// Forensic provenance: which uploaded proof this position was read from.
  /// SetNull — deleting a proof file row keeps the extracted history.
  proofId String?          @map("proof_id")
  proof   Mt5AccountProof? @relation(fields: [proofId], references: [id], onDelete: SetNull)

  /// S3 vision — MT5 ticket/order number as printed in the history row.
  /// Forensic provenance + the strongest dedup key when present (mobile
  /// layouts don't print tickets → nullable; dedup then falls back to the
  /// (symbol, side, openTime, volume) heuristic).
  ticket String?

  /// Instrument as printed by MT5 (uppercase string, no DB enum — mirror
  /// `Trade.pair` rationale).
  symbol String
  side   TradeDirection

  openTime  DateTime  @map("open_time")
  closeTime DateTime? @map("close_time")

  /// Lots, mirror `Trade.lotSize` precision.
  volume     Decimal  @db.Decimal(12, 4)
  entryPrice Decimal? @map("entry_price") @db.Decimal(20, 8)
  exitPrice  Decimal? @map("exit_price") @db.Decimal(20, 8)
  /// P&L in account currency as printed in the MT5 history (2 decimals).
  pnl        Decimal? @db.Decimal(14, 2)

  source     ExtractedPositionSource @default(mt5_screen_ocr)
  /// Vision extraction confidence 0-1 for THIS row.
  confidence Float?

  createdAt DateTime @default(now()) @map("created_at")

  discrepancies Discrepancy[]

  // Reconciliation hot-path: account-scoped, time-ordered window scans.
  @@index([brokerAccountId, openTime])
  @@map("extracted_positions")
}

/// S3 — one detected gap between what the member declared and the proven
/// reality (or an unfilled ritual without a valid reason). Severity 1-3:
/// 1 = minor (timing/size drift), 2 = notable (oubli), 3 = major (false
/// declaration). `claudeReasoning` holds STATIC §2-clean labels written by the
/// deterministic reconciliation engine (reconcile.ts + constancy.ts) — NOT
/// AI-emitted free text. If a future change writes real Claude output here it
/// MUST add detectAMFViolation + detectCrisis + safeFreeText at the write-site.
/// `memberReason` is the member's own explanation ("motif valable" — brief §29:
/// an excused absence is NOT indiscipline); member free text → safeFreeText +
/// crisis routing at the Zod boundary.
model Discrepancy {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  type DiscrepancyType

  /// Declared side (null for missing_declared / unfilled_no_reason).
  declaredTradeId String? @map("declared_trade_id")
  declaredTrade   Trade?  @relation(fields: [declaredTradeId], references: [id], onDelete: SetNull)

  /// Reality side (null for false_declared / unfilled_no_reason).
  extractedPositionId String?            @map("extracted_position_id")
  extractedPosition   ExtractedPosition? @relation(fields: [extractedPositionId], references: [id], onDelete: SetNull)

  /// S3 §31 généralisée — the SCHEDULED meeting this `meeting_missed_no_reason`
  /// gap refers to (null for every other type). THE dedup key: one gap per
  /// (member, meeting). SetNull keeps the gap's lifecycle if the meeting row is
  /// later purged. `detectedAt` is the DETECTION instant (≈ when the rattrapage
  /// window closed, ~30 j after the meeting) so the gap lands inside the
  /// constancy (28 j) + alert (14 j) windows — NOT the old meeting date.
  meetingId String?  @map("meeting_id")
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  /// S3 §32 généralisée — THE dedup ref of a `tracking_skipped_no_reason` gap:
  /// "<instrumentKey>@<occurrenceKey>" (e.g. "process-fidelity@2026-W26"), null for
  /// every other type. `detectedAt` is the DETECTION instant (≈ when the rattrapage
  /// grace closed) so the gap lands inside the constancy (28 j) + alert (14 j)
  /// windows. No FK to the tracking engine (§21.5 isolation: the verification side
  /// references a skipped occurrence by an opaque string, never by a tracking row).
  trackingRef String? @map("tracking_ref")

  /// 1 = minor, 2 = notable, 3 = major. Display/sort signal only — the
  /// ScoreEvent delta is a fixed per-reason constant (reconcile.ts), NOT
  /// derived from this severity.
  severity Int
  status   DiscrepancyStatus @default(open)

  /// Static §2-clean label produced by the deterministic reconciliation engine
  /// (reconcile.ts / constancy.ts). NOT free-text from Claude — the 4 write-
  /// sites write fixed French strings (e.g. "Un trade déclaré dans le journal…").
  /// If a future change writes real Claude output here it MUST add
  /// detectAMFViolation + detectCrisis + safeFreeText at the write-site.
  claudeReasoning String? @map("claude_reasoning") @db.Text

  /// Member-provided valid reason ("j'étais malade", "panne internet").
  /// Distinguishes an EXCUSED gap from indiscipline (brief §29 "sans motif
  /// valable"). safeFreeText + crisis routing at the Zod boundary.
  memberReason   String?   @map("member_reason") @db.Text
  memberReasonAt DateTime? @map("member_reason_at")

  /// S3 §33 « micro-relance avant l'alerte » — set the instant a single gentle
  /// reminder was pushed for THIS gap (≤1 ever). Null = never reminded yet. The
  /// gentle scan stamps it so a benevolent nudge is sent at most once per gap,
  /// BEFORE any repetition alert escalates. Completion metadata only (§21.5).
  gentleReminderAt DateTime? @map("gentle_reminder_at")

  detectedAt DateTime @default(now()) @map("detected_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  scoreEvents ScoreEvent[]

  // One meeting-miss gap per (member, meeting) — the scan dedup key. NULL
  // meetingId rows (every other type) never collide (Postgres NULLs distinct).
  @@unique([memberId, meetingId])
  // One tracking-skip gap per (member, instrument@occurrence). NULL trackingRef
  // rows (every other type) never collide (Postgres NULLs distinct).
  @@unique([memberId, trackingRef])
  // RAW partial unique index `discrepancies_blank_day_uniq` ON (member_id,
  // detected_at) WHERE type = 'unfilled_no_reason' — hand-written in migration
  // 20260629110000 (Prisma 7 can't model a WHERE predicate). Enforces ONE
  // blank-day excuse per (member, civil day); the loser's create folds P2002 to
  // a no-op in constancy.ts. Same convention as discrepancies_reconcile_key_uniq.
  // Member + admin views: open discrepancies first.
  @@index([memberId, status])
  @@index([memberId, detectedAt(sort: Desc)])
  @@map("discrepancies")
}

/// S3 — the constancy & work-investment score (DEDICATED model, decision
/// Eliot 2026-06-10 — distinct from the 4 declarative `BehavioralScore`
/// dimensions because THIS one is confronted with external reality).
/// `value` 0-100; `breakdown` JSON `{ honesty, regularity, discipline }`
/// mirrors the BehavioralScore `components` transparency pattern ("why is
/// my score X?"). Window convention mirrors `WeeklyReport` (periodStart/
/// periodEnd @db.Date + idempotent upsert per period).
model ConstancyScore {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// 0-100. Float (not Int) — event-sourced fractional deltas accumulate;
  /// the UI rounds for display.
  value     Float
  /// `{ honesty: number, regularity: number, discipline: number }` 0-100 each
  /// — validated at the Zod boundary (lib/schemas, S3 session).
  breakdown Json

  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date

  computedAt DateTime @default(now()) @map("computed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Idempotent recompute: one score row per (member, period).
  @@unique([memberId, periodStart])
  @@index([memberId, computedAt(sort: Desc)])
  @@map("constancy_scores")
}

/// S3 — event-sourced journal of constancy deltas ("le score monte et
/// descend correctement selon le comportement" — brief §31 DoD#3). Each row
/// is one auditable reason why the score moved; the score recompute folds
/// the window's events. Keeps the score explainable to the member without
/// complaisance ni culpabilisation gratuite.
model ScoreEvent {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Signed per-event weight (positive = filled/did the work, negative =
  /// forgot / reality gap / false declaration). It records the event's
  /// direction and relative magnitude; it is NOT summed into the score
  /// directly — the weekly fold (constancy.ts) recomputes `value` from the
  /// event REASONS via the honesty/regularity/discipline formulas, so a stored
  /// `-8` does not mean "-8 points on the 0-100 score".
  delta  Float
  reason ScoreEventReason

  /// Audit link to the discrepancy that caused a negative event. SetNull —
  /// purging a discrepancy keeps the score history intact.
  relatedDiscrepancyId String?      @map("related_discrepancy_id")
  relatedDiscrepancy   Discrepancy? @relation(fields: [relatedDiscrepancyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([memberId, createdAt(sort: Desc)])
  @@map("score_events")
}

/// S3 — repetition alert feeding the S5 coaching surface. Garde-fou §2 by
/// construction: `category` is structurally `psychological` (single-value
/// enum — no trading-advice alert can exist). An alert row is only created
/// when `repeatCount >= threshold` (REPETITION ONLY — a single slip never
/// alerts, brief §31 DoD#4). Downstream: a Mark Douglas delivery may carry
/// `sourceAlertId` (S3 → S5 junction), and the weekly/monthly snapshots read
/// count-only alert stats.
model Alert {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Slug of the repeated failure pattern, e.g. `forgot_no_reason_repeat`,
  /// `reality_gap_repeat`, `false_declaration_repeat`. Bounded server-side by
  /// the `ALERT_RULES` constant (alerts.ts) — the single write-site — not by a
  /// Zod allowlist.
  triggerType String @map("trigger_type")

  /// How many times the pattern occurred in the evaluation window…
  repeatCount Int @map("repeat_count")
  /// …and the threshold that was crossed (kept for auditability: "3 oublis
  /// sans motif en 14 jours").
  threshold   Int

  category AlertCategory @default(psychological)
  status   AlertStatus   @default(open)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// S5 coaching deliveries this alert caused (Mark Douglas accompaniment).
  douglasDeliveries MarkDouglasDelivery[]

  @@index([memberId, status])
  // S3 re-challenge — partial UNIQUE index `alerts_active_trigger_uniq`
  // ON (member_id, trigger_type) WHERE status <> 'dismissed' enforces « ≤1 active
  // alert per (member, trigger) » at the DB level (kills the scanAlertsForMember
  // read-then-create race between the cron and the event-driven batch.ts pass).
  // Created in the migration SQL only — Prisma 7 doesn't model partial-index
  // predicates declaratively (same pattern as `discrepancies_reconcile_key_uniq`
  // / `mental_micro_objectives_one_open_per_member`). NOT declared as `@@unique`
  // here to avoid Prisma generating a duplicate full unique index + drift.
  @@map("alerts")
}

/// S5 §32-E3 — a mental/discipline micro-objective the coaching engine proposes
/// to the member, then closes at the next visit (the "boucle d'engagement saine").
/// Created from the member's strongest live mental signal (top mental-map entry,
/// itself derived from an S3 alert or a dominant score signal — traced via
/// `sourceKind`/`sourceRef`, E2/B). The member follows up next visit → the loop
/// closes with an `outcome`-bearing status. Measurable progression (livrable C) =
/// kept / (kept+missed) over closed objectives.
///
/// Garde-fou §2/§33.2 BY CONSTRUCTION: every field is psychological/process —
/// `axis` ∈ {discipline, honesty, ego, consistency} (mirror `MentalAxis` in
/// lib/coaching/mental-map.ts, bounded server-side like `Alert.triggerType`),
/// `title`/`intention` are CURATED Mark Douglas copy (deterministic, never free
/// LLM text → no AIGeneratedBanner), NO P&L / market field can exist. Firewall
/// §21.5: the ONLY relation is to User (cascade RGPD §17) — no FK to Trade /
/// BehavioralScore / ScoreEvent / Alert, so nothing flows back into the real edge.
model MentalMicroObjective {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Mental axis trained — mirror of `MentalAxis` (lib/coaching/mental-map.ts).
  /// Bounded by the coaching layer (single write-site), not a Zod allowlist.
  axis String

  /// Origin motif (E2/B traceability). `sourceKind` ∈ {alert, signal, annotation};
  /// `sourceRef` = the alert id (alert), the score reason (signal), or the tagged
  /// TradeAnnotation/TrainingAnnotation id (annotation — J-AI corrections echo).
  /// Free String bounded by the coaching layer (single write-site), NOT a Prisma
  /// enum, so adding `annotation` needs no migration. Never a FK (firewall §21.5).
  sourceKind String @map("source_kind")
  sourceRef  String @map("source_ref")

  /// Curated member-facing copy captured at creation (longitudinal snapshot —
  /// a later code change to the copy must not rewrite a past objective).
  title     String
  intention String

  status MentalObjectiveStatus @default(open)

  createdAt DateTime  @default(now()) @map("created_at")
  /// Set when the loop closes (status leaves `open`). Null while open.
  closedAt  DateTime? @map("closed_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // "What is the member's open micro-objective?" + closed-history reads.
  @@index([memberId, status])
  // S5 re-challenge #3 — partial UNIQUE index `mental_micro_objectives_one_open_per_member`
  // ON (member_id) WHERE status = 'open' enforces the E3 invariant « ≤1 open per member »
  // at the DB level (kills the ensure() read-then-create race). Created in the migration
  // SQL only — Prisma 7 doesn't model partial-index predicates declaratively (same pattern
  // as `access_requests_email_pending_uniq` / `notification_queue` partials). NOT declared
  // as `@@unique` here to avoid Prisma generating a duplicate full unique index + drift.
  @@map("mental_micro_objectives")
}

/// S4/S7 — multi-capture trade attachment ("photos" pluriel, briefs §28/§29).
/// The legacy single `screenshotEntryKey`/`screenshotExitKey` columns on
/// `Trade` remain the V1 path (backward compat); this table is the additive
/// 1-N path for multi-photo flows. Cascade with the trade (RGPD, mirror
/// `TradeAnnotation`).
model TradeMedia {
  id      String @id @default(cuid())
  tradeId String @map("trade_id")
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  kind    TradeMediaKind @default(entry)
  /// Storage key, `lib/storage` conventions: `trades/{userId}/{nanoid}.{ext}`.
  fileKey String         @map("file_key")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tradeId])
  @@map("trade_media")
}

/// S8 — backtest session container ("crée une session de backtest" — brief
/// 08). Groups `TrainingTrade` entries logged during one practice sitting.
/// FIREWALL §21.5: lives 100% inside the training world — NO link to `Trade`,
/// `BehavioralScore` or any real-edge model, only the implicit User link.
/// All free text safeFreeText-hardened at the Zod boundary.
model TrainingSession {
  id       String @id @default(cuid())
  memberId String @map("member_id")
  member   User   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  /// Member label ("Backtest GBPUSD janvier 2024").
  label     String?
  /// Practised instrument (uppercase string, mirror `TrainingTrade.pair`).
  symbol    String?
  /// Practised timeframe label ("M15", "H1") — free short string, no enum
  /// (mirror `pair` rationale: list evolves without migration).
  timeframe String?

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  notes     String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trades TrainingTrade[]

  @@index([memberId, startedAt(sort: Desc)])
  @@map("training_sessions")
}

// =============================================================================
// Réunion Trading Hub — replay sessions (séances)            [SEANCES — J1]
// =============================================================================
// Native re-platform of the standalone `reunion-trading-hub` static generator
// (D:/Projects/reunion-trading-hub) INTO Fxmily: members open the replays +
// the faithful analysis of Eliott's live meetings with their Fxmily account,
// and Eliott pilots everything from the admin.
//
// Posture §2: these rows hold the REPLAY + a FAITHFUL summary of what Eliott
// SAID in his own formation session (Règle n°1 — verbatim fidelity, zero
// invention). Archived educational content of the coach himself — NOT the app
// emitting trade advice.
//
// 0 FK to the real-edge models (`Trade` / `BehavioralScore` / `User`): a replay
// session is platform-wide admin content (mirror `Meeting` §30.3 isolation),
// not a per-member datum — so no member PII ever lands here and a purge never
// cascades. The local pipeline (Zoom→Vimeo→Fathom→IA `claude -p`) is the WRITER
// (via the J4 cron API); the member/admin surfaces are READERS.

/// Replay session slot. `analyse` = 12h00 Paris meeting, `debrief` = 20h00.
/// Distinct from `MeetingSlot {midday,evening}` (attendance feature) on purpose:
/// this is the CONTENT hub, not the presence tracker.
enum ReplaySlot {
  analyse
  debrief
}

/// Replay session lifecycle (admin go/no-go authority). `scheduled` = declared
/// upcoming (not published) · `done` = held (page published) · `cancelled` =
/// cancelled (minimal page). Mirrors the static hub status so the pipeline maps 1:1.
enum ReplayStatus {
  scheduled
  done
  cancelled
}

/// Normalised directional bias of a followed asset, consumed by the bias panel.
/// The pipeline maps the IA vocabulary (long/haussier/bull → haussier,
/// short/baissier/bear → baissier, neutre → neutre) at the ingest boundary, so
/// the DB only ever holds the 3 canonical values. Posture §2: this qualifies
/// what Eliott SAID in the replay, never a live recommendation from the app.
enum ReplayBias {
  haussier
  baissier
  neutre
}

/// Source of the transcript the IA content was derived from (traceability,
/// Règle n°1). `fathom` = nominal voice ; `whisper`/`manual` = faithful local
/// fallback (degraded mode). Never displayed raw — only the derived summary.
enum ReplayTranscriptSource {
  fathom
  whisper
  manual
}

/// One recorded meeting session (séance) = the content unit of the réunion hub.
/// Keyed by `(date, slot)` (one analyse + one debrief per civil day, mirror the
/// static generator's clean URL `/{date}/{slot}/`). Holds the published, DERIVED
/// content (Vimeo replay + summary + key takeaways + per-asset analysis) — the
/// raw transcript segments stay in the local pipeline (source of truth) and are
/// NOT mirrored here (data minimisation + posture §2).
model ReplaySession {
  id String @id @default(cuid())

  /// Civil day (Europe/Paris) of the session. `@db.Date` pins UTC-midnight
  /// (canon DailyCheckin/Meeting). DERIVED from the meeting's real start by the
  /// pipeline, never recomputed downstream (anti DST-drift, mirror §30.7).
  date   DateTime     @db.Date
  slot   ReplaySlot
  status ReplayStatus @default(scheduled)

  /// Display title (e.g. "Analyse du 29 juin"). Pipeline-derived from slot+date.
  title String

  /// FR display time, bounded "00h00".."23h59" ("12h00" / "20h00"), exactly as
  /// the admin declares it (zero-padded). Bornes the recovery window upstream.
  time String?

  /// Short 1-2 sentence summary shown under the title (IA-derived, Règle n°1).
  summary String? @db.Text

  /// A-Z key takeaways of the WHOLE session (IA, Règle n°1, zero invention):
  /// the through-line, macro context, global decisions — the primary debrief
  /// surface "understandable without having watched the meeting".
  /// `@default([])`: a non-optional scalar list must store `[]` (never SQL NULL)
  /// so `isEmpty`/`NOT has` filters stay correct and the column matches its
  /// non-nullable TS type (Prisma scalar-list NULL gotcha; cf. migration).
  keyTakeaways String[] @default([]) @map("key_takeaways")

  /// Replay duration in seconds (optional).
  duration Int?

  /// Reason shown when `status = cancelled` (free-text, `safeFreeText`-sanitised
  /// at the admin Server Action boundary).
  cancelReason String? @map("cancel_reason") @db.Text

  // ── Vimeo replay (unlisted + privacy hash) ────────────────────────────────
  /// Numeric Vimeo video id.
  vimeoId         String? @map("vimeo_id")
  /// Privacy hash (unlisted). REQUIRED with `vimeoId` for the embed `h=` param.
  vimeoHash       String? @map("vimeo_hash")
  /// Pre-computed embed URL (optional; else derived from id+hash).
  vimeoEmbedUrl   String? @map("vimeo_embed_url")
  /// True while Vimeo transcodes: shows "en préparation" without loading the player.
  vimeoProcessing Boolean @default(false) @map("vimeo_processing")

  // ── Transcript metadata (content lives derived, never raw here) ───────────
  transcriptSource  ReplayTranscriptSource? @map("transcript_source")
  transcriptLang    String?                 @map("transcript_lang")
  /// True = transcript expected but not yet arrived (Fathom async): the page
  /// ships with the replay first, enriched later. Symmetric to vimeoProcessing.
  transcriptPending Boolean                 @default(false) @map("transcript_pending")

  // ── IA content traceability (text help, never the transcript) ─────────────
  contentGenerated   Boolean @default(false) @map("content_generated")
  contentModel       String? @map("content_model")
  /// True if the IA failed / went off-schema → content to regenerate (fallback
  /// renders replay-only, never a fabricated analysis).
  contentNeedsReview Boolean @default(false) @map("content_needs_review")

  // ── Pipeline idempotence checkpoints (admin status surface, J3) ───────────
  cpMp4        Boolean @default(false) @map("cp_mp4")
  cpVimeo      Boolean @default(false) @map("cp_vimeo")
  cpTranscript Boolean @default(false) @map("cp_transcript")
  cpAi         Boolean @default(false) @map("cp_ai")
  cpDeployed   Boolean @default(false) @map("cp_deployed")

  // ── Pipeline failure (admin "jamais d'échec silencieux", J3) ──────────────
  /// Failing FSM step (mp4|vimeo|transcript|ai|deployed). Null unless failed.
  /// The 5th key is `deployed` (the `cpDeployed` checkpoint / `STEP_DEFS` key in
  /// `admin-derive.ts` + the J4 pipeline `failure.step` enum) — NOT `deploy`.
  pipelineFailedStep  String? @map("pipeline_failed_step")
  /// Diagnostic (never a secret). Null unless failed.
  pipelineFailedError String? @map("pipeline_failed_error") @db.Text

  /// When the local pipeline last touched this row (heartbeat / freshness).
  pipelineSyncedAt DateTime? @map("pipeline_synced_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assets   ReplayAsset[]
  messages ReplayMessage[]

  /// One analyse + one debrief per civil day (idempotent pipeline upsert key,
  /// mirror Meeting `@@unique(date, slot)`). Doubles as the hub listing filter.
  @@unique([date, slot])
  /// Hub listing: sessions by status, newest-first. No standalone `[status]` or
  /// `[date]` index — redundant prefixes (repo convention).
  @@index([status, date(sort: Desc)])
  @@map("replay_sessions")
}

/// One followed asset within a replay session (comparable cards; DXY = macro).
model ReplayAsset {
  id        String        @id @default(cuid())
  sessionId String        @map("session_id")
  session   ReplaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// Symbol ("EURUSD", "XAUUSD", "NQ", "SP500", "GBPUSD", "DXY").
  symbol String
  /// Human-readable name ("Euro / Dollar").
  name   String?
  /// Normalised directional bias (see `ReplayBias`). Null if not stated.
  bias   ReplayBias?
  /// True for a macro-context asset (e.g. DXY), rendered apart.
  macro  Boolean     @default(false)

  /// Key levels as `[{ label, value }]` (display-only, small) — Json mirrors the
  /// static hub contract; the SVG ladder only ever plots stated numeric values.
  levels  Json?
  /// Full A-Z reading of the asset (debrief): faithful paragraphs, zero ajout
  /// hors transcript (Règle n°1). Length follows the matter actually said.
  /// `@default([])` so an asset with no reading stores `[]`, never SQL NULL
  /// (non-nullable list invariant, mirror `ReplaySession.keyTakeaways`).
  reading String[] @default([])

  /// Display order within the session (DXY/macro rendered apart regardless).
  position Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// One row per symbol per session (idempotent pipeline upsert + collision
  /// guard the static hub enforced at build, lifted to a DB invariant).
  @@unique([sessionId, symbol])
  /// Ordered render within a session.
  @@index([sessionId, position])
  @@map("replay_assets")
}

/// One of the 6 Discord messages (5 assets + DXY) shown in the admin for copy
/// before the session. Pipeline-produced (IA), admin-only surface.
model ReplayMessage {
  id        String        @id @default(cuid())
  sessionId String        @map("session_id")
  session   ReplaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// Target asset label ("EURUSD", … "DXY").
  asset String
  /// Message body (verbatim-faithful, copy-paste ready).
  text  String @db.Text

  /// Display/copy order (DXY last = 6th, mirror the static hub).
  position Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// One message per asset per session (idempotent pipeline upsert).
  @@unique([sessionId, asset])
  /// Ordered copy list in the admin.
  @@index([sessionId, position])
  @@map("replay_messages")
}

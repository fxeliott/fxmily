# Fxmily cron environment template.
#
# Place at `/etc/fxmily/cron.env` (mode 0600, owner fxmily:fxmily).
# Sourced by `/usr/local/bin/fxmily-cron` and `/usr/local/bin/fxmily-backup`.
#
# DO NOT commit a populated copy of this file. Real secrets live in the
# host filesystem only — they never enter the Docker image.

# Shared secret with the Next.js `/api/cron/*` route handlers.
# Generate via : `openssl rand -hex 24`
# Keep in sync with the `CRON_SECRET` value inside `/etc/fxmily/web.env`
# (which the Docker `web` service reads). Rotation playbook : update both
# files atomically (`mv -i` after a tmp write), then `docker compose
# restart web`. Mismatched secrets just produce 401s in the cron log.
CRON_SECRET=changeme_openssl_rand_hex_24_BYTES_REQUIRED

# App URL the cron wrapper curls into. Always HTTPS in production.
APP_URL=https://app.fxmilyapp.com

# Backup-only — passphrase for `gpg --symmetric` of the pg_dump archive
# before R2 upload. Same length recommendation : `openssl rand -base64 32`.
# Stored in plain at 0600 because `gpg --batch --passphrase-file` is the
# only way to keep the wrapper non-interactive without an agent.
GPG_PASS_FILE=/etc/fxmily/gpg.pass

# R2 endpoint (Cloudflare R2 S3-compatible). Bucket name + creds live in
# the AWS CLI profile `fxmily-backup` (configured separately on the host).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=fxmily-backups

# Log file the cron wrapper appends each run (counts only, no PII —
# the audit row in Postgres is the canonical record).
CRON_LOG=/var/log/fxmily/cron.log

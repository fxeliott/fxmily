# Fxmily cron environment template.
#
# Place at `/etc/fxmily/cron.env` (mode 0600, owner fxmily:fxmily).
# Sourced by `/usr/local/bin/fxmily-cron`, `/usr/local/bin/fxmily-backup`,
# and `/usr/local/bin/fxmily-autoheal`.
#
# DO NOT commit a populated copy of this file. Real secrets live in the
# host filesystem only — they never enter the Docker image.

# Shared secret with the Next.js `/api/cron/*` route handlers.
# Generate via : `openssl rand -hex 24`
# Keep in sync with the `CRON_SECRET` value inside `/etc/fxmily/web.env`
# (which the Docker `web` service reads). Rotation playbook : update both
# files atomically (`mv -i` after a tmp write), then `docker compose
# restart web`. Mismatched secrets just produce 401s in the cron log.
CRON_SECRET=changeme_openssl_rand_hex_24_BYTES_REQUIRED

# App URL the cron wrapper curls into. Always HTTPS in production.
APP_URL=https://app.fxmilyapp.com

# Backup-only — passphrase for `gpg --symmetric` of the pg_dump archive
# before R2 upload. Same length recommendation : `openssl rand -base64 32`.
# Stored in plain at 0600 because `gpg --batch --passphrase-file` is the
# only way to keep the wrapper non-interactive without an agent.
GPG_PASS_FILE=/etc/fxmily/gpg.pass

# R2 endpoint (Cloudflare R2 S3-compatible). Bucket name + creds live in
# the AWS CLI profile `fxmily-backup` (configured separately on the host).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=fxmily-backups

# §9-B durability gate. Set to 1 on PRODUCTION once R2 above is wired: an
# off-site upload that is missing/unconfigured then becomes a HARD failure
# (fxmily-backup exit 4) so monitoring fires, instead of a green cron silently
# keeping a local-only, non-disaster-safe backup. Leave 0 on pre-R2 hosts —
# the backup still runs locally but logs a LOUD warning every night.
BACKUP_REQUIRE_OFFSITE=0

# Dead-man-switch ping URLs (opt-in). After a fully-successful run, each backup
# script pings its URL; a MISSING ping (cron died, host down, step failed) lets
# Healthchecks.io fire an alert once the grace window lapses — so a silently
# stopped backup cron no longer goes unnoticed. Provision the checks via
# `ops/scripts/healthchecks-setup.sh`, then paste the hc-ping.com URLs below.
# Leave blank to disable (the scripts no-op the ping). HEALTHCHECK_PING_URL is
# the shared fallback if a per-script URL is unset.
HEALTHCHECK_PING_URL=
HEALTHCHECK_PING_URL_PG=
HEALTHCHECK_PING_URL_UPLOADS=
HEALTHCHECK_PING_URL_CADDY=

# Autoheal watchdog alert (opt-in). The host self-healing watchdog
# (`/usr/local/bin/fxmily-autoheal`, every minute) is SIGNAL-AWARE
# (healthchecks.io semantics):
#   - successful restart  → GET AUTOHEAL_ALERT_URL           (OK signal)
#   - escalation ("still unhealthy after cooldown — human needed")
#     or restart command error → GET <AUTOHEAL_ALERT_URL>/fail (FAILURE signal
#     → healthchecks.io notifies the operator on the transition)
# so a chronically unhealthy container reaches a human, not just
# /var/log/fxmily/autoheal.log. Use an hc-ping.com check URL. Leave blank to
# disable (the watchdog no-ops the ping). Without this the alert path is dead
# by default (audit INFRA-03).
AUTOHEAL_ALERT_URL=

# Optional override for the FAILURE endpoint above. Only needed when the
# receiver is NOT healthchecks.io-compatible (default = AUTOHEAL_ALERT_URL
# + "/fail", which is the hc-ping.com convention). Leave blank otherwise.
AUTOHEAL_ALERT_FAIL_URL=

# Log file the cron wrapper appends each run (counts only, no PII —
# the audit row in Postgres is the canonical record).
CRON_LOG=/var/log/fxmily/cron.log

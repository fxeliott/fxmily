#!/usr/bin/env bash
# /usr/local/bin/fxmily-backup — daily Postgres dump → GPG → R2 upload.
#
# Wired by `/etc/cron.d/fxmily-app` daily at 02:30 UTC (after the score
# recompute window so the snapshot reflects the full day's writes).
#
# Failure semantics :
#   - dump failure  → exit 1, no upload, alert via cron stderr
#   - encrypt fail  → exit 2, leaves un-encrypted dump on disk for ops
#   - upload fail   → exit 3, encrypted dump preserved locally (R2 retry
#                     by hand or wait for the next 02:30 cycle)
#
# Local retention : 7 days (`-mtime +7 -delete`).
# Remote retention : 30 days (R2 lifecycle policy applied bucket-side).

set -euo pipefail

# shellcheck disable=SC1091
source /etc/fxmily/cron.env  # GPG_PASS_FILE, R2_ENDPOINT, R2_BUCKET, CRON_LOG

CRON_LOG="${CRON_LOG:-/var/log/fxmily/cron.log}"
BACKUP_DIR="/etc/fxmily/backups"
TS=$(date -u +%Y%m%d-%H%M)
DUMP_FILE="${BACKUP_DIR}/fxmily-${TS}.sql.gz"
ENCRYPTED_FILE="${DUMP_FILE}.gpg"

mkdir -p "$BACKUP_DIR"
mkdir -p "$(dirname "$CRON_LOG")"

ts() { date -u +'%Y-%m-%dT%H:%M:%SZ'; }
log() { echo "[$(ts)] [fxmily-backup] $*" >> "$CRON_LOG"; }

log "starting → $DUMP_FILE"

# ---- 1. pg_dump from inside the Postgres container -------------------------
# `compose exec -T` keeps stdin closed (no TTY) so cron stays clean.
# `pg_dump --no-owner --no-acl` strips the `fxmily` role grants so a
# restore on a fresh DB doesn't fail when the role doesn't exist yet.
if ! docker compose -f /opt/fxmily/docker-compose.prod.yml exec -T postgres \
    pg_dump --no-owner --no-acl -U fxmily fxmily | gzip > "$DUMP_FILE"; then
  log "FAIL pg_dump ; partial file removed"
  rm -f "$DUMP_FILE"
  exit 1
fi
DUMP_SIZE=$(du -h "$DUMP_FILE" | cut -f1)
log "dump OK ($DUMP_SIZE)"

# ---- 1b. Integrity + non-empty guard --------------------------------------
# `pipefail` catches a pg_dump *error*, but not a silently truncated/corrupt
# gzip stream or a 0-byte dump. A backup you cannot decompress is not a backup
# (§9-B: proven restores, not backups). Verify before we throw away step 1's
# work and call the day "backed up".
if ! gzip -t "$DUMP_FILE" 2>/dev/null; then
  log "FAIL dump failed gzip integrity check ; removing corrupt file"
  rm -f "$DUMP_FILE"
  exit 1
fi
DUMP_BYTES=$(stat -c%s "$DUMP_FILE" 2>/dev/null || echo 0)
if (( DUMP_BYTES < 1000 )); then
  log "FAIL dump suspiciously small (${DUMP_BYTES} bytes) ; removing"
  rm -f "$DUMP_FILE"
  exit 1
fi

# ---- 2. GPG symmetric encryption ------------------------------------------
# AES-256 + iter+salted S2K (gpg defaults). Passphrase from a 0600 file —
# never on the command line (would leak via /proc/<pid>/cmdline).
if ! gpg --cipher-algo AES256 --symmetric --batch --yes \
    --passphrase-file "$GPG_PASS_FILE" "$DUMP_FILE"; then
  log "FAIL gpg encrypt ; un-encrypted dump preserved at $DUMP_FILE for ops"
  exit 2
fi
log "encrypt OK → $ENCRYPTED_FILE"

# Strict cleanup of the un-encrypted file as soon as the encrypted one
# exists. Replace, don't keep both — disk on CX22 is 40 GB.
rm -f "$DUMP_FILE"

# ---- 3. R2 upload (optional V1, mandatory V2 if cross-region DR target) ----
# Step skipped silently if R2_ENDPOINT is unset/empty (V1 launch state) OR
# if `aws` CLI is not installed. The encrypted dump remains on local disk
# under 7-day rotation (step 4). The 30-day R2 lifecycle only kicks in
# once R2 is wired (Cloudflare R2 bucket + API token + `aws configure`).
#
# `aws --profile fxmily-backup` was provisioned at first deploy with the
# R2 access keys (Cloudflare → R2 → API Tokens → "Object Read & Write").
# `--no-progress` keeps the cron stderr noise-free.
R2_ENDPOINT="${R2_ENDPOINT:-}"
R2_BUCKET="${R2_BUCKET:-}"
# §9-B — off-host backup is THE durability guarantee. A copy that only lives
# on the same VPS disk is gone the moment the disk/host dies. Set
# `BACKUP_REQUIRE_OFFSITE=1` in cron.env on any host that must not lose data
# (i.e. production): a missing/unconfigured off-site target then becomes a HARD
# failure (exit 4) so the dead-man-switch / healthchecks fires, instead of a
# green cron silently hiding a non-durable backup. Default 0 keeps pre-R2
# environments working but emits a LOUD warning every run.
REQUIRE_OFFSITE="${BACKUP_REQUIRE_OFFSITE:-0}"
offsite_missing() {
  local reason="$1"
  if [[ "$REQUIRE_OFFSITE" == "1" ]]; then
    log "FAIL off-site backup REQUIRED but $reason — encrypted dump kept locally for manual upload"
    exit 4
  fi
  log "WARNING off-site backup skipped ($reason) — LOCAL-ONLY, NOT disaster-safe. Set BACKUP_REQUIRE_OFFSITE=1 once R2 is wired."
}
if [[ -z "$R2_ENDPOINT" || -z "$R2_BUCKET" ]]; then
  offsite_missing "R2_ENDPOINT or R2_BUCKET unset"
elif ! command -v aws >/dev/null 2>&1; then
  offsite_missing "aws CLI not installed"
elif ! aws s3 cp "$ENCRYPTED_FILE" "s3://${R2_BUCKET}/$(basename "$ENCRYPTED_FILE")" \
    --endpoint-url "$R2_ENDPOINT" \
    --profile fxmily-backup \
    --no-progress; then
  log "FAIL R2 upload ; encrypted dump preserved locally for retry"
  exit 3
else
  log "upload OK → s3://${R2_BUCKET}/$(basename "$ENCRYPTED_FILE")"
fi

# ---- 4. Local retention ----------------------------------------------------
# 7 days local. Older files were already on R2 (30-day lifecycle there).
find "$BACKUP_DIR" -name 'fxmily-*.sql.gz.gpg' -mtime +7 -delete
log "rotation OK (kept 7 days local)"

log "done"

#!/usr/bin/env bash
# /usr/local/bin/fxmily-cron — invoke a Fxmily cron endpoint with the secret.
#
# Carbon-copy of the J6 runbook helper, extended in J10 to log per-route
# exit status into the central cron log. Used by `/etc/cron.d/fxmily-app`.
#
# Usage :
#   fxmily-cron <route>
#       e.g. fxmily-cron recompute-scores
#            fxmily-cron purge-deleted
#
# Sources : /etc/fxmily/cron.env (CRON_SECRET, APP_URL, CRON_LOG).
# Logs to : $CRON_LOG (default /var/log/fxmily/cron.log).
#
# Exit codes :
#   0   route returned 200/2xx
#   22  route returned non-2xx (curl --fail-with-body)
#   28  curl timeout
#   2   misuse (no route given)

set -euo pipefail

ROUTE="${1:-}"
if [[ -z "$ROUTE" ]]; then
  echo "usage: fxmily-cron <route>" >&2
  exit 2
fi

# Allowlist (J10 Phase G hardening — code-reviewer B4 + security-auditor T1.1).
# `$ROUTE` is interpolated into the curl URL ; un-validated input would let a
# compromise of /etc/cron.d/* reach arbitrary `/api/...` paths via traversal
# (`../auth/signin?evil=1`) and exfiltrate `CRON_SECRET` via Host header. The
# Next.js side ALSO refuses unknown cron routes (404) but defense-in-depth
# starts here, before the secret leaves the host.
case "$ROUTE" in
  checkin-reminders|recompute-scores|recompute-leaderboard|dispatch-douglas|weekly-reports|dispatch-notifications|purge-deleted|purge-push-subscriptions|purge-audit-log|mindset-check-reminders|generate-meetings|purge-access-requests|calendar-overdue-alert|monthly-debrief-overdue-alert|onboarding-profile-overdue-alert|verification-scan|weekly-report-overdue-alert|verification-batch-overdue-alert|admin-daily-brief|restore-drill) ;;
  *)
    echo "[fxmily-cron] route '$ROUTE' is not in the allowlist" >&2
    exit 2
    ;;
esac

# Source secrets. Fail-loud if missing — refuse to run blind.
if [[ ! -r /etc/fxmily/cron.env ]]; then
  echo "[fxmily-cron] /etc/fxmily/cron.env unreadable (mode 0600 + owner ?)" >&2
  exit 2
fi
# shellcheck disable=SC1091
source /etc/fxmily/cron.env

CRON_LOG="${CRON_LOG:-/var/log/fxmily/cron.log}"

ts() { date -u +'%Y-%m-%dT%H:%M:%SZ'; }

mkdir -p "$(dirname "$CRON_LOG")"

START_TS="$(ts)"

# Tour 15 — `restore-drill` is a LOCAL host binary, not an /api/cron route.
# It routes through this wrapper so the host crontab only ever uses the ONE
# line shape every deployed generation of the root validator accepts
# (`fxmily /usr/local/bin/fxmily-cron <task>`). The validator is root-pinned
# and never self-converges from the fxmily-writable staging dir (by design:
# that path would be a root escalation), so a crontab line must NEVER depend
# on a newer validator regex — the tour-14 direct `fxmily-restore-drill`
# line proved it by failing the 2026-07-06 deploy against the still-installed
# tour-12 validator. THIS runner, by contrast, IS converged on every deploy.
if [[ "$ROUTE" == "restore-drill" ]]; then
  DRILL_BIN=/usr/local/bin/fxmily-restore-drill
  if [[ ! -x "$DRILL_BIN" ]]; then
    echo "[$(ts)] [fxmily-cron] restore-drill FAIL: $DRILL_BIN missing — reinstall the up-to-date fxmily-sync-cron (it installs the drill binary), see ops/cron/README.md" >> "$CRON_LOG"
    exit 22
  fi
  if "$DRILL_BIN" >> "$CRON_LOG" 2>&1; then
    echo "[$(ts)] [fxmily-cron] restore-drill OK ($START_TS → $(ts))" >> "$CRON_LOG"
    exit 0
  fi
  echo "[$(ts)] [fxmily-cron] restore-drill FAIL non-zero exit ($START_TS → $(ts))" >> "$CRON_LOG"
  exit 22
fi

# `--max-time 600` — most cron tasks return < 60s. The 10-minute ceiling
# protects against a stuck weekly-reports run from blocking the next run.
# `--retry 0` because re-firing a non-idempotent route is worse than a
# missed run (the cron will fire again on the next schedule).
HTTP_CODE=$(curl \
  --silent \
  --show-error \
  --output /dev/null \
  --write-out '%{http_code}' \
  --max-time 600 \
  --retry 0 \
  -X POST \
  -H "X-Cron-Secret: ${CRON_SECRET}" \
  -H "User-Agent: fxmily-cron/1.0" \
  "${APP_URL}/api/cron/${ROUTE}" \
  || echo "000")

END_TS="$(ts)"

if [[ "$HTTP_CODE" == "200" ]]; then
  echo "[$END_TS] [fxmily-cron] $ROUTE OK ($START_TS → $END_TS)" >> "$CRON_LOG"
  exit 0
else
  echo "[$END_TS] [fxmily-cron] $ROUTE FAIL http=$HTTP_CODE ($START_TS → $END_TS)" >> "$CRON_LOG"
  # Exit 22 mimics curl's --fail-with-body convention so monit / cron
  # alert wrappers can tell apart "endpoint replied error" from "host
  # broken" (network errors come back as 28/56/etc).
  exit 22
fi

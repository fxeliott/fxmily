#!/usr/bin/env bash
# /usr/local/bin/fxmily-autoheal — host-side self-healing watchdog (§9-C).
#
# WHY THIS EXISTS
# --------------
# `restart: unless-stopped` (docker-compose.prod.yml) only restarts a container
# that has EXITED. It does NOT restart a container that is running-but-UNHEALTHY
# — e.g. the Next.js process is alive but `/api/health` returns 503 because the
# Prisma pool deadlocked, the event loop stalled, or a dependency is wedged.
# Docker marks it `unhealthy`, Caddy returns 502/503 to members, and nothing
# ever heals it. This watchdog closes that gap: it polls the Docker HEALTHCHECK
# status and bounces any container whose health is `unhealthy`.
#
# WHY A HOST SCRIPT (not the willfarrell/autoheal container)
# --------------------------------------------------------
# Consistent with the existing architecture (crons run on the host, not in
# containers — see docker-compose.prod.yml header): no extra image to pin/patch,
# no Docker socket mounted INTO a container (smaller attack surface), fully
# reproducible from this repo.
#
# WIRING (host, one-time — see ops/scripts/provision-* / runbook):
#   cp ops/scripts/fxmily-autoheal /usr/local/bin/ && chmod +x /usr/local/bin/fxmily-autoheal
#   then a root entry in /etc/cron.d/fxmily-app (crontab.fxmily) runs it every minute.
#
# SELF-HEALING WITHOUT HIDING CHRONIC FAILURE
# -------------------------------------------
# A blind restart-every-minute loop would mask a container that is broken for a
# real reason. So we apply a COOLDOWN: after a restart we wait COOLDOWN_SECS
# before acting again. If a container is STILL unhealthy after the cooldown, we
# fire the FAIL signal of the alert URL ("self-heal tried, human needed") —
# healthchecks.io then notifies the operator on the transition. A successful
# restart pings the base (OK) URL so the check also works as a dead-man switch.

set -euo pipefail

# Load operator config (AUTOHEAL_ALERT_URL, cooldown, paths) the same way
# fxmily-backup does. The root crontab entry passes no env, so WITHOUT this the
# alert URL is always empty in prod and every restart/escalation stays silent
# (audit INFRA-03/RES-2). Runs as root → can read the 0600 owner-only file.
CRON_ENV="${FXMILY_CRON_ENV:-/etc/fxmily/cron.env}"
# shellcheck disable=SC1090
[[ -r "$CRON_ENV" ]] && source "$CRON_ENV"

# Containers to watch. Kept explicit (not label-discovered) so a misconfigured
# label can never silently drop a service from the watchdog.
#
# fxmily-postgres is the worst single point of failure (a wedged DB takes the
# whole app down) and it DOES define a healthcheck (pg_isready), so it is
# watched. If Postgres is bounced, `web`'s Prisma pool goes stale → `web`'s own
# healthcheck flips unhealthy → the next tick heals `web` too (≤60s), so no
# explicit cascade is needed here.
#
# fxmily-caddy is intentionally NOT listed: it declares no healthcheck in
# docker-compose.prod.yml, so its status is always `nohealth` (a no-op here).
# Adding a Caddy healthcheck blindly could trip a restart loop, so that is left
# to a deliberate compose change first.
CONTAINERS=("fxmily-web" "fxmily-postgres")

COOLDOWN_SECS="${AUTOHEAL_COOLDOWN_SECS:-300}"   # 5 min between restarts of the same container
STATE_DIR="${AUTOHEAL_STATE_DIR:-/var/lib/fxmily/autoheal}"
LOG_FILE="${AUTOHEAL_LOG:-/var/log/fxmily/autoheal.log}"
# Optional dead-man-switch / alert ping fired on every restart (healthchecks.io
# style URL). Left empty = no ping.
ALERT_URL="${AUTOHEAL_ALERT_URL:-}"

mkdir -p "$STATE_DIR" "$(dirname "$LOG_FILE")"

ts() { date -u +'%Y-%m-%dT%H:%M:%SZ'; }
log() { echo "[$(ts)] [fxmily-autoheal] $*" >> "$LOG_FILE"; }

# Single-flight: a slow `docker restart` can outlast the 1-min cron cadence, so
# a second invocation could act on the same container concurrently. Hold a
# non-blocking lock; a stacked run exits cleanly instead of thrashing (INFRA-04).
exec 9>"${STATE_DIR}/autoheal.lock"
flock -n 9 || exit 0

# Fire the optional alert / dead-man-switch URL. Best-effort: a failed ping must
# never abort the watchdog (that would defeat self-healing). No-op when
# AUTOHEAL_ALERT_URL is unset.
#
# SIGNAL-AWARE (2026-07-02 fix, semantic-inversion bug): before this fix every
# outcome — successful restart, escalation, restart failure — sent the SAME
# bare GET to the base URL. On healthchecks.io a bare GET is a SUCCESS signal,
# so the "human needed" escalation actively RESET the dead-man timer and
# suppressed the very alarm it was supposed to raise. Now:
#   alert_ping        → base URL        (healthchecks.io OK signal)
#   alert_ping fail   → <base>/fail     (healthchecks.io FAILURE signal →
#                        immediate operator notification on the transition)
# A non-healthchecks receiver can point AUTOHEAL_ALERT_FAIL_URL somewhere else;
# it defaults to <AUTOHEAL_ALERT_URL>/fail.
alert_ping() {
  local kind="${1:-ok}"
  [[ -n "$ALERT_URL" ]] || return 0
  local url="$ALERT_URL"
  if [[ "$kind" == "fail" ]]; then
    url="${AUTOHEAL_ALERT_FAIL_URL:-${ALERT_URL%/}/fail}"
  fi
  curl -fsS -m 10 --retry 3 "$url" >/dev/null 2>&1 ||
    log "WARN alert ping (${kind}) failed"
}

container_health() {
  # Prints the health status, or "missing" if the container does not exist.
  docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}nohealth{{end}}' \
    "$1" 2>/dev/null || echo "missing"
}

for c in "${CONTAINERS[@]}"; do
  status="$(container_health "$c")"

  case "$status" in
    healthy | starting | nohealth | missing)
      # healthy / still starting / no healthcheck / not present → nothing to do.
      # (`missing` during a deploy swap is transient; the deploy owns that path.)
      continue
      ;;
    unhealthy)
      marker="${STATE_DIR}/${c}.last-restart"
      now_epoch="$(date -u +%s)"
      last_epoch=0
      [[ -f "$marker" ]] && last_epoch="$(cat "$marker" 2>/dev/null || echo 0)"
      age=$(( now_epoch - last_epoch ))

      if (( age < COOLDOWN_SECS )); then
        # Already restarted recently and STILL unhealthy → escalate, don't thrash.
        log "ESCALATION ${c} still unhealthy ${age}s after the last restart (cooldown ${COOLDOWN_SECS}s) — manual intervention likely needed"
        alert_ping fail
        continue
      fi

      log "RESTART ${c} is unhealthy — restarting (last restart ${age}s ago)"
      if docker restart "$c" >/dev/null 2>&1; then
        echo "$now_epoch" > "$marker"
        log "RESTART ${c} restart issued OK"
        alert_ping
      else
        log "FAIL ${c} restart command failed — manual intervention required"
        alert_ping fail
      fi
      ;;
    *)
      log "WARN ${c} unknown health status '${status}'"
      ;;
  esac
done

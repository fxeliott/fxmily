# Phase M bootstrap — copy this file to `tokens.local.env`, fill the values,
# then `chmod 600 tokens.local.env` AND `shred -u` after the bootstrap
# script has run.
#
# This file MUST NEVER be committed (covered by .gitignore `*.local.env`).
#
# **V1 default (post-Phase R 2026-05-09)** :
#   - Use existing Hetzner `hetzner-dieu` (178.104.39.201) → set
#     `FXMILY_HETZNER_IP` and pass `--skip-hetzner` to bootstrap.
#   - Use existing domain `fxmilyapp.com` → `FXMILY_DOMAIN` already
#     defaults to it (env var optional override).

# =============================================================================
# REQUIRED — provider tokens
# =============================================================================

# Hetzner Cloud — Read & Write API Token (Project → Security → API Tokens)
# **OPTIONAL** if reusing existing server (set FXMILY_HETZNER_IP and pass
# --skip-hetzner). Required only if provisioning a new CX22.
HCLOUD_TOKEN=

# Cloudflare — Custom API Token (Profile → API Tokens → Create Token)
#   Permissions : Zone:Zone:Read + Zone:DNS:Edit
#   Zone Resources : Include / Specific zone / fxmilyapp.com
#   TTL : 90 jours recommandé (rotation calendar reminder J-7)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=fxmilyapp.com
# Récupérer dans Cloudflare → fxmilyapp.com → Overview → sidebar API → Zone ID
CLOUDFLARE_ZONE_ID=

# Resend — API Key "Sending access" only (NOT "Full access")
# Dashboard → API Keys → Create API Key
RESEND_API_KEY=

# Sentry — DSN + Auth Token (recommandé : Region EU/Frankfurt pour RGPD)
#   - SENTRY_DSN : Settings → Projects → fxmily-web → Client Keys (DSN)
#   - SENTRY_AUTH_TOKEN : Settings → Auth Tokens → Create New Token
#     (Sentry org auth tokens en 2026 ; bundle scopes auto)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=fxmily
SENTRY_PROJECT=fxmily-web

# =============================================================================
# REQUIRED — locally-generated secrets (NEVER paste a real secret in Claude!)
# =============================================================================

# AUTH_SECRET : `openssl rand -base64 32` — JWT signing key
AUTH_SECRET=
AUTH_URL=https://app.fxmilyapp.com

# CRON_SECRET : `openssl rand -hex 24` — cron route gate
CRON_SECRET=

# VAPID keys : `pnpm --filter @fxmily/web exec web-push generate-vapid-keys`
# IMPORTANT : VAPID_PUBLIC_KEY = NEXT_PUBLIC_VAPID_PUBLIC_KEY (same value)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:eliot@fxmilyapp.com

# =============================================================================
# REQUIRED — runtime config
# =============================================================================

# Database — Postgres on hetzner-dieu (existing). Password chosen by Eliot.
DATABASE_URL=postgresql://fxmily:CHOOSE_A_STRONG_PASSWORD_32_CHARS@localhost:5432/fxmily?schema=public

# Resend — sender + recipient
RESEND_FROM=Fxmily <noreply@fxmilyapp.com>
WEEKLY_REPORT_RECIPIENT=eliot@fxmilyapp.com

# =============================================================================
# OPTIONAL — feature flags / overrides
# =============================================================================

# Skip Hetzner provisioning if reusing existing server (REQUIRED for V1 path).
FXMILY_HETZNER_IP=178.104.39.201

# Override default domain (V1 = fxmilyapp.com, V2 = fxmily.com if purchased).
# FXMILY_DOMAIN=fxmilyapp.com

# Anthropic API — leave empty to ship with mock weekly-report client.
# Get key from https://console.anthropic.com/settings/keys
# Allowlist : claude-sonnet-4-6 | claude-haiku-4-5 | claude-opus-4-7
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Cloudflare R2 — leave empty to ship with LocalStorageAdapter (dev fallback).
# Sign up at https://dash.cloudflare.com → R2 (10 GB free, no CB demanded
# unless you exceed quota).
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=fxmily-media
# R2_PUBLIC_URL=https://media.fxmilyapp.com

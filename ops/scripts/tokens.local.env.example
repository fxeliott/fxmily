# Phase M bootstrap — copy this file to `tokens.local.env`, fill the
# values, then `chmod 600 tokens.local.env` AND `shred -u` after the
# bootstrap script has run.
#
# This file MUST NEVER be committed (covered by .gitignore *.local.env).

# Hetzner Cloud — Read & Write API Token (Project → Security → API Tokens)
HCLOUD_TOKEN=

# Cloudflare — API Token "Edit zone DNS" scope = fxmily.com Zone
# Profile → API Tokens → Create Token
CLOUDFLARE_API_TOKEN=

# Resend — API Key "domains:write emails:send"
# Resend Dashboard → API Keys → Create
RESEND_API_KEY=

# Sentry — DSN + Auth Token
# Project Settings → Client Keys (DSN) for SENTRY_DSN
# Settings → Auth Tokens (project:write + project:releases) for SENTRY_AUTH_TOKEN
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=fxmily
SENTRY_PROJECT=fxmily-web

# Optional :
# CRON_SECRET=  # auto-generated via `openssl rand -hex 24` if absent
# FXMILY_HETZNER_IP=  # set to skip provisioning step

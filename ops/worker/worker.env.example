# ops/worker/worker.env — local AI worker secrets (COPY to worker.env, gitignored).
#
# The wrapper (run-batch.sh) sources this file. Already-set environment vars win,
# so a local runtime proof can override with `FXMILY_BASE_URL=... run-batch.sh`.
#
#   cp ops/worker/worker.env.example ops/worker/worker.env
#   # then fill the FIVE tokens below — each pipeline validates its own token
#   # (core_require_token) and fails LOUDLY if the one it needs is missing.

# 32+ char admin batch token — MUST match the target app's ADMIN_BATCH_TOKEN.
# Used by the ONBOARDING and WEEKLY pipelines.
#   prod  : /etc/fxmily/web.env  ADMIN_BATCH_TOKEN
#   local : apps/web/.env        ADMIN_BATCH_TOKEN
FXMILY_ADMIN_TOKEN=

# 32+ chars — MUST match MONTHLY_ADMIN_BATCH_TOKEN (monthly digest pipeline;
# rotation independent of the weekly token, SPEC §25.2).
FXMILY_MONTHLY_ADMIN_TOKEN=

# 32+ chars — MUST match CALENDAR_ADMIN_BATCH_TOKEN (adaptive calendar pipeline).
FXMILY_CALENDAR_TOKEN=

# 32+ chars — MUST match VERIFICATION_ADMIN_BATCH_TOKEN (MT5 vision verification).
FXMILY_VERIFICATION_ADMIN_BATCH_TOKEN=

# 32+ chars — MUST match PROFILE_ADMIN_BATCH_TOKEN (J-E monthly deep
# re-profiling; rotation independent of every other token, SPEC §21.5).
FXMILY_PROFILE_ADMIN_TOKEN=

# Target app. Default (unset) = https://app.fxmilyapp.com. For a local dry run
# against the dev stack, set http://localhost:3000.
# FXMILY_BASE_URL=https://app.fxmilyapp.com

# Optional — override the shared Claude knobs (see ops/scripts/lib/claude-batch-core.sh).
# Leave unset to inherit the pinned defaults (Opus 4.8, xhigh, 60-120s jitter).
# FXMILY_CLAUDE_MODEL=claude-opus-4-8
# FXMILY_CLAUDE_EFFORT=xhigh
# FXMILY_SLEEP_MIN_S=60
# FXMILY_SLEEP_MAX_S=120

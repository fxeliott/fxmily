{
  "name": "fxmily",
  "version": "0.0.1",
  "private": true,
  "description": "Fxmily — suivi comportemental des membres de la formation de trading Fxmily",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "check:test-dates": "node scripts/check-no-absolute-dates-in-tests.mjs",
    "check:e2e-copy": "node scripts/check-e2e-copy-sync.mjs",
    "check:cron-sync": "node scripts/check-cron-crontab-sync.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.14"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "@hono/node-server": ">=1.19.13",
      "hono": ">=4.12.21",
      "esbuild": ">=0.28.1",
      "brace-expansion@^5.0.0": ">=5.0.7",
      "fast-uri@^3.0.0": ">=3.1.3 <4",
      "@opentelemetry/core": ">=2.8.0 <3",
      "undici": ">=7.28.0 <8",
      "@babel/core": ">=7.29.6 <8",
      "js-yaml": ">=4.2.0 <5"
    }
  }
}
